/**
 * 桂花茶溯源小程序 - 全局样式文件
 * 定义：主题令牌体系、通用样式、深色模式支持
 * 色系：青色(#2E8B57) + 金色(#DAA520)
 */

/* ==================== 主题令牌定义 ==================== */
page {
  /* ========== 颜色令牌 ========== */
  /* 主题色 - 青色系 */
  --color-primary: #2E8B57;
  --color-primary-light: #3CB371;
  --color-primary-dark: #228B22;

  /* 辅助色 - 金色系 */
  --color-secondary: #DAA520;
  --color-secondary-light: #F0C75E;
  --color-secondary-dark: #B8860B;

  /* 背景色令牌 */
  --color-bg-primary: #F5F5F0;
  --color-bg-secondary: #FFFFFF;
  --color-bg-card: #FFFFFF;
  --color-bg-elevated: #FAFAF7;

  /* 文字色令牌 */
  --color-text-primary: #333333;
  --color-text-secondary: #666666;
  --color-text-hint: #999999;
  --color-text-white: #FFFFFF;
  --color-text-inverse: #FFFFFF;

  /* 边框色令牌 */
  --color-border: #E8E8E8;
  --color-border-light: #F0F0F0;
  --color-border-strong: #D0D0D0;

  /* 状态色令牌 */
  --color-success: #52C41A;
  --color-warning: #FAAD14;
  --color-error: #FF4D4F;
  --color-info: #1890FF;

  /* 渐变令牌 */
  --gradient-primary: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  --gradient-secondary: linear-gradient(135deg, var(--color-secondary), var(--color-secondary-light));
  --gradient-header: linear-gradient(135deg, #2E8B57 0%, #3CB371 50%, #228B22 100%);

  /* ========== 间距令牌 ========== */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-2xl: 64rpx;

  /* ========== 圆角令牌 ========== */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-round: 50%;

  /* ========== 阴影令牌 ========== */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.16);
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);

  /* ========== 字体大小令牌 ========== */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  /* ========== 行高令牌 ========== */
  --line-height-tight: 1.4;
  --line-height-normal: 1.6;
  --line-height-relaxed: 1.8;

  /* ========== 兼容旧变量名 ========== */
  --bg-primary: var(--color-bg-primary);
  --bg-secondary: var(--color-bg-secondary);
  --bg-card: var(--color-bg-card);
  --text-primary: var(--color-text-primary);
  --text-secondary: var(--color-text-secondary);
  --text-hint: var(--color-text-hint);
  --text-white: var(--color-text-white);
  --border-color: var(--color-border);
  --border-light: var(--color-border-light);

  /* 页面基础样式 */
  background-color: var(--color-bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-md);
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* ==================== 深色模式变量覆盖 ==================== */
page.theme-dark {
  /* 主题色 - 调整为更适合深色背景 */
  --color-primary: #3CB371;
  --color-primary-light: #66CDAA;
  --color-primary-dark: #2E8B57;

  /* 辅助色 */
  --color-secondary: #F0C75E;
  --color-secondary-light: #FFD700;
  --color-secondary-dark: #DAA520;

  /* 背景色 - 深色 */
  --color-bg-primary: #121212;
  --color-bg-secondary: #1E1E1E;
  --color-bg-card: #2A2A2A;
  --color-bg-elevated: #323232;

  /* 文字色 - 深色模式下调整对比度 */
  --color-text-primary: #E8E8E8;
  --color-text-secondary: #A0A0A0;
  --color-text-hint: #707070;
  --color-text-white: #FFFFFF;
  --color-text-inverse: #121212;

  /* 边框色 - 深色模式下更明显 */
  --color-border: #3A3A3A;
  --color-border-light: #2F2F2F;
  --color-border-strong: #4A4A4A;

  /* 状态色 - 深色模式下更柔和 */
  --color-success: #52C41A;
  --color-warning: #FAAD14;
  --color-error: #FF7875;
  --color-info: #40A9FF;

  /* 渐变 - 深色模式调整 */
  --gradient-header: linear-gradient(135deg, #1B5E3A 0%, #2E8B57 50%, #1B5E3A 100%);

  /* 阴影 - 深色模式下更柔和但有层次感 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.25);

  /* 兼容旧变量名 */
  --bg-primary: var(--color-bg-primary);
  --bg-secondary: var(--color-bg-secondary);
  --bg-card: var(--color-bg-card);
  --text-primary: var(--color-text-primary);
  --text-secondary: var(--color-text-secondary);
  --text-hint: var(--color-text-hint);
  --text-white: var(--color-text-white);
  --border-color: var(--color-border);
  --border-light: var(--color-border-light);
}

/* ==================== 通用容器样式 ==================== */
.container {
  padding: var(--spacing-lg);
  box-sizing: border-box;
  min-height: 100vh;
}

/* 卡片样式 - 使用主题令牌 */
.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border-light);
  transition: background-color 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

/* 深色模式卡片优化 - 增强边框对比度 */
page.theme-dark .card {
  box-shadow: var(--shadow-card);
  border-color: var(--color-border);
}

/* 卡片标题 */
.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-secondary));
  border-radius: 4rpx;
  margin-right: var(--spacing-sm);
}

/* ==================== 按钮样式 - 使用主题令牌 ==================== */
.btn-primary {
  background: var(--gradient-primary);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
  font-weight: 500;
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: var(--gradient-secondary);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
  font-weight: 500;
  box-shadow: var(--shadow-md);
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
}

/* ==================== 文字样式 - 使用主题令牌 ==================== */
.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-secondary);
}

.text-hint {
  color: var(--color-text-hint);
  font-size: var(--font-sm);
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: 600;
}

/* ==================== 布局工具类 ==================== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ==================== 间距工具类 ==================== */
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

/* ==================== 图标基础样式 ==================== */
.icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon-sm {
  width: 32rpx;
  height: 32rpx;
}

.icon-md {
  width: 48rpx;
  height: 48rpx;
}

.icon-lg {
  width: 64rpx;
  height: 64rpx;
}

/* ==================== 分隔线 - 使用主题令牌 ==================== */
.divider {
  height: 1rpx;
  background-color: var(--color-border);
  margin: var(--spacing-md) 0;
}

/* ==================== 标签样式 - 使用主题令牌 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
}

.tag-success {
  background-color: rgba(82, 196, 26, 0.1);
  color: var(--color-success);
}

.tag-primary {
  background-color: rgba(46, 139, 87, 0.1);
  color: var(--color-primary);
}

.tag-warning {
  background-color: rgba(250, 173, 20, 0.1);
  color: var(--color-warning);
}

/* 深色模式标签透明度调整 */
page.theme-dark .tag-success {
  background-color: rgba(82, 196, 26, 0.15);
}

page.theme-dark .tag-primary {
  background-color: rgba(60, 179, 113, 0.15);
}

page.theme-dark .tag-warning {
  background-color: rgba(250, 173, 20, 0.15);
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fadeIn {
  animation: fadeIn 0.4s ease-out forwards;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

/* ==================== 字号调节（关怀版） ==================== */

page.font-large {
  --font-xs: 28rpx;
  --font-sm: 30rpx;
  --font-md: 35rpx;
  --font-lg: 40rpx;
  --font-xl: 45rpx;
  --font-xxl: 55rpx;
  --spacing-xs: 10rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 30rpx;
  --spacing-lg: 40rpx;
  --spacing-xl: 60rpx;
  line-height: 1.7;
}

page.font-extra {
  --font-xs: 33rpx;
  --font-sm: 36rpx;
  --font-md: 42rpx;
  --font-lg: 48rpx;
  --font-xl: 54rpx;
  --font-xxl: 66rpx;
  --spacing-xs: 12rpx;
  --spacing-sm: 24rpx;
  --spacing-md: 36rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 72rpx;
  line-height: 1.8;
}

page.font-large .card,
page.font-extra .card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  border-radius: var(--radius-lg);
}

page.font-large .btn-primary,
page.font-large .btn-secondary,
page.font-large .btn-outline,
page.font-extra .btn-primary,
page.font-extra .btn-secondary,
page.font-extra .btn-outline {
  padding: var(--spacing-md) var(--spacing-xl);
  border-radius: var(--radius-lg);
}

page.font-large input,
page.font-extra input,
page.font-large textarea,
page.font-extra textarea {
  min-height: 88rpx;
  font-size: var(--font-md);
}

/* ==================== 色弱模式：合格/不合格增强区分 ==================== */

/* 合格状态 —— 增加 ✅ 图标前缀 + 斜纹底纹 */
page.color-weak .tag-success::before,
page.color-weak .status-pass::before,
page.color-weak [data-status="pass"]::before {
  content: '✓';
  display: inline-block;
  margin-right: 6rpx;
  font-weight: 700;
  color: #1F7A34;
  font-size: 1.1em;
}

page.color-weak .tag-success,
page.color-weak .status-pass,
page.color-weak [data-status="pass"] {
  background-image: repeating-linear-gradient(
    45deg,
    rgba(31, 122, 52, 0.06) 0 8rpx,
    transparent 8rpx 16rpx
  );
  border: 3rpx solid #1F7A34 !important;
  font-weight: 600 !important;
  color: #1F7A34 !important;
}

/* 不合格状态 —— 增加 ❌ 图标前缀 + 斜线底纹 */
page.color-weak .status-fail::before,
page.color-weak [data-status="fail"]::before {
  content: '✗';
  display: inline-block;
  margin-right: 6rpx;
  font-weight: 700;
  color: #B71C1C;
  font-size: 1.1em;
}

page.color-weak .status-fail,
page.color-weak [data-status="fail"] {
  background-image: repeating-linear-gradient(
    -45deg,
    rgba(183, 28, 28, 0.08) 0 8rpx,
    transparent 8rpx 16rpx
  );
  border: 3rpx solid #B71C1C !important;
  font-weight: 700 !important;
  color: #B71C1C !important;
  text-decoration: underline wavy #B71C1C;
  text-underline-offset: 6rpx;
}

/* 色弱模式：警告级别增加边框与图案 */
page.color-weak .level-excellent::after {
  content: ' ★★★';
  color: #1F7A34;
}

page.color-weak .level-good::after {
  content: ' ★★';
  color: #388E3C;
}

page.color-weak .level-warning::after {
  content: ' ★';
  color: #F57F17;
}

page.color-weak .level-danger::after {
  content: ' ⚠';
  color: #B71C1C;
}

/* 色弱模式：状态颜色调整为高对比度非彩虹色 */
page.color-weak {
  --color-success: #1F7A34;        /* 深绿（替代草绿） */
  --color-warning: #F57F17;        /* 深橙（替代黄） */
  --color-error: #B71C1C;          /* 深红（替代品红） */
  --color-info: #0D47A1;           /* 深蓝（代指信息） */
  --color-primary: #1565C0;        /* 调整主色调为深蓝 */
  --color-secondary: #6D4C41;      /* 调整辅助色为深棕 */
}

/* 色弱模式：检测进度条增加格纹 */
page.color-weak .progress-pass {
  background-image:
    repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.2) 0 4rpx,
      transparent 4rpx 8rpx
    );
  border: 2rpx solid #1F7A34;
}

page.color-weak .progress-danger {
  background-image:
    repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.25) 0 4rpx,
      transparent 4rpx 8rpx
    );
  border: 2rpx solid #B71C1C;
}

/* 色弱模式：合格/不合格大标签 */
page.color-weak .status-badge-pass {
  position: relative;
}
page.color-weak .status-badge-pass::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 70%; height: 4rpx;
  background: #1F7A34;
  transform: translate(-50%, -50%) rotate(-8deg);
  opacity: 0.35;
}

page.color-weak .status-badge-fail {
  position: relative;
}
page.color-weak .status-badge-fail::after {
  content: '✗';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 300%;
  color: rgba(183, 28, 28, 0.25);
  font-weight: 900;
}

/* ==================== 无障碍设置面板（通用）- 使用主题令牌 ==================== */

.a11y-panel {
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-md);
  margin-bottom: var(--spacing-lg);
  border: 1rpx solid var(--color-border-light);
  transition: background-color 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

/* 深色模式面板优化 */
page.theme-dark .a11y-panel {
  border-color: var(--color-border);
}

.a11y-panel-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  display: flex;
  align-items: center;
}

.a11y-panel-title-icon {
  margin-right: var(--spacing-sm);
}

.a11y-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.a11y-row:last-child {
  border-bottom: none;
}

.a11y-label {
  font-size: var(--font-md);
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  flex: 1;
}

.a11y-label-icon {
  margin-right: var(--spacing-sm);
  font-size: var(--font-lg);
}

.a11y-label-text {
  font-weight: 500;
}

.a11y-label-desc {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  margin-top: 4rpx;
  line-height: 1.4;
}

.a11y-label-stack {
  display: flex;
  flex-direction: column;
}

.a11y-options {
  display: flex;
  gap: var(--spacing-sm);
}

.a11y-option {
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-primary);
  transition: all 0.2s ease;
}

.a11y-option.active {
  background: var(--gradient-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
  font-weight: 500;
}

.a11y-switch {
  width: 96rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: var(--color-border);
  position: relative;
  transition: all 0.3s ease;
}

.a11y-switch.on {
  background: var(--gradient-primary);
}

.a11y-switch-dot {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-text-white);
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.a11y-switch.on .a11y-switch-dot {
  left: 48rpx;
}
