/**
 * 桂花茶溯源小程序 - 全局样式文件
 * 定义：全局变量、通用样式、主题色彩
 * 色系：青色(#2E8B57) + 金色(#DAA520)
 */

/* ==================== CSS变量定义 ==================== */
page {
  /* 主题色 - 青色系 */
  --color-primary: #2E8B57;          /* 海绿色 - 主色调 */
  --color-primary-light: #3CB371;    /* 中海绿 - 浅色 */
  --color-primary-dark: #228B22;     /* 森林绿 - 深色 */
  
  /* 辅助色 - 金色系 */
  --color-secondary: #DAA520;        /* 金麒麟色 - 辅助主色 */
  --color-secondary-light: #F0C75E;  /* 浅金色 */
  --color-secondary-dark: #B8860B;   /* 暗金色 */
  
  /* 背景色 */
  --bg-primary: #F5F5F0;             /* 米白色背景 */
  --bg-secondary: #FFFFFF;           /* 白色背景 */
  --bg-card: #FFFFFF;                /* 卡片背景 */
  
  /* 文字色 */
  --text-primary: #333333;           /* 主文字 */
  --text-secondary: #666666;         /* 次要文字 */
  --text-hint: #999999;              /* 提示文字 */
  --text-white: #FFFFFF;             /* 白色文字 */
  
  /* 边框色 */
  --border-color: #E8E8E8;           /* 边框颜色 */
  --border-light: #F0F0F0;           /* 浅边框 */
  
  /* 状态色 */
  --color-success: #52C41A;          /* 成功 */
  --color-warning: #FAAD14;          /* 警告 */
  --color-error: #FF4D4F;            /* 错误 */
  --color-info: #1890FF;             /* 信息 */
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-round: 50%;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.16);
  
  /* 字体大小 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;
  
  /* 页面基础样式 */
  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: 1.6;
}

/* ==================== 通用容器样式 ==================== */
.container {
  padding: var(--spacing-lg);
  box-sizing: border-box;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}

/* 卡片标题 */
.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-secondary));
  border-radius: 4rpx;
  margin-right: var(--spacing-sm);
}

/* ==================== 按钮样式 ==================== */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: var(--text-white);
  border: none;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
  font-weight: 500;
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: linear-gradient(135deg, var(--color-secondary), var(--color-secondary-light));
  color: var(--text-white);
  border: none;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
  font-weight: 500;
  box-shadow: var(--shadow-md);
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
}

/* ==================== 文字样式 ==================== */
.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-secondary);
}

.text-hint {
  color: var(--text-hint);
  font-size: var(--font-sm);
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: 600;
}

/* ==================== 布局工具类 ==================== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ==================== 间距工具类 ==================== */
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

/* ==================== 图标基础样式 ==================== */
.icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon-sm {
  width: 32rpx;
  height: 32rpx;
}

.icon-md {
  width: 48rpx;
  height: 48rpx;
}

.icon-lg {
  width: 64rpx;
  height: 64rpx;
}

/* ==================== 分隔线 ==================== */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: var(--spacing-md) 0;
}

/* ==================== 标签样式 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
}

.tag-success {
  background-color: rgba(82, 196, 26, 0.1);
  color: var(--color-success);
}

.tag-primary {
  background-color: rgba(46, 139, 87, 0.1);
  color: var(--color-primary);
}

.tag-warning {
  background-color: rgba(250, 173, 20, 0.1);
  color: var(--color-warning);
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fadeIn {
  animation: fadeIn 0.4s ease-out forwards;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

/* ==================== 字号调节（关怀版） ==================== */

page.font-large {
  --font-xs: 28rpx;
  --font-sm: 30rpx;
  --font-md: 35rpx;
  --font-lg: 40rpx;
  --font-xl: 45rpx;
  --font-xxl: 55rpx;
  --spacing-xs: 10rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 30rpx;
  --spacing-lg: 40rpx;
  --spacing-xl: 60rpx;
  line-height: 1.7;
}

page.font-extra {
  --font-xs: 33rpx;
  --font-sm: 36rpx;
  --font-md: 42rpx;
  --font-lg: 48rpx;
  --font-xl: 54rpx;
  --font-xxl: 66rpx;
  --spacing-xs: 12rpx;
  --spacing-sm: 24rpx;
  --spacing-md: 36rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 72rpx;
  line-height: 1.8;
}

page.font-large .card,
page.font-extra .card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  border-radius: var(--radius-lg);
}

page.font-large .btn-primary,
page.font-large .btn-secondary,
page.font-large .btn-outline,
page.font-extra .btn-primary,
page.font-extra .btn-secondary,
page.font-extra .btn-outline {
  padding: var(--spacing-md) var(--spacing-xl);
  border-radius: var(--radius-lg);
}

page.font-large input,
page.font-extra input,
page.font-large textarea,
page.font-extra textarea {
  min-height: 88rpx;
  font-size: var(--font-md);
}

/* ==================== 色弱模式：合格/不合格增强区分 ==================== */

/* 合格状态 —— 增加 ✅ 图标前缀 + 斜纹底纹 */
page.color-weak .tag-success::before,
page.color-weak .status-pass::before,
page.color-weak [data-status="pass"]::before {
  content: '✓';
  display: inline-block;
  margin-right: 6rpx;
  font-weight: 700;
  color: #1F7A34;
  font-size: 1.1em;
}

page.color-weak .tag-success,
page.color-weak .status-pass,
page.color-weak [data-status="pass"] {
  background-image: repeating-linear-gradient(
    45deg,
    rgba(31, 122, 52, 0.06) 0 8rpx,
    transparent 8rpx 16rpx
  );
  border: 3rpx solid #1F7A34 !important;
  font-weight: 600 !important;
  color: #1F7A34 !important;
}

/* 不合格状态 —— 增加 ❌ 图标前缀 + 斜线底纹 */
page.color-weak .status-fail::before,
page.color-weak [data-status="fail"]::before {
  content: '✗';
  display: inline-block;
  margin-right: 6rpx;
  font-weight: 700;
  color: #B71C1C;
  font-size: 1.1em;
}

page.color-weak .status-fail,
page.color-weak [data-status="fail"] {
  background-image: repeating-linear-gradient(
    -45deg,
    rgba(183, 28, 28, 0.08) 0 8rpx,
    transparent 8rpx 16rpx
  );
  border: 3rpx solid #B71C1C !important;
  font-weight: 700 !important;
  color: #B71C1C !important;
  text-decoration: underline wavy #B71C1C;
  text-underline-offset: 6rpx;
}

/* 色弱模式：警告级别增加边框与图案 */
page.color-weak .level-excellent::after {
  content: ' ★★★';
  color: #1F7A34;
}

page.color-weak .level-good::after {
  content: ' ★★';
  color: #388E3C;
}

page.color-weak .level-warning::after {
  content: ' ★';
  color: #F57F17;
}

page.color-weak .level-danger::after {
  content: ' ⚠';
  color: #B71C1C;
}

/* 色弱模式：状态颜色调整为高对比度非彩虹色 */
page.color-weak {
  --color-success: #1F7A34;        /* 深绿（替代草绿） */
  --color-warning: #F57F17;        /* 深橙（替代黄） */
  --color-error: #B71C1C;          /* 深红（替代品红） */
  --color-info: #0D47A1;           /* 深蓝（代指信息） */
  --color-primary: #1565C0;        /* 调整主色调为深蓝 */
  --color-secondary: #6D4C41;      /* 调整辅助色为深棕 */
}

/* 色弱模式：检测进度条增加格纹 */
page.color-weak .progress-pass {
  background-image:
    repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.2) 0 4rpx,
      transparent 4rpx 8rpx
    );
  border: 2rpx solid #1F7A34;
}

page.color-weak .progress-danger {
  background-image:
    repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.25) 0 4rpx,
      transparent 4rpx 8rpx
    );
  border: 2rpx solid #B71C1C;
}

/* 色弱模式：合格/不合格大标签 */
page.color-weak .status-badge-pass {
  position: relative;
}
page.color-weak .status-badge-pass::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 70%; height: 4rpx;
  background: #1F7A34;
  transform: translate(-50%, -50%) rotate(-8deg);
  opacity: 0.35;
}

page.color-weak .status-badge-fail {
  position: relative;
}
page.color-weak .status-badge-fail::after {
  content: '✗';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 300%;
  color: rgba(183, 28, 28, 0.25);
  font-weight: 900;
}

/* ==================== 无障碍设置面板（通用） ==================== */

.a11y-panel {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-md);
  margin-bottom: var(--spacing-lg);
}

.a11y-panel-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
  display: flex;
  align-items: center;
}

.a11y-panel-title-icon {
  margin-right: var(--spacing-sm);
}

.a11y-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.a11y-row:last-child {
  border-bottom: none;
}

.a11y-label {
  font-size: var(--font-md);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  flex: 1;
}

.a11y-label-icon {
  margin-right: var(--spacing-sm);
  font-size: var(--font-lg);
}

.a11y-label-text {
  font-weight: 500;
}

.a11y-label-desc {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-top: 4rpx;
  line-height: 1.4;
}

.a11y-label-stack {
  display: flex;
  flex-direction: column;
}

.a11y-options {
  display: flex;
  gap: var(--spacing-sm);
}

.a11y-option {
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border-color);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background: var(--bg-primary);
  transition: all 0.2s ease;
}

.a11y-option.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: var(--text-white);
  border-color: var(--color-primary);
  font-weight: 500;
}

.a11y-switch {
  width: 96rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: var(--border-color);
  position: relative;
  transition: all 0.3s ease;
}

.a11y-switch.on {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
}

.a11y-switch-dot {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.a11y-switch.on .a11y-switch-dot {
  left: 48rpx;
}

