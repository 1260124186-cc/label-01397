.notifications-page {
  min-height: 100vh;
  background: #F5F5F0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.notifications-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.unread-count {
  font-size: 26rpx;
  color: #2E8B57;
  font-weight: 500;
}

.toolbar-right {
  display: flex;
  gap: 16rpx;
}

.toolbar-btn {
  font-size: 26rpx;
  color: #666666;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
}

.toolbar-btn:active {
  background: #F5F5F5;
}

.toolbar-btn-danger {
  color: #ff4d4f;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  padding: 0 60rpx;
}

.notifications-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: all 0.2s ease;
}

.notification-item:active {
  background: #FAFAFA;
}

.notification-item.unread {
  border-left: 6rpx solid #2E8B57;
}

.notification-indicator {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FF4D4F;
}

.notification-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-header-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.notification-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-type-badge {
  flex-shrink: 0;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.notification-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.notification-time {
  font-size: 22rpx;
  color: #999999;
}
