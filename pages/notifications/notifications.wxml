<view class="notifications-page">
  <view wx:if="{{!isEmpty}}" class="notifications-toolbar">
    <view class="toolbar-left">
      <text class="unread-count" wx:if="{{unreadCount > 0}}">{{unreadCount}} 条未读</text>
    </view>
    <view class="toolbar-right">
      <view class="toolbar-btn" wx:if="{{unreadCount > 0}}" bindtap="onMarkAllRead">全部已读</view>
      <view class="toolbar-btn toolbar-btn-danger" bindtap="onClearAll">清空</view>
    </view>
  </view>

  <view wx:if="{{isEmpty}}" class="empty-state">
    <view class="empty-icon">🔔</view>
    <view class="empty-title">暂无消息通知</view>
    <view class="empty-desc">溯源动态、安全提醒和活动通知将显示在这里</view>
  </view>

  <view wx:else class="notifications-list">
    <view
      wx:for="{{notifications}}"
      wx:key="id"
      class="notification-item {{item.isRead ? 'read' : 'unread'}}"
      data-id="{{item.id}}"
      data-isread="{{item.isRead}}"
      data-extra="{{item.extra}}"
      bindtap="onNotificationTap"
    >
      <view class="notification-indicator" wx:if="{{!item.isRead}}"></view>
      <view class="notification-icon" style="background: {{item.typeColor}}15;">
        <text>{{item.icon}}</text>
      </view>
      <view class="notification-content">
        <view class="notification-header-row">
          <view class="notification-title">{{item.title}}</view>
          <view class="notification-type-badge" style="color: {{item.typeColor}}; background: {{item.typeColor}}10;">
            {{item.type === 'system' ? '系统' : item.type === 'trace' ? '溯源' : item.type === 'recall' ? '安全' : item.type === 'activity' ? '活动' : '隐私'}}
          </view>
        </view>
        <view class="notification-text">{{item.content}}</view>
        <view class="notification-time">{{item.formatTime}}</view>
      </view>
    </view>
  </view>
</view>
