<view class="detail-page">
  <view class="section-card">
    <view class="section-label">产品名称</view>
    <view class="product-name-display">
      <text wx:if="{{productName}}">{{productName}}</text>
      <text wx:else class="placeholder-text">请从溯源详情页创建笔记</text>
    </view>
  </view>

  <view class="section-card">
    <view class="section-label">品鉴评分</view>
    <view class="rating-row">
      <view
        wx:for="{{[1,2,3,4,5]}}"
        wx:key="*this"
        class="rating-star {{item <= rating ? 'active' : ''}}"
        data-rating="{{item}}"
        bindtap="onRatingTap"
      >★</view>
    </view>
    <view class="rating-hint">
      <text wx:if="{{rating === 0}}">点击星星评分</text>
      <text wx:elif="{{rating <= 2}}">一般</text>
      <text wx:elif="{{rating <= 3}}">不错</text>
      <text wx:elif="{{rating <= 4}}">很好</text>
      <text wx:else>极佳</text>
    </view>
  </view>

  <view class="section-card">
    <view class="section-label">风味标签（最多5个）</view>
    <view class="preset-tags">
      <view
        wx:for="{{presetTags}}"
        wx:key="*this"
        class="preset-tag {{tags.indexOf(item) !== -1 ? 'selected' : ''}}"
        data-tag="{{item}}"
        bindtap="onPresetTagTap"
      >{{item}}</view>
    </view>
    <view class="custom-tag-input">
      <input
        class="tag-input"
        type="text"
        placeholder="自定义标签"
        value="{{inputTag}}"
        bindinput="onInputTagInput"
        maxlength="6"
        bindconfirm="onAddInputTag"
      />
      <view class="tag-add-btn" bindtap="onAddInputTag">添加</view>
    </view>
    <view wx:if="{{tags.length > 0}}" class="selected-tags">
      <view
        wx:for="{{tags}}"
        wx:key="*this"
        class="selected-tag"
      >
        <text>{{item}}</text>
        <text class="tag-remove" data-tag="{{item}}" catchtap="onRemoveTag">×</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-label">品鉴内容</view>
    <textarea
      class="content-textarea"
      placeholder="记录你对这款茶的品鉴感受，如外观、汤色、香气、口感、叶底等..."
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="500"
      auto-height
    />
    <view class="content-counter">{{content.length}}/500</view>
  </view>

  <!-- 信任级别提示 -->
  <view class="publish-info-card" wx:if="{{isEdit && traceId}}">
    <view class="info-row" wx:if="{{isScanVerified}}">
      <text class="info-icon verified">✓</text>
      <text class="info-text verified-text">您已扫码验真，发布评价将显示「已验真购买」标识</text>
    </view>
    <view class="info-row" wx:if="{{hasSubmittedReview}}">
      <text class="info-icon done">✓</text>
      <text class="info-text done-text">您已评价过该产品</text>
    </view>
  </view>

  <!-- 发布为评价按钮 -->
  <view class="action-buttons" wx:if="{{isEdit && traceId}}">
    <view class="publish-btn {{hasSubmittedReview || publishing ? 'disabled' : ''}}" bindtap="openPublishConfirm">
      <text class="btn-icon">📝</text>
      <text class="btn-text">{{publishing ? '发布中...' : '发布为评价'}}</text>
    </view>
    <view class="view-product-btn" bindtap="goToProductDetail">
      <text class="btn-icon">🔍</text>
      <text class="btn-text">查看产品</text>
    </view>
  </view>

  <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="onSave">
    {{saving ? '保存中...' : '保存笔记'}}
  </view>

  <!-- 发布确认弹窗 -->
  <view class="publish-modal {{showPublishConfirm ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closePublishConfirm">
    <view class="publish-modal-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="publish-modal-header">
        <text class="publish-modal-title">📝 发布笔记为评价</text>
        <view class="publish-modal-close" bindtap="closePublishConfirm">×</view>
      </view>
      <scroll-view scroll-y="true" class="publish-modal-body" wx:if="{{publishPreview}}">
        <view class="publish-preview">
          <view class="preview-label">评价预览</view>
          <view class="preview-rating">
            <text class="preview-rating-label">评分：</text>
            <text wx:for="{{5}}" wx:key="index" class="preview-star {{index < publishPreview.rating ? 'filled' : 'empty'}}">★</text>
            <text class="preview-rating-value">{{publishPreview.rating}}.0</text>
          </view>
          <view class="preview-tags" wx:if="{{publishPreview.tasteTags && publishPreview.tasteTags.length > 0}}">
            <text class="preview-tags-label">口感标签：</text>
            <view class="preview-tag-list">
              <view class="preview-tag" wx:for="{{publishPreview.tasteTags}}" wx:key="*this" wx:for-item="tag">
                <text>{{tag}}</text>
              </view>
            </view>
          </view>
          <view class="preview-content">
            <text class="preview-content-label">评价内容：</text>
            <text class="preview-content-text">{{publishPreview.content}}</text>
          </view>
          <view class="preview-trust" wx:if="{{publishPreview.trustLevel}}">
            <text class="preview-trust-label">信任级别：</text>
            <view class="preview-trust-badge" style="background: {{publishPreview.trustLevel.color}}20; border-color: {{publishPreview.trustLevel.color}};">
              <text class="preview-trust-icon" style="color: {{publishPreview.trustLevel.color}};">{{publishPreview.trustLevel.icon}}</text>
              <text class="preview-trust-name" style="color: {{publishPreview.trustLevel.color}};">{{publishPreview.trustLevel.name}}</text>
            </view>
          </view>
        </view>
        <view class="publish-tip">
          <text class="tip-icon">💡</text>
          <text class="tip-text">发布后，您的品鉴笔记内容将作为评价公开显示</text>
        </view>
      </scroll-view>
      <view class="publish-modal-footer">
        <view class="publish-cancel-btn" bindtap="closePublishConfirm">
          <text>取消</text>
        </view>
        <view class="publish-confirm-btn {{publishing ? 'disabled' : ''}}" bindtap="publishAsReview">
          <text>{{publishing ? '发布中...' : '确认发布'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
