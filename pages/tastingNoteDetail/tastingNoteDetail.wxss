.detail-page {
  min-height: 100vh;
  background: #F5F5F0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.section-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.product-name-display {
  font-size: 30rpx;
  color: #2E8B57;
  font-weight: 500;
}

.placeholder-text {
  color: #CCCCCC;
  font-weight: 400;
}

.rating-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.rating-star {
  font-size: 52rpx;
  color: #E0E0E0;
  transition: all 0.2s ease;
}

.rating-star.active {
  color: #DAA520;
  transform: scale(1.1);
}

.rating-hint {
  font-size: 26rpx;
  color: #DAA520;
}

.preset-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.preset-tag {
  padding: 12rpx 24rpx;
  background: #F5F5F0;
  border: 2rpx solid #E8E8E8;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.preset-tag.selected {
  background: rgba(46, 139, 87, 0.1);
  border-color: #2E8B57;
  color: #2E8B57;
  font-weight: 500;
}

.preset-tag:active {
  transform: scale(0.95);
}

.custom-tag-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background: #F8F8F5;
  border: 2rpx solid #E8E8E8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #333333;
}

.tag-add-btn {
  padding: 14rpx 28rpx;
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.tag-add-btn:active {
  background: rgba(46, 139, 87, 0.2);
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, rgba(46, 139, 87, 0.1), rgba(218, 165, 32, 0.08));
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #2E8B57;
}

.tag-remove {
  font-size: 28rpx;
  color: #999999;
  padding: 0 4rpx;
}

.content-textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
  padding: 20rpx;
  background: #F8F8F5;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.content-counter {
  text-align: right;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 12rpx;
}

.save-btn {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
  margin-top: 16rpx;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.save-btn.disabled {
  background: #CCCCCC;
  box-shadow: none;
}
