.page-container {
  min-height: 100vh;
  background: #F5F5F0;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  width: 600rpx;
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #52C41A, #3CB371);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: white;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.4);
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.success-message {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.report-info {
  width: 100%;
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.report-info .info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.report-info .label {
  font-size: 26rpx;
  color: #999;
}

.report-info .value {
  font-size: 26rpx;
  color: #333;
  max-width: 60%;
  word-break: break-all;
}

.btn-success {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(46, 139, 87, 0.3);
}

.btn-success::after {
  border: none;
}

.form-container {
  padding: 30rpx;
}

.product-info-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #E6F7E6 0%, #F0FFF0 100%);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #B7EB8F;
}

.product-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.product-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2E8B57;
}

.product-trace {
  font-size: 24rpx;
  color: #666;
}

.form-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.required {
  color: #FF4D4F;
  font-size: 28rpx;
}

.photo-hint,
.contact-hint {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-item.selected {
  background: #F6FFED;
  border-color: #52C41A;
}

.type-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.type-label {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.textarea-wrapper {
  position: relative;
}

.description-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: #999;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.photo {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: #F0F0F0;
}

.photo-remove {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.photo-add-area {
  display: flex;
  gap: 20rpx;
}

.add-btn {
  width: 200rpx;
  height: 200rpx;
  background: #FAFAFA;
  border: 2rpx dashed #D9D9D9;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.camera-btn {
  background: #FFF7E6;
  border-color: #FFD591;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
}

.camera-btn .add-icon {
  font-size: 40rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.contact-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.tips-section {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFF1CC 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #FFE0A0;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #D48806;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #8B6914;
  line-height: 1.5;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #FF4D4F, #FF7875);
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 77, 79, 0.3);
}

.btn-submit::after {
  border: none;
}

.btn-submit[disabled] {
  opacity: 0.7;
}

.secondary-btns {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: white;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid #E0E0E0;
}
