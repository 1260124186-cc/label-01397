.service-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

.page-header {
  position: relative;
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  text-align: center;
  color: #FFFFFF;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.quick-actions {
  padding: 0 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.action-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-card.primary {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 2rpx solid rgba(46, 139, 87, 0.2);
}

.action-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(46, 139, 87, 0.1);
  border-radius: 20rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.ticket-badge {
  background: #E74C3C;
  color: #FFFFFF;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
  margin-left: 12rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #888888;
}

.action-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

.contact-info {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF8E1;
  border-radius: 16rpx;
}

.contact-text {
  flex: 1;
}

.contact-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.contact-value {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.contact-value.highlight {
  color: #2E8B57;
  font-size: 32rpx;
}

.contact-action {
  font-size: 26rpx;
  color: #2E8B57;
  padding: 10rpx 24rpx;
  background: rgba(46, 139, 87, 0.1);
  border-radius: 30rpx;
}

.faq-section {
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.toggle-all-btn {
  font-size: 26rpx;
  color: #2E8B57;
}

.search-bar {
  margin-bottom: 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #AAAAAA;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #CCCCCC;
  padding: 10rpx;
}

.category-scroll {
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.category-tabs {
  display: inline-flex;
  padding: 4rpx 0;
}

.category-tab {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.category-tab.active {
  background: #2E8B57;
  color: #FFFFFF;
}

.faq-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
}

.faq-item {
  border-bottom: 1rpx solid #F0F0F0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}

.question-text {
  flex: 1;
  display: flex;
  align-items: flex-start;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.q-icon {
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #E8F5E9;
  color: #2E8B57;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.question-toggle {
  font-size: 32rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
  transition: transform 0.3s;
}

.question-toggle.expanded {
  transform: rotate(180deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
}

.faq-answer.show {
  max-height: 600rpx;
}

.answer-text {
  display: flex;
  align-items: flex-start;
  padding: 0 32rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
}

.a-icon {
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #FFF3E0;
  color: #FF9800;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.faq-empty {
  text-align: center;
  padding: 80rpx 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #2E8B57;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.bottom-space {
  height: 40rpx;
}

.claim-card {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFE7BA 100%);
  border: 2rpx solid rgba(212, 107, 8, 0.2);
}

.claim-icon {
  background: rgba(212, 107, 8, 0.15) !important;
}

.claim-badge {
  background: #D46B08 !important;
}

.claim-tag-g002 {
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  margin-left: 12rpx;
  font-weight: 600;
}

.claim-submit-card {
  background: linear-gradient(135deg, #E6F4EA 0%, #C8E6C9 100%);
  border: 2rpx solid rgba(46, 139, 87, 0.2);
}

.claim-submit-icon {
  background: rgba(46, 139, 87, 0.15) !important;
}

.g002-notice {
  display: flex;
  align-items: flex-start;
  margin: 8rpx 32rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF1F0 0%, #FFCCC7 100%);
  border-radius: 16rpx;
  border: 1rpx solid #FFA39E;
}

.g002-notice .notice-icon {
  font-size: 40rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.g002-notice .notice-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.g002-notice .notice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #CF1322;
  margin-bottom: 6rpx;
}

.g002-notice .notice-desc {
  font-size: 22rpx;
  color: #A8071A;
  line-height: 1.5;
}

.g002-notice .notice-go {
  font-size: 24rpx;
  color: #fff;
  background: #CF1322;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  align-self: center;
}
