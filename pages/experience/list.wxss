.experience-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

.page-header {
  position: relative;
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  text-align: center;
  color: #FFFFFF;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.quick-actions {
  padding: 0 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.action-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-card.primary {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 2rpx solid rgba(46, 139, 87, 0.2);
}

.action-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(46, 139, 87, 0.1);
  border-radius: 20rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #888888;
}

.action-arrow {
  font-size: 36rpx;
  color: #888888;
  margin-left: 16rpx;
}

.badge {
  background: #E74C3C;
  color: #FFFFFF;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
  margin-left: 12rpx;
}

.section-title-row {
  padding: 24rpx 32rpx 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.title-icon {
  margin-right: 8rpx;
}

.activity-list {
  padding: 0 32rpx;
}

.activity-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.activity-icon {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border-radius: 22rpx;
  color: #FFFFFF;
}

.activity-content {
  padding-right: 110rpx;
}

.activity-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.activity-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.activity-points {
  background: #FFF3E0;
  color: #FF9800;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  font-weight: 600;
}

.activity-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #888888;
  margin-right: 24rpx;
  margin-bottom: 8rpx;
}

.activity-highlights {
  display: flex;
  flex-wrap: wrap;
}

.highlight-tag {
  font-size: 24rpx;
  color: #2E8B57;
  margin-right: 16rpx;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.activity-arrow {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
  text-align: right;
  font-size: 28rpx;
  color: #2E8B57;
  font-weight: 500;
}

.points-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin: 16rpx 32rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #F57C00;
}

.bottom-space {
  height: 40rpx;
}
