.my-reservations-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

.tab-bar {
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-scroll {
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-block;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
  transition: all 0.2s;
}

.tab-item.active {
  color: #2E8B57;
  font-weight: 600;
  font-size: 30rpx;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #2E8B57;
  border-radius: 3rpx;
}

.reservation-list {
  padding: 24rpx 32rpx;
}

.reservation-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.activity-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 18rpx;
  color: #FFFFFF;
  margin-right: 20rpx;
}

.activity-info {
  flex: 1;
}

.activity-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.reservation-id {
  font-size: 22rpx;
  color: #999999;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-confirmed {
  background: #E3F2FD;
  color: #1976D2;
}

.status-checked_in {
  background: #E8F5E9;
  color: #2E8B57;
}

.status-cancelled {
  background: #F5F5F5;
  color: #999999;
}

.status-pending {
  background: #FFF3E0;
  color: #F57C00;
}

.card-body {
  padding: 24rpx 32rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.info-label {
  width: 180rpx;
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}

.info-value.success {
  color: #2E8B57;
  font-weight: 500;
}

.info-value.points {
  color: #FF9800;
  font-weight: 600;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #FAFAFA;
  border-top: 1rpx solid #F0F0F0;
}

.footer-left {
  font-size: 22rpx;
  color: #999999;
}

.footer-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
}

.btn-danger {
  background: #FFEBEE;
  color: #E74C3C;
  border: 1rpx solid #FFCDD2;
}

.btn-default {
  background: #F5F5F5;
  color: #666666;
}

.empty-state {
  padding: 160rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.bottom-space {
  height: 40rpx;
}
