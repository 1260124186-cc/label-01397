<view class="my-reservations-page">

  <view class="tab-bar">
    <scroll-view scroll-x class="tab-scroll" enhanced show-scrollbar="{{false}}">
      <view class="tabs">
        <view
          wx:for="{{tabs}}"
          wx:key="key"
          class="tab-item {{activeTab === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          bindtap="selectTab"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="reservation-list" wx:if="{{filteredReservations.length > 0}}">
    <view
      wx:for="{{filteredReservations}}"
      wx:key="id"
      class="reservation-card"
      data-id="{{item.id}}"
      bindtap="viewDetail"
    >
      <view class="card-header">
        <view class="card-left">
          <view class="activity-icon" style="background: {{item.activityColor}};">
            {{item.activityIcon}}
          </view>
          <view class="activity-info">
            <view class="activity-name">{{item.activityTypeName}}</view>
            <view class="reservation-id">预约号：{{item.id}}</view>
          </view>
        </view>
        <view class="status-tag status-{{item.status}}">
          {{item.statusLabel}}
        </view>
      </view>

      <view class="card-body">
        <view class="info-row">
          <view class="info-label">📅 日期</view>
          <view class="info-value">{{item.date}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">👥 人数</view>
          <view class="info-value">{{item.peopleCount}}人</view>
        </view>
        <view class="info-row">
          <view class="info-label">👤 联系人</view>
          <view class="info-value">{{item.contactName}} · {{item.contactPhone}}</view>
        </view>
        <view class="info-row" wx:if="{{item.checkedInAt}}">
          <view class="info-label">✅ 签到时间</view>
          <view class="info-value success">{{item.checkInTimeLabel}}</view>
        </view>
        <view class="info-row" wx:if="{{item.checkInPointsAwarded}}">
          <view class="info-label">💚 积分奖励</view>
          <view class="info-value points">+{{item.rewardPoints}} 绿色积分</view>
        </view>
      </view>

      <view class="card-footer">
        <view class="footer-left">{{item.createTimeLabel}}</view>
        <view class="footer-actions">
          <view
            wx:if="{{item.status === 'confirmed'}}"
            class="action-btn btn-danger"
            data-id="{{item.id}}"
            catchtap="cancelReservation"
          >取消预约</view>
          <view
            wx:if="{{item.status === 'confirmed'}}"
            class="action-btn btn-primary"
            data-id="{{item.id}}"
            catchtap="showQrCode"
          >出示预约码</view>
          <view
            wx:if="{{item.status === 'checked_in'}}"
            class="action-btn btn-default"
            data-id="{{item.id}}"
            catchtap="viewDetail"
          >查看详情</view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon">📭</view>
    <view class="empty-title">暂无预约记录</view>
    <view class="empty-desc">去预约一场精彩的线下体验吧</view>
    <view class="empty-btn" bindtap="goNewReservation">去预约</view>
  </view>

  <view class="bottom-space"></view>
</view>
