.detail-page {
  min-height: 100vh;
  background: #F5F5F0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.cert-hero {
  padding: 48rpx 32rpx 56rpx;
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.hero-type {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.hero-status {
  display: flex;
  justify-content: center;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
}

.status-chip.verified {
  background: rgba(82, 196, 26, 0.9);
}

.status-chip.warning {
  background: rgba(250, 173, 20, 0.9);
}

.status-chip.pending {
  background: rgba(153, 153, 153, 0.9);
}

.action-bar {
  display: flex;
  align-items: stretch;
  background: #FFFFFF;
  margin: -28rpx 32rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 8rpx;
  background: transparent;
  border: none;
  line-height: 1.4;
}

.action-item::after {
  border: none;
}

.action-item:active {
  background: #F5F5F0;
}

.action-item.danger .action-label {
  color: #ff4d4f;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-label {
  font-size: 24rpx;
  color: #333333;
}

.action-divider {
  width: 1rpx;
  background: #F0F0F0;
  margin: 20rpx 0;
}

.section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #2E8B57, #DAA520);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-subtitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.info-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.mt-md {
  margin-top: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  min-height: 40rpx;
}

.info-row.column {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

.info-value.mono {
  font-family: 'Courier New', monospace;
}

.info-value.small {
  font-size: 22rpx;
}

.info-value.link {
  color: #2E8B57;
  font-weight: 500;
}

.info-value.highlight-green {
  color: #52C41A;
  font-weight: 600;
}

.info-value.text-success {
  color: #52C41A;
}

.info-value.text-warning {
  color: #FAAD14;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  max-width: 65%;
  justify-content: flex-end;
}

.copy-btn {
  padding: 6rpx 16rpx;
  background: #F0F7F2;
  color: #2E8B57;
  font-size: 22rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.copy-btn:active {
  background: #E0EEE5;
}

.info-divider {
  height: 1rpx;
  background: #F0F0F0;
}

.product-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.product-card:active {
  background: #FAFAFA;
}

.product-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #F5F5F0;
}

.product-img image {
  width: 100%;
  height: 100%;
}

.product-img.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-batch,
.product-trace {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.product-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
}

.summary-stats {
  display: flex;
  gap: 16rpx;
}

.stat-box {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-box.pass {
  border-top: 4rpx solid #52C41A;
}

.stat-box.fail {
  border-top: 4rpx solid #ff4d4f;
}

.stat-box.ok {
  border-top: 4rpx solid #52C41A;
}

.stat-box.total {
  border-top: 4rpx solid #1890FF;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.2;
}

.stat-box.pass .stat-num { color: #52C41A; }
.stat-box.fail .stat-num { color: #ff4d4f; }
.stat-box.ok .stat-num { color: #52C41A; }
.stat-box.total .stat-num { color: #1890FF; }

.stat-text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 4rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #F0F0F0;
  color: #666666;
}

.tag.green {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.bc-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(114, 46, 209, 0.1), rgba(24, 144, 255, 0.1));
  border: 1rpx solid rgba(114, 46, 209, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
}

.bc-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.bc-info {
  flex: 1;
}

.bc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #722ED1;
  margin-bottom: 6rpx;
}

.bc-desc {
  font-size: 22rpx;
  color: #999999;
}

.chain-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F0;
}

.chain-field:last-child {
  border-bottom: none;
}

.chain-field-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.chain-check {
  font-size: 24rpx;
}

.chain-label {
  font-size: 26rpx;
  color: #666666;
}

.chain-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  max-width: 50%;
  text-align: right;
  word-break: break-all;
}

.trust-tip {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(135deg, rgba(46, 139, 87, 0.08), rgba(218, 165, 32, 0.08));
  border: 1rpx solid rgba(46, 139, 87, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.trust-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.trust-content {
  flex: 1;
}

.trust-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-bottom: 8rpx;
}

.trust-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.canvas-container {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 2000px;
  opacity: 0;
  pointer-events: none;
}

.export-canvas {
  width: 750px;
  height: 2000px;
}

.info-value.highlight-pink {
  color: #EB2F96;
  font-weight: 600;
}

.info-value.left-align {
  text-align: left;
  max-width: 100%;
  line-height: 1.6;
}

.project-emoji {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.donation-amount-card {
  background: linear-gradient(135deg, #EB2F96, #FF85C0);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(235, 47, 150, 0.25);
}

.donation-amount-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.donation-amount-value {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: 2rpx;
}

.donation-match-tip {
  margin-top: 20rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  font-size: 24rpx;
  backdrop-filter: blur(10px);
}

.donation-tax-tip {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(135deg, rgba(235, 47, 150, 0.06), rgba(255, 133, 192, 0.06));
  border: 1rpx solid rgba(235, 47, 150, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.tax-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.tax-content {
  flex: 1;
}

.tax-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #EB2F96;
  margin-bottom: 8rpx;
}

.tax-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.donation-action-row {
  display: flex;
  gap: 20rpx;
}

.donation-action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.donation-action-btn.outline {
  background: #FFFFFF;
  border: 2rpx solid #EB2F96;
  color: #EB2F96;
}

.donation-action-btn.outline:active {
  background: rgba(235, 47, 150, 0.06);
}

.donation-action-btn.primary {
  background: linear-gradient(135deg, #EB2F96, #FF85C0);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(235, 47, 150, 0.3);
}

.donation-action-btn.primary:active {
  opacity: 0.92;
  transform: scale(0.98);
}
