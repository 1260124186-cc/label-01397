/* 批次查询结果页样式 */

.page-container {
  min-height: 100vh;
  background: #F5F5F0;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  animation: bounce 1s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 150rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.btn-back {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #2E8B57;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-back::after {
  border: none;
}

/* 批次容器 */
.batch-container {
  display: flex;
  flex-direction: column;
}

/* 批次头部 */
.batch-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.batch-icon {
  font-size: 60rpx;
}

.batch-info {
  flex: 1;
}

.batch-no {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.batch-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* SKU列表 */
.sku-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.sku-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s ease;
}

.sku-item:active {
  transform: scale(0.98);
}

.sku-image-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
  flex-shrink: 0;
}

.sku-image {
  width: 100%;
  height: 100%;
}

.sku-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.sku-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sku-spec,
.sku-trace-id,
.sku-date {
  font-size: 24rpx;
  color: #999;
}

.sku-trace-id {
  color: #2E8B57;
}

.sku-arrow {
  font-size: 40rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* 底部提示 */
.footer-tip {
  margin-top: 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

.batch-compare-btn {
  margin-top: 30rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #DAA520, #F0C75E);
  color: #FFFFFF;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(218, 165, 32, 0.3);
}

.batch-compare-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.batch-select-toggle {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
  flex-shrink: 0;
}

.batch-select-toggle:active {
  background: rgba(255, 255, 255, 0.35);
}

.sku-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fff;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  transition: all 0.2s ease;
}

.sku-checkbox-checked {
  border-color: #13C2C2;
  background: #13C2C2;
}

.sku-item-selected {
  border: 2rpx solid #13C2C2;
  background: #e6fffb;
}

.batch-export-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 100;
}

.export-select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.export-select-all-text {
  font-size: 26rpx;
  color: #595959;
}

.export-selected-count {
  flex: 1;
  font-size: 26rpx;
  color: #8c8c8c;
}

.batch-export-btn {
  padding: 16rpx 36rpx;
  background: linear-gradient(135deg, #13C2C2 0%, #36CFC9 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(19, 194, 194, 0.3);
}

.batch-export-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
  color: #bfbfbf;
}

.export-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.export-modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 85vh;
  overflow-y: auto;
}

.export-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 8rpx;
}

.export-modal-subtitle {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.export-watermark-info {
  background: linear-gradient(135deg, #f6ffed 0%, #e6fffb 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #b7eb8f;
}

.export-watermark-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #595959;
  line-height: 1.8;
}

.export-watermark-label {
  color: #8c8c8c;
  width: 120rpx;
  flex-shrink: 0;
}

.export-watermark-value {
  color: #262626;
  font-weight: 500;
  flex: 1;
  word-break: break-all;
}

.export-section {
  margin-bottom: 32rpx;
}

.export-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.export-section-title-icon {
  margin-right: 8rpx;
}

.export-format-list,
.export-scope-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.export-format-item,
.export-scope-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  background: #fafafa;
  transition: all 0.2s ease;
}

.export-format-item.selected,
.export-scope-item.selected {
  border-color: #13C2C2;
  background: #e6fffb;
}

.export-item-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.export-format-item.selected .export-item-radio,
.export-scope-item.selected .export-item-radio {
  border-color: #13C2C2;
}

.export-item-radio-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #13C2C2;
  opacity: 0;
}

.export-format-item.selected .export-item-radio-inner,
.export-scope-item.selected .export-item-radio-inner {
  opacity: 1;
}

.export-item-content {
  flex: 1;
}

.export-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 4rpx;
}

.export-item-desc {
  font-size: 22rpx;
  color: #8c8c8c;
}

.export-modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.export-cancel-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  color: #595959;
  font-weight: 500;
}

.export-confirm-btn {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #13C2C2 0%, #36CFC9 100%);
  color: #fff;
  font-weight: 600;
}

.export-confirm-btn.disabled {
  background: #d9d9d9;
  color: #bfbfbf;
}
