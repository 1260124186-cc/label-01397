.page-container {
  min-height: 100vh;
  background: #F5F5F0;
  padding: 24rpx;
}

.dealer-info-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: white;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
}

.dealer-label {
  color: #999;
}

.dealer-name {
  color: #333;
  font-weight: 500;
  margin: 0 12rpx;
  flex: 1;
}

.level-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.level-province {
  background: rgba(114, 46, 209, 0.15);
  color: #722ED1;
}

.level-city {
  background: rgba(218, 165, 32, 0.15);
  color: #DAA520;
}

.level-store {
  background: rgba(46, 139, 87, 0.15);
  color: #2E8B57;
}

.scan-section {
  padding: 40rpx 0;
}

.scan-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 24rpx;
  padding: 60rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
}

.scan-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.scan-text {
  font-size: 34rpx;
  font-weight: bold;
  color: white;
}

.divider {
  display: flex;
  align-items: center;
  margin: 24rpx 0;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #ddd;
}

.divider-text {
  padding: 0 24rpx;
  color: #999;
  font-size: 24rpx;
}

.input-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.input-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.code-input {
  flex: 1;
  height: 80rpx;
  background: #F8F8F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.btn-parse {
  height: 80rpx;
  line-height: 80rpx;
  background: #1890FF;
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 0 36rpx;
  margin: 0;
}

.btn-parse::after {
  border: none;
}

.test-codes {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.test-label {
  color: #999;
  font-size: 24rpx;
}

.test-code {
  padding: 8rpx 20rpx;
  background: #F0F5FF;
  color: #1890FF;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.parsed-result {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.result-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #F0FFF0 0%, #E8F5E9 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.code-type-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  color: white;
  margin-right: 16rpx;
}

.ct-icon {
  margin-right: 8rpx;
}

.ct-label {
  font-size: 24rpx;
}

.result-code {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-family: monospace;
}

.result-body {
  padding: 24rpx;
}

.info-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-of-type {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  color: #999;
  font-size: 26rpx;
}

.info-value {
  flex: 1;
  color: #333;
  font-size: 26rpx;
  text-align: right;
}

.quantity-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.quantity-row .info-label {
  padding: 0;
  border: none;
}

.qty-control {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 56rpx;
  text-align: center;
  background: #F5F5F0;
  border-radius: 12rpx;
  font-size: 36rpx;
  color: #333;
}

.qty-input {
  width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: #F8F8F5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.result-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: #FAFAF7;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin: 0;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: #F0F0F0;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: white;
}

.recent-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.ri-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.ri-icon.in {
  background: #2E8B57;
}

.ri-info {
  flex: 1;
}

.ri-product {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.ri-meta {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.ri-qty {
  font-size: 30rpx;
  font-weight: bold;
}

.ri-qty.in {
  color: #2E8B57;
}

.user-role-badge {
  font-size: 20rpx;
  background: rgba(46, 139, 87, 0.15);
  color: #2E8B57;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-left: auto;
}
