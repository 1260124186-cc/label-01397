.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 40%, #F5F5F0 100%);
  padding: 0;
  display: flex;
  flex-direction: column;
}

.login-header {
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  position: relative;
}

.back-btn {
  position: absolute;
  top: 60rpx;
  left: 30rpx;
  font-size: 60rpx;
  color: #fff;
  width: 60rpx;
  height: 60rpx;
  line-height: 56rpx;
  text-align: center;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.login-tabs {
  display: flex;
  margin: 0 40rpx 30rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #2E8B57;
  color: #fff;
  font-weight: 500;
}

.login-form,
.auth-form {
  margin: 0 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #FAFAFA;
}

.form-input:focus {
  border-color: #2E8B57;
  background: #fff;
}

.sample-accounts {
  margin: 20rpx 0 30rpx;
}

.sample-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 14rpx;
}

.sample-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.sample-tag {
  display: flex;
  align-items: center;
  background: #F0FFF0;
  border: 1rpx solid #90EE90;
  border-radius: 8rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  color: #2E8B57;
}

.sample-role {
  color: #DAA520;
  margin-right: 6rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(90deg, #2E8B57 0%, #3CB371 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  margin-top: 10rpx;
}

.login-btn::after {
  border: none;
}

.login-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
}

.login-footer {
  margin-top: auto;
  padding: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #999;
}
