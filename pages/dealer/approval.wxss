.approval-page {
  min-height: 100vh;
  background: #F5F5F0;
}

.page-header {
  display: flex;
  align-items: center;
  background: #2E8B57;
  padding: 24rpx 30rpx;
}

.back-btn {
  font-size: 56rpx;
  color: #fff;
  width: 60rpx;
  height: 60rpx;
  line-height: 54rpx;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
  color: #fff;
}

.header-right {
  width: 60rpx;
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #EEE;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active {
  color: #2E8B57;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2E8B57;
  border-radius: 2rpx;
}

.tab-badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  margin-left: 6rpx;
  min-width: 28rpx;
  text-align: center;
}

.approval-list {
  padding: 24rpx;
}

.approval-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #2E8B57;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.approval-item.pending {
  border-left-color: #DAA520;
}

.approval-item.approved {
  border-left-color: #2E8B57;
}

.approval-item.rejected {
  border-left-color: #ff4d4f;
}

.approval-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  width: 72rpx;
  text-align: center;
  flex-shrink: 0;
}

.approval-content {
  flex: 1;
  min-width: 0;
}

.approval-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.approval-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.approval-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.approval-status.pending {
  background: #FFF8E1;
  color: #DAA520;
}

.approval-status.approved {
  background: #E8F5E9;
  color: #2E8B57;
}

.approval-status.rejected {
  background: #FFEBEE;
  color: #ff4d4f;
}

.approval-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.approval-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.approval-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.empty-state {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
