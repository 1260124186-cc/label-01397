<view class="cert-container">
  <view class="empty-state" wx:if="{{!certificate && allCertificates.length === 0}}">
    <view class="empty-icon">📜</view>
    <view class="empty-title">暂无证书</view>
    <view class="empty-desc">完成培训课程并通过测验即可获得结业证书</view>
    <view class="empty-btn" bindtap="goHome">
      去学习
    </view>
  </view>

  <view class="cert-list" wx:if="{{allCertificates.length > 1}}">
    <scroll-view scroll-x class="cert-scroll">
      <view class="cert-tabs">
        <block wx:for="{{allCertificates}}" wx:key="certId">
          <view 
            class="cert-tab {{certificate && certificate.certId === item.certId ? 'active' : ''}}"
            bindtap="onCertSelect"
            data-courseid="{{item.courseId}}"
            style="border-color: {{item.categoryColor}}"
          >
            <text class="tab-icon">{{item.categoryIcon}}</text>
            <text class="tab-name">{{item.categoryLabel}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <view class="cert-wrapper" wx:if="{{certificate}}">
    <view class="cert-card" style="border-color: {{certificate.categoryColor}}">
      <view class="cert-border-top" style="background: {{certificate.categoryColor}}"></view>
      
      <view class="cert-header">
        <view class="cert-logo">🍵</view>
        <view class="cert-title" style="color: {{certificate.categoryColor}}">
          结 业 证 书
        </view>
        <view class="cert-subtitle">CERTIFICATE OF COMPLETION</view>
      </view>

      <view class="cert-body">
        <view class="cert-label">兹证明</view>
        <view class="cert-name">{{certificate.userName}}</view>
        <view class="cert-dealer">（{{certificate.dealerName}}）</view>
        
        <view class="cert-course-section">
          <view class="cert-course-label">已完成</view>
          <view class="cert-course-badge" style="background: {{certificate.categoryColor}}20; color: {{certificate.categoryColor}}">
            <text class="badge-icon">{{certificate.categoryIcon}}</text>
            <text class="badge-text">{{certificate.categoryLabel}}</text>
          </view>
          <view class="cert-course-name">{{certificate.courseName}}</view>
          <view class="cert-course-label">培训课程学习，成绩合格，特发此证。</view>
        </view>

        <view class="cert-footer">
          <view class="cert-info">
            <view class="info-item">
              <text class="info-label">证书编号</text>
              <text class="info-value">{{certificate.certNo}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">颁发日期</text>
              <text class="info-value">{{certificate.issueTimeStr}}</text>
            </view>
          </view>
          
          <view class="cert-issuer">
            <view class="issuer-seal" style="border-color: {{certificate.categoryColor}}; color: {{certificate.categoryColor}}">
              <view class="seal-text">{{certificate.issuer}}</view>
              <view class="seal-star">★</view>
            </view>
          </view>
        </view>
      </view>

      <view class="cert-border-bottom" style="background: {{certificate.categoryColor}}"></view>
    </view>

    <view class="cert-actions">
      <view class="action-btn" bindtap="onShare">
        <text class="action-icon">📤</text>
        <text class="action-text">分享证书</text>
      </view>
      <view class="action-btn primary" style="background: {{certificate.categoryColor}}" bindtap="onSaveImage">
        <text class="action-icon">💾</text>
        <text class="action-text">保存图片</text>
      </view>
    </view>

    <view class="cert-tips">
      <text>💡 提示：完成全部必修课程后可解锁出库权限</text>
    </view>
  </view>

  <view class="bottom-nav" wx:if="{{certificate}}">
    <view class="nav-btn" bindtap="goBack">
      返回课程
    </view>
    <view class="nav-btn primary" bindtap="goHome">
      返回首页
    </view>
  </view>
</view>
