.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.stats-banner {
  position: relative;
  margin-bottom: 20rpx;
}

.stats-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 50%, #52C41A 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.stats-content {
  position: relative;
  padding: 30rpx;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 90rpx;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.user-detail {
  color: #fff;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-dealer {
  font-size: 24rpx;
  opacity: 0.9;
}

.cert-entry {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  text-align: center;
  color: #fff;
}

.cert-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.cert-count {
  font-size: 32rpx;
  font-weight: 600;
}

.cert-label {
  font-size: 20rpx;
  opacity: 0.9;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stockout-status {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.status-success, .status-warning {
  display: flex;
  align-items: center;
}

.status-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.status-success .status-text {
  color: #52C41A;
  font-size: 26rpx;
  font-weight: 500;
}

.status-warning .status-text {
  color: #FA8C16;
  font-size: 26rpx;
  font-weight: 500;
}

.category-tabs {
  background: #fff;
  margin-bottom: 20rpx;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-container {
  display: inline-flex;
  padding: 20rpx 10rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 30rpx;
  margin: 0 10rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #2E8B57, #52C41A);
}

.tab-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 24rpx;
  color: #666;
}

.tab-item.active .tab-label {
  color: #fff;
}

.course-list {
  padding: 0 30rpx 30rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.course-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.course-cover {
  position: relative;
  height: 280rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.course-category {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
}

.course-badge {
  position: absolute;
  top: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.course-badge.required {
  right: 20rpx;
  background: #FF4D4F;
  color: #fff;
}

.course-badge.cert {
  right: 120rpx;
  background: #722ED1;
  color: #fff;
}

.course-info {
  padding: 24rpx 30rpx;
}

.course-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.course-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.course-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999;
  margin-right: 30rpx;
}

.meta-icon {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.meta-item.difficulty {
  background: #E6F7FF;
  color: #1890FF;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.course-progress {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-status {
  font-size: 24rpx;
  font-weight: 500;
}

.progress-status.not-started {
  color: #999;
}

.progress-status.in-progress {
  color: #1890FF;
}

.progress-status.completed {
  color: #52C41A;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
}

.progress-bar {
  height: 8rpx;
  background: #EEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E8B57, #52C41A);
  border-radius: 4rpx;
  transition: width 0.3s;
}
