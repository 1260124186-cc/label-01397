.cert-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 30rpx;
  padding-bottom: 140rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #388E3C 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.cert-list {
  margin-bottom: 30rpx;
}

.cert-scroll {
  white-space: nowrap;
}

.cert-tabs {
  display: inline-flex;
  gap: 20rpx;
  padding: 10rpx 0;
}

.cert-tab {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 30rpx;
  border: 2rpx solid #E0E0E0;
  font-size: 26rpx;
  color: #666;
}

.cert-tab.active {
  background: #E8F5E9;
  color: #2E7D32;
  font-weight: bold;
}

.tab-icon {
  font-size: 28rpx;
}

.tab-name {
  white-space: nowrap;
}

.cert-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cert-card {
  width: 100%;
  background: linear-gradient(145deg, #FFFEF9 0%, #FFF8E7 100%);
  border-radius: 20rpx;
  border: 4rpx solid #2E7D32;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.cert-border-top,
.cert-border-bottom {
  height: 8rpx;
  background: #2E7D32;
}

.cert-header {
  text-align: center;
  padding: 50rpx 40rpx 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.8) 0%, transparent 100%);
}

.cert-logo {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.cert-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2E7D32;
  letter-spacing: 20rpx;
  margin-bottom: 10rpx;
  padding-left: 20rpx;
}

.cert-subtitle {
  font-size: 22rpx;
  color: #999;
  letter-spacing: 4rpx;
}

.cert-body {
  padding: 30rpx 50rpx 40rpx;
}

.cert-label {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 10rpx;
}

.cert-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 8rpx;
}

.cert-dealer {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.cert-course-section {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.cert-course-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.cert-course-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(46, 125, 50, 0.1);
  border-radius: 20rpx;
  margin-bottom: 15rpx;
}

.badge-icon {
  font-size: 24rpx;
}

.badge-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #2E7D32;
}

.cert-course-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.cert-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.cert-info {
  flex: 1;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 15rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 22rpx;
  color: #999;
}

.info-value {
  font-size: 24rpx;
  color: #333;
  font-family: 'Courier New', monospace;
}

.cert-issuer {
  flex-shrink: 0;
}

.issuer-seal {
  width: 140rpx;
  height: 140rpx;
  border: 4rpx solid #2E7D32;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #2E7D32;
  transform: rotate(-15deg);
}

.seal-text {
  font-size: 20rpx;
  text-align: center;
  line-height: 1.3;
  font-weight: bold;
}

.seal-star {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.cert-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-btn.primary {
  background: #2E7D32;
  color: #fff;
  font-weight: bold;
}

.action-icon {
  font-size: 28rpx;
}

.cert-tips {
  margin-top: 30rpx;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  gap: 20rpx;
}

.nav-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background: #F5F5F5;
  color: #333;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.nav-btn.primary {
  background: linear-gradient(135deg, #2E7D32 0%, #388E3C 100%);
  color: #fff;
  font-weight: bold;
}
