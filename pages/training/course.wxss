.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

.course-header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.header-bg {
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.7) 100%);
}

.header-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 30rpx;
  color: #fff;
}

.course-category {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-bottom: 16rpx;
}

.course-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.course-desc {
  font-size: 24rpx;
  opacity: 0.9;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.course-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  margin-right: 24rpx;
  opacity: 0.9;
}

.meta-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.meta-item.difficulty {
  background: rgba(255,255,255,0.2);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.meta-item.required {
  background: #FF4D4F;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.progress-card {
  background: #fff;
  margin: -40rpx 30rpx 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.progress-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.progress-status {
  font-size: 24rpx;
  color: #FA8C16;
}

.progress-status.completed {
  color: #52C41A;
}

.progress-bar-container {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #EEE;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E8B57, #52C41A);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-percent {
  font-size: 26rpx;
  font-weight: 600;
  color: #2E8B57;
  min-width: 80rpx;
  text-align: right;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.stat {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.section-card {
  background: #fff;
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.quiz-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.quiz-status.passed {
  background: #F6FFED;
  color: #52C41A;
}

.quiz-status.failed {
  background: #FFF1F0;
  color: #FF4D4F;
}

.quiz-status.pending {
  background: #FFF7E6;
  color: #FA8C16;
}

.chapter-list {
  margin: -10rpx;
}

.chapter-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #FAFAFA;
  transition: all 0.2s;
}

.chapter-item:active {
  background: #F0F0F0;
}

.chapter-item.completed {
  background: #F6FFED;
}

.chapter-index {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #E8E8E8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.chapter-item.completed .chapter-index {
  background: #52C41A;
}

.check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.index-text {
  color: #999;
  font-size: 26rpx;
  font-weight: 600;
}

.chapter-info {
  flex: 1;
  min-width: 0;
}

.chapter-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.chapter-item.completed .chapter-title {
  color: #52C41A;
}

.chapter-meta {
  display: flex;
  align-items: center;
}

.meta-text {
  font-size: 22rpx;
  color: #999;
  margin-right: 20rpx;
}

.chapter-arrow {
  font-size: 40rpx;
  color: #CCC;
  flex-shrink: 0;
}

.quiz-result {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.result-label {
  font-size: 24rpx;
  color: #999;
}

.result-score {
  font-size: 32rpx;
  font-weight: 600;
}

.result-text {
  font-size: 24rpx;
  color: #666;
}

.quiz-info {
  margin-bottom: 20rpx;
}

.quiz-desc {
  font-size: 24rpx;
  color: #999;
}

.quiz-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #2E8B57, #52C41A);
  color: #fff;
  border: none;
}

.quiz-btn.disabled {
  background: #D9D9D9;
  color: #999;
}

.cert-preview {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFE7BA 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.cert-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.cert-text {
  flex: 1;
}

.cert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #D48806;
  margin-bottom: 4rpx;
}

.cert-desc {
  font-size: 24rpx;
  color: #D48806;
  opacity: 0.8;
}

.cert-arrow {
  font-size: 36rpx;
  color: #D48806;
}

.cert-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #D48806, #FA8C16);
  color: #fff;
  border: none;
}

.bottom-tip {
  display: flex;
  align-items: flex-start;
  background: #FFFBE6;
  border-left: 8rpx solid #FAAD14;
  padding: 24rpx 30rpx;
  margin: 20rpx 30rpx 0;
  border-radius: 0 12rpx 12rpx 0;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #D48806;
  line-height: 1.6;
}
