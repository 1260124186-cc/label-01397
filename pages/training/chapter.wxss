.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 140rpx;
}

.chapter-header {
  background: linear-gradient(135deg, #2E8B57 0%, #52C41A 100%);
  padding: 30rpx;
  color: #fff;
}

.chapter-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-text {
  font-size: 24rpx;
  opacity: 0.9;
}

.nav-status {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.nav-status.completed {
  background: rgba(255, 255, 255, 0.3);
}

.chapter-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.chapter-meta {
  display: flex;
  margin-bottom: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  opacity: 0.9;
  margin-right: 30rpx;
}

.study-progress {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: #FFD700;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-tip {
  font-size: 22rpx;
  opacity: 0.8;
}

.chapter-content {
  padding: 30rpx;
}

.content-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.content-card :deep(h2) {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin: 40rpx 0 20rpx;
}

.content-card :deep(h3) {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 30rpx 0 16rpx;
}

.content-card :deep(p) {
  margin: 16rpx 0;
  line-height: 1.8;
  color: #666;
  font-size: 28rpx;
}

.content-card :deep(strong) {
  color: #2E8B57;
  font-weight: 600;
}

.content-card :deep(li) {
  margin: 12rpx 0;
  padding-left: 10rpx;
  line-height: 1.8;
  color: #666;
  font-size: 28rpx;
}

.media-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.media-list {
  display: flex;
  flex-direction: column;
}

.media-item {
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FAFAFA;
}

.media-item:last-child {
  margin-bottom: 0;
}

.media-image {
  width: 100%;
  height: 400rpx;
}

.media-caption {
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  background: #FAFAFA;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin: 0 10rpx;
  border: none;
}

.nav-btn.prev {
  background: #F5F5F5;
  color: #666;
}

.nav-btn.back {
  background: #E8F5E9;
  color: #2E8B57;
  flex: 0.8;
}

.nav-btn.next {
  background: linear-gradient(135deg, #2E8B57, #52C41A);
  color: #fff;
}

.nav-btn.disabled {
  background: #F0F0F0;
  color: #CCC;
}
