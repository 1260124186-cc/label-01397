<view class="export-trace {{a11yClasses}}">
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <view class="loading-text">{{i18n.loadingText}}</view>
  </view>

  <view wx:elif="{{error}}" class="error-container">
    <view class="error-icon">⚠️</view>
    <view class="error-text">{{error}}</view>
    <button class="retry-btn" bindtap="loadExportData" data-traceId="{{traceId}}">{{i18n.retry}}</button>
  </view>

  <view wx:else class="content">
    <view class="header-section">
      <view class="header-top">
        <view class="trace-info">
          <view class="trace-id-label">{{i18n.traceIdLabel}}</view>
          <view class="trace-id-value">{{traceId}}</view>
        </view>
        <view class="export-badge">{{i18n.badgeExport}}</view>
      </view>
      <view class="header-subtitle">{{i18n.subtitle}}</view>

      <view class="view-toggle-section">
        <view class="view-mode-label">{{i18n.header.viewModeLabel}}</view>
        <view class="view-mode-toggle">
          <view class="mode-item mode-domestic" bindtap="switchToDomestic">
            <text class="mode-icon">🏠</text>
            <text class="mode-text">{{i18n.header.viewModeDomestic}}</text>
          </view>
          <view class="mode-item mode-export active">
            <text class="mode-icon">🌏</text>
            <text class="mode-text">{{i18n.header.viewModeExport}}</text>
          </view>
        </view>
      </view>

      <view class="lang-switch">
        <view class="lang-label">{{i18n.header.interfaceLangLabel}}</view>
        <view class="lang-options">
          <view
            wx:for="{{availableLanguagesWithLabel}}"
            wx:key="code"
            class="lang-item {{currentLang === item.code ? 'active' : ''}}"
            data-lang="{{item.code}}"
            bindtap="switchLanguage"
          >
            {{item.label}}
          </view>
        </view>
      </view>
    </view>

    <view class="section basic-info-section">
      <view class="section-header">
        <text class="section-icon">📋</text>
        <text class="section-title">{{i18n.basicInfo.title}}</text>
      </view>
      <view class="info-card">
        <view class="info-row">
          <view class="info-label">{{i18n.basicInfo.exportBatchNo}}</view>
          <view class="info-value copyable" data-value="{{exportInfo.exportBatchNo}}" bindtap="copyValue">
            {{exportInfo.exportBatchNo}}
            <text class="copy-icon">📋</text>
          </view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.basicInfo.hsCode}}</view>
          <view class="info-value copyable" data-value="{{exportInfo.hsCode}}" bindtap="copyValue">
            <text class="hs-code">{{exportInfo.hsCode}}</text>
            <text class="copy-icon">📋</text>
          </view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.basicInfo.hsCodeDesc}}</view>
          <view class="info-value desc">{{exportInfo.hsCodeDescription}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.basicInfo.countryOfOrigin}}</view>
          <view class="info-value">{{exportInfo.countryOfOrigin}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.basicInfo.originRegion}}</view>
          <view class="info-value">{{exportInfo.originRegion}}</view>
        </view>
        <view class="info-row" wx:if="{{exportInfo.targetMarkets && exportInfo.targetMarkets.length > 0}}">
          <view class="info-label">{{i18n.basicInfo.targetMarkets}}</view>
          <view class="info-value">
            <view class="market-tags">
              <text wx:for="{{exportInfo.targetMarkets}}" wx:key="*this" class="market-tag">{{item}}</text>
            </view>
          </view>
        </view>
        <view class="info-row" wx:if="{{basicInfo && basicInfo.productName}}">
          <view class="info-label">{{i18n.basicInfo.productName}}</view>
          <view class="info-value">{{basicInfo.productName}}</view>
        </view>
      </view>
    </view>

    <view class="section certificate-section">
      <view class="section-header">
        <text class="section-icon">📜</text>
        <text class="section-title">{{i18n.certificateOfOrigin.title}}</text>
        <text class="section-badge co-badge">{{i18n.certificateOfOrigin.badge}}</text>
      </view>
      <view class="cert-card">
        <view class="cert-status valid">
          <text class="status-icon">✓</text>
          <text class="status-text">{{i18n.certificateOfOrigin.statusValid}}</text>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.certificateOfOrigin.certNo}}</view>
          <view class="info-value copyable" data-value="{{exportInfo.certificateOfOrigin.certNo}}" bindtap="copyValue">
            {{exportInfo.certificateOfOrigin.certNo}}
            <text class="copy-icon">📋</text>
          </view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.certificateOfOrigin.certType}}</view>
          <view class="info-value">{{exportInfo.certificateOfOrigin.certType}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.certificateOfOrigin.issuingAuthority}}</view>
          <view class="info-value">{{exportInfo.certificateOfOrigin.issuingAuthority}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.certificateOfOrigin.issueDate}}</view>
          <view class="info-value">{{exportInfo.certificateOfOrigin.issueDate}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.certificateOfOrigin.validUntil}}</view>
          <view class="info-value">{{exportInfo.certificateOfOrigin.validUntil}}</view>
        </view>
        <button
          class="verify-btn"
          data-url="{{exportInfo.certificateOfOrigin.verifyUrl}}"
          bindtap="openUrl"
        >
          {{i18n.certificateOfOrigin.verifyButton}}
        </button>
      </view>
    </view>

    <view class="section inspection-section">
      <view class="section-header">
        <text class="section-icon">🔬</text>
        <text class="section-title">{{i18n.inspectionQuarantine.title}}</text>
        <text class="section-badge ciq-badge">{{i18n.inspectionQuarantine.badge}}</text>
      </view>
      <view class="cert-card">
        <view class="cert-status pass">
          <text class="status-icon">✓</text>
          <text class="status-text">{{i18n.inspectionQuarantine.resultPass}}</text>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.inspectionQuarantine.certNo}}</view>
          <view class="info-value copyable" data-value="{{exportInfo.inspectionQuarantine.certNo}}" bindtap="copyValue">
            {{exportInfo.inspectionQuarantine.certNo}}
            <text class="copy-icon">📋</text>
          </view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.inspectionQuarantine.issuingAuthority}}</view>
          <view class="info-value">{{exportInfo.inspectionQuarantine.issuingAuthority}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.inspectionQuarantine.inspectionDate}}</view>
          <view class="info-value">{{exportInfo.inspectionQuarantine.inspectionDate}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">{{i18n.inspectionQuarantine.standard}}</view>
          <view class="info-value desc">{{exportInfo.inspectionQuarantine.standard}}</view>
        </view>

        <view wx:if="{{exportInfo.inspectionQuarantine.items && exportInfo.inspectionQuarantine.items.length > 0}}" class="inspection-items">
          <view class="items-title">{{i18n.inspectionQuarantine.items}}</view>
          <view class="items-table">
            <view class="table-header">
              <view class="table-cell">{{i18n.inspectionQuarantine.tableItem}}</view>
              <view class="table-cell">{{i18n.inspectionQuarantine.tableResult}}</view>
              <view class="table-cell">{{i18n.inspectionQuarantine.tableStandard}}</view>
            </view>
            <view wx:for="{{exportInfo.inspectionQuarantine.items}}" wx:key="item" class="table-row">
              <view class="table-cell">{{item.item}}</view>
              <view class="table-cell result-pass">{{item.result}}</view>
              <view class="table-cell">{{item.standard}}</view>
            </view>
          </view>
        </view>

        <button
          class="verify-btn"
          data-url="{{exportInfo.inspectionQuarantine.verifyUrl}}"
          bindtap="openUrl"
        >
          {{i18n.inspectionQuarantine.verifyButton}}
        </button>
      </view>
    </view>

    <view class="section label-section">
      <view class="section-header">
        <text class="section-icon">🏷️</text>
        <text class="section-title">{{i18n.multilingualLabel.title}}</text>
      </view>
      <view class="label-subtitle">{{i18n.multilingualLabel.subtitle}}</view>

      <view class="label-lang-switch">
        <view
          wx:for="{{availableLabelLanguagesWithLabel}}"
          wx:key="code"
          class="label-lang-item {{currentLabelLang === item.code ? 'active' : ''}}"
          data-lang="{{item.code}}"
          bindtap="switchLabelLang"
        >
          {{item.label}}
        </view>
      </view>

      <view wx:if="{{currentLabelData}}" class="label-preview-card">
        <view class="label-header">
          <text class="label-product-name">{{currentLabelData.data.productName}}</text>
        </view>
        <view class="label-body">
          <view class="label-row">
            <view class="label-key">{{i18n.multilingualLabel.ingredients}}</view>
            <view class="label-value">{{currentLabelData.data.ingredients}}</view>
          </view>
          <view class="label-row">
            <view class="label-key">{{i18n.multilingualLabel.netContent}}</view>
            <view class="label-value">{{currentLabelData.data.netContent}}</view>
          </view>
          <view class="label-row">
            <view class="label-key">{{i18n.multilingualLabel.shelfLife}}</view>
            <view class="label-value">{{currentLabelData.data.shelfLife}}</view>
          </view>
          <view class="label-row">
            <view class="label-key">{{i18n.multilingualLabel.storageMethod}}</view>
            <view class="label-value">{{currentLabelData.data.storageMethod}}</view>
          </view>
          <view class="label-row">
            <view class="label-key">{{i18n.multilingualLabel.origin}}</view>
            <view class="label-value">{{currentLabelData.data.origin}}</view>
          </view>
          <view class="label-row">
            <view class="label-key">{{i18n.multilingualLabel.manufacturer}}</view>
            <view class="label-value">{{currentLabelData.data.manufacturer}}</view>
          </view>
          <view class="label-row">
            <view class="label-key">{{i18n.multilingualLabel.address}}</view>
            <view class="label-value">{{currentLabelData.data.address}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section shipping-section">
      <view class="section-header">
        <text class="section-icon">🚢</text>
        <text class="section-title">{{i18n.shipping.title}}</text>
        <text class="section-badge shipping-badge">{{i18n.shipping.badge}}</text>
      </view>
      <view class="shipping-card">
        <view class="shipping-status in-transit">
          <text class="status-icon">🚢</text>
          <text class="status-text">
            <text wx:if="{{shippingInfo && shippingInfo.method === 'ocean'}}">{{i18n.shipping.methodOcean}} {{mappedShippingStatusLabel}}</text>
            <text wx:elif="{{shippingInfo && shippingInfo.method === 'air'}}">{{i18n.shipping.methodAir}} {{mappedShippingStatusLabel}}</text>
            <text wx:else>{{mappedShippingStatusLabel}}</text>
          </text>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.shipping.method}}</view>
          <view class="info-value">{{mappedShippingMethodLabel}}</view>
        </view>

        <view wx:if="{{shippingInfo && shippingInfo.containerNo}}" class="info-row">
          <view class="info-label">{{i18n.shipping.containerNo}}</view>
          <view class="info-value copyable container-no" data-value="{{shippingInfo.containerNo}}" bindtap="copyValue">
            <text class="highlight-value">{{shippingInfo.containerNo}}</text>
            <text class="copy-icon">📋</text>
          </view>
        </view>

        <view wx:if="{{shippingInfo && shippingInfo.containerType}}" class="info-row">
          <view class="info-label">{{i18n.shipping.containerType}}</view>
          <view class="info-value">{{shippingInfo.containerType}}</view>
        </view>

        <view wx:if="{{shippingInfo && shippingInfo.vesselName}}" class="info-row">
          <view class="info-label">{{i18n.shipping.vesselName}}</view>
          <view class="info-value">{{shippingInfo.vesselName}}</view>
        </view>

        <view wx:if="{{shippingInfo && shippingInfo.voyageNo}}" class="info-row">
          <view class="info-label">{{i18n.shipping.voyageNo}}</view>
          <view class="info-value">{{shippingInfo.voyageNo}}</view>
        </view>

        <view wx:if="{{shippingInfo && shippingInfo.billOfLading}}" class="info-row">
          <view class="info-label">{{i18n.shipping.billOfLading}}</view>
          <view class="info-value copyable" data-value="{{shippingInfo.billOfLading}}" bindtap="copyValue">
            {{shippingInfo.billOfLading}}
            <text class="copy-icon">📋</text>
          </view>
        </view>

        <view class="shipping-route">
          <view class="route-port">
            <view class="port-name">{{safePortOfLoading}}</view>
            <view class="port-label">{{i18n.shipping.portOfLoading}}</view>
            <view class="port-date">{{shippingInfo.etd || i18n.na}}</view>
          </view>
          <view class="route-arrow">
            <view class="arrow-line"></view>
            <view class="arrow-icon">→</view>
            <view class="arrow-line"></view>
          </view>
          <view class="route-port">
            <view class="port-name">{{safePortOfDischarge}}</view>
            <view class="port-label">{{i18n.shipping.portOfDischarge}}</view>
            <view class="port-date">{{shippingInfo.eta || i18n.na}}</view>
          </view>
        </view>

        <button
          class="tracking-btn"
          data-url="{{shippingInfo.trackingUrl}}"
          bindtap="openUrl"
        >
          {{i18n.shipping.trackingButton}}
        </button>
      </view>
    </view>

    <view class="section customs-section">
      <view class="section-header">
        <text class="section-icon">🛃</text>
        <text class="section-title">{{i18n.customsClearance.title}}</text>
        <text class="section-badge customs-badge">{{i18n.customsClearance.badge}}</text>
        <text class="refresh-icon" bindtap="refreshCustoms">🔄</text>
      </view>
      <view class="customs-card">
        <view class="customs-status {{customsStatus.status || 'pending'}}">
          <view class="status-indicator"></view>
          <view class="status-text">
            <block wx:if="{{customsStatus.status === 'cleared'}}">{{i18n.customsClearance.statusCleared}}</block>
            <block wx:elif="{{customsStatus.status === 'in_transit'}}">{{i18n.customsClearance.statusInTransit}}</block>
            <block wx:elif="{{customsStatus.status === 'declared'}}">{{i18n.customsClearance.statusDeclared}}</block>
            <block wx:elif="{{customsStatus.status === 'pending'}}">{{i18n.customsClearance.statusPending}}</block>
            <block wx:elif="{{customsStatus.status === 'rejected'}}">{{i18n.customsClearance.statusRejected}}</block>
            <block wx:else>{{mappedCustomsStatusLabel}}</block>
          </view>
        </view>

        <view wx:if="{{customsStatus.declarationNo}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.declarationNo}}</view>
          <view class="info-value copyable" data-value="{{customsStatus.declarationNo}}" bindtap="copyValue">
            {{customsStatus.declarationNo}}
            <text class="copy-icon">📋</text>
          </view>
        </view>

        <view wx:if="{{customsStatus.declareDate}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.declareDate}}</view>
          <view class="info-value">{{customsStatus.declareDate}}</view>
        </view>

        <view wx:if="{{customsStatus.customsOffice}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.customsOffice}}</view>
          <view class="info-value">{{customsStatus.customsOffice}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.customsClearance.importCountry}}</view>
          <view class="info-value">{{safeImportCountry}}</view>
        </view>

        <view wx:if="{{customsStatus.importCustoms}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.importCustoms}}</view>
          <view class="info-value">{{customsStatus.importCustoms}}</view>
        </view>

        <view wx:if="{{customsStatus.tariffCode}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.tariffCode}}</view>
          <view class="info-value">{{customsStatus.tariffCode}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.customsClearance.dutyRate}}</view>
          <view class="info-value">{{safeDutyRate}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.customsClearance.importValue}}</view>
          <view class="info-value highlight-value">{{safeImportValue}}</view>
        </view>

        <view wx:if="{{customsStatus.taxPaid}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.taxPaid}}</view>
          <view class="info-value">{{customsStatus.taxPaid}}</view>
        </view>

        <view wx:if="{{customsStatus.clearanceDate}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.clearanceDate}}</view>
          <view class="info-value">{{customsStatus.clearanceDate}}</view>
        </view>

        <view wx:if="{{customsStatus.inspectionRequired !== undefined}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.inspectionRequired}}</view>
          <view class="info-value">
            <text wx:if="{{customsStatus.inspectionRequired}}">{{i18n.customsClearance.yes}}</text>
            <text wx:else>{{i18n.customsClearance.no}}</text>
          </view>
        </view>

        <view wx:if="{{customsStatus.inspectionStatus}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.inspectionStatus}}</view>
          <view class="info-value">
            <block wx:if="{{customsStatus.inspectionStatus === 'passed'}}"><text class="status-pass">{{i18n.customsClearance.inspectionPassed}}</text></block>
            <block wx:elif="{{customsStatus.inspectionStatus === 'pending'}}">{{i18n.customsClearance.inspectionPending}}</block>
            <block wx:elif="{{customsStatus.inspectionStatus === 'failed'}}"><text class="status-fail">{{i18n.customsClearance.inspectionFailed}}</text></block>
            <block wx:else>{{mappedInspectionStatusLabel}}</block>
          </view>
        </view>

        <view wx:if="{{customsStatus.remarks}}" class="info-row">
          <view class="info-label">{{i18n.customsClearance.remarks}}</view>
          <view class="info-value desc">{{customsStatus.remarks}}</view>
        </view>
      </view>
    </view>

    <view class="section distributor-section">
      <view class="section-header">
        <text class="section-icon">🏪</text>
        <text class="section-title">{{i18n.overseasDistributor.title}}</text>
        <text class="section-badge distributor-badge">{{i18n.overseasDistributor.badge}}</text>
      </view>
      <view class="distributor-card">
        <view class="distributor-name">{{exportInfo.overseasDistributor.name}}</view>
        <view class="distributor-level">{{mappedDistributorLevel}}</view>

        <view class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.country}}</view>
          <view class="info-value">{{exportInfo.overseasDistributor.country}}</view>
        </view>

        <view wx:if="{{exportInfo.overseasDistributor.region}}" class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.region}}</view>
          <view class="info-value">{{exportInfo.overseasDistributor.region}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.address}}</view>
          <view class="info-value desc">{{exportInfo.overseasDistributor.address}}</view>
        </view>

        <view wx:if="{{exportInfo.overseasDistributor.contactPerson}}" class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.contactPerson}}</view>
          <view class="info-value">{{exportInfo.overseasDistributor.contactPerson}}</view>
        </view>

        <view wx:if="{{exportInfo.overseasDistributor.contactEmail}}" class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.contactEmail}}</view>
          <view class="info-value copyable" data-value="{{exportInfo.overseasDistributor.contactEmail}}" bindtap="copyValue">
            {{exportInfo.overseasDistributor.contactEmail}}
            <text class="copy-icon">📋</text>
          </view>
        </view>

        <view wx:if="{{exportInfo.overseasDistributor.contactPhone}}" class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.contactPhone}}</view>
          <view class="info-value copyable" data-value="{{exportInfo.overseasDistributor.contactPhone}}" bindtap="copyValue">
            {{exportInfo.overseasDistributor.contactPhone}}
            <text class="copy-icon">📋</text>
          </view>
        </view>

        <view wx:if="{{exportInfo.overseasDistributor.licenseNo}}" class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.licenseNo}}</view>
          <view class="info-value copyable" data-value="{{exportInfo.overseasDistributor.licenseNo}}" bindtap="copyValue">
            {{exportInfo.overseasDistributor.licenseNo}}
            <text class="copy-icon">📋</text>
          </view>
        </view>

        <view wx:if="{{exportInfo.overseasDistributor.authorizedDate}}" class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.authorizedDate}}</view>
          <view class="info-value">{{exportInfo.overseasDistributor.authorizedDate}}</view>
        </view>

        <view wx:if="{{exportInfo.overseasDistributor.authorizedProducts && exportInfo.overseasDistributor.authorizedProducts.length > 0}}" class="info-row">
          <view class="info-label">{{i18n.overseasDistributor.authorizedProducts}}</view>
          <view class="info-value">
            <view class="product-tags">
              <text wx:for="{{exportInfo.overseasDistributor.authorizedProducts}}" wx:key="*this" class="product-tag">{{item}}</text>
            </view>
          </view>
        </view>

        <button
          class="verify-btn"
          data-url="{{exportInfo.overseasDistributor.verifyUrl}}"
          bindtap="openUrl"
        >
          {{i18n.overseasDistributor.verifyButton}}
        </button>
      </view>
    </view>

    <view class="section blockchain-section">
      <view class="section-header">
        <text class="section-icon">🔗</text>
        <text class="section-title">{{i18n.blockchain.title}}</text>
        <text class="section-badge blockchain-badge">{{i18n.blockchain.badge}}</text>
      </view>
      <view class="blockchain-card">
        <view class="blockchain-status {{blockchainVerified ? 'verified' : ''}}">
          <view class="status-dot"></view>
          <view class="status-text">
            <text wx:if="{{blockchainVerified}}">{{i18n.blockchain.verified}}</text>
            <text wx:else>{{i18n.blockchain.pendingVerify}}</text>
          </view>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.blockchain.chainName}}</view>
          <view class="info-value">{{mappedBlockchainChainName}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.blockchain.txHash}}</view>
          <view class="info-value hash-value copyable" data-value="{{exportInfo.exportBlockchain.txHash}}" bindtap="copyValue">
            <text>{{exportInfo.exportBlockchain.txHashShort}}</text>
            <text class="copy-icon">📋</text>
          </view>
        </view>

        <view class="info-row">
          <view class="info-label">{{i18n.blockchain.timestamp}}</view>
          <view class="info-value">{{exportInfo.exportBlockchain.timestamp}}</view>
        </view>

        <view wx:if="{{mappedOnChainFields && mappedOnChainFields.length > 0}}" class="onchain-fields">
          <view class="fields-title">{{i18n.blockchain.onChainFields}}</view>
          <view class="field-list">
            <view wx:for="{{mappedOnChainFields}}" wx:key="key" class="field-item">
              <view class="field-label">{{item.label}}</view>
              <view class="field-value">{{item.value}}</view>
              <view class="field-badge">{{i18n.blockchain.onChain}}</view>
            </view>
          </view>
        </view>

        <button
          class="verify-btn blockchain-verify-btn"
          bindtap="verifyBlockchain"
          loading="{{blockchainVerifying}}"
        >
          <block wx:if="{{blockchainVerifying}}">{{i18n.blockchain.verifying}}</block>
          <block wx:else>{{i18n.blockchain.verifyButton}}</block>
        </button>
      </view>
    </view>

    <view class="section footer-section">
      <view class="footer-hint">{{i18n.viewToggle.sameTraceId}} · {{i18n.viewToggle.differentView}}</view>
      <view class="footer-trace-id">{{i18n.viewToggle.footerTraceId}}: {{traceId}}</view>
      <button class="switch-view-btn" bindtap="switchToDomestic">
        {{i18n.viewToggle.switchToDomestic}}
      </button>
    </view>
  </view>
</view>
