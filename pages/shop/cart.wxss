.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.member-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
  color: #fff;
}

.member-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.member-text {
  font-size: 26rpx;
}

.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.item-checkbox {
  padding: 10rpx;
  margin-right: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #2E8B57;
  border-color: #2E8B57;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  display: flex;
  align-items: baseline;
  color: #ff4d4f;
}

.price-symbol {
  font-size: 22rpx;
  font-weight: bold;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.item-quantity {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.qty-btn.disabled {
  color: #ccc;
}

.qty-value {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.item-delete {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 10rpx 20rpx;
}

.promo-tip {
  display: flex;
  align-items: center;
  margin: 0 20rpx 20rpx 20rpx;
  padding: 20rpx 24rpx;
  background: #fff7e6;
  border-radius: 12rpx;
}

.promo-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.promo-text {
  font-size: 24rpx;
  color: #fa8c16;
}

.coupon-entry {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  margin: 0 20rpx 20rpx 20rpx;
  border-radius: 12rpx;
}

.coupon-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.coupon-label {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.coupon-value {
  font-size: 26rpx;
  color: #ff4d4f;
  display: flex;
  align-items: center;
}

.coupon-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 8rpx;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bar-left {
  display: flex;
  align-items: center;
}

.select-all {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
}

.select-text {
  font-size: 26rpx;
  color: #666;
  margin-left: 12rpx;
}

.bar-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.total-info {
  text-align: right;
}

.total-label {
  font-size: 26rpx;
  color: #333;
}

.total-symbol {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.total-value {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.total-desc {
  font-size: 22rpx;
  color: #ff4d4f;
  text-align: right;
}

.checkout-btn {
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4d4f 100%);
  border-radius: 40rpx;
  font-weight: 500;
}

.coupon-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.coupon-mask.show {
  opacity: 1;
  visibility: visible;
}

.coupon-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.coupon-panel.show {
  transform: translateY(0);
}

.coupon-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.coupon-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.coupon-close {
  font-size: 32rpx;
  color: #999;
}

.coupon-scroll {
  flex: 1;
  padding: 20rpx;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coupon-card {
  display: flex;
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  overflow: hidden;
}

.coupon-card.selected {
  border-color: #2E8B57;
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4d4f 100%);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.coupon-amount {
  display: flex;
  align-items: baseline;
}

.amount-symbol {
  font-size: 24rpx;
  font-weight: bold;
}

.amount-value {
  font-size: 48rpx;
  font-weight: bold;
}

.coupon-condition {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 6rpx;
}

.coupon-right {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.coupon-desc {
  font-size: 24rpx;
  color: #999;
}

.no-coupon {
  text-align: center;
  padding: 80rpx;
  font-size: 28rpx;
  color: #999;
}

@page {
  margin-bottom: 100rpx;
}
