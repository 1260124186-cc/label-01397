<view class="page-container" wx:if="{{product}}">
  <!-- 商品图片轮播 -->
  <swiper class="product-swiper" autoplay circular bindchange="onImageChange">
    <swiper-item wx:for="{{product.images}}" wx:key="*this">
      <image 
        class="product-image" 
        src="{{item}}" 
        mode="aspectFill"
        data-url="{{item}}"
        bindtap="onPreviewImage"
      ></image>
    </swiper-item>
  </swiper>
  <view class="image-indicator">
    {{currentImageIndex + 1}}/{{product.images.length}}
  </view>

  <!-- 价格区域 -->
  <view class="price-section">
    <view class="price-row">
      <view class="price-main">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{isMember ? selectedSku.memberPrice : selectedSku.price}}</text>
        <text wx:if="{{isMember}}" class="member-tag">会员价</text>
        <text wx:if="{{isMember && selectedSku.price > selectedSku.memberPrice}}" class="original-price">¥{{selectedSku.price}}</text>
      </view>
      <view class="sales-info">
        已售{{product.sales}}件
      </view>
    </view>
    <view class="product-title">{{product.productName}}</view>
    <view class="product-subtitle">{{product.subtitle}}</view>
  </view>

  <!-- 促销活动 -->
  <view class="promo-section" wx:if="{{promotions.length > 0}}">
    <view class="section-label">活动</view>
    <view class="promo-list">
      <view class="promo-item" wx:for="{{promotions}}" wx:key="id" wx:if="{{index < 2}}">
        <text class="promo-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
        <text class="promo-text">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- ==================== 茶食搭配推荐模块 ==================== -->
  <view wx:if="{{showPairingSection && pairingPlan}}" class="pairing-section" role="region" aria-label="茶食搭配推荐">
    <view class="section-header">
      <view class="section-title">
        <text class="section-title-icon">🍵</text>
        <text>推荐茶食搭配</text>
      </view>
      <view class="view-all-btn" bindtap="onViewFullPairing" aria-label="查看完整搭配方案">
        <text>完整方案</text>
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <!-- 品种搭配卡片 -->
    <view class="pairing-variety-card" style="background: {{pairingPlan.pairing.themeBg}};">
      <view class="pairing-variety-left">
        <view class="pairing-variety-icon">{{pairingPlan.pairing.icon}}</view>
        <view class="pairing-variety-info">
          <view class="pairing-variety-name">{{pairingPlan.pairing.varietyName}}</view>
          <view class="pairing-variety-tagline">{{pairingPlan.pairing.tagline}}</view>
        </view>
      </view>
      <view class="pairing-match-tag">
        <text>搭配指数</text>
        <view class="match-stars">⭐⭐⭐⭐⭐</view>
      </view>
    </view>

    <!-- 搭配推荐文字 -->
    <view class="pairing-intro-box">
      <view class="pairing-intro-label">💡 搭配师说</view>
      <view class="pairing-intro-text">{{pairingPlan.pairing.pairingIntro}}</view>
    </view>

    <!-- 推荐食品列表 -->
    <view class="recommend-food-title">
      <text class="food-title-icon">🍰</text>
      <text>推荐搭配茶点（{{pairingPlan.pairing.recommendedFoodList.length}}款）</text>
    </view>
    <scroll-view scroll-x="{{true}}" class="recommend-food-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="recommend-food-list">
        <view 
          wx:for="{{pairingPlan.pairing.recommendedFoodList}}" 
          wx:key="foodId" 
          class="food-card"
        >
          <image class="food-card-img" src="{{item.thumbnail}}" mode="aspectFill" />
          <view class="food-card-info">
            <view class="food-card-name">{{item.name}}</view>
            <view class="food-card-spec">{{item.spec}}</view>
            <view class="food-card-price-row">
              <text class="food-card-price">¥{{item.price}}</text>
              <text wx:if="{{isMember}}" class="food-card-member-price">VIP¥{{item.memberPrice}}</text>
            </view>
            <view class="food-card-tags">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="food-tag">{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 一键加购区域 -->
    <view class="one-click-add-box">
      <view class="price-breakdown">
        <view class="breakdown-label">一键加购（茶 + {{pairingPlan.pairing.defaultFoodIds.length}}款茶点）</view>
        <view class="breakdown-prices">
          <text wx:if="{{!isMember}}" class="total-price">¥{{pairingPlan.priceInfo.totalPrice}}</text>
          <text wx:if="{{isMember}}" class="total-price member-total">¥{{pairingPlan.priceInfo.memberPrice}}</text>
          <text wx:if="{{isMember && pairingPlan.priceInfo.savings > 0}}" class="save-tag">立省¥{{pairingPlan.priceInfo.savings}}</text>
        </view>
      </view>
      <button class="one-click-btn" bindtap="onPairingOneClickAdd" aria-label="一键加购推荐搭配">
        <text class="btn-icon">🛒</text>
        <text>一键加购全部</text>
      </button>
    </view>

    <!-- 相关UGC搭配分享 -->
    <view wx:if="{{relatedUgcs.length > 0}}" class="related-ugc-section">
      <view class="ugc-section-title">
        <text class="ugc-title-icon">📸</text>
        <text>茶友们的搭配分享（{{relatedUgcs.length}}）</text>
      </view>
      <scroll-view scroll-x="{{true}}" class="ugc-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="ugc-list">
          <view 
            wx:for="{{relatedUgcs}}" 
            wx:key="postId" 
            class="ugc-mini-card"
            data-images="{{item.images}}"
            bindtap="onUgcCardTap"
          >
            <image wx:if="{{item.images.length > 0}}" class="ugc-card-img" src="{{item.images[0]}}" mode="aspectFill" />
            <view class="ugc-card-content">
              <view class="ugc-card-text">{{item.content}}</view>
              <view class="ugc-card-footer">
                <view class="ugc-user-info">
                  <image wx:if="{{item.user.avatar}}" class="ugc-avatar" src="{{item.user.avatar}}" />
                  <text wx:else class="ugc-avatar-default">👤</text>
                  <text class="ugc-nickname">{{item.user.nickName}}</text>
                </view>
                <view class="ugc-like-count">
                  <text>❤️</text>
                  <text>{{item.likes}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 规格选择 -->
  <view class="spec-section" bindtap="onAddToCart">
    <view class="section-label">规格</view>
    <view class="spec-content">
      <text class="spec-text">{{selectedSpecsText}}</text>
      <text class="spec-arrow">›</text>
    </view>
  </view>

  <!-- 服务保障 -->
  <view class="service-section">
    <view class="service-item" wx:for="{{product.serviceTags}}" wx:key="*this">
      <text class="service-icon">✓</text>
      <text class="service-text">{{item}}</text>
    </view>
  </view>

  <!-- 溯源入口 -->
  <view class="trace-section" bindtap="goToTrace">
    <view class="trace-left">
      <text class="trace-icon">🔗</text>
      <view class="trace-info">
        <view class="trace-title">产品溯源</view>
        <view class="trace-desc">查看完整溯源信息 · 区块链存证</view>
      </view>
    </view>
    <text class="trace-arrow">›</text>
  </view>

  <!-- 订单溯源入口 -->
  <view class="trace-section order-trace" bindtap="goToOrderTrace">
    <view class="trace-left">
      <text class="trace-icon">📦</text>
      <view class="trace-info">
        <view class="trace-title">订单溯源</view>
        <view class="trace-desc">订单号关联批次 · 收货扫码验真</view>
      </view>
    </view>
    <text class="trace-arrow">›</text>
  </view>

  <!-- 商品详情 -->
  <view class="detail-section">
    <view class="detail-title">商品详情</view>
    <view class="detail-content">
      <view class="detail-desc">{{product.description}}</view>
      <view class="detail-images">
        <image 
          class="detail-image" 
          wx:for="{{product.images}}" 
          wx:key="*this"
          src="{{item}}" 
          mode="widthFix"
          data-url="{{item}}"
          bindtap="onPreviewImage"
        ></image>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="bar-item" bindtap="onBackHome">
      <text class="bar-icon">🏠</text>
      <text class="bar-text">首页</text>
    </view>
    <view class="bar-item" bindtap="onCartTap">
      <text class="bar-icon">🛒</text>
      <text class="bar-text">购物车</text>
      <view class="bar-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
    <view class="bar-item" bindtap="onShareTap">
      <text class="bar-icon">📤</text>
      <text class="bar-text">分享</text>
    </view>
    <view class="bar-btn bar-btn-cart" bindtap="onAddToCart">加入购物车</view>
    <view class="bar-btn bar-btn-buy" bindtap="onBuyNow">立即购买</view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-page" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- 规格选择器 -->
<sku-selector 
  show="{{showSkuSelector}}"
  trace-id="{{traceId}}"
  mode="{{skuMode}}"
  is-member="{{isMember}}"
  bind:close="onSkuClose"
  bind:addcart="onSkuAddCart"
  bind:buynow="onSkuBuyNow"
></sku-selector>

<!-- 分享弹窗 -->
<view class="share-mask {{showShareMenu ? 'show' : ''}}" catchtap="onShareClose">
  <view class="share-panel {{showShareMenu ? 'show' : ''}}" catchtap="preventBubble">
    <view class="share-title">分享至</view>
    <view class="share-options">
      <button class="share-option" open-type="share">
        <view class="share-icon-wrap">💬</view>
        <text class="share-label">微信好友</text>
      </button>
      <view class="share-option" bindtap="onShareClose">
        <view class="share-icon-wrap">⭕</view>
        <text class="share-label">朋友圈</text>
      </view>
    </view>
    <view class="share-cancel" bindtap="onShareClose">取消</view>
  </view>
</view>
