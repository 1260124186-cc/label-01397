<view class="page-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索桂花茶产品" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
    </view>
    <view class="cart-btn" catchtap="onCartTap">
      <text class="cart-icon">🛒</text>
      <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" autoplay circular interval="4000" bindchange="onBannerChange">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-item">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="banner-content">
          <view class="banner-title">{{item.title}}</view>
          <view class="banner-subtitle">{{item.subtitle}}</view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 促销活动 -->
  <view class="promo-bar" wx:if="{{promotions.length > 0}}">
    <text class="promo-icon">🎉</text>
    <scroll-view class="promo-scroll" scroll-x>
      <view class="promo-list">
        <view class="promo-item" wx:for="{{promotions}}" wx:key="id">
          <text class="promo-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
          <text class="promo-text">{{item.desc}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view 
        class="category-item {{currentCategory === item ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="*this"
        data-category="{{item}}"
        bindtap="onCategoryTap"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view 
      class="sort-item {{currentSort === item.key ? 'active' : ''}}"
      wx:for="{{sortOptions}}"
      wx:key="key"
      data-sort="{{item.key}}"
      bindtap="onSortTap"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 产品列表 -->
  <view class="product-list">
    <view 
      class="product-card"
      wx:for="{{productList}}"
      wx:key="traceId"
      data-traceid="{{item.traceId}}"
      bindtap="onProductTap"
    >
      <view class="product-image-wrap">
        <image class="product-image" src="{{item.thumbnail}}" mode="aspectFill"></image>
        <view class="product-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <view class="product-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 2}}">
            {{tag}}
          </view>
        </view>
      </view>
      <view class="product-info">
        <view class="product-name">{{item.productName}}</view>
        <view class="product-subtitle">{{item.subtitle}}</view>
        <view class="product-bottom">
          <view class="product-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.skuList[0].price}}</text>
            <text class="price-unit">起</text>
          </view>
          <view class="add-cart-btn" catchtap="onAddToCartTap" data-traceid="{{item.traceId}}">
            <text class="add-icon">+</text>
          </view>
        </view>
        <view class="product-sales">已售{{item.sales}}件</view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{!loading && productList.length === 0}}">
    <text class="empty-icon">🍵</text>
    <text class="empty-text">暂无相关产品</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>

<!-- 规格选择器 -->
<sku-selector 
  show="{{showSkuSelector}}"
  trace-id="{{selectedTraceId}}"
  is-member="{{isMember}}"
  bind:close="onSkuClose"
  bind:addcart="onSkuAddCart"
  bind:buynow="onSkuBuyNow"
></sku-selector>
