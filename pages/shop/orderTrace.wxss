.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.verify-section {
  padding: 40rpx 30rpx;
}

.verify-header {
  text-align: center;
  padding: 40rpx 0 60rpx 0;
}

.verify-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.verify-title {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.verify-subtitle {
  font-size: 26rpx;
  color: #999;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx 30rpx;
  margin-bottom: 40rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-input {
  font-size: 28rpx;
  color: #333;
  width: 100%;
}

.input-with-btn {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.input-with-btn .form-input {
  flex: 1;
}

.scan-btn {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #2E8B57;
  background: #e8f5e9;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.verify-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  font-size: 32rpx;
  color: #fff;
  background: #ccc;
  border-radius: 45rpx;
  margin-bottom: 40rpx;
}

.verify-btn.active {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
}

.tips-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

.result-section {
  padding-bottom: 40rpx;
}

.result-header {
  text-align: center;
  padding: 60rpx 30rpx;
  color: #fff;
}

.result-header.success {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
}

.result-icon {
  display: inline-block;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.result-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.info-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  max-width: 60%;
}

.blockchain-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.bc-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.bc-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.bc-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.bc-badge {
  font-size: 22rpx;
  color: #2E8B57;
  background: #e8f5e9;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.bc-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bc-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bc-label {
  font-size: 24rpx;
  color: #999;
}

.bc-value {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  padding: 30rpx 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 90rpx;
  font-size: 28rpx;
  color: #2E8B57;
  background: #fff;
  border: 2rpx solid #2E8B57;
  border-radius: 45rpx;
}

.action-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4d4f 100%);
  border-color: transparent;
}

.action-icon {
  font-size: 32rpx;
}

.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #2E8B57;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
