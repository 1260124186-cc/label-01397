/*
 * 桂花茶溯源小程序 - UGC搭配社区列表页样式
 * 页面路径：pages/ugc/list
 */

.page-container {
  min-height: 100vh;
  background-color: #FAFAFA;
  padding-bottom: 180rpx;
}

/* ==================== 顶部筛选栏 ==================== */
.filter-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 排序切换 */
.sort-row {
  display: flex;
  flex-direction: row;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.sort-item {
  position: relative;
  padding: 28rpx 32rpx 24rpx;
  margin-right: 24rpx;
}

.sort-text {
  font-size: 30rpx;
  color: #666666;
  font-weight: 500;
}

.sort-item.active .sort-text {
  color: #E91E63;
  font-weight: bold;
  font-size: 32rpx;
}

.sort-underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #E91E63, #FF4081);
  border-radius: 3rpx;
}

/* 品种筛选横向滚动 */
.variety-scroll {
  width: 100%;
  white-space: nowrap;
}

.variety-row {
  display: inline-flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.variety-tag {
  display: inline-block;
  padding: 14rpx 32rpx;
  background-color: #F5F5F5;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.25s ease;
}

.variety-tag.active {
  background: linear-gradient(135deg, #E91E63, #FF4081);
  color: #FFFFFF;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(233, 30, 99, 0.25);
}

/* ==================== 内容区 ==================== */
.content-area {
  padding: 24rpx 16rpx;
}

/* ==================== 骨架屏 ==================== */
.skeleton-wrap {
  padding: 0 8rpx;
}

.waterfall-columns {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  padding: 0 0 20rpx;
}

.skeleton-img {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(90deg, #F0F0F0 25%, #F8F8F8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: skeletonShimmer 1.5s infinite;
}

.skeleton-img.tall {
  height: 420rpx;
}

.skeleton-line {
  height: 24rpx;
  margin: 16rpx 20rpx 0;
  background: linear-gradient(90deg, #F0F0F0 25%, #F8F8F8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: skeletonShimmer 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-line.short {
  width: 40%;
}

.skeleton-line.medium {
  width: 70%;
}

@keyframes skeletonShimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #FFEBEE, #FCE4EC);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.empty-btn {
  width: 360rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #E91E63, #FF4081);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
  box-shadow: 0 8rpx 24rpx rgba(233, 30, 99, 0.3);
}

.empty-btn::after {
  border: none;
}

/* ==================== UGC卡片 ==================== */
.ugc-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  break-inside: avoid;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.ugc-image {
  width: 100%;
  display: block;
  background: #F0F0F0;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}

.image-count-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(8rpx);
}

.ugc-card-body {
  padding: 20rpx;
}

/* 用户栏 */
.user-bar {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #EEEEEE;
  margin-right: 14rpx;
  border: 2rpx solid #FFFFFF;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.user-nickname {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-level {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

/* 内容文字 */
.ugc-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.55;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 标签区 */
.tag-area {
  margin-bottom: 14rpx;
}

.tag-chip {
  display: inline-block;
  font-size: 20rpx;
  color: #E91E63;
  background: rgba(233, 30, 99, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

/* 品种标签 */
.variety-badge {
  display: inline-block;
  margin-bottom: 16rpx;
}

.variety-badge text {
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #AB47BC, #E91E63);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

/* 底部操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 4rpx;
}

.action-icon {
  font-size: 28rpx;
}

.action-count {
  font-size: 22rpx;
  color: #888888;
}

.action-item.like.liked .action-count {
  color: #E91E63;
}

.action-item.like.animating {
  animation: likeScale 0.3s ease;
}

@keyframes likeScale {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

/* ==================== 底部占位 ==================== */
.bottom-placeholder {
  height: 40rpx;
}

/* ==================== 悬浮发布按钮 ==================== */
.float-upload-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #E91E63 0%, #C2185B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 32rpx rgba(233, 30, 99, 0.45);
  z-index: 999;
  animation: floatPulse 2.5s ease-in-out infinite;
}

@keyframes floatPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 10rpx 32rpx rgba(233, 30, 99, 0.45); }
  50% { transform: scale(1.05); box-shadow: 0 12rpx 40rpx rgba(233, 30, 99, 0.55); }
}

.float-btn-icon {
  font-size: 48rpx;
}
