<!--
  桂花茶溯源小程序 - UGC搭配社区列表页
  功能：展示茶友分享的搭配内容，瀑布流双列布局
-->

<view class="page-container">

  <!-- ==================== 顶部筛选栏 ==================== -->
  <view class="filter-bar">
    <!-- 排序切换 -->
    <view class="sort-row">
      <view
        wx:for="{{sortList}}"
        wx:key="key"
        class="sort-item {{sortType === item.key ? 'active' : ''}}"
        data-type="{{item.key}}"
        bindtap="switchSort"
      >
        <text class="sort-text">{{item.name}}</text>
        <view class="sort-underline" wx:if="{{sortType === item.key}}"></view>
      </view>
    </view>

    <!-- 品种筛选横向滚动 -->
    <scroll-view scroll-x class="variety-scroll" enhanced show-scrollbar="{{false}}">
      <view class="variety-row">
        <view
          wx:for="{{varietyList}}"
          wx:key="*this"
          class="variety-tag {{filterVariety === item ? 'active' : ''}}"
          data-variety="{{item}}"
          bindtap="switchVariety"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ==================== 内容区 ==================== -->
  <view class="content-area">

    <!-- Loading骨架屏 -->
    <view class="skeleton-wrap" wx:if="{{loading}}">
      <view class="waterfall-columns">
        <view class="skeleton-column">
          <view class="skeleton-card">
            <view class="skeleton-img"></view>
            <view class="skeleton-line short"></view>
            <view class="skeleton-line"></view>
            <view class="skeleton-line medium"></view>
          </view>
          <view class="skeleton-card">
            <view class="skeleton-img tall"></view>
            <view class="skeleton-line short"></view>
            <view class="skeleton-line"></view>
          </view>
        </view>
        <view class="skeleton-column">
          <view class="skeleton-card">
            <view class="skeleton-img tall"></view>
            <view class="skeleton-line short"></view>
            <view class="skeleton-line medium"></view>
          </view>
          <view class="skeleton-card">
            <view class="skeleton-img"></view>
            <view class="skeleton-line short"></view>
            <view class="skeleton-line"></view>
            <view class="skeleton-line"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && showEmpty}}">
      <view class="empty-icon-wrap">
        <text class="empty-icon">📷</text>
      </view>
      <view class="empty-title">还没有搭配分享</view>
      <view class="empty-desc">快来分享你的第一份桂花茶搭配吧~</view>
      <button class="empty-btn" bindtap="onGoUpload">去发布搭配</button>
    </view>

    <!-- 瀑布流卡片列表 -->
    <view class="waterfall-columns" wx:if="{{!loading && !showEmpty}}">
      <view class="waterfall-column">
        <view
          wx:for="{{posts}}"
          wx:key="postId"
          wx:if="{{index % 2 === 0}}"
          class="ugc-card"
          data-postid="{{item.postId}}"
          bindtap="onPostTap"
        >
          <!-- 图片 -->
          <image
            wx:if="{{item.images && item.images.length > 0}}"
            class="ugc-image"
            src="{{item.images[0]}}"
            mode="widthFix"
            lazy-load
          />
          <view class="image-count-badge" wx:if="{{item.images && item.images.length > 1}}">
            <text>{{item.images.length}}图</text>
          </view>

          <view class="ugc-card-body">
            <!-- 用户栏 -->
            <view class="user-bar">
              <image class="user-avatar" src="{{item.user.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
              <view class="user-info">
                <text class="user-nickname">{{item.user.nickName}}</text>
                <view class="user-level" wx:if="{{item.user.level}}">
                  <text>Lv.{{item.user.level}}</text>
                </view>
              </view>
            </view>

            <!-- 内容文字（最多2行） -->
            <view class="ugc-content">{{item.content}}</view>

            <!-- 标签区 -->
            <view class="tag-area" wx:if="{{item.tags && item.tags.length > 0}}">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag-chip">#{{tag}}</text>
            </view>

            <!-- 品种标签 -->
            <view class="variety-badge" wx:if="{{item.variety}}">
              <text>{{item.variety}}</text>
            </view>

            <!-- 底部操作栏 -->
            <view class="action-bar">
              <view
                class="action-item like {{item.isLiked ? 'liked' : ''}} {{animatingLikeId === item.postId ? 'animating' : ''}}"
                catchtap="onLikeTap"
                data-postid="{{item.postId}}"
              >
                <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
                <text class="action-count">{{item.likes || 0}}</text>
              </view>
              <view class="action-item comment">
                <text class="action-icon">💬</text>
                <text class="action-count">{{item.comments || 0}}</text>
              </view>
              <view
                class="action-item share"
                catchtap="onShareTap"
                data-postid="{{item.postId}}"
                open-type="share"
              >
                <text class="action-icon">↗️</text>
                <text class="action-count">{{item.shares || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="waterfall-column">
        <view
          wx:for="{{posts}}"
          wx:key="postId"
          wx:if="{{index % 2 === 1}}"
          class="ugc-card"
          data-postid="{{item.postId}}"
          bindtap="onPostTap"
        >
          <!-- 图片 -->
          <image
            wx:if="{{item.images && item.images.length > 0}}"
            class="ugc-image"
            src="{{item.images[0]}}"
            mode="widthFix"
            lazy-load
          />
          <view class="image-count-badge" wx:if="{{item.images && item.images.length > 1}}">
            <text>{{item.images.length}}图</text>
          </view>

          <view class="ugc-card-body">
            <!-- 用户栏 -->
            <view class="user-bar">
              <image class="user-avatar" src="{{item.user.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
              <view class="user-info">
                <text class="user-nickname">{{item.user.nickName}}</text>
                <view class="user-level" wx:if="{{item.user.level}}">
                  <text>Lv.{{item.user.level}}</text>
                </view>
              </view>
            </view>

            <!-- 内容文字（最多2行） -->
            <view class="ugc-content">{{item.content}}</view>

            <!-- 标签区 -->
            <view class="tag-area" wx:if="{{item.tags && item.tags.length > 0}}">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag-chip">#{{tag}}</text>
            </view>

            <!-- 品种标签 -->
            <view class="variety-badge" wx:if="{{item.variety}}">
              <text>{{item.variety}}</text>
            </view>

            <!-- 底部操作栏 -->
            <view class="action-bar">
              <view
                class="action-item like {{item.isLiked ? 'liked' : ''}} {{animatingLikeId === item.postId ? 'animating' : ''}}"
                catchtap="onLikeTap"
                data-postid="{{item.postId}}"
              >
                <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
                <text class="action-count">{{item.likes || 0}}</text>
              </view>
              <view class="action-item comment">
                <text class="action-icon">💬</text>
                <text class="action-count">{{item.comments || 0}}</text>
              </view>
              <view
                class="action-item share"
                catchtap="onShareTap"
                data-postid="{{item.postId}}"
                open-type="share"
              >
                <text class="action-icon">↗️</text>
                <text class="action-count">{{item.shares || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </view>

  <!-- ==================== 右下角悬浮发布按钮 ==================== -->
  <view class="float-upload-btn" bindtap="onGoUpload">
    <text class="float-btn-icon">📷</text>
  </view>

</view>
