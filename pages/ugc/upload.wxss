/*
 * 桂花茶溯源小程序 - UGC上传发布页样式
 * 页面路径：pages/ugc/upload
 */

.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* ==================== 主滚动区 ==================== */
.main-scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* ==================== 通用卡片 ==================== */
.section-card {
  background: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
}

.section-count {
  font-size: 26rpx;
  color: #E91E63;
  font-weight: 500;
}

/* ==================== 图片上传区 ==================== */
.image-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.image-thumb {
  width: 100%;
  height: 100%;
  background: #F0F0F0;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
}

.delete-icon {
  font-size: 24rpx;
  color: #FF4757;
  font-weight: bold;
}

/* 上传占位框 */
.upload-placeholder {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1 / 1;
  border: 2rpx dashed #CCCCCC;
  border-radius: 16rpx;
  background: #FAFAFA;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.upload-placeholder:active {
  background: #F0F0F0;
  border-color: #E91E63;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  opacity: 0.6;
}

.upload-text {
  font-size: 22rpx;
  color: #999999;
}

.image-tip {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #FFF8F5;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #888888;
  line-height: 1.5;
}

/* ==================== 文字内容区 ==================== */
.word-count {
  font-size: 24rpx;
  color: #999999;
}

.word-count.over {
  color: #FF4757;
  font-weight: 500;
}

.content-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background: #FAFAFA;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
}

.textarea-placeholder {
  color: #BBBBBB;
  font-size: 28rpx;
}

/* 建议标签 */
.suggest-tags-wrap {
  margin-top: 24rpx;
}

.suggest-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.suggest-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.suggest-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.suggest-tag:active {
  background: rgba(233, 30, 99, 0.1);
  color: #E91E63;
}

/* ==================== 选择品种区 ==================== */
.variety-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.variety-card {
  flex: 1;
  position: relative;
}

.variety-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  background: #FAFAFA;
  border: 3rpx solid transparent;
  border-radius: 20rpx;
  transition: all 0.25s ease;
  position: relative;
}

.variety-card.selected .variety-card-inner {
  background: linear-gradient(135deg, #FFEBEE 0%, #FCE4EC 100%);
  box-shadow: 0 4rpx 16rpx rgba(233, 30, 99, 0.15);
}

.variety-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.variety-name {
  font-size: 26rpx;
  color: #555555;
  font-weight: 500;
}

.variety-card.selected .variety-name {
  color: #E91E63;
  font-weight: bold;
}

.check-mark {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #E91E63, #FF4081);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(233, 30, 99, 0.3);
}

.check-mark text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: bold;
}

/* ==================== 选择搭配食品区 ==================== */
.food-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.food-item {
  width: calc((100% - 32rpx) / 3);
  box-sizing: border-box;
}

.food-image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F0F0F0;
}

.food-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.food-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(233, 30, 99, 0.35);
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 10rpx;
  box-sizing: border-box;
}

.food-check {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #E91E63, #FF4081);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(233, 30, 99, 0.4);
}

.food-check text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: bold;
}

.food-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #555555;
  text-align: center;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-tip {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #E91E63;
  font-weight: 500;
  padding: 12rpx;
  background: rgba(233, 30, 99, 0.06);
  border-radius: 12rpx;
}

/* ==================== 底部占位 ==================== */
.bottom-safe-area {
  height: 80rpx;
}

/* ==================== 底部固定发布按钮 ==================== */
.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #E91E63 0%, #C2185B 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  margin: 0;
  box-shadow: 0 8rpx 28rpx rgba(233, 30, 99, 0.35);
  transition: all 0.2s ease;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(233, 30, 99, 0.3);
}

.submit-btn.disabled {
  opacity: 0.7;
}
