.record-page {
  padding: 20rpx 24rpx 40rpx;
  background: #F5F5F0;
  min-height: 100vh;
}

.flavor-curve-section {
  background: linear-gradient(135deg, #2E8B57 0%, #1E6B3F 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.curve-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 28rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.rounds-curve {
  margin-bottom: 24rpx;
}

.curve-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-bottom: 16rpx;
}

.curve-bars {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 160rpx;
  padding: 0 8rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.bar-value {
  width: 100%;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 8rpx 8rpx 0 0;
  text-align: center;
  font-size: 18rpx;
  color: #1E6B3F;
  padding-top: 4rpx;
  min-height: 30rpx;
}

.bar-label {
  font-size: 20rpx;
  opacity: 0.8;
  margin-top: 6rpx;
}

.top-tags {
  margin-top: 8rpx;
}

.tags-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-bottom: 12rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  font-size: 24rpx;
}

.filter-tabs {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.tab-item {
  padding: 12rpx 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
}

.tab-item.active {
  background: #2E8B57;
  color: #fff;
}

.tab-right {
  margin-left: auto;
  font-size: 26rpx;
  color: #2E8B57;
  padding: 12rpx 20rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-product {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.record-round {
  padding: 6rpx 16rpx;
  background: #E8F5E9;
  color: #2E8B57;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.record-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
}

.record-weather {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.record-rating {
  font-size: 32rpx;
  color: #DAA520;
  margin-bottom: 12rpx;
}

.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 18rpx;
  background: #FFF8E1;
  color: #DAA520;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.record-feeling {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  padding: 16rpx;
  background: #FAFAF5;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #2E8B57;
  padding: 6rpx 0;
}

.action-btn.danger {
  color: #ff4d4f;
}
