<view class="record-page">
  <view wx:if="{{flavorCurve && flavorCurve.hasData}}" class="flavor-curve-section">
    <view class="section-title">📊 个人风味曲线</view>
    <view class="curve-stats">
      <view class="stat-item">
        <view class="stat-value">{{flavorCurve.totalCount || 0}}</view>
        <view class="stat-label">冲泡次数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{flavorCurve.avgTemp}}℃</view>
        <view class="stat-label">平均水温</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{flavorCurve.avgRating}}</view>
        <view class="stat-label">平均评分</view>
      </view>
    </view>

    <view wx:if="{{flavorCurve.rounds.length > 0}}" class="rounds-curve">
      <view class="curve-label">各泡平均时长（秒）</view>
      <view class="curve-bars">
        <view wx:for="{{flavorCurve.rounds}}" wx:key="round" class="bar-item">
          <view class="bar-value" style="height: {{item.avgDuration / 3}}rpx;">{{item.avgDuration}}</view>
          <view class="bar-label">第{{item.round}}泡</view>
        </view>
      </view>
    </view>

    <view wx:if="{{flavorCurve.topTags.length > 0}}" class="top-tags">
      <view class="tags-label">常用标签</view>
      <view class="tags-list">
        <text wx:for="{{flavorCurve.topTags}}" wx:key="*this" class="tag-item">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="filter-tabs">
    <view
      class="tab-item {{filterTab === 'all' ? 'active' : ''}}"
      data-tab="all"
      bindtap="switchTab"
    >全部记录</view>
    <view
      class="tab-item {{filterTab === 'rated' ? 'active' : ''}}"
      data-tab="rated"
      bindtap="switchTab"
    >已评分</view>
    <view class="tab-right" bindtap="goToEnvironment">⚙️ 环境设置</view>
  </view>

  <view wx:if="{{isEmpty}}" class="empty-state">
    <view class="empty-icon">🫖</view>
    <view class="empty-title">暂无冲泡记录</view>
    <view class="empty-desc">开始冲泡时，记录每次的参数和感受，构建你的专属风味曲线</view>
  </view>

  <view wx:else class="records-list">
    <view
      wx:for="{{records}}"
      wx:key="id"
      class="record-card"
    >
      <view class="record-header">
        <view class="record-product">{{item.productName || '未关联产品'}}</view>
        <view class="record-round">第{{item.brewRound}}泡</view>
      </view>

      <view class="record-meta">
        <view class="meta-item">🌡️ {{item.waterTemp}}℃</view>
        <view class="meta-item">⏱️ {{item.durationText}}</view>
        <view class="meta-item">🍃 {{item.teaAmount}}g</view>
        <view class="meta-item">💧 {{item.hardnessText}}</view>
      </view>

      <view wx:if="{{item.weather}}" class="record-weather">
        📍 {{item.weather.city}} {{item.weather.weather}} {{item.weather.temp}}℃
      </view>

      <view wx:if="{{item.rating > 0}}" class="record-rating">{{item.stars}}</view>

      <view wx:if="{{item.tags && item.tags.length > 0}}" class="record-tags">
        <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
      </view>

      <view wx:if="{{item.feeling}}" class="record-feeling">{{item.feelingPreview}}</view>

      <view class="record-footer">
        <text class="record-time">{{item.formatTime}}</text>
        <view class="record-actions">
          <view class="action-btn" catchtap="onCreateNote" data-id="{{item.id}}">📝 生成笔记</view>
          <view class="action-btn danger" catchtap="onDeleteRecord" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>
  </view>
</view>
