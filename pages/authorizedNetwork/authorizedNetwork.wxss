.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  padding: 24rpx 20rpx;
  color: #FFFFFF;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.3);
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.search-clear {
  font-size: 28rpx;
  color: #999999;
  padding: 4rpx 8rpx;
}

.verify-btn {
  display: flex;
  align-items: center;
  background: #F6FFED;
  border: 1rpx solid #B7EB8F;
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
  gap: 6rpx;
}

.verify-icon {
  font-size: 26rpx;
}

.verify-text {
  font-size: 24rpx;
  color: #52C41A;
  font-weight: 500;
}

.filter-bar {
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.type-filters {
  white-space: nowrap;
}

.type-filter {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background: #F5F5F5;
  gap: 6rpx;
}

.type-filter.active {
  background: #E6F7FF;
  border: 1rpx solid #1890FF;
}

.filter-icon {
  font-size: 24rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #333333;
}

.type-filter.active .filter-label {
  color: #1890FF;
  font-weight: 500;
}

.city-filter {
  background: #FFFFFF;
  padding: 0 24rpx 16rpx;
}

.city-scroll {
  white-space: nowrap;
}

.city-item {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  background: #F5F5F5;
  font-size: 24rpx;
  color: #666666;
  gap: 6rpx;
}

.city-item.active {
  background: #2E8B57;
  color: #FFFFFF;
}

.city-count {
  font-size: 20rpx;
  opacity: 0.7;
}

.view-mode-switch {
  display: flex;
  background: #FFFFFF;
  padding: 12rpx 24rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  background: #F5F5F5;
  font-size: 26rpx;
  color: #666666;
}

.mode-btn.active {
  background: #2E8B57;
  color: #FFFFFF;
  font-weight: 500;
}

.map-container {
  position: relative;
  width: 100%;
  height: calc(100vh - 420rpx);
}

.store-map {
  width: 100%;
  height: 100%;
}

.map-actions {
  position: absolute;
  right: 24rpx;
  bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.map-action-btn {
  width: 72rpx;
  height: 72rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.15);
}

.list-container {
  padding: 16rpx 24rpx;
}

.store-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.store-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.store-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.store-type-badge {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  gap: 6rpx;
}

.store-type-icon {
  font-size: 24rpx;
}

.store-type-text {
  font-size: 22rpx;
  font-weight: 500;
}

.store-auth-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.auth-icon {
  color: #52C41A;
  font-size: 24rpx;
  font-weight: bold;
}

.auth-text {
  color: #52C41A;
  font-size: 22rpx;
}

.store-card-body {
  margin-bottom: 16rpx;
}

.store-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.store-info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
  gap: 8rpx;
}

.info-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.info-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

.store-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.store-rating {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.rating-star {
  font-size: 24rpx;
}

.rating-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #DAA520;
}

.review-count {
  font-size: 22rpx;
  color: #999999;
}

.store-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.nav-btn {
  background: #E6F7FF;
  color: #1890FF;
}

.detail-btn {
  background: #F6FFED;
  color: #52C41A;
}

.store-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.store-tag {
  font-size: 20rpx;
  color: #999999;
  background: #F5F5F5;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

.store-card-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: none;
}

.store-card-popup.show {
  display: block;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
}

.popup-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 70vh;
}

.popup-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.popup-type-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.popup-title-wrap {
  flex: 1;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.popup-auth {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 4rpx;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999999;
}

.popup-body {
  margin-bottom: 24rpx;
}

.popup-info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  gap: 10rpx;
}

.popup-info-icon {
  font-size: 26rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.popup-info-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.popup-actions {
  display: flex;
  gap: 20rpx;
}

.popup-action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.popup-action-btn.nav-btn {
  background: #1890FF;
  color: #FFFFFF;
}

.popup-action-btn.detail-btn {
  background: #F6FFED;
  color: #52C41A;
  border: 1rpx solid #B7EB8F;
}
