<view class="notes-page">
  <view class="notes-add-btn" bindtap="onAddNote">
    <text class="add-icon">＋</text>
    <text class="add-text">写笔记</text>
  </view>

  <view wx:if="{{isEmpty}}" class="empty-state">
    <view class="empty-icon">📝</view>
    <view class="empty-title">暂无品鉴笔记</view>
    <view class="empty-desc">记录你对茶叶的品鉴感受，构建你的茶叶品鉴档案</view>
  </view>

  <view wx:else class="notes-list">
    <view
      wx:for="{{notes}}"
      wx:key="id"
      class="note-card"
      data-id="{{item.id}}"
      bindtap="onNoteTap"
    >
      <view class="note-header">
        <view class="note-product">{{item.productName || '未关联产品'}}</view>
        <view class="note-stars">{{item.stars}}</view>
      </view>
      <view wx:if="{{item.tags && item.tags.length > 0}}" class="note-tags">
        <text
          wx:for="{{item.tags}}"
          wx:for-item="tag"
          wx:key="*this"
          class="note-tag"
        >{{tag}}</text>
      </view>
      <view class="note-content">{{item.contentPreview}}</view>
      <view class="note-footer">
        <text class="note-time">{{item.formatTime}}</text>
        <view class="note-delete" catchtap="onDeleteNote" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>
</view>
