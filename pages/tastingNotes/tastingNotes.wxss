.notes-page {
  min-height: 100vh;
  background: #F5F5F0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.notes-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  border-radius: 44rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.25);
  font-size: 30rpx;
  font-weight: 600;
}

.notes-add-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.add-icon {
  font-size: 36rpx;
  font-weight: 300;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  padding: 0 60rpx;
}

.notes-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.note-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.note-card:active {
  transform: scale(0.99);
  background: #FAFAFA;
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.note-product {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 16rpx;
}

.note-stars {
  font-size: 28rpx;
  color: #DAA520;
  flex-shrink: 0;
  letter-spacing: 4rpx;
}

.note-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.note-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(46, 139, 87, 0.08);
  color: #2E8B57;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.note-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.note-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.note-time {
  font-size: 22rpx;
  color: #999999;
}

.note-delete {
  font-size: 24rpx;
  color: #CCCCCC;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.note-delete:active {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.1);
}
