.page-container {
  min-height: 100vh;
  background: #F5F5F0;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* ========== 选择步骤 ========== */
.select-step {
  padding: 30rpx;
}

.step-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.step-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.step-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999;
}

.selected-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.selected-label {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}

.selected-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.selected-tag-close {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(46, 139, 87, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #2E8B57;
}

.btn-compare {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 收藏夹区域 */
.fav-section {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.section-title-icon {
  font-size: 32rpx;
}

.fav-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fav-chip {
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s ease;
}

.fav-chip-active {
  background: rgba(218, 165, 32, 0.1);
  border-color: #DAA520;
  color: #DAA520;
  font-weight: 500;
}

/* 产品列表 */
.product-section {
  margin-bottom: 24rpx;
}

.product-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #E8E8E8;
  transition: all 0.2s ease;
}

.product-card-selected {
  border-color: #2E8B57;
  background: rgba(46, 139, 87, 0.04);
  box-shadow: 0 2rpx 16rpx rgba(46, 139, 87, 0.12);
}

.product-check {
  flex-shrink: 0;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D0D0D0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
  transition: all 0.2s ease;
}

.check-circle-active {
  background: #2E8B57;
  border-color: #2E8B57;
}

.product-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F0F0F0;
}

.product-info-mini {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.product-name-mini {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-variety-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.product-spec-mini {
  font-size: 22rpx;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.btn-start {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 139, 87, 0.3);
}

.btn-start:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ========== 对比结果 ========== */
.result-step {
  padding: 30rpx;
}

.product-headers {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.header-card {
  flex: 1;
  min-width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.header-variety {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.variety-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.header-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #F0F0F0;
}

.header-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.header-spec {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 差异提示横幅 */
.diff-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: rgba(218, 165, 32, 0.08);
  border: 2rpx solid rgba(218, 165, 32, 0.2);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.diff-banner-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.diff-banner-text {
  font-size: 26rpx;
  color: #B8860B;
  line-height: 1.5;
}

/* 视图切换 */
.view-switcher {
  display: flex;
  gap: 0;
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.switch-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #FFFFFF;
  transition: all 0.2s ease;
}

.switch-btn-active {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  font-weight: 600;
}

/* 雷达图 */
.radar-card {
  padding: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.radar-canvas {
  width: 690rpx;
  height: 690rpx;
}

.radar-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.radar-tip {
  text-align: center;
  font-size: 22rpx;
  color: #DAA520;
  margin-top: 12rpx;
}

/* 对比表格 */
.compare-table {
  padding: 0;
  overflow: hidden;
}

.table-row {
  display: flex;
  align-items: stretch;
  border-bottom: 1rpx solid #F0F0F0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row-diff {
  background: rgba(218, 165, 32, 0.04);
  border-left: 4rpx solid #DAA520;
}

.table-header-row {
  background: rgba(46, 139, 87, 0.04);
}

.table-cell {
  padding: 20rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.table-cell-label {
  width: 180rpx;
  justify-content: flex-start;
  font-weight: 500;
  color: #333;
  flex-shrink: 0;
}

.table-cell-diff-label {
  color: #DAA520;
}

.diff-star {
  color: #DAA520;
  margin-right: 6rpx;
}

.table-cell-value {
  flex: 1;
  color: #333;
}

.table-cell-advantage {
  color: #DAA520;
  font-weight: 600;
}

.table-cell-abnormal {
  color: #FF4D4F;
  font-weight: 600;
}

.cell-text {
  font-size: 26rpx;
}

.advantage-arrow {
  font-size: 22rpx;
  color: #DAA520;
  margin-left: 6rpx;
}

.cell-variety-mini {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 差异详情 */
.diff-detail {
  margin-top: 24rpx;
}

.diff-detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.diff-detail-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
}

.diff-item-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #DAA520;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.diff-item-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.diff-dim-name {
  font-weight: 600;
  color: #DAA520;
}

.diff-winner {
  font-weight: 600;
  color: #2E8B57;
}

/* 品种差异对照 */
.variety-highlight {
  margin-top: 24rpx;
}

.highlight-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.highlight-grid {
  display: flex;
  flex-direction: column;
}

.highlight-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.highlight-row:last-child {
  border-bottom: none;
}

.highlight-dim {
  width: 160rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.highlight-val {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.highlight-vs {
  width: 60rpx;
  text-align: center;
  font-size: 22rpx;
  color: #CCC;
  font-weight: 700;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
  padding-bottom: 20rpx;
}

.btn-back-select {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.btn-share-img {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #DAA520, #F0C75E);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(218, 165, 32, 0.3);
}

.btn-share-img:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ========== 分享长图遮罩 ========== */
.share-canvas-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.share-canvas-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-canvas {
  width: 750rpx;
  height: 1600rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
}

.share-canvas-tip {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #FFFFFF;
}
