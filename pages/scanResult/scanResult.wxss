/* 扫码结果确认页样式 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2E8B57 0%, #F5F5F0 30%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: rotate 2s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}

/* 结果容器 */
.result-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 成功图标 */
.success-icon-wrapper {
  position: relative;
  margin-bottom: 40rpx;
}

.success-icon {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #52C41A, #3CB371);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.4);
}

.scan-type-badge {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #DAA520;
  color: white;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

/* 产品卡片 */
.product-card {
  width: 100%;
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 40rpx;
}

.product-image-wrapper {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  background: #f0f0f0;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.product-spec,
.product-trace-id,
.product-batch,
.product-date {
  font-size: 28rpx;
  color: #666;
}

.product-trace-id {
  color: #2E8B57;
  font-weight: 500;
}

/* 提示区域 */
.tip-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 50rpx;
  padding: 24rpx 32rpx;
  background: rgba(46, 139, 87, 0.08);
  border-radius: 16rpx;
}

.tip-icon {
  font-size: 36rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #2E8B57;
}

/* 操作按钮 */
.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.btn-confirm {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(46, 139, 87, 0.3);
}

.btn-confirm::after {
  border: none;
}

.btn-cancel {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: white;
  color: #666;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid #ddd;
}

.btn-cancel::after {
  border: none;
}

/* 重新扫码 */
.rescan-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(218, 165, 32, 0.1);
}

.rescan-icon {
  font-size: 32rpx;
}

.rescan-text {
  font-size: 28rpx;
  color: #DAA520;
}
