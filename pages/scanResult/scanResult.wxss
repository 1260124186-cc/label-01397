.page-container {
  min-height: 100vh;
  background: #F5F5F0;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: rotate 2s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}

.result-container {
  display: flex;
  flex-direction: column;
}

.verify-header {
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: white;
}

.verify-header.first {
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);
}

.verify-header.repeat {
  background: linear-gradient(180deg, #DAA520 0%, #F4C430 100%);
}

.verify-icon-wrapper {
  position: relative;
  margin-bottom: 30rpx;
}

.verify-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  color: white;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.verify-icon.genuine {
  background: rgba(255, 255, 255, 0.25);
}

.verify-icon.suspicious {
  background: rgba(255, 200, 0, 0.3);
}

.verify-icon.fake {
  background: rgba(255, 80, 80, 0.3);
}

.scan-type-badge {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.3);
  color: white;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.verify-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.verify-message {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 30rpx;
  text-align: center;
}

.verify-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.25);
}

.tag-auth.genuine {
  background: rgba(255, 255, 255, 0.35);
}

.tag-auth.suspicious {
  background: rgba(255, 200, 0, 0.4);
}

.tag-auth.fake {
  background: rgba(255, 80, 80, 0.4);
}

.tag-risk.warning {
  background: rgba(255, 200, 0, 0.5);
}

.tag-risk.danger {
  background: rgba(255, 80, 80, 0.5);
}

.alert-section {
  margin: -20rpx 30rpx 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(90deg, #FFF5F5 0%, #FFE8E8 100%);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #D4380D;
}

.section-icon {
  font-size: 36rpx;
}

.toggle-icon {
  font-size: 24rpx;
  color: #999;
}

.alert-list {
  padding: 0 30rpx 20rpx;
}

.alert-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
}

.alert-item.alert-danger {
  background: #FFF1F0;
  border: 1rpx solid #FFCCC7;
}

.alert-item.alert-warning {
  background: #FFFBE6;
  border: 1rpx solid #FFE58F;
}

.alert-item.alert-info {
  background: #E6F7FF;
  border: 1rpx solid #91D5FF;
}

.alert-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.alert-item.alert-danger .alert-title {
  color: #CF1322;
}

.alert-item.alert-warning .alert-title {
  color: #D48806;
}

.alert-item.alert-info .alert-title {
  color: #096DD9;
}

.alert-message {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.card {
  margin: 0 30rpx 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.card-icon {
  font-size: 36rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-body {
  padding: 20rpx 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #FAFAFA;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-value.highlight {
  color: #2E8B57;
  font-weight: 500;
}

.info-value.highlight-big {
  color: #DAA520;
  font-weight: 600;
  font-size: 32rpx;
}

.status-good {
  color: #52C41A;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background: #F6FFED;
  border-radius: 8rpx;
}

.status-bad {
  color: #FF4D4F;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background: #FFF1F0;
  border-radius: 8rpx;
}

.report-no {
  font-size: 24rpx;
  color: #999;
}

.locations-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #FAFAFA;
}

.location-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-end;
  max-width: 65%;
}

.location-tag {
  font-size: 24rpx;
  color: #2E8B57;
  padding: 6rpx 16rpx;
  background: #F6FFED;
  border-radius: 12rpx;
}

.history-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 10rpx;
  font-size: 28rpx;
  color: #1890FF;
}

.history-list {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.history-dot.first {
  background: #2E8B57;
}

.history-dot.repeat {
  background: #DAA520;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.history-time {
  font-size: 26rpx;
  color: #333;
}

.history-location {
  font-size: 24rpx;
  color: #999;
}

.history-type {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
}

.action-card {
  padding: 30rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 24rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(46, 139, 87, 0.3);
}

.btn-danger {
  background: linear-gradient(135deg, #FF4D4F, #FF7875);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(255, 77, 79, 0.3);
}

.secondary-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.secondary-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  color: #666;
}

.btn-icon {
  font-size: 40rpx;
}

.security-tips {
  margin: 0 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFF1CC 100%);
  border-radius: 20rpx;
  border: 1rpx solid #FFE0A0;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #D48806;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #8B6914;
  line-height: 1.6;
}

.ar-experience-card {
  background: linear-gradient(135deg, #F8F0FF 0%, #F0F8FF 50%, #F0FFF0 100%);
  border: 2rpx solid rgba(46, 139, 87, 0.2);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(46, 139, 87, 0.1);
}

.ar-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.ar-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ar-card-text {
  flex: 1;
}

.ar-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-bottom: 4rpx;
}

.ar-card-desc {
  font-size: 24rpx;
  color: #666666;
}

.ar-card-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.ar-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.ar-btn:active {
  transform: scale(0.96);
}

.ar-btn-tree {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.3);
}

.ar-btn-process {
  background: linear-gradient(135deg, #DAA520, #F0C75E);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(218, 165, 32, 0.3);
}

.ar-btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.ar-btn-text {
  font-size: 26rpx;
  font-weight: 500;
}

.ar-card-tip {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  flex: 1;
}

.toggle-icon {
  font-size: 24rpx;
  color: #999;
}

.divergence-card {
  border: 2rpx solid #FFCCC7;
}

.card-header.divergence {
  background: linear-gradient(135deg, #FFF1F0 0%, #FFCCC7 100%);
  margin: -30rpx -30rpx 20rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx 16rpx 0 0;
  cursor: pointer;
}

.divergence-badge {
  font-size: 22rpx;
  color: #FF4D4F;
  background: #FFF1F0;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-left: 16rpx;
  font-weight: 500;
}

.divergence-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.divergence-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #F0F0F0;
}

.divergence-row:last-child {
  border-bottom: none;
}

.div-label {
  font-size: 26rpx;
  color: #666;
}

.div-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.div-value.danger {
  color: #FF4D4F;
}

.divergence-tip {
  background: #FFF1F0;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #CF1322;
  line-height: 1.6;
  margin-top: 8rpx;
}

.divergence-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.divergence-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  border-radius: 38rpx;
  border: none;
}

.divergence-btn::after {
  border: none;
}

.divergence-btn.report {
  background: linear-gradient(135deg, #FF4D4F, #FF7875);
  color: white;
}

.divergence-btn.contact {
  background: #F5F5F0;
  color: #666;
}

.channel-card .card-header {
  cursor: pointer;
}

.channel-summary {
  display: flex;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #F6FFED 0%, #D9F7BE 100%);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.summary-label {
  font-size: 26rpx;
  color: #389E0D;
  font-weight: 500;
  flex-shrink: 0;
}

.summary-text {
  font-size: 26rpx;
  color: #52C41A;
  flex: 1;
  line-height: 1.5;
}

.channel-timeline {
  margin-top: 16rpx;
}

.channel-step {
  display: flex;
  position: relative;
}

.step-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.step-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: white;
  flex-shrink: 0;
}

.step-line {
  width: 4rpx;
  flex: 1;
  min-height: 40rpx;
  background: #E8E8E8;
  margin: 8rpx 0;
}

.step-content {
  flex: 1;
  padding-bottom: 24rpx;
}

.channel-step:last-child .step-content {
  padding-bottom: 0;
}

.step-role {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.step-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.step-location {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.step-time {
  font-size: 22rpx;
  color: #bbb;
}

.recall-alert-banner {
  background: linear-gradient(135deg, #D32F2F 0%, #F44336 100%);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.25);
}

.recall-alert-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.recall-alert-content {
  flex: 1;
}

.recall-alert-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.recall-alert-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.recall-alert-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 16rpx;
  font-weight: 300;
}

/* ==================== 礼盒相关样式 ==================== */

.subcode-giftbox-card {
  margin: 24rpx;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFEFD5 100%);
  border: 2rpx solid #FFD700;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 215, 0, 0.15);
}

.subcode-badge-wrap {
  margin-bottom: 20rpx;
}

.subcode-badge {
  display: inline-block;
  background: linear-gradient(135deg, #DAA520, #F4C430);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.subcode-position {
  margin-bottom: 24rpx;
}

.subcode-position-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.subcode-giftbox-name {
  font-size: 32rpx;
  color: #8B4513;
  font-weight: 600;
  line-height: 1.5;
}

.subcode-actions {
  display: flex;
  gap: 20rpx;
}

.subcode-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.subcode-btn-outline {
  background: #fff;
  color: #DAA520;
  border: 2rpx solid #DAA520;
}

.subcode-btn-primary {
  background: linear-gradient(135deg, #DAA520, #F4C430);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(218, 165, 32, 0.3);
}

.giftbox-verify-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #F0F0E8;
}

.giftbox-verify-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0E8;
  margin-bottom: 24rpx;
}

.giftbox-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.giftbox-verify-info {
  flex: 1;
}

.giftbox-name {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.giftbox-status-title {
  font-size: 28rpx;
  font-weight: 500;
}

.giftbox-status-title.status-complete_genuine {
  color: #2E8B57;
}

.giftbox-status-title.status-partially_genuine {
  color: #DAA520;
}

.giftbox-status-title.status-all_opened {
  color: #FF4D4F;
}

.giftbox-progress-wrap {
  margin-bottom: 24rpx;
}

.giftbox-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 26rpx;
  color: #666;
}

.progress-count {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.giftbox-progress-bar {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.giftbox-progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.giftbox-progress-fill.status-complete_genuine {
  background: linear-gradient(90deg, #2E8B57, #3CB371);
}

.giftbox-progress-fill.status-partially_genuine {
  background: linear-gradient(90deg, #DAA520, #F4C430);
}

.giftbox-progress-fill.status-all_opened {
  background: linear-gradient(90deg, #FF4D4F, #FF7875);
}

.giftbox-progress-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.giftbox-sub-status-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sub-status-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  gap: 16rpx;
}

.sub-status-item.status-first {
  background: linear-gradient(135deg, #F6FFED 0%, #D9F7BE 100%);
  border: 1rpx solid #B7EB8F;
}

.sub-status-item.status-repeat {
  background: #FFF7E6;
  border: 1rpx solid #FFE0A0;
}

.sub-status-index {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  background: #fff;
  color: #666;
