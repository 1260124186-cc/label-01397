<view class="page-container">
  
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-icon">🔍</view>
    <view class="loading-text">正在进行防伪验证...</view>
  </view>

  <view wx:else class="result-container">
    
    <view class="verify-header {{verifyResult.scanType}}">
      <view class="verify-icon-wrapper">
        <view class="verify-icon {{verifyResult.authenticity}}">
          <text wx:if="{{verifyResult.authenticity === 'genuine'}}">✓</text>
          <text wx:elif="{{verifyResult.authenticity === 'suspicious'}}">!</text>
          <text wx:else>✗</text>
        </view>
        <view class="scan-type-badge">{{scanType === 'barCode' ? '条形码' : '二维码'}}</view>
      </view>
      <view class="verify-title">{{verifyResult.title}}</view>
      <view class="verify-message">{{verifyResult.message}}</view>
      <view class="verify-tags">
        <view class="tag tag-{{verifyResult.scanType}}">
          {{verifyResult.scanType === 'first' ? '首次验证' : '重复验证'}}
        </view>
        <view class="tag tag-auth tag-{{verifyResult.authenticity}}">
          <text wx:if="{{verifyResult.authenticity === 'genuine'}}">正品</text>
          <text wx:elif="{{verifyResult.authenticity === 'suspicious'}}">存疑</text>
          <text wx:else>仿冒</text>
        </view>
        <view wx:if="{{verifyResult.abnormal.riskLevel !== 'normal'}}" class="tag tag-risk tag-{{verifyResult.abnormal.riskLevel}}">
          <text wx:if="{{verifyResult.abnormal.riskLevel === 'warning'}}">⚠️ 警告</text>
          <text wx:elif="{{verifyResult.abnormal.riskLevel === 'danger'}}">🔴 危险</text>
        </view>
      </view>
    </view>

    <view wx:if="{{verifyResult.abnormal.isAbnormal}}" class="alert-section">
      <view class="section-header" bindtap="toggleAlerts">
        <view class="section-title">
          <text class="section-icon">🚨</text>
          <text>安全告警 ({{verifyResult.abnormal.alerts.length}})</text>
        </view>
        <text class="toggle-icon">{{showAlerts ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{showAlerts}}" class="alert-list">
        <block wx:for="{{verifyResult.abnormal.alerts}}" wx:key="type">
          <view class="alert-item alert-{{item.level}}">
            <view class="alert-icon">
              <text wx:if="{{item.level === 'danger'}}">🔴</text>
              <text wx:elif="{{item.level === 'warning'}}">🟡</text>
              <text wx:else>🔵</text>
            </view>
            <view class="alert-content">
              <view class="alert-title">{{item.title}}</view>
              <view class="alert-message">{{item.message}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="card factory-info-card">
      <view class="card-header">
        <text class="card-icon">🏭</text>
        <text class="card-title">出厂信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">产品名称</text>
          <text class="info-value">{{verifyResult.factoryInfo.productName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">规格</text>
          <text class="info-value">{{verifyResult.factoryInfo.specification}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">批次号</text>
          <text class="info-value highlight">{{verifyResult.factoryInfo.batchNo}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">出厂日期</text>
          <text class="info-value">{{verifyResult.factoryInfo.productionTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">采摘时间</text>
          <text class="info-value">{{verifyResult.factoryInfo.pickTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">桂花品种</text>
          <text class="info-value">{{verifyResult.factoryInfo.variety}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">产地</text>
          <text class="info-value">{{verifyResult.factoryInfo.origin}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">检测报告</text>
          <view class="info-value">
            <text wx:if="{{verifyResult.factoryInfo.hasAbnormal}}" class="status-bad">异常</text>
            <text wx:else class="status-good">正常</text>
            <text class="report-no">{{verifyResult.factoryInfo.testReportNo}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{divergenceAlert}}" class="card divergence-card">
      <view class="card-header divergence" bindtap="toggleDivergenceAlert">
        <view class="card-title-wrap">
          <text class="card-icon">🚨</text>
          <text class="card-title">窜货预警</text>
          <view class="divergence-badge">疑似窜货</view>
        </view>
        <text class="toggle-icon">{{showDivergenceAlert ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{showDivergenceAlert}}" class="card-body">
        <view class="divergence-content">
          <view class="divergence-row">
            <text class="div-label">扫码地区</text>
            <text class="div-value danger">{{divergenceAlert.scanCity || '未知地区'}}</text>
          </view>
          <view class="divergence-row">
            <text class="div-label">授权区域</text>
            <text class="div-value">{{divergenceAlert.authorizedRegions}}</text>
          </view>
          <view class="divergence-tip">
            ⚠️ 该产品首次在非授权区域被扫码，存在窜货风险，请谨慎购买或联系客服核实。
          </view>
          <view class="divergence-actions">
            <button class="divergence-btn report" bindtap="goToReport">举报可疑产品</button>
            <button class="divergence-btn contact" bindtap="goToDealerPage">联系渠道商</button>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{channelFlow.length > 0}}" class="card channel-card">
      <view class="card-header" bindtap="toggleChannelFlow">
        <view class="card-title-wrap">
          <text class="card-icon">🛤️</text>
          <text class="card-title">渠道溯源</text>
        </view>
        <text class="toggle-icon">{{showChannelFlow ? '▲' : '▼'}}</text>
      </view>
      <view class="card-body">
        <view class="channel-summary">
          <text class="summary-label">流通路径：</text>
          <text class="summary-text">{{channelSummary}}</text>
        </view>
        <view wx:if="{{showChannelFlow}}" class="channel-timeline">
          <block wx:for="{{channelFlow}}" wx:key="step">
            <view class="channel-step">
              <view class="step-indicator">
                <view class="step-icon" style="background: {{item.color}}">
                  <text>{{item.icon}}</text>
                </view>
                <view wx:if="{{index < channelFlow.length - 1}}" class="step-line"></view>
              </view>
              <view class="step-content">
                <view class="step-role">{{item.role}}</view>
                <view class="step-name">{{item.name}}</view>
                <view class="step-location">📍 {{item.location}}</view>
                <view class="step-time">{{item.time}}</view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="card scan-info-card">
      <view class="card-header">
        <text class="card-icon">📊</text>
        <text class="card-title">扫码查询信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">本次扫码时间</text>
          <text class="info-value">{{verifyResult.scanInfo.currentScan.time}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">本次扫码地区</text>
          <text class="info-value">{{verifyResult.scanInfo.currentScan.location}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">累计查询次数</text>
          <text class="info-value highlight-big">{{verifyResult.scanInfo.totalQueryCount}} 次</text>
        </view>
        <view class="info-row">
          <text class="info-label">首次查询时间</text>
          <text class="info-value">{{verifyResult.scanInfo.firstScanTime}}</text>
        </view>
        <view wx:if="{{verifyResult.scanType === 'repeat'}}" class="info-row">
          <text class="info-label">首次查询地区</text>
          <text class="info-value">{{verifyResult.scanInfo.firstScanLocation}}</text>
        </view>
        <view wx:if="{{verifyResult.scanType === 'repeat'}}" class="info-row">
          <text class="info-label">最近查询时间</text>
          <text class="info-value">{{verifyResult.scanInfo.lastScanTime}}</text>
        </view>
        <view wx:if="{{verifyResult.scanType === 'repeat'}}" class="info-row">
          <text class="info-label">最近查询地区</text>
          <text class="info-value">{{verifyResult.scanInfo.lastScanLocation}}</text>
        </view>

        <view wx:if="{{verifyResult.scanType === 'repeat' && verifyResult.scanInfo.queryLocations.length > 0}}" class="locations-row">
          <text class="info-label">查询地区分布</text>
          <view class="location-tags">
            <block wx:for="{{verifyResult.scanInfo.queryLocations}}" wx:key="*this">
              <text class="location-tag">{{item}}</text>
            </block>
          </view>
        </view>

        <view wx:if="{{verifyResult.scanType === 'repeat' && verifyResult.scanInfo.recentRecords && verifyResult.scanInfo.recentRecords.length > 0}}" class="history-toggle" bindtap="toggleHistory">
          <text>查看最近查询记录</text>
          <text class="toggle-icon">{{showHistory ? '▲' : '▼'}}</text>
        </view>

        <view wx:if="{{showHistory && verifyResult.scanType === 'repeat' && verifyResult.scanInfo.recentRecords}}" class="history-list">
          <block wx:for="{{verifyResult.scanInfo.recentRecords}}" wx:key="time">
            <view class="history-item">
              <view class="history-dot {{item.type}}"></view>
              <view class="history-info">
                <text class="history-time">{{item.time}}</text>
                <text class="history-location">{{item.location}}</text>
              </view>
              <view class="history-type">
                <text wx:if="{{item.type === 'first'}}">首次</text>
                <text wx:else>重复</text>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="card ar-experience-card" wx:if="{{verifyResult.authenticity === 'genuine'}}">
      <view class="ar-card-header">
        <view class="ar-card-icon">🔮</view>
        <view class="ar-card-text">
          <view class="ar-card-title">AR 增强现实体验</view>
          <view class="ar-card-desc">扫描包装触发3D桂花树与窨制过程动画</view>
        </view>
      </view>
      <view class="ar-card-actions">
        <view class="ar-btn ar-btn-tree" bindtap="openARExperience" data-scene="tree">
          <text class="ar-btn-icon">🌳</text>
          <text class="ar-btn-text">3D桂花树</text>
        </view>
        <view class="ar-btn ar-btn-process" bindtap="openARExperience" data-scene="process">
          <text class="ar-btn-icon">🫖</text>
          <text class="ar-btn-text">窨制动画</text>
        </view>
      </view>
      <view class="ar-card-tip">📱 需要相机权限，建议在光线充足环境下体验</view>
    </view>

    <view class="card action-card">
      <button class="btn btn-primary" bindtap="confirmToDetail">
        查看完整溯源信息
      </button>
      <button class="btn btn-danger" bindtap="goToReport">
        🚨 一键举报可疑产品
      </button>
      <view class="secondary-actions">
        <view class="secondary-btn" bindtap="rescan">
          <text class="btn-icon">📷</text>
          <text>重新扫码</text>
        </view>
        <view class="secondary-btn" bindtap="cancelAndBack">
          <text class="btn-icon">←</text>
          <text>返回首页</text>
        </view>
      </view>
    </view>

    <view class="security-tips">
      <view class="tips-title">🛡️ 防伪小贴士</view>
      <view class="tips-list">
        <view class="tip-item">• 首次扫码显示"正品首次验证"最为可靠</view>
        <view class="tip-item">• 如发现多次异地扫码，请谨慎购买</view>
        <view class="tip-item">• 购买渠道请认准官方授权店铺</view>
      </view>
    </view>

  </view>

</view>
