<view class="page-container {{a11yClasses}}">

  <view wx:if="{{!loading && recallInfo}}" class="recall-alert-banner" bindtap="goToRecallDetail">
    <view class="recall-alert-icon">🚨</view>
    <view class="recall-alert-content">
      <view class="recall-alert-title">产品安全召回警示</view>
      <view class="recall-alert-desc">{{recallInfo.recallLevelLabel}} · {{recallInfo.issueCategory}} · 批次 {{recallInfo.batchNo}}</view>
    </view>
    <view class="recall-alert-arrow">→</view>
  </view>

  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-icon">🔍</view>
    <view class="loading-text">正在进行防伪验证...</view>
  </view>

  <view wx:else class="result-container">

    <!-- ===== 子码专属：礼盒归属提示卡片 ===== -->
    <view wx:if="{{isGiftBoxSubCode && subCodeContext}}" class="card subcode-giftbox-card">
      <view class="subcode-badge-wrap">
        <view class="subcode-badge">🎁 礼盒子码</view>
      </view>
      <view class="subcode-position">
        <text class="subcode-position-label">此产品属于</text>
        <text class="subcode-giftbox-name">{{subCodeContext.positionText}}</text>
      </view>
      <view class="subcode-actions">
        <view class="subcode-btn subcode-btn-outline" bindtap="goToGiftBoxMainPage">
          <text class="btn-icon">📷</text>
          <text>扫礼盒主码</text>
        </view>
        <view class="subcode-btn subcode-btn-primary" bindtap="goToGiftBoxDetailPage">
          <text class="btn-icon">🎁</text>
          <text>查看礼盒详情</text>
        </view>
      </view>
    </view>

    <!-- ===== 主码专属：礼盒防伪验证概览 ===== -->
    <view wx:if="{{isGiftBoxMainCode && giftBoxVerify}}" class="card giftbox-verify-card">
      <view class="giftbox-verify-header">
        <view class="giftbox-icon">🎁</view>
        <view class="giftbox-verify-info">
          <view class="giftbox-name">{{giftBoxVerify.giftBoxName}}</view>
          <view class="giftbox-status-title status-{{giftBoxVerify.authenticityStatus}}">
            <text wx:if="{{giftBoxVerify.allFirstVerified}}">✅ {{giftBoxVerify.statusTitle}}</text>
            <text wx:elif="{{giftBoxVerify.authenticityStatus === 'all_opened'}}">⚠️ {{giftBoxVerify.statusTitle}}</text>
            <text wx:else>🔍 {{giftBoxVerify.statusTitle}}</text>
          </view>
        </view>
      </view>

      <view class="giftbox-progress-wrap">
        <view class="giftbox-progress-header">
          <text class="progress-label">礼盒正品验证进度</text>
          <text class="progress-count">{{giftBoxVerify.firstScanCount}} / {{giftBoxVerify.totalItems}} 件首次验证</text>
        </view>
        <view class="giftbox-progress-bar">
          <view class="giftbox-progress-fill status-{{giftBoxVerify.authenticityStatus}}" style="width: {{giftBoxVerify.progressPercent}}%;"></view>
        </view>
        <view class="giftbox-progress-desc">{{giftBoxVerify.statusMessage}}</view>
      </view>

      <view class="giftbox-sub-status-list">
        <block wx:for="{{giftBoxVerify.subCodeResults}}" wx:key="traceId" wx:for-index="idx">
          <view class="sub-status-item {{item.isFirstScan ? 'status-first' : 'status-repeat'}}" data-index="{{idx}}" bindtap="viewSubItemScanInfo">
            <view class="sub-status-index">No.{{item.index}}</view>
            <view class="sub-status-info">
              <view class="sub-status-name">{{item.name}}</view>
              <view class="sub-status-meta">
                <text wx:if="{{item.isFirstScan}}" class="tag tag-first">首次验证</text>
                <text wx:else class="tag tag-repeat">已查询 {{item.scanCount}} 次</text>
              </view>
            </view>
            <view class="sub-status-arrow">→</view>
          </view>
        </block>
      </view>
    </view>

    <view class="verify-header {{verifyResult.scanType}}" role="region" aria-label="防伪验证结果：{{verifyResult.title}}">
      <view class="verify-icon-wrapper">
        <view class="verify-icon {{verifyResult.authenticity}}" aria-hidden="true">
          <text wx:if="{{verifyResult.authenticity === 'genuine'}}">✓</text>
          <text wx:elif="{{verifyResult.authenticity === 'suspicious'}}">!</text>
          <text wx:else>✗</text>
        </view>
        <view class="scan-type-badge">{{scanType === 'barCode' ? '条形码' : '二维码'}}</view>
      </view>
      <view class="verify-title" role="heading" aria-level="1">{{verifyResult.title}}</view>
      <view class="verify-message" aria-live="polite">{{verifyResult.message}}</view>
      <view class="verify-tags">
        <view class="tag tag-{{verifyResult.scanType}}">
          {{verifyResult.scanType === 'first' ? '首次验证' : '重复验证'}}
        </view>
        <view class="tag tag-auth tag-{{verifyResult.authenticity}}">
          <text wx:if="{{verifyResult.authenticity === 'genuine'}}">正品</text>
          <text wx:elif="{{verifyResult.authenticity === 'suspicious'}}">存疑</text>
          <text wx:else>仿冒</text>
        </view>
        <view wx:if="{{verifyResult.abnormal.riskLevel !== 'normal'}}" class="tag tag-risk tag-{{verifyResult.abnormal.riskLevel}}">
          <text wx:if="{{verifyResult.abnormal.riskLevel === 'warning'}}">⚠️ 警告</text>
          <text wx:elif="{{verifyResult.abnormal.riskLevel === 'danger'}}">🔴 危险</text>
        </view>
      </view>

      <!-- 语音播报按钮 -->
      <view class="tts-verify-btn {{ttsIsPlaying ? 'playing' : ''}}" bindtap="toggleTTsPlay"
            role="button"
            aria-label="{{ttsIsPlaying ? '语音播报中，点击暂停' : '点击朗读验证结果'}}">
        <text class="tts-btn-icon">{{ttsIsPlaying ? '🔊' : '🔈'}}</text>
        <text class="tts-btn-text">{{ttsIsPlaying ? '播报中' : '听结果'}}</text>
      </view>
    </view>

    <view wx:if="{{verifyResult.abnormal.isAbnormal}}" class="alert-section">
      <view class="section-header" bindtap="toggleAlerts">
        <view class="section-title">
          <text class="section-icon">🚨</text>
          <text>安全告警 ({{verifyResult.abnormal.alerts.length}})</text>
        </view>
        <text class="toggle-icon">{{showAlerts ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{showAlerts}}" class="alert-list">
        <block wx:for="{{verifyResult.abnormal.alerts}}" wx:key="type">
          <view class="alert-item alert-{{item.level}}">
            <view class="alert-icon">
              <text wx:if="{{item.level === 'danger'}}">🔴</text>
              <text wx:elif="{{item.level === 'warning'}}">🟡</text>
              <text wx:else>🔵</text>
            </view>
            <view class="alert-content">
              <view class="alert-title">{{item.title}}</view>
              <view class="alert-message">{{item.message}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="card factory-info-card">
      <view class="card-header">
        <text class="card-icon">🏭</text>
        <text class="card-title">出厂信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">产品名称</text>
          <text class="info-value">{{verifyResult.factoryInfo.productName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">规格</text>
          <text class="info-value">{{verifyResult.factoryInfo.specification}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">批次号</text>
          <text class="info-value highlight">{{verifyResult.factoryInfo.batchNo}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">出厂日期</text>
          <text class="info-value">{{verifyResult.factoryInfo.productionTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">采摘时间</text>
          <text class="info-value">{{verifyResult.factoryInfo.pickTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">桂花品种</text>
          <text class="info-value">{{verifyResult.factoryInfo.variety}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">产地</text>
          <text class="info-value">{{verifyResult.factoryInfo.origin}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">检测报告</text>
          <view class="info-value">
            <text wx:if="{{verifyResult.factoryInfo.hasAbnormal}}" class="status-bad">异常</text>
            <text wx:else class="status-good">正常</text>
            <text class="report-no">{{verifyResult.factoryInfo.testReportNo}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{divergenceAlert}}" class="card divergence-card">
      <view class="card-header divergence" bindtap="toggleDivergenceAlert">
        <view class="card-title-wrap">
          <text class="card-icon">🚨</text>
          <text class="card-title">窜货预警</text>
          <view class="divergence-badge">疑似窜货</view>
        </view>
        <text class="toggle-icon">{{showDivergenceAlert ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{showDivergenceAlert}}" class="card-body">
        <view class="divergence-content">
          <view class="divergence-row">
            <text class="div-label">扫码地区</text>
            <text class="div-value danger">{{divergenceAlert.scanCity || '未知地区'}}</text>
          </view>
          <view class="divergence-row">
            <text class="div-label">授权区域</text>
            <text class="div-value">{{divergenceAlert.authorizedRegions}}</text>
          </view>
          <view class="divergence-tip">
            ⚠️ 该产品首次在非授权区域被扫码，存在窜货风险，请谨慎购买或联系客服核实。
          </view>
          <view class="divergence-actions">
            <button class="divergence-btn report" bindtap="goToReport">举报可疑产品</button>
            <button class="divergence-btn contact" bindtap="goToDealerPage">联系渠道商</button>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{channelFlow.length > 0}}" class="card channel-card">
      <view class="card-header" bindtap="toggleChannelFlow">
        <view class="card-title-wrap">
          <text class="card-icon">🛤️</text>
          <text class="card-title">渠道溯源</text>
        </view>
        <text class="toggle-icon">{{showChannelFlow ? '▲' : '▼'}}</text>
      </view>
      <view class="card-body">
        <view class="channel-summary">
          <text class="summary-label">流通路径：</text>
          <text class="summary-text">{{channelSummary}}</text>
        </view>
        <view wx:if="{{showChannelFlow}}" class="channel-timeline">
          <block wx:for="{{channelFlow}}" wx:key="step">
            <view class="channel-step">
              <view class="step-indicator">
                <view class="step-icon" style="background: {{item.color}}">
                  <text>{{item.icon}}</text>
                </view>
                <view wx:if="{{index < channelFlow.length - 1}}" class="step-line"></view>
              </view>
              <view class="step-content">
                <view class="step-role">{{item.role}}</view>
                <view class="step-name">{{item.name}}</view>
                <view class="step-location">📍 {{item.location}}</view>
                <view class="step-time">{{item.time}}</view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="card scan-info-card">
      <view class="card-header">
        <text class="card-icon">📊</text>
        <text class="card-title">扫码查询信息</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">本次扫码时间</text>
          <text class="info-value">{{verifyResult.scanInfo.currentScan.time}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">本次扫码地区</text>
          <text class="info-value">{{verifyResult.scanInfo.currentScan.location}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">累计查询次数</text>
          <text class="info-value highlight-big">{{verifyResult.scanInfo.totalQueryCount}} 次</text>
        </view>
        <view class="info-row">
          <text class="info-label">首次查询时间</text>
          <text class="info-value">{{verifyResult.scanInfo.firstScanTime}}</text>
        </view>
        <view wx:if="{{verifyResult.scanType === 'repeat'}}" class="info-row">
          <text class="info-label">首次查询地区</text>
          <text class="info-value">{{verifyResult.scanInfo.firstScanLocation}}</text>
        </view>
        <view wx:if="{{verifyResult.scanType === 'repeat'}}" class="info-row">
          <text class="info-label">最近查询时间</text>
          <text class="info-value">{{verifyResult.scanInfo.lastScanTime}}</text>
        </view>
        <view wx:if="{{verifyResult.scanType === 'repeat'}}" class="info-row">
          <text class="info-label">最近查询地区</text>
          <text class="info-value">{{verifyResult.scanInfo.lastScanLocation}}</text>
        </view>

        <view wx:if="{{verifyResult.scanType === 'repeat' && verifyResult.scanInfo.queryLocations.length > 0}}" class="locations-row">
          <text class="info-label">查询地区分布</text>
          <view class="location-tags">
            <block wx:for="{{verifyResult.scanInfo.queryLocations}}" wx:key="*this">
              <text class="location-tag">{{item}}</text>
            </block>
          </view>
        </view>

        <view wx:if="{{verifyResult.scanType === 'repeat' && verifyResult.scanInfo.recentRecords && verifyResult.scanInfo.recentRecords.length > 0}}" class="history-toggle" bindtap="toggleHistory">
          <text>查看最近查询记录</text>
          <text class="toggle-icon">{{showHistory ? '▲' : '▼'}}</text>
        </view>

        <view wx:if="{{showHistory && verifyResult.scanType === 'repeat' && verifyResult.scanInfo.recentRecords}}" class="history-list">
          <block wx:for="{{verifyResult.scanInfo.recentRecords}}" wx:key="time">
            <view class="history-item">
              <view class="history-dot {{item.type}}"></view>
              <view class="history-info">
                <text class="history-time">{{item.time}}</text>
                <text class="history-location">{{item.location}}</text>
              </view>
              <view class="history-type">
                <text wx:if="{{item.type === 'first'}}">首次</text>
                <text wx:else>重复</text>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- ===== 主码专属：礼盒子产品卡片列表 ===== -->
    <view wx:if="{{isGiftBoxMainCode && giftBoxItems.length > 0}}" class="card giftbox-items-card">
      <view class="card-header">
        <view class="card-title-wrap">
          <text class="card-icon">📦</text>
          <text class="card-title">礼盒组成</text>
          <text class="item-count-badge">共 {{giftBoxItems.length}} 件</text>
        </view>
      </view>
      <view class="card-body">
        <block wx:for="{{giftBoxItems}}" wx:key="traceId">
          <view class="giftbox-item-card" data-trace-id="{{item.traceId}}" bindtap="goToSubItemDetail">
            <view class="giftbox-item-index">
              <view class="index-badge">No.{{item.index}}</view>
            </view>
            <view class="giftbox-item-thumb">
              <image src="{{item.thumbnail}}" mode="aspectFill" />
            </view>
            <view class="giftbox-item-info">
              <view class="giftbox-item-name">{{item.name}}</view>
              <view class="giftbox-item-variety">{{item.variety}} · {{item.specification}}</view>
              <view class="giftbox-item-highlight">{{item.highlight}}</view>
            </view>
            <view class="giftbox-item-arrow">
              <text>查看详情 →</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="card ar-experience-card" wx:if="{{verifyResult.authenticity === 'genuine'}}">
      <view class="ar-card-header">
        <view class="ar-card-icon">🔮</view>
        <view class="ar-card-text">
          <view class="ar-card-title">AR 增强现实体验</view>
          <view class="ar-card-desc">扫描包装触发3D桂花树与窨制过程动画</view>
        </view>
      </view>
      <view class="ar-card-actions">
        <view class="ar-btn ar-btn-tree" bindtap="openARExperience" data-scene="tree">
          <text class="ar-btn-icon">🌳</text>
          <text class="ar-btn-text">3D桂花树</text>
        </view>
        <view class="ar-btn ar-btn-process" bindtap="openARExperience" data-scene="process">
          <text class="ar-btn-icon">🫖</text>
          <text class="ar-btn-text">窨制动画</text>
        </view>
      </view>
      <view class="ar-card-tip">📱 需要相机权限，建议在光线充足环境下体验</view>
    </view>

    <view class="card action-card">
      <button class="btn btn-primary" bindtap="confirmToDetail">
        查看完整溯源信息
      </button>
      <button class="btn btn-danger" bindtap="goToReport">
        🚨 一键举报可疑产品
      </button>
      <view class="secondary-actions">
        <view class="secondary-btn" bindtap="rescan">
          <text class="btn-icon">📷</text>
          <text>重新扫码</text>
        </view>
        <view class="secondary-btn" bindtap="cancelAndBack">
          <text class="btn-icon">←</text>
          <text>返回首页</text>
        </view>
      </view>
    </view>

    <view class="security-tips">
      <view class="tips-title">🛡️ 防伪小贴士</view>
      <view class="tips-list">
        <view class="tip-item">• 首次扫码显示"正品首次验证"最为可靠</view>
        <view class="tip-item">• 如发现多次异地扫码，请谨慎购买</view>
        <view class="tip-item">• 购买渠道请认准官方授权店铺</view>
      </view>
    </view>

    <!-- ==================== 语音播报浮动控制条 ==================== -->
    <view class="tts-float-control {{ttsShowControl ? 'visible' : 'hidden'}}" role="region" aria-label="语音播报控制">
      <view class="tts-control-bar">
        <view class="tts-play-btn {{ttsIsPlaying ? 'playing' : ''}}" bindtap="toggleTTsPlay"
              role="button" aria-label="{{ttsIsPlaying && !ttsIsPaused ? '暂停播报' : ttsIsPaused ? '继续播报' : '开始播报'}}">
          <text class="play-icon">{{ttsIsPlaying && !ttsIsPaused ? '⏸' : '▶'}}</text>
        </view>
        <view class="tts-info" bindtap="toggleTTSControl">
          <view class="tts-status-text" aria-live="polite">
            {{ttsIsPlaying ? (ttsIsPaused ? '已暂停' : '正在播报验证结果') : '点击开始语音播报'}}
          </view>
          <view class="tts-progress-bar">
            <view class="tts-progress-fill" style="width: {{ttsProgress}}%;"></view>
          </view>
        </view>
        <view class="tts-stop-btn" bindtap="stopTTS"
              role="button" aria-label="停止播报">
          <text>⏹</text>
        </view>
      </view>

      <!-- 展开的控制面板 -->
      <view class="tts-expanded-panel {{ttsShowControl ? 'show' : ''}}">
        <view class="tts-panel-section">
          <view class="tts-panel-title">语速调节</view>
          <view class="tts-speed-options">
            <view class="tts-speed-btn {{ttsSpeed == 0.5 ? 'active' : ''}}" bindtap="setTTSSpeed" data-speed="0.5"
                  role="button" aria-selected="{{ttsSpeed == 0.5}}" aria-label="慢速 0.5倍">
              0.5x
            </view>
            <view class="tts-speed-btn {{ttsSpeed == 0.75 ? 'active' : ''}}" bindtap="setTTSSpeed" data-speed="0.75"
                  role="button" aria-selected="{{ttsSpeed == 0.75}}" aria-label="较慢 0.75倍">
              0.75x
            </view>
            <view class="tts-speed-btn {{ttsSpeed == 1.0 ? 'active' : ''}}" bindtap="setTTSSpeed" data-speed="1.0"
                  role="button" aria-selected="{{ttsSpeed == 1.0}}" aria-label="正常 1.0倍">
              1.0x
            </view>
            <view class="tts-speed-btn {{ttsSpeed == 1.25 ? 'active' : ''}}" bindtap="setTTSSpeed" data-speed="1.25"
                  role="button" aria-selected="{{ttsSpeed == 1.25}}" aria-label="较快 1.25倍">
              1.25x
            </view>
            <view class="tts-speed-btn {{ttsSpeed == 1.5 ? 'active' : ''}}" bindtap="setTTSSpeed" data-speed="1.5"
                  role="button" aria-selected="{{ttsSpeed == 1.5}}" aria-label="快速 1.5倍">
              1.5x
            </view>
          </view>
        </view>

        <view class="tts-panel-section">
          <view class="tts-panel-title">音量调节</view>
          <view class="tts-volume-options">
            <view class="tts-volume-btn {{ttsVolume == 0.2 ? 'active' : ''}}" bindtap="setTTSVolume" data-volume="0.2"
                  role="button" aria-selected="{{ttsVolume == 0.2}}" aria-label="低音量">
              🔈 低
            </view>
            <view class="tts-volume-btn {{ttsVolume == 0.5 ? 'active' : ''}}" bindtap="setTTSVolume" data-volume="0.5"
                  role="button" aria-selected="{{ttsVolume == 0.5}}" aria-label="中音量">
              🔉 中
            </view>
            <view class="tts-volume-btn {{ttsVolume == 0.8 ? 'active' : ''}}" bindtap="setTTSVolume" data-volume="0.8"
                  role="button" aria-selected="{{ttsVolume == 0.8}}" aria-label="高音量">
              🔊 高
            </view>
            <view class="tts-volume-btn {{ttsVolume == 1.0 ? 'active' : ''}}" bindtap="setTTSVolume" data-volume="1.0"
                  role="button" aria-selected="{{ttsVolume == 1.0}}" aria-label="最大音量">
              🔊 最大
            </view>
          </view>
        </view>

        <view class="tts-panel-section">
          <view class="tts-toggle-row">
            <text class="tts-toggle-label">语音播报开关</text>
            <switch checked="{{ttsEnabled}}" bindchange="toggleTTSEnabled" color="#2E8B57"
                    aria-label="{{ttsEnabled ? '关闭语音播报' : '开启语音播报'}}"/>
          </view>
        </view>
      </view>
    </view>

  </view>

</view>
