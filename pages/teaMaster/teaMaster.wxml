<!--
  桂花茶溯源小程序 - 制茶师/窨制班组档案页
  功能：展示制茶师介绍、代表批次、工艺理念、照片
-->

<view class="page-container" wx:if="{{!loading && teamData}}">

  <!-- 顶部头部：制茶师照片 + 基本信息 -->
  <view class="master-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="avatar-wrapper" bindtap="previewAvatar">
        <image class="master-avatar" src="{{teamData.photo}}" mode="aspectFill" />
        <view class="avatar-badge">{{teamData.leaderQualificationLevel}}</view>
      </view>
      <view class="master-info">
        <view class="master-name-row">
          <text class="master-name">{{teamData.leaderNameMasked}}</text>
          <text class="master-jobno">工号：{{teamData.leaderJobNo}}</text>
        </view>
        <view class="master-team">{{teamData.teamName}}</view>
        <view class="master-tags">
          <view class="tag-item primary">{{teamData.leaderQualification}}</view>
          <view class="tag-item">{{teamData.leaderExperienceYears}}年从业经验</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心数据卡片 -->
  <view class="stats-card">
    <view class="stats-item">
      <view class="stats-value">{{teamData.teamSize}}</view>
      <view class="stats-label">团队人数</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-value">{{2026 - teamData.foundingYear}}</view>
      <view class="stats-label">成立年数</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-value">{{teamData.representativeBatches.length}}</view>
      <view class="stats-label">代表批次</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-value">{{teamData.awards.length}}</view>
      <view class="stats-label">获奖荣誉</view>
    </view>
  </view>

  <!-- Tab 导航 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'intro' ? 'active' : ''}}" data-tab="intro" bindtap="switchTab">
      <text class="tab-icon">📖</text>
      <text class="tab-label">班组介绍</text>
    </view>
    <view class="tab-item {{activeTab === 'philosophy' ? 'active' : ''}}" data-tab="philosophy" bindtap="switchTab">
      <text class="tab-icon">💭</text>
      <text class="tab-label">工艺理念</text>
    </view>
    <view class="tab-item {{activeTab === 'batches' ? 'active' : ''}}" data-tab="batches" bindtap="switchTab">
      <text class="tab-icon">📦</text>
      <text class="tab-label">代表批次</text>
    </view>
    <view class="tab-item {{activeTab === 'photos' ? 'active' : ''}}" data-tab="photos" bindtap="switchTab">
      <text class="tab-icon">📷</text>
      <text class="tab-label">工作照片</text>
    </view>
  </view>

  <!-- Tab 内容 -->
  <view class="tab-content">

    <!-- Tab1：班组介绍 -->
    <view class="tab-pane" wx:if="{{activeTab === 'intro'}}">
      <view class="section-card">
        <view class="section-title">
          <text class="title-icon">👥</text>
          <text>团队简介</text>
        </view>
        <view class="section-content">
          <text class="intro-text">{{teamData.introduction}}</text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">
          <text class="title-icon">🎯</text>
          <text>专长领域</text>
        </view>
        <view class="specialty-tags">
          <view class="specialty-tag">{{teamData.specialty}}</view>
        </view>
      </view>

      <view class="section-card" wx:if="{{teamData.certifications && teamData.certifications.length > 0}}">
        <view class="section-title">
          <text class="title-icon">📜</text>
          <text>资质证书</text>
        </view>
        <view class="cert-list">
          <view
            wx:for="{{teamData.certifications}}"
            wx:key="*this"
            class="cert-item"
            data-cert="{{item}}"
            bindtap="viewCertificationDetail"
          >
            <text class="cert-icon">🏅</text>
            <text class="cert-name">{{item}}</text>
            <text class="cert-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="section-card" wx:if="{{teamData.awards && teamData.awards.length > 0}}">
        <view class="section-title">
          <text class="title-icon">🏆</text>
          <text>荣誉奖项</text>
        </view>
        <view class="award-list">
          <view
            wx:for="{{teamData.awards}}"
            wx:key="title"
            class="award-item"
            data-award="{{item}}"
            bindtap="viewAwardDetail"
          >
            <view class="award-year">{{item.year}}</view>
            <view class="award-info">
              <view class="award-title">{{item.title}}</view>
              <view class="award-level">{{item.level}}</view>
            </view>
            <text class="award-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Tab2：工艺理念 -->
    <view class="tab-pane" wx:if="{{activeTab === 'philosophy'}}">
      <view class="philosophy-card">
        <view class="philosophy-icon">💭</view>
        <view class="philosophy-quote">"{{teamData.craftPhilosophy}}"</view>
        <view class="philosophy-author">—— {{teamData.teamName}}</view>
      </view>

      <view class="section-card">
        <view class="section-title">
          <text class="title-icon">🎋</text>
          <text>制茶师资质</text>
        </view>
        <view class="qualification-grid">
          <view class="qual-item">
            <view class="qual-icon">👤</view>
            <view class="qual-info">
              <view class="qual-label">制茶师姓名</view>
              <view class="qual-value">{{teamData.leaderNameMasked}}</view>
            </view>
          </view>
          <view class="qual-item">
            <view class="qual-icon">🪪</view>
            <view class="qual-info">
              <view class="qual-label">工号</view>
              <view class="qual-value">{{teamData.leaderJobNo}}</view>
            </view>
          </view>
          <view class="qual-item">
            <view class="qual-icon">⭐</view>
            <view class="qual-info">
              <view class="qual-label">资质等级</view>
              <view class="qual-value highlight">{{teamData.leaderQualification}}</view>
            </view>
          </view>
          <view class="qual-item">
            <view class="qual-icon">📅</view>
            <view class="qual-info">
              <view class="qual-label">从业年限</view>
              <view class="qual-value">{{teamData.leaderExperienceYears}}年</view>
            </view>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">
          <text class="title-icon">🏛️</text>
          <text>团队传承</text>
        </view>
        <view class="heritage-content">
          <view class="heritage-row">
            <text class="heritage-label">成立时间</text>
            <text class="heritage-value">{{teamData.foundingYear}}年</text>
          </view>
          <view class="heritage-row">
            <text class="heritage-label">团队规模</text>
            <text class="heritage-value">{{teamData.teamSize}}人</text>
          </view>
          <view class="heritage-row">
            <text class="heritage-label">擅长工艺</text>
            <text class="heritage-value">{{teamData.specialty}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Tab3：代表批次 -->
    <view class="tab-pane" wx:if="{{activeTab === 'batches'}}">
      <view class="batch-list" wx:if="{{teamData.representativeBatches && teamData.representativeBatches.length > 0}}">
        <view
          wx:for="{{teamData.representativeBatches}}"
          wx:key="batchNo"
          class="batch-card"
          data-batchno="{{item.batchNo}}"
          bindtap="viewBatchDetail"
        >
          <view class="batch-header">
            <view class="batch-no-badge">{{item.batchNo}}</view>
            <view class="batch-year">{{item.year}}年</view>
          </view>
          <view class="batch-product">{{item.productName}}</view>
          <view class="batch-remark" wx:if="{{item.remark}}">
            <text class="remark-icon">⭐</text>
            <text class="remark-text">{{item.remark}}</text>
          </view>
          <view class="batch-footer">
            <text class="batch-link">查看批次详情 ›</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text class="empty-icon">📦</text>
        <text class="empty-text">暂无代表批次</text>
      </view>
    </view>

    <!-- Tab4：工作照片 -->
    <view class="tab-pane" wx:if="{{activeTab === 'photos'}}">
      <view class="photo-section" wx:if="{{teamData.teamPhotos && teamData.teamPhotos.length > 0}}">
        <swiper
          class="photo-swiper"
          indicator-dots="{{true}}"
          autoplay="{{true}}"
          interval="{{3500}}"
          circular="{{true}}"
          bindchange="onPhotoChange"
          indicator-color="rgba(255,255,255,0.4)"
          indicator-active-color="#FFFFFF"
        >
          <swiper-item wx:for="{{teamData.teamPhotos}}" wx:key="*this">
            <image
              class="swiper-photo"
              src="{{item}}"
              mode="aspectFill"
              data-url="{{item}}"
              bindtap="previewTeamPhoto"
            />
          </swiper-item>
        </swiper>
        <view class="photo-counter">
          {{currentPhotoIndex + 1}} / {{teamData.teamPhotos.length}}
        </view>
      </view>

      <view class="photo-grid-section">
        <view class="section-title">
          <text class="title-icon">📸</text>
          <text>团队风采</text>
        </view>
        <view class="photo-grid">
          <view
            wx:for="{{teamData.teamPhotos}}"
            wx:key="*this"
            class="photo-grid-item"
            data-url="{{item}}"
            bindtap="previewTeamPhoto"
          >
            <image class="grid-photo" src="{{item}}" mode="aspectFill" />
          </view>
        </view>
      </view>

      <view class="empty-tip" wx:if="{{(!teamData.teamPhotos || teamData.teamPhotos.length === 0)}}">
        <text class="empty-icon">📷</text>
        <text class="empty-text">暂无工作照片</text>
      </view>
    </view>

  </view>

</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>
