.page-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.section-title.small {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  justify-content: space-between;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.toggle-arrow {
  color: #999;
  font-size: 24rpx;
}

.api-status-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
}

.api-status-bar.status-normal {
  background: #e6f7ff;
  color: #1890ff;
}

.api-status-bar.status-error {
  background: #fff1f0;
  color: #ff4d4f;
}

.status-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-weight: bold;
  margin-right: 12rpx;
  font-size: 24rpx;
  background: rgba(255,255,255,0.6);
}

.status-normal .status-icon {
  background: #fff;
}

.status-error .status-icon {
  background: #fff;
}

.status-text {
  flex: 1;
}

.sync-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.7);
  font-size: 24rpx;
}

.input-wrap {
  position: relative;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 60rpx 20rpx 24rpx;
  background: #fafafa;
  transition: border-color 0.2s;
}

.input-wrap:focus-within {
  border-color: #1E88E5;
  background: #fff;
}

.code-input {
  font-size: 30rpx;
  color: #1a1a1a;
  width: 100%;
  letter-spacing: 1rpx;
}

.clear-btn {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #666;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}

.input-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: opacity 0.2s;
}

.scan-btn {
  background: #f0f7ff;
  color: #1E88E5;
  border: 2rpx solid #1E88E5;
}

.query-btn {
  background: linear-gradient(135deg, #1E88E5, #1565C0);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(30, 136, 229, 0.3);
}

.query-btn.disabled {
  opacity: 0.6;
}

.btn-icon {
  font-size: 32rpx;
}

.loading-spin {
  font-size: 32rpx;
  animation: spin 1s linear infinite;
  display: inline-block;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.sample-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sample-item {
  width: calc(50% - 8rpx);
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
  transition: all 0.2s;
  box-sizing: border-box;
}

.sample-item:active {
  transform: scale(0.97);
}

.sample-item.status-approved {
  border-color: #52C41A;
  background: #f6ffed;
}

.sample-item.status-warning {
  border-color: #FF7A45;
  background: #fff7e6;
}

.sample-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.sample-item.status-approved .sample-label {
  color: #389e0d;
}

.sample-item.status-warning .sample-label {
  color: #d4380d;
}

.sample-code {
  font-size: 22rpx;
  color: #333;
  font-family: 'SF Mono', 'Menlo', monospace;
  word-break: break-all;
  line-height: 1.4;
}

.error-section {
  background: #fff2f0;
  border: 2rpx solid #ffccc7;
  text-align: center;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: #ff4d4f;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.error-tips {
  text-align: left;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.8;
}

.result-header {
  border-top: 8rpx solid #1E88E5;
  padding-top: 32rpx;
}

.result-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.brand-summary {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e6f7ff 100%);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.brand-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.brand-meta {
  flex: 1;
  min-width: 0;
}

.brand-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.brand-batch {
  font-size: 24rpx;
  color: #8c8c8c;
}

.goto-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #1E88E5;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.goto-btn .arrow {
  margin-left: 6rpx;
}

.compliance-banner {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #fffbe6 0%, #fff1b8 100%);
  border-radius: 12rpx;
  border-left: 6rpx solid #faad14;
}

.compliance-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #52C41A;
  color: #fff;
  text-align: center;
  line-height: 40rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 24rpx;
}

.compliance-text {
  font-size: 26rpx;
  color: #614700;
  line-height: 1.5;
  font-weight: 500;
}

.gov-card-header {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.gov-title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
}

.gov-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.gov-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.gov-status {
  padding: 8rpx 20rpx;
  border: 2rpx solid;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.province-card {
  border-top: 6rpx solid #1E88E5;
}

.national-card {
  border-top: 6rpx solid #D32F2F;
}

.gov-card-body {
  padding-top: 20rpx;
}

.gov-info-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 2rpx dashed #f0f0f0;
}

.gov-info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  flex-shrink: 0;
  color: #8c8c8c;
  font-size: 26rpx;
  line-height: 1.5;
}

.info-value {
  flex: 1;
  color: #1a1a1a;
  font-size: 26rpx;
  line-height: 1.5;
  word-break: break-all;
}

.code-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.code-value .code-text {
  flex: 1;
  font-family: 'SF Mono', 'Menlo', monospace;
  color: #1E88E5;
}

.code-value .code-text.break {
  word-break: break-all;
}

.copy-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.warning-box {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background: #fff7e6;
  border-radius: 10rpx;
  margin-top: 20rpx;
  border-left: 6rpx solid #ff7a45;
}

.warn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.warn-text {
  font-size: 26rpx;
  color: #d4380d;
  line-height: 1.6;
  flex: 1;
}

.verify-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  border-radius: 10rpx;
  color: #1890ff;
  font-size: 26rpx;
  font-weight: 500;
}

.verify-action .arrow {
  font-size: 28rpx;
}

.inspection-card {
  border-top: 6rpx solid #722ED1;
}

.inspection-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.inspection-title-wrap {
  display: flex;
  align-items: center;
  flex: 1;
  flex-wrap: wrap;
  gap: 12rpx;
}

.inspection-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.inspection-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.record-count {
  font-size: 22rpx;
  color: #8c8c8c;
  background: #f0f0f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.inspection-body {
  padding-top: 20rpx;
}

.inspection-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #d9d9d9;
}

.inspection-item:last-child {
  margin-bottom: 0;
}

.inspection-item.result-pass {
  background: #f6ffed;
  border-left-color: #52C41A;
}

.inspection-item.result-fail {
  background: #fff1f0;
  border-left-color: #ff4d4f;
}

.inspection-result {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.result-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: inline-block;
}

.result-badge.pass {
  background: #52C41A;
  color: #fff;
}

.result-badge.fail {
  background: #ff4d4f;
  color: #fff;
}

.inspection-details {
  flex: 1;
  min-width: 0;
}

.inspection-date,
.inspection-institution,
.inspection-report {
  font-size: 24rpx;
  color: #595959;
  margin-bottom: 6rpx;
  line-height: 1.5;
}

.inspection-abnormal {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx dashed #ffccc7;
}

.abnormal-label {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.abnormal-text {
  font-size: 24rpx;
  color: #d4380d;
}

.sync-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #fafafa;
  color: #8c8c8c;
  font-size: 22rpx;
}

.sync-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.footer-tips {
  padding: 28rpx;
  background: #fffbe6;
  border-radius: 12rpx;
  margin-top: 8rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #614700;
  margin-bottom: 16rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #874d00;
  line-height: 1.8;
}

.history-body {
  padding-top: 16rpx;
}

.clear-history {
  text-align: right;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.history-left {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.history-code {
  font-size: 26rpx;
  color: #1a1a1a;
  font-family: 'SF Mono', 'Menlo', monospace;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.history-meta {
  font-size: 22rpx;
  color: #8c8c8c;
}

.history-name {
  margin-right: 4rpx;
}

.history-right {
  text-align: right;
  flex-shrink: 0;
}

.history-status {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  margin-bottom: 6rpx;
  background: #f0f0f0;
  color: #666;
}

.history-status.status-approved {
  background: #f6ffed;
  color: #389e0d;
}

.history-status.status-warning {
  background: #fff7e6;
  color: #d4380d;
}

.history-status.status-recall,
.history-status.status-revoked {
  background: #fff1f0;
  color: #cf1322;
}

.history-time {
  font-size: 22rpx;
  color: #bfbfbf;
}
