  font-size: 22rpx;
  color: #999999;
}

.bc-info-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.bc-txhash-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.bc-txhash-container {
