}

.round-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #2E8B57;
  min-width: 60rpx;
  text-align: center;
}

/* ==================== 冲泡记录保存弹窗 ==================== */
.brew-save-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
