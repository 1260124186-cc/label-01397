  border-radius: 12rpx;
}

.bc-stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #2E8B57;
}

.bc-stat-label {
  font-size: 22rpx;
  color: #999999;
}

.bc-scan-records {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bc-scan-record-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.bc-scan-type-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #FFFFFF;
  flex-shrink: 0;
}

.bc-scan-type-badge.first {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
}

.bc-scan-type-badge.repeat {
  background: linear-gradient(135deg, #FF8F00, #FFB300);
}

.bc-scan-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.bc-scan-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bc-scan-location {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.bc-scan-type-text {
  font-size: 22rpx;
  color: #999999;
}

.bc-scan-bottom {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bc-scan-time {
  font-size: 22rpx;
  color: #999999;
}

.bc-scan-ip {
  font-size: 22rpx;
  color: #BBBBBB;
}

.bc-current-scan {
  margin-top: 12rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #E8F5E9, #F1F8E9);
  border-radius: 12rpx;
  border: 1rpx solid #C8E6C9;
}

.bc-current-scan-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.bc-current-scan-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2E8B57;
}

.bc-current-scan-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  color: #FFFFFF;
}

.bc-current-scan-badge.first {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
}

.bc-current-scan-badge.repeat {
  background: linear-gradient(135deg, #FF8F00, #FFB300);
}

.bc-current-scan-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.bc-current-scan-product {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.bc-current-scan-total {
  font-size: 24rpx;
  color: #666666;
}

.bc-tsa-badge {
  font-size: 20rpx;
  color: #1565C0;
  background: #E3F2FD;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
  font-weight: 600;
}

.bc-tsa-brief {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.bc-tsa-brief-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 16rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.bc-tsa-brief-label {
  font-size: 22rpx;
  color: #999999;
}

.bc-tsa-brief-value {
  font-size: 24rpx;
  color: #333333;
}

.bc-tsa-cert-detail {
  margin-top: 16rpx;
}

.bc-tsa-cert-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #E0E0E0;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.bc-tsa-cert-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border-bottom: 2rpx solid #90CAF9;
}

.bc-tsa-cert-icon {
  font-size: 32rpx;
}

.bc-tsa-cert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1565C0;
}

.bc-tsa-cert-body {
  padding: 16rpx 24rpx;
}

.bc-tsa-cert-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.bc-tsa-cert-item:last-child {
  border-bottom: none;
}

.bc-tsa-cert-label {
  font-size: 22rpx;
  color: #999999;
}

.bc-tsa-cert-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bc-tsa-cert-value {
  font-size: 24rpx;
  color: #333333;
  word-break: break-all;
  flex: 1;
}

.bc-tsa-cert-copy {
  font-size: 22rpx;
  color: #1565C0;
  padding: 4rpx 14rpx;
  background: #E3F2FD;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.bc-mono {
  font-family: monospace;
  font-size: 22rpx;
  color: #1565C0;
}

.bc-hash-small {
  font-size: 20rpx;
  color: #666666;
  line-height: 1.5;
}

.bc-legal {
  font-size: 22rpx;
  color: #B71C1C;
  font-weight: 500;
}

.bc-tsa-cert-footer {
  padding: 16rpx 24rpx;
  background: #FFFDE7;
  border-top: 1rpx solid #FFF9C4;
}

.bc-tsa-cert-verify-hint {
  font-size: 22rpx;
  color: #F57F17;
  text-align: center;
}

/* ==================== 返回顶部按钮 ==================== */
.back-top {
  position: fixed;
  right: 32rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.3s ease;
  z-index: 100;
}

.back-top.show {
  opacity: 1;
  transform: scale(1);
}

.back-top:active {
  transform: scale(0.92);
}

.back-top-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ==================== PDF报告弹窗 ==================== */
.pdf-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.pdf-modal.show {
  opacity: 1;
  visibility: visible;
}

.pdf-content {
  width: 90%;
  max-width: 650rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.pdf-modal.show .pdf-content {
  transform: scale(1);
}

.pdf-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
}

.pdf-title {
  font-size: 32rpx;
  font-weight: 600;
}

.pdf-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.pdf-body {
  padding: 32rpx;
  max-height: calc(80vh - 120rpx);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.pdf-institution {
  text-align: center;
  margin-bottom: 24rpx;
}

.pdf-logo {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.pdf-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.pdf-info {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.pdf-row {
  display: flex;
  margin-bottom: 8rpx;
}

.pdf-row:last-child {
  margin-bottom: 0;
}

.pdf-label {
  font-size: 24rpx;
  color: #999999;
  min-width: 140rpx;
}

.pdf-value {
  font-size: 24rpx;
  color: #333333;
}

.pdf-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #E8E8E8, transparent);
  margin: 24rpx 0;
}

.pdf-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.pdf-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666666;
  border-bottom: 1rpx dashed #F0F0F0;
}

.pdf-pass {
  color: #52C41A;
  font-weight: 500;
}

.pdf-footer {
  margin-top: 32rpx;
  text-align: center;
}

.pdf-stamp {
  display: inline-block;
  padding: 16rpx 48rpx;
  border: 4rpx solid #52C41A;
  border-radius: 8rpx;
  color: #52C41A;
  font-size: 32rpx;
  font-weight: 600;
  transform: rotate(-5deg);
  margin-bottom: 16rpx;
}

.pdf-conclusion {
  font-size: 24rpx;
  color: #666666;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #F5F5F0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E8E8E8;
  border-top-color: #2E8B57;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

/* ==================== 农残检测可视化增强样式 ==================== */

/* 异常卡片样式 */
.test-module-card {
  transition: all 0.3s ease;
}

.test-abnormal-card {
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 30%);
  border: 2rpx solid rgba(255, 77, 79, 0.2);
}

.title-badge.danger {
  background: linear-gradient(135deg, #FF4D4F, #FF7875);
}

/* 异常警告横幅 */
.abnormal-warning-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF2F0, #FFF5F5);
  border: 2rpx solid #FFCCC7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.warning-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.warning-content {
  flex: 1;
}

.warning-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF4D4F;
  margin-bottom: 6rpx;
}

.warning-desc {
  font-size: 24rpx;
  color: #FF7875;
}

/* 检测机构报告编号可点击 */
.institution-meta text:first-child {
  cursor: pointer;
}

/* 操作按钮组 */
.test-action-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 12rpx;
  background: linear-gradient(135deg, #F8FFF8, #F5F5F0);
  border: 1rpx solid #E8E8E8;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #E8F5E9, #F0F0E8);
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

/* 国标对比总览 */
.standard-overview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #F6FFED, #FFFFFF);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #B7EB8F;
}

.overview-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.overview-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.overview-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.overview-badge.pass {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.overview-badge.fail {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

/* 进度条图表 */
.progress-chart {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 8rpx;
}

.progress-item {
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s ease;
}

.progress-item:last-child {
  margin-bottom: 0;
}

.progress-item.danger {
  background: linear-gradient(135deg, #FFF2F0, #FFFFFF);
  border: 1rpx solid #FFCCC7;
}

.progress-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.progress-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.progress-status.pass {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.progress-status.fail {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.progress-bar-container {
  position: relative;
}

.progress-bar-bg {
  position: relative;
  height: 24rpx;
  background: #F0F0F0;
  border-radius: 12rpx;
  overflow: visible;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.6s ease;
}

.progress-bar-fill.excellent {
  background: linear-gradient(90deg, #52C41A, #95DE64);
}

.progress-bar-fill.good {
  background: linear-gradient(90deg, #52C41A, #73D13D);
}

.progress-bar-fill.warning {
  background: linear-gradient(90deg, #FAAD14, #FFC53D);
}

.progress-bar-fill.danger {
  background: linear-gradient(90deg, #FF4D4F, #FF7875);
  animation: dangerPulse 1.5s ease-in-out infinite;
}

@keyframes dangerPulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(255, 77, 79, 0.4);
  }
  50% {
    box-shadow: 0 0 0 8rpx rgba(255, 77, 79, 0);
  }
}

.progress-limit-line {
  position: absolute;
  top: -4rpx;
  width: 3rpx;
  height: 32rpx;
  background: #FF4D4F;
  border-radius: 2rpx;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.progress-value {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: 500;
}

.progress-limit {
  font-size: 24rpx;
  color: #999999;
}

.progress-multiple {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.multiple-label {
  font-size: 22rpx;
  color: #999999;
  margin-right: 8rpx;
}

.multiple-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #52C41A;
}

/* 异常说明 */
.abnormal-desc {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(255, 77, 79, 0.06);
  border-radius: 12rpx;
  border-left: 4rpx solid #FF4D4F;
}

.desc-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.desc-text {
  font-size: 24rpx;
  color: #FF4D4F;
  line-height: 1.5;
}

/* 国标提示 - 异常样式 */
.standard-tip.danger {
  background: rgba(255, 77, 79, 0.1);
}

.standard-tip.danger .tip-text {
  color: #FF4D4F;
}

/* 历史报告时间轴 */
.history-reports-section {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #FAFAFA, #FFFFFF);
  border-radius: 16rpx;
  overflow: hidden;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  cursor: pointer;
  transition: background 0.2s ease;
}

.history-header:active {
  background: rgba(0, 0, 0, 0.02);
}

.history-title {
  display: flex;
  align-items: center;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.history-title text:nth-child(2) {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 12rpx;
}

.history-count {
  font-size: 22rpx;
  color: #999999;
  background: #F0F0F0;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.history-toggle {
  font-size: 28rpx;
  color: #999999;
  transition: transform 0.3s ease;
}

.history-toggle.expanded {
  transform: rotate(180deg);
}

.history-timeline {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
  padding: 0 24rpx;
}

.history-timeline.show {
  max-height: 2000rpx;
  padding: 0 24rpx 24rpx;
}

.timeline-item {
  position: relative;
  padding-left: 40rpx;
  padding-bottom: 32rpx;
  cursor: pointer;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item.latest .timeline-content {
  background: linear-gradient(135deg, #F6FFED, #FFFFFF);
  border: 1rpx solid #B7EB8F;
}

.timeline-item.abnormal .timeline-content {
  background: linear-gradient(135deg, #FFF2F0, #FFFFFF);
  border: 1rpx solid #FFCCC7;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 20rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  z-index: 2;
}

.timeline-dot.excellent {
  background: #52C41A;
  box-shadow: 0 0 0 6rpx rgba(82, 196, 26, 0.15);
}

.timeline-dot.good {
  background: #73D13D;
  box-shadow: 0 0 0 6rpx rgba(115, 209, 61, 0.15);
}

.timeline-dot.danger {
  background: #FF4D4F;
  box-shadow: 0 0 0 6rpx rgba(255, 77, 79, 0.15);
  animation: dangerPulse 2s ease-in-out infinite;
}

.timeline-line {
  position: absolute;
  left: 9rpx;
  top: 44rpx;
  width: 2rpx;
  height: calc(100% - 24rpx);
  background: linear-gradient(180deg, #D9D9D9, #F0F0F0);
  z-index: 1;
}

.timeline-content {
  position: relative;
  background: #FFFFFF;
  border: 1rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  transition: all 0.2s ease;
}

.timeline-content:active {
  transform: scale(0.98);
}

.timeline-date {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.timeline-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.timeline-report-no {
  font-size: 24rpx;
  color: #666666;
  font-family: monospace;
}

.timeline-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.timeline-status.excellent {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.timeline-status.good {
  background: rgba(115, 209, 61, 0.1);
  color: #73D13D;
}

.timeline-status.danger {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.timeline-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.timeline-meta text {
  font-size: 22rpx;
  color: #999999;
}

.timeline-tag {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #52C41A, #73D13D);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* PDF 报告异常样式 */
.pdf-header.danger-header {
  background: linear-gradient(135deg, #FF4D4F, #FF7875);
}

.pdf-abnormal-warning {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: rgba(255, 77, 79, 0.08);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.pdf-warning-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.pdf-warning-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.pdf-result-item.abnormal-item {
  background: rgba(255, 77, 79, 0.06);
  border-radius: 8rpx;
}

.pdf-result-tag {
  font-weight: 500;
}

.pdf-fail {
  color: #FF4D4F;
  font-weight: 600;
}

.pdf-stamp.pdf-stamp-danger {
  border-color: #FF4D4F;
  color: #FF4D4F;
}

/* PDF 操作按钮 */
.pdf-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.pdf-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #F8FFF8, #F5F5F0);
  border: 1rpx solid #E8E8E8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  transition: all 0.2s ease;
}

.pdf-action-btn:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #E8F5E9, #F0F0E8);
}

/* 报告验真弹窗 */
.verify-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.verify-modal.show {
  opacity: 1;
  visibility: visible;
}

.verify-content {
  width: 90%;
  max-width: 650rpx;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.verify-modal.show .verify-content {
  transform: scale(1);
}

.verify-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
}

.verify-title {
  font-size: 32rpx;
  font-weight: 600;
}

.verify-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.verify-body {
  padding: 32rpx;
  max-height: calc(85vh - 120rpx);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.verify-input-section {
  margin-bottom: 24rpx;
}

.verify-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}

.verify-input-wrapper {
  background: #FAFAFA;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 4rpx 20rpx;
  transition: all 0.2s ease;
}

.verify-input-wrapper:focus-within {
  border-color: #2E8B57;
  background: #FFFFFF;
}

.verify-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #333333;
}

.verify-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.verify-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.verify-btn:active {
  transform: scale(0.96);
}

.verify-btn.primary {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
}

.verify-btn.secondary {
  background: linear-gradient(135deg, #F5F5F0, #EDEDE5);
  color: #666666;
  border: 1rpx solid #E8E8E8;
}

/* 验真结果 */
.verify-result {
  margin-top: 8rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  overflow: hidden;
}

.verify-result-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  gap: 12rpx;
}

.verify-result-header.valid {
  background: linear-gradient(135deg, #F6FFED, #FFFFFF);
  border-bottom: 1rpx solid #B7EB8F;
}

.verify-result-header.invalid {
  background: linear-gradient(135deg, #FFF2F0, #FFFFFF);
  border-bottom: 1rpx solid #FFCCC7;
}

.verify-result-icon {
  font-size: 40rpx;
}

.verify-result-title {
  font-size: 32rpx;
  font-weight: 600;
}

.verify-result-header.valid .verify-result-title {
  color: #52C41A;
}

.verify-result-header.invalid .verify-result-title {
  color: #FF4D4F;
}

.verify-result-body {
  padding: 24rpx;
}

.invalid-body {
  text-align: center;
}

.verify-invalid-msg {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.verify-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx dashed #F0F0F0;
}

.verify-row:last-child {
  border-bottom: none;
}

.verify-row-label {
  font-size: 26rpx;
  color: #999999;
}

.verify-row-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  max-width: 360rpx;
  text-align: right;
  word-break: break-all;
}

.verify-row-value.danger-text {
  color: #FF4D4F;
}

.verify-tip {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(46, 139, 87, 0.06);
  border-radius: 12rpx;
}

.verify-tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.verify-tip-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* ==================== 窨制工艺深化功能样式 ==================== */

/* 工艺模块 Tab 导航 */
.process-tab-bar {
  display: flex;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.process-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.process-tab-item.active {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.3);
}

.process-tab-item.active .tab-icon,
.process-tab-item.active .tab-label {
  color: #FFFFFF;
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
}

.process-tab-content {
  animation: fadeInUp 0.3s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 窨制记录标题 */
.records-title,
.timeline-section-title,
.comparison-section-title,
.media-section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.records-title-icon,
.timeline-title-icon,
.comparison-title-icon,
.media-title-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.records-title-text,
.timeline-title-text,
.comparison-title-text,
.media-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

/* 窨制记录时间轴 */
.scenting-records-timeline {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
  position: relative;
}

.record-timeline-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
}

.record-round-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #E0E0E0;
  transition: all 0.3s ease;
  z-index: 2;
}

.record-timeline-item.active .record-round-badge {
  background: linear-gradient(135deg, #DAA520, #F0C75E);
  border-color: #DAA520;
  box-shadow: 0 0 0 8rpx rgba(218, 165, 32, 0.15);
  transform: scale(1.1);
}

.round-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #999999;
}

.record-timeline-item.active .round-num {
  color: #FFFFFF;
}

.record-line {
  position: absolute;
  top: 32rpx;
  left: 50%;
  width: 100%;
  height: 4rpx;
  background: linear-gradient(90deg, #E0E0E0, #F0F0F0);
  z-index: 1;
}

/* 窨制记录详情卡片 */
.record-detail-card {
  background: linear-gradient(135deg, #FFFEF5, #FFFDF0);
  border: 2rpx solid rgba(218, 165, 32, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  animation: cardSlideIn 0.3s ease;
}

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.record-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed rgba(218, 165, 32, 0.3);
}

.record-round-tag {
  background: linear-gradient(135deg, #DAA520, #F0C75E);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.record-note {
  font-size: 24rpx;
  color: #DAA520;
  font-weight: 500;
}

.record-detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.record-detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
}

.detail-item-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.detail-item-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.detail-item-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.record-detail-footer {
  text-align: center;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(218, 165, 32, 0.2);
}

.record-timestamp {
  font-size: 22rpx;
  color: #999999;
}

/* 工艺多媒体展示 */
.process-media-section {
  margin-top: 24rpx;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.media-item {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  aspect-ratio: 1;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.media-item:active {
  transform: scale(0.96);
}

.media-image {
  width: 100%;
  height: 100%;
  display: block;
}

.media-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 20rpx 12rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.media-step-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.media-step-name {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 横向时间轴动画 */
.timeline-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #F8FFF8, #F5F5F0);
  border-radius: 16rpx;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: #FFFFFF;
  border-radius: 50%;
  border: 2rpx solid #E8E8E8;
  font-size: 28rpx;
  transition: all 0.2s ease;
  cursor: pointer;
}

.control-btn:active {
  transform: scale(0.92);
  background: #F5F5F5;
}

.control-btn.primary {
  width: auto;
  padding: 0 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-color: transparent;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  gap: 8rpx;
}

.control-btn.speed-btn {
  flex-direction: column;
  width: auto;
  padding: 8rpx 16rpx;
  height: auto;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.speed-label {
  font-size: 18rpx;
  color: #666666;
  margin-top: 2rpx;
}

/* 横向时间轴 */
.horizontal-timeline {
  margin-bottom: 24rpx;
  padding: 20rpx 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.timeline-track {
  display: flex;
  align-items: flex-start;
  min-width: max-content;
  padding: 0 40rpx;
  position: relative;
}

.timeline-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 0 24rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.timeline-step-dot {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F0F0F0;
  border: 4rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transition: all 0.3s ease;
}

.timeline-step.completed .timeline-step-dot {
  background: linear-gradient(135deg, #52C41A, #95DE64);
  border-color: #52C41A;
}

.timeline-step.active .timeline-step-dot {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-color: #2E8B57;
  box-shadow: 0 0 0 12rpx rgba(46, 139, 87, 0.15);
  transform: scale(1.15);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 12rpx rgba(46, 139, 87, 0.15);
  }
  50% {
    box-shadow: 0 0 0 20rpx rgba(46, 139, 87, 0.05);
  }
}

.step-dot-icon {
  font-size: 36rpx;
}

.timeline-step.completed .step-dot-icon,
.timeline-step.active .step-dot-icon {
  filter: brightness(0) invert(1);
}

.timeline-step-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999999;
  font-weight: 500;
  white-space: nowrap;
  transition: color 0.3s ease;
}

.timeline-step.completed .timeline-step-label,
.timeline-step.active .timeline-step-label {
  color: #2E8B57;
  font-weight: 600;
}

.timeline-connector {
  position: absolute;
  top: 40rpx;
  left: calc(50% + 40rpx);
  width: calc(100% - 80rpx);
  height: 6rpx;
  background: #E0E0E0;
  z-index: 1;
  transition: background 0.3s ease;
}

.timeline-step.completed .timeline-connector {
  background: linear-gradient(90deg, #52C41A, #95DE64);
}

/* 时间轴步骤详情卡片 */
.timeline-step-detail {
  display: flex;
  align-items: stretch;
  background: linear-gradient(135deg, #F8FFF8, #FFFFFF);
  border: 2rpx solid rgba(46, 139, 87, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  animation: detailSlideIn 0.4s ease;
  gap: 20rpx;
}

@keyframes detailSlideIn {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.timeline-detail-icon {
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.timeline-detail-content {
  flex: 1;
  min-width: 0;
}

.timeline-detail-step {
  display: flex;
  flex-direction: column;
  margin-bottom: 8rpx;
}

.step-number {
  font-size: 22rpx;
  color: #2E8B57;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.step-name-large {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.timeline-detail-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

.timeline-detail-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  cursor: pointer;
  transition: transform 0.2s ease;
}

.timeline-detail-image:active {
  transform: scale(0.96);
}

.timeline-tip {
  display: flex;
  align-items: center;
  background: rgba(46, 139, 87, 0.06);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.timeline-tip .tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.timeline-tip .tip-text {
  font-size: 22rpx;
  color: #666666;
  line-height: 1.5;
}

/* 工艺对比模块 */
.comparison-overview {
  display: flex;
  align-items: stretch;
  background: linear-gradient(135deg, #FFF8E1, #FFFEF5);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.comparison-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.comparison-col.golden {
  background: linear-gradient(135deg, rgba(218, 165, 32, 0.1), rgba(255, 255, 255, 0.8));
  border-radius: 16rpx;
  padding: 16rpx;
}

.comparison-col.silver {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.1), rgba(255, 255, 255, 0.8));
  border-radius: 16rpx;
  padding: 16rpx;
}

.col-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.col-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.col-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.col-stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 10rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #DAA520;
}

.comparison-col.silver .stat-value {
  color: #666666;
}

.stat-label {
  font-size: 20rpx;
  color: #999999;
  margin-top: 2rpx;
}

.comparison-vs {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #DAA520;
  background: #FFFFFF;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  align-self: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 对比表格 */
.comparison-table {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 1rpx solid #E8E8E8;
}

.comparison-table-header {
  display: flex;
  background: linear-gradient(135deg, #F5F5F0, #F0F0E8);
}

.table-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  text-align: center;
  font-size: 24rpx;
}

.header-cell {
  font-weight: 600;
  color: #333333;
}

.header-cell.golden {
  background: linear-gradient(135deg, rgba(218, 165, 32, 0.15), rgba(218, 165, 32, 0.05));
  color: #DAA520;
}

.header-cell.silver {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.15), rgba(192, 192, 192, 0.05));
  color: #666666;
}

.comparison-table-row {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
  transition: background 0.2s ease;
}

