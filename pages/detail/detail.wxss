}

.bc-info-icon {
  font-size: 20rpx;
}

.bc-info-text {
  font-size: 20rpx;
  color: #777777;
  font-family: monospace;
}

.version-history-footer {
  flex-shrink: 0;
  padding: 20rpx 32rpx 28rpx;
  border-top: 2rpx solid #F0F0F0;
}

.version-history-cancel-btn {
  width: 100%;
  padding: 22rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border-radius: 48rpx;
}

.version-history-back-btn {
  width: 100%;
  padding: 22rpx;
  background: linear-gradient(135deg, #DAA520 0%, #B8860B 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  border-radius: 48rpx;
  box-shadow: 0 6rpx 20rpx rgba(218, 165, 32, 0.3);
}

/* ==================== 农残检测时间轴版本关联 ==================== */
.timeline-version-link {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  background: #F0FAF3;
