  transition: background 0.2s ease;
}

.history-header:active {
  background: rgba(0, 0, 0, 0.02);
}

.history-title {
  display: flex;
  align-items: center;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.history-title text:nth-child(2) {
  font-size: 28rpx;
