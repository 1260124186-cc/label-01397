}

/* ---- Scenic Swiper (照片轮播) ---- */
.scenic-swiper-section {
  margin-bottom: 28rpx;
}

.scenic-swiper {
  width: 100%;
  height: 380rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(20, 50, 20, 0.12);
}

.swiper-slide-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.scenic-image {
  width: 100%;
  height: 100%;
  display: block;
}

.scenic-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 60rpx 24rpx 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.25) 55%, transparent 100%);
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.caption-type-tag {
  flex-shrink: 0;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #2E8B57;
  border-radius: 8rpx;
  font-weight: 600;
}

.caption-text {
  flex: 1;
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.5);
  line-height: 1.4;
}

.swiper-counter {
  margin-top: 14rpx;
  text-align: right;
  font-size: 22rpx;
  color: #8AA08A;
  font-weight: 500;
}

/* ---- Map Component ---- */
.map-section {
  margin-bottom: 28rpx;
}

.trace-map {
  width: 100%;
  height: 440rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #E0E8E0;
  box-shadow: 0 6rpx 20rpx rgba(20, 50, 20, 0.1);
}

.map-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  background: #F5FAF5;
  border-radius: 14rpx;
  border: 1rpx solid #E0EBE0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #4A5E4A;
  font-weight: 500;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.legend-dot.legend-tea {
  background: #2E8B57;
  box-shadow: 0 0 0 3rpx rgba(46, 139, 87, 0.18);
}

.legend-dot.legend-osm {
  background: #DAA520;
  box-shadow: 0 0 0 3rpx rgba(218, 165, 32, 0.18);
}

.legend-dot.legend-fac {
  background: #5D6D7E;
  box-shadow: 0 0 0 3rpx rgba(93, 109, 126, 0.18);
}

/* ---- Weather Section (采摘天气) ---- */
.weather-section {
  margin-bottom: 8rpx;
}

.weather-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.weather-card {
  background: #FFFFFF;
  border: 1rpx solid #E0E8E0;
  border-radius: 20rpx;
  padding: 22rpx 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(20, 50, 20, 0.06);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease;
}

.weather-card:active {
  transform: scale(0.975);
}

.weather-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding-bottom: 14rpx;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid #E0E8E0;
}

.weather-title-icon {
  font-size: 28rpx;
}

.weather-card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1F3A1F;
}

.weather-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.weather-icon-big {
  font-size: 54rpx;
  line-height: 1;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.weather-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.weather-temp {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F3A1F;
  letter-spacing: -0.5rpx;
}

.weather-desc {
  font-size: 22rpx;
  color: #667766;
  font-weight: 500;
}

.weather-meta-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.meta-chip {
  flex: 1;
  font-size: 20rpx;
  text-align: center;
  padding: 8rpx 4rpx;
  background: #F3F8F3;
  border-radius: 8rpx;
  color: #526852;
  font-weight: 500;
}

.weather-footer {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #E8F0E8;
}

.weather-date,
.weather-location {
  font-size: 20rpx;
  color: #8AA08A;
  line-height: 1.3;
}

.weather-quality-bar {
  position: absolute;
  top: 0;
  right: 0;
  padding: 8rpx 14rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-bottom-left-radius: 16rpx;
}

.weather-card:nth-child(2) .weather-quality-bar {
  background: linear-gradient(135deg, #DAA520 0%, #E8C256 100%);
}

.air-quality {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.weather-note {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 18rpx 22rpx;
  background: #FFF8E7;
  border-radius: 14rpx;
  border: 1rpx solid #F3E3BE;
}

.note-icon {
  font-size: 26rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.note-text {
  flex: 1;
  font-size: 24rpx;
  color: #8B6914;
  line-height: 1.7;
}

/* ===================================================== */
/*  ===== 地图标记弹窗 · Map Callout Modal =====         */
/* ===================================================== */

.map-callout-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 36rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.map-callout-modal.show {
  opacity: 1;
  visibility: visible;
}

.map-callout-content {
  width: 100%;
  max-height: 88vh;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  transform: translateY(60rpx) scale(0.95);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.3);
}

.map-callout-modal.show .map-callout-content {
  transform: translateY(0) scale(1);
}

.callout-header {
  position: relative;
  padding: 36rpx 36rpx 32rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.callout-icon-box {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(6rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  flex-shrink: 0;
}

.callout-big-icon {
  font-size: 48rpx;
}

.callout-title-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.callout-title {
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
}

.callout-type-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.callout-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 48rpx;
  line-height: 1;
  opacity: 0.85;
  z-index: 3;
}

.callout-body {
  padding: 28rpx 36rpx 36rpx;
  max-height: calc(88vh - 200rpx);
  overflow-y: auto;
}

.callout-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.callout-image-item {
  width: 100%;
  padding-top: 100%;
  position: relative;
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid #E8F0E8;
  box-shadow: 0 2rpx 8rpx rgba(20, 50, 20, 0.08);
  transition: transform 0.2s ease;
}

.callout-image-item:active {
  transform: scale(0.96);
}

.callout-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.callout-desc {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx dashed #E8F0E8;
}

.callout-desc:last-of-type {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.desc-label {
  font-size: 22rpx;
  color: #8AA08A;
  font-weight: 500;
}

.desc-value {
  font-size: 26rpx;
  color: #2F4F2F;
  line-height: 1.7;
}

.callout-action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #E8F0E8;
}

.callout-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.callout-btn.primary {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(46, 139, 87, 0.3);
}

.callout-btn.primary:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 10rpx rgba(46, 139, 87, 0.3);
}

.callout-btn.secondary {
  background: #F3F8F3;
  color: #526852;
  border: 1rpx solid #D0E0D0;
}

.callout-btn.secondary:active {
  transform: scale(0.97);
  background: #E8F0E8;
}

/* ===================================================== */
/*  ===== 品种差异化样式 · Variety Styles =====          */
/* ===================================================== */

/* ---- 金桂 ---- */
.variety-badge.variety-jin-gui {
  background: linear-gradient(135deg, #DAA520 0%, #E8C256 100%) !important;
  border: 2rpx solid #C49518 !important;
  color: #FFFFFF !important;
  box-shadow: 0 3rpx 10rpx rgba(218, 165, 32, 0.35) !important;
}

.variety-icon-jin-gui {
  background: linear-gradient(135deg, #FFF4D6 0%, #FFE7A3 100%) !important;
  border: 3rpx solid #E8C256 !important;
}

.variety-icon-jin-gui text {
  color: #B8860B !important;
}

/* ---- 银桂 ---- */
.variety-badge.variety-yin-gui {
  background: linear-gradient(135deg, #A8B5B0 0%, #D5DBD9 100%) !important;
  border: 2rpx solid #8A9995 !important;
  color: #FFFFFF !important;
  box-shadow: 0 3rpx 10rpx rgba(168, 181, 176, 0.35) !important;
}

.variety-icon-yin-gui {
  background: linear-gradient(135deg, #F0F3F2 0%, #DCE4E2 100%) !important;
  border: 3rpx solid #C0C8C6 !important;
}

.variety-icon-yin-gui text {
  color: #70807D !important;
}

/* ---- 丹桂 ---- */
.variety-badge.variety-dan-gui {
  background: linear-gradient(135deg, #CD5C5C 0%, #E88B8B 100%) !important;
  border: 2rpx solid #B04040 !important;
  color: #FFFFFF !important;
  box-shadow: 0 3rpx 10rpx rgba(205, 92, 92, 0.35) !important;
}

.variety-icon-dan-gui {
  background: linear-gradient(135deg, #FFE8E8 0%, #FFD0D0 100%) !important;
  border: 3rpx solid #E88B8B !important;
}

.variety-icon-dan-gui text {
  color: #A52A2A !important;
}

/* ---- 四季桂 ---- */
.variety-badge.variety-si-ji-gui {
  background: linear-gradient(135deg, #6B8E23 0%, #90C040 100%) !important;
  border: 2rpx solid #556B2F !important;
  color: #FFFFFF !important;
  box-shadow: 0 3rpx 10rpx rgba(107, 142, 35, 0.35) !important;
}

.variety-icon-si-ji-gui {
  background: linear-gradient(135deg, #EFF8DE 0%, #DCF2B5 100%) !important;
  border: 3rpx solid #90C040 !important;
}

.variety-icon-si-ji-gui text {
  color: #556B2F !important;
}

/* ---- 品种描述 (品种 Badge 下方) ---- */
.variety-description {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  background: #FFFDF5;
  border: 1rpx solid #F3E3BE;
  border-radius: 14rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.variety-description .desc-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.variety-description text:last-child {
  font-size: 24rpx;
  color: #8B6914;
  line-height: 1.75;
  flex: 1;
}

/* ============================================================
   分享与社交传播模块样式
   ============================================================ */

.share-social-card {
  background: linear-gradient(180deg, #FAFFFD 0%, #F5F9F0 100%);
  border-top: 8rpx solid #2E8B57;
}

.share-activity-tip {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(90deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
  border: 2rpx dashed #DAA520;
}

.share-activity-tip .tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.share-activity-tip .tip-text {
  font-size: 26rpx;
  color: #8B6914;
  font-weight: 500;
  line-height: 1.5;
  flex: 1;
}

.share-stats-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 139, 87, 0.08);
}

.share-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.share-stat-item .stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #2E8B57;
  line-height: 1.2;
}

.share-stat-item .stat-label {
  font-size: 22rpx;
  color: #888888;
  margin-top: 8rpx;
}

.share-stat-divider {
  width: 2rpx;
  height: 70rpx;
  background: linear-gradient(180deg, transparent 0%, #E8E8E8 50%, transparent 100%);
}

.share-action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.share-action-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.share-action-card:active {
  transform: scale(0.96);
  border-color: #2E8B57;
}

.action-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
}

.action-icon-wrap .action-icon {
  font-size: 44rpx;
}

.share-action-card .action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.share-action-card .action-desc {
  font-size: 22rpx;
  color: #999999;
}

.share-rules-box {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #2E8B57;
}

.share-rules-box .rules-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-item .rule-num {
  width: 40rpx;
  height: 40rpx;
  background: #2E8B57;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 2rpx;
  font-weight: 600;
}

.rule-item .rule-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.7;
  flex: 1;
}

.invitees-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.invitees-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F0F0F0;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.invitees-title .invitees-count {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: normal;
}

.invitee-item {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #F8F8F8;
}

.invitee-item:last-child {
  border-bottom: none;
}

.invitee-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.invitee-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.invitee-info .invitee-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.invitee-info .invitee-trace {
  font-size: 22rpx;
  color: #999999;
}

.invitee-status .status-done {
  font-size: 24rpx;
  color: #2E8B57;
  background: #E8F5E9;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.invitee-status .status-pending {
  font-size: 24rpx;
  color: #DAA520;
  background: #FFF8E1;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* ============================================================
   分享弹窗样式
   ============================================================ */

.share-modal,
.reward-modal {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  z-index: 9999;
  display: none;
  align-items: center;
  justify-content: center;
}

.share-modal.show,
.reward-modal.show {
  display: flex;
}

.share-modal-content,
.reward-modal-content {
  width: 680rpx;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.cert-content {
  width: 720rpx;
}

.share-modal-header,
.cert-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #F0F0F0;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
}

.cert-header {
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
}

.share-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.share-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 44rpx;
  line-height: 1;
  opacity: 0.9;
}

.share-modal-body {
  padding: 32rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cert-body {
  padding: 24rpx;
}

.share-preview-area,
.cert-preview-area {
  position: relative;
  background: #FAFAFA;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
}

.cert-preview-area {
  min-height: 1100rpx;
}

.share-card-canvas {
  position: absolute;
  left: -9999rpx;
  top: 0;
  opacity: 0;
  pointer-events: none;
}

.cert-canvas {
  position: absolute;
  left: -9999rpx;
  top: 0;
  opacity: 0;
  pointer-events: none;
}

.share-preview-image {
  width: 100%;
  height: 100%;
  max-height: 600rpx;
}

.cert-preview-image {
  width: 100%;
  display: block;
}

.share-loading-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.share-loading-mask text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #666666;
}

.cert-scroll {
  max-height: 65vh;
  border-radius: 16rpx;
  overflow: hidden;
}

.share-tip-text {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.share-modal-footer {
  display: flex;
  padding: 24rpx 32rpx 36rpx;
  gap: 24rpx;
  border-top: 1rpx solid #F5F5F5;
  background: #FAFAFA;
}

.share-footer-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.share-footer-btn.secondary {
  background: #FFFFFF;
  color: #666666;
  border: 2rpx solid #E0E0E0;
}

.share-footer-btn.primary {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.35);
}

.share-footer-btn.primary.gold {
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
  box-shadow: 0 8rpx 24rpx rgba(218, 165, 32, 0.35);
  color: #5D4E00;
}

.share-footer-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.loading-spinner.small {
  width: 60rpx;
  height: 60rpx;
  border-width: 4rpx;
}

/* ============================================================
   奖励弹窗样式
   ============================================================ */

.reward-modal-content {
  width: 640rpx;
  background: linear-gradient(180deg, #FFF8E1 0%, #FFFFFF 40%);
}

.reward-celebration {
  padding: 48rpx 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.celebration-icon {
  font-size: 100rpx;
  animation: bounce 1s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.celebration-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #DAA520;
  margin-top: 20rpx;
}

.reward-list {
  padding: 20rpx 32rpx;
}

.reward-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.reward-item.inviter-reward {
  border: 2rpx solid #E8F5E9;
}

.reward-item.invitee-reward {
  border: 2rpx solid #FFF3E0;
}

.reward-role {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed #E8E8E8;
}

.inviter-reward .reward-role {
  color: #2E8B57;
}

.invitee-reward .reward-role {
  color: #E65100;
}

.reward-detail {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.reward-detail + .reward-detail {
  border-top: 1rpx solid #F5F5F5;
}

.reward-detail .reward-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.reward-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.reward-name {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 6rpx;
}

.reward-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #DAA520;
}

.inviter-reward .reward-value {
  color: #2E8B57;
}

.reward-actions {
  display: flex;
  flex-direction: column;
  padding: 12rpx 32rpx 40rpx;
  gap: 16rpx;
}

.reward-action-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.reward-action-btn.primary {
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
  color: #5D4E00;
  box-shadow: 0 8rpx 24rpx rgba(218, 165, 32, 0.35);
}

.reward-action-btn.secondary {
  background: #FFFFFF;
  color: #2E8B57;
  border: 2rpx solid #2E8B57;
}

.reward-action-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}
