}

.maint-photos {
  font-size: 22rpx;
  color: #2E8B57;
  font-weight: 500;
}

/* ===================================================== */
/*  ===== 产地地理信息 · Location Section =====          */
/* ===================================================== */

.location-card .title-badge {
  margin-left: 12rpx;
