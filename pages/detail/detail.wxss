  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.interactive-section .section-sub-title .sub-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* ==================== 冲泡计时器样式 ==================== */
.timer-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.water-temp-selector {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.temp-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.temp-item.active {
  background: linear-gradient(135deg, #FFF8E1, #FFFEF5);
  border-color: #DAA520;
  transform: scale(1.02);
}

.temp-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.temp-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.temp-desc {
  font-size: 20rpx;
  color: #999999;
}

.temp-item.active .temp-label {
  color: #DAA520;
}

.timer-display {
  margin: 20rpx 0;
}

.timer-circle {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: conic-gradient(#DAA520 calc(var(--progress, 0) * 1%), #E8E8E8 0);
  display: flex;
  align-items: center;
  justify-content: center;
}

.timer-circle::before {
  content: '';
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.timer-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timer-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #DAA520;
  font-family: 'DIN Alternate', sans-serif;
  letter-spacing: 2rpx;
}

.timer-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.timer-controls {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.control-btn {
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.control-btn.reset-btn {
  background: #F5F5F5;
  color: #666666;
}

.control-btn.primary-btn {
  background: linear-gradient(135deg, #FFD700 0%, #DAA520 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(218, 165, 32, 0.3);
}

.control-btn.primary-btn:active {
  transform: scale(0.96);
}

/* ==================== 分步冲泡向导样式 ==================== */
.brew-guide-container {
  display: flex;
  flex-direction: column;
}

.brew-step-nav {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.step-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-nav-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E8E8E8;
  color: #999999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  z-index: 1;
  transition: all 0.3s ease;
}

.step-nav-item.active .step-nav-dot {
  background: linear-gradient(135deg, #FFD700 0%, #DAA520 100%);
  color: #FFFFFF;
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(218, 165, 32, 0.4);
}

.step-nav-item.completed .step-nav-dot {
  background: #2E8B57;
  color: #FFFFFF;
}

.step-nav-name {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.step-nav-item.active .step-nav-name {
  color: #DAA520;
  font-weight: 600;
}

.step-nav-item.completed .step-nav-name {
  color: #2E8B57;
}

.step-nav-line {
  position: absolute;
  top: 28rpx;
  left: 60%;
  width: 80%;
  height: 4rpx;
  background: #E8E8E8;
  z-index: 0;
}

.step-nav-item.completed .step-nav-line {
  background: #2E8B57;
}

.brew-step-detail {
  background: linear-gradient(135deg, #FFFEF5 0%, #FFF8E1 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.step-detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.step-detail-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.step-detail-info {
  flex: 1;
}

.step-detail-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.step-detail-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.step-detail-content {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.step-detail-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-line;
}

.step-detail-tip {
  display: flex;
  align-items: flex-start;
  background: rgba(46, 139, 87, 0.1);
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
}

.tip-bulb {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.tip-content {
  font-size: 24rpx;
  color: #2E8B57;
  line-height: 1.5;
}

.step-timer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-top: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.step-timer-display {
  display: flex;
  flex-direction: column;
}

.step-timer-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.step-timer-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #DAA520;
  font-family: 'DIN Alternate', sans-serif;
}

.step-timer-controls {
  display: flex;
  gap: 12rpx;
}

.mini-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.mini-btn.primary {
  background: linear-gradient(135deg, #FFD700 0%, #DAA520 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(218, 165, 32, 0.3);
}

.mini-btn:active {
  transform: scale(0.9);
}

.brew-guide-controls {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.guide-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  transition: all 0.3s ease;
}

.guide-btn.prev-btn,
.guide-btn.restart-btn {
  background: #F5F5F5;
  color: #666666;
}

.guide-btn.next-btn {
  background: linear-gradient(135deg, #FFD700 0%, #DAA520 100%);
  color: #FFFFFF;
  font-weight: 600;
}

.guide-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.guide-btn:active {
  transform: scale(0.96);
}

/* ==================== 用量计算器样式 ==================== */
.dosage-container {
  display: flex;
