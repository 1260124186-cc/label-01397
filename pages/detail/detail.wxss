  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.bc-verify-result {
  margin-top: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #E8E8E8;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.bc-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
