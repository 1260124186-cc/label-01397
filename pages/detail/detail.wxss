.blockchain-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F8FF 100%);
}

.title-right,
.title-right-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: auto;
}

.bc-verified-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
