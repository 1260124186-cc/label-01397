}

.round-label {
  font-size: 28rpx;
  color: #636E72;
  font-weight: 500;
}

.round-controls {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.round-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 50%;
