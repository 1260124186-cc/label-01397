  padding: 12rpx 24rpx;
  border: 2rpx solid #DDDDDD;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.taste-tag-select.selected {
  color: #333333;
  font-weight: 500;
}

.tag-icon {
  font-size: 28rpx;
}

/* 文本域 */
.review-textarea,
.report-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  box-sizing: border-box;
  background: #FAFAFA;
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 图片上传 */
.image-upload-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.uploaded-image-item {
  position: relative;
  aspect-ratio: 1;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #F0F0F0;
}

.remove-image-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.add-image-btn {
  aspect-ratio: 1;
  border: 2rpx dashed #CCCCCC;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #999999;
}

.add-icon {
  font-size: 48rpx;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
}

/* 审核提示 */
.audit-tip,
.report-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx;
  background: #FFF9E6;
  border-radius: 12rpx;
  margin-top: 24rpx;
}

.audit-tip .tip-icon,
.report-tip .tip-icon {
  font-size: 28rpx;
}

.audit-tip .tip-text,
.report-tip .tip-text {
  font-size: 24rpx;
  color: #DAA520;
  line-height: 1.5;
  flex: 1;
}

.report-tip {
  background: #F0F7FF;
}

.report-tip .tip-text {
  color: #1890FF;
}

.review-modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #EEEEEE;
}

.review-submit-btn {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx;
  border-radius: 50rpx;
}

/* 举报弹窗 */
.report-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.report-modal.show {
  opacity: 1;
  visibility: visible;
}

.report-modal-content {
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.report-modal.show .report-modal-content {
  transform: scale(1);
}

.report-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.report-modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.report-modal-close {
  font-size: 44rpx;
  color: #999999;
  line-height: 1;
  padding: 8rpx;
}

.report-modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.report-reason-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.report-reason-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.report-reason-item.selected {
  border-color: #2E8B57;
  background: #F5F9F6;
}

.reason-radio {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-reason-item.selected .reason-radio {
  border-color: #2E8B57;
}

.radio-inner {
  width: 20rpx;
  height: 20rpx;
  background: #2E8B57;
  border-radius: 50%;
}

.reason-text {
  font-size: 26rpx;
  color: #333333;
}

.report-modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #EEEEEE;
}

.report-cancel-btn {
  flex: 1;
  background: #F5F5F5;
  color: #666666;
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx;
  border-radius: 40rpx;
}

.report-submit-btn {
  flex: 1;
  background: linear-gradient(135deg, #F44336 0%, #FF6B6B 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 20rpx;
  border-radius: 40rpx;
}

/* ==================== 礼盒/组合装模块样式 ==================== */

/* 子码归属提示卡片（金色主题） */
.subcode-giftbox-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx;
  margin: 24rpx 0 0;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFF2D6 100%);
  border: 2rpx solid #E8C872;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(218, 165, 32, 0.15);
}

.subcode-gb-icon {
  font-size: 56rpx;
  line-height: 1;
  flex-shrink: 0;
}

.subcode-gb-content {
  flex: 1;
  min-width: 0;
}

.subcode-gb-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #DAA520 0%, #B8860B 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.subcode-gb-text {
  font-size: 28rpx;
  color: #5A4A1F;
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.subcode-gb-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.subcode-gb-btn {
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1.4;
}

.subcode-gb-btn.primary {
  background: linear-gradient(135deg, #DAA520 0%, #B8860B 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(218, 165, 32, 0.3);
}

.subcode-gb-btn.primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.subcode-gb-btn.outline {
  background: #FFFFFF;
  color: #8B6914;
  border: 2rpx solid #DAA520;
}

.subcode-gb-btn.outline:active {
  background: #FFFAF0;
}

/* 礼盒概览卡片 */
.giftbox-overview-card {
  margin: 20rpx 0 0;
  padding: 28rpx;
  background: linear-gradient(135deg, #FFFBF2 0%, #FFF8E7 100%);
  border-radius: 16rpx;
  border: 1rpx solid #F0E0B0;
}

.giftbox-overview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  gap: 16rpx;
}

.giftbox-overview-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D2E0A;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.giftbox-overview-tag {
  padding: 6rpx 18rpx;
  background: linear-gradient(135deg, #DAA520 0%, #CD853F 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.giftbox-overview-desc {
  font-size: 26rpx;
  color: #6B5A30;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.giftbox-overview-specs {
  display: flex;
  gap: 32rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}

.giftbox-spec-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.giftbox-spec-label {
  font-size: 22rpx;
  color: #9B8A60;
}

.giftbox-spec-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #5A4A1F;
  font-family: 'Courier New', monospace;
}

.giftbox-highlights {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.giftbox-hl-tag {
  padding: 8rpx 20rpx;
  background: rgba(218, 165, 32, 0.12);
  color: #8B6914;
  font-size: 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(218, 165, 32, 0.25);
}

/* 子产品列表 */
.giftbox-items-list {
  margin: 24rpx 0 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.giftbox-item-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #F0ECE4;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
  position: relative;
}

.giftbox-item-card.current {
  border-color: #DAA520;
  background: linear-gradient(135deg, #FFFBF2 0%, #FFFFFF 100%);
  box-shadow: 0 4rpx 16rpx rgba(218, 165, 32, 0.12);
}

.giftbox-item-card:active {
  transform: scale(0.99);
  background: #FAFAF7;
}

.giftbox-item-index {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  min-width: 72rpx;
}

.giftbox-item-no {
  font-size: 24rpx;
  font-weight: 700;
  color: #DAA520;
  background: rgba(218, 165, 32, 0.12);
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  font-family: 'Courier New', monospace;
}

.giftbox-item-current-tag {
  font-size: 18rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #DAA520 0%, #B8860B 100%);
  padding: 3rpx 10rpx;
  border-radius: 10rpx;
  font-weight: 600;
}

.giftbox-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F7F4EE;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.giftbox-item-image image {
  width: 100%;
  height: 100%;
}

.giftbox-item-placeholder {
  font-size: 48rpx;
}

.giftbox-item-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.giftbox-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.giftbox-item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.giftbox-item-dot {
  color: #CCCCCC;
}

.giftbox-item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.giftbox-item-tag {
  padding: 4rpx 14rpx;
  background: #F2EFE8;
  color: #8B7355;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.giftbox-item-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.giftbox-item-card.current .giftbox-item-arrow {
  color: #DAA520;
}

/* 礼盒分享按钮 */
.giftbox-share-bar {
  margin: 28rpx 0 0;
  padding-top: 20rpx;
  border-top: 1rpx dashed #E8E0CC;
}

.giftbox-share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 22rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.25);
  transition: all 0.2s ease;
}

.giftbox-share-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.2);
}

.giftbox-share-icon {
  font-size: 32rpx;
}

/* 分享模式选择弹窗 */
.share-mode-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.share-mode-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0.8;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.share-mode-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  margin-bottom: 12rpx;
}

.share-mode-desc {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
  margin-bottom: 36rpx;
}

.share-mode-options {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.share-mode-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 36rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid #EEEEEE;
  background: #FAFAFA;
  transition: all 0.2s ease;
}

.share-mode-option:active {
  transform: scale(0.98);
}

.share-mode-option.whole {
  background: linear-gradient(135deg, #FFFBF2 0%, #FFF8E7 100%);
  border-color: #E8C872;
}

.share-mode-option.single {
  background: linear-gradient(135deg, #F2FBF6 0%, #F0FAF3 100%);
  border-color: #A8D8B8;
}

.share-mode-icon {
  font-size: 64rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.share-mode-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.share-mode-detail {
  font-size: 22rpx;
  color: #777777;
  text-align: center;
  line-height: 1.5;
}

.share-mode-cancel {
  display: block;
  width: 100%;
  padding: 26rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  border-radius: 48rpx;
}

.share-mode-cancel:active {
  background: #EAEAEA;
}

.giftbox-module-card {
  background: #FFFFFF;
}

/* ==================== 版本更新 Toast ==================== */
.version-update-toast {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 24rpx 32rpx 20rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
  box-shadow: 0 8rpx 32rpx rgba(46, 139, 87, 0.25);
  color: #FFFFFF;
  animation: toastSlideDown 0.4s ease;
}

@keyframes toastSlideDown {
  from { transform: translateY(-100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.toast-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.toast-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.toast-text {
  flex: 1;
  min-width: 0;
}

.toast-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.toast-desc {
  font-size: 22rpx;
  opacity: 0.9;
}

.toast-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.toast-action-text {
  font-size: 24rpx;
  font-weight: 600;
}

.toast-action-arrow {
  font-size: 28rpx;
}

.toast-close {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 16rpx);
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  opacity: 0.85;
}

/* ==================== 基础信息中的版本入口 ==================== */
.version-info-section {
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #F0FAF3 0%, #E8F5EC 100%);
  border: 2rpx solid #C8E6D4;
  border-radius: 20rpx;
  padding: 20rpx;
}

.version-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.version-info-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.version-icon {
  font-size: 36rpx;
}

.version-info-text {
  display: flex;
  flex-direction: column;
}

.version-label {
  font-size: 22rpx;
  color: #666666;
}

.version-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-top: 2rpx;
}

.version-info-right {
  flex-shrink: 0;
}

.version-history-link {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: 500;
}

.version-change-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 14rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
}

.change-btn-icon {
  font-size: 24rpx;
}

.change-btn-text {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: 500;
}

/* ==================== 区块链模块版本选择器 ==================== */
.bc-version-selector {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx dashed #E0E8E0;
}

.bc-version-scroll {
  width: 100%;
  white-space: nowrap;
}

.bc-version-tabs {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx;
}

.bc-version-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 22rpx;
  background: #F5F9F6;
  border: 2rpx solid #D8E8DC;
  border-radius: 14rpx;
  min-width: 120rpx;
  transition: all 0.2s ease;
}

.bc-version-tab.active {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  border-color: #2E8B57;
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.25);
}

.bc-version-tab-label {
  font-size: 20rpx;
  color: #666666;
  margin-bottom: 2rpx;
}

.bc-version-tab.active .bc-version-tab-label {
  color: rgba(255, 255, 255, 0.85);
}

.bc-version-tab-ver {
  font-size: 24rpx;
  font-weight: 700;
  color: #2E8B57;
}

.bc-version-tab.active .bc-version-tab-ver {
  color: #FFFFFF;
}

.bc-version-highlight {
  color: #2E8B57;
  font-weight: 700;
}

/* ==================== 变更详情弹窗 ==================== */
.changelog-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 10000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.changelog-modal.show {
  opacity: 1;
  visibility: visible;
}

.changelog-content {
  width: 100%;
  max-height: 82vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  padding-bottom: env(safe-area-inset-bottom);
}

.changelog-modal.show .changelog-content {
  transform: translateY(0);
}

.changelog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
