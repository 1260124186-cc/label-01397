  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.bc-section-icon {
  font-size: 30rpx;
}

.bc-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.bc-section-arrow {
  font-size: 28rpx;
  color: #999999;
  transition: transform 0.3s;
  transform: rotate(90deg);
