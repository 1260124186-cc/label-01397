}

.result-title {
  font-size: 26rpx;
  color: #999999;
}

.result-body {
  margin-bottom: 12rpx;
}

.result-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.result-grams {
  font-size: 64rpx;
  font-weight: 700;
  color: #DAA520;
  font-family: 'DIN Alternate', sans-serif;
}

.result-unit {
  font-size: 28rpx;
  color: #DAA520;
  margin-left: 8rpx;
}

.result-extra {
  margin-top: 4rpx;
}

.extra-info {
  font-size: 24rpx;
  color: #999999;
}

.result-footer {
  padding-top: 12rpx;
