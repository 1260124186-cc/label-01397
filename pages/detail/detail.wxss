/* ============================================================
   分享弹窗样式
   ============================================================ */

.share-modal,
.reward-modal {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  z-index: 9999;
  display: none;
  align-items: center;
  justify-content: center;
}

.share-modal.show,
.reward-modal.show {
  display: flex;
}

.share-modal-content,
.reward-modal-content {
  width: 680rpx;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.cert-content {
  width: 720rpx;
}

.share-modal-header,
.cert-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #F0F0F0;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
}

.cert-header {
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
}

.share-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.share-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 44rpx;
  line-height: 1;
  opacity: 0.9;
}

.share-modal-body {
  padding: 32rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cert-body {
  padding: 24rpx;
}

.share-preview-area,
.cert-preview-area {
  position: relative;
  background: #FAFAFA;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
}

.cert-preview-area {
  min-height: 1100rpx;
}

.share-card-canvas {
  position: absolute;
  left: -9999rpx;
  top: 0;
  opacity: 0;
  pointer-events: none;
}

.cert-canvas {
  position: absolute;
  left: -9999rpx;
  top: 0;
  opacity: 0;
  pointer-events: none;
}

.share-preview-image {
  width: 100%;
  height: 100%;
  max-height: 600rpx;
}

.cert-preview-image {
  width: 100%;
  display: block;
}

.share-loading-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.share-loading-mask text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #666666;
}

.cert-scroll {
  max-height: 65vh;
  border-radius: 16rpx;
  overflow: hidden;
}

.share-tip-text {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.share-modal-footer {
