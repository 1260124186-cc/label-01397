  align-items: center;
}

.hardness-label {
  font-size: 26rpx;
  color: #636E72;
}

.hardness-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2E8B57;
}

.hardness-detail {
  font-size: 24rpx;
  color: #636E72;
}

.brew-round-row {
