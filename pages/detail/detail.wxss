  border: 1rpx solid #2E8B57;
}

.bc-action-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.bc-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  position: relative;
}

.bc-btn-verify {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
}

.bc-btn-copy {
  background: #F8F9FA;
  color: #333333;
  border: 1rpx solid #E0E0E0;
}

.bc-btn-explorer {
  background: #F8F9FA;
  color: #333333;
  border: 1rpx solid #E0E0E0;
}

.bc-btn-icon {
