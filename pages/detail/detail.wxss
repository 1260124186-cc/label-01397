  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.bc-badge-icon {
  font-size: 20rpx;
  color: #2E8B57;
  font-weight: bold;
}

.bc-badge-text {
  font-size: 20rpx;
  color: #2E8B57;
