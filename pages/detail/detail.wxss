/* ==================== 历史版本列表弹窗 ==================== */
.version-history-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 10000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.version-history-modal.show {
  opacity: 1;
  visibility: visible;
}

.version-history-content {
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  padding-bottom: env(safe-area-inset-bottom);
}

.version-history-modal.show .version-history-content {
  transform: translateY(0);
}

.version-history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 2rpx solid #F0F0F0;
  flex-shrink: 0;
}

.version-history-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.version-history-title-icon {
  font-size: 40rpx;
}

.version-history-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.version-history-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999999;
}

.version-history-readonly-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 20rpx 32rpx 0;
  padding: 18rpx 22rpx;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFF2D6 100%);
  border: 2rpx solid #E8C872;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.readonly-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.readonly-text {
  flex: 1;
  font-size: 24rpx;
  color: #8B6914;
  font-weight: 500;
}

.back-current-btn {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, #DAA520 0%, #B8860B 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 24rpx;
}

.version-history-body {
  flex: 1;
  padding: 24rpx 32rpx 16rpx;
  overflow-y: auto;
}

.version-timeline {
  position: relative;
  padding-left: 12rpx;
}

.version-timeline-item {
  position: relative;
  padding-left: 40rpx;
  padding-bottom: 24rpx;
}

.version-timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 20rpx;
  width: 20rpx;
  height: 20rpx;
  background: #CCCCCC;
  border: 4rpx solid #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 0 0 2rpx #CCCCCC;
  z-index: 2;
}

.timeline-dot.latest {
  background: #2E8B57;
  box-shadow: 0 0 0 2rpx #2E8B57, 0 0 0 8rpx rgba(46, 139, 87, 0.15);
}

.version-timeline-item.selected .timeline-dot {
  background: #2E8B57;
  box-shadow: 0 0 0 2rpx #2E8B57, 0 0 0 10rpx rgba(46, 139, 87, 0.2);
}

.timeline-line {
  position: absolute;
  left: 9rpx;
  top: 44rpx;
  bottom: 0;
  width: 2rpx;
  background: #E0E0E0;
  z-index: 1;
}

.version-timeline-item.selected .timeline-line {
  background: #C8E6D4;
}

.version-item-card {
  background: #FAFBFA;
  border: 2rpx solid #E8EEE8;
  border-radius: 18rpx;
  padding: 20rpx;
  transition: all 0.2s ease;
}

.version-item-card.active {
  background: linear-gradient(135deg, #F0FAF3 0%, #F5FBF7 100%);
  border-color: #2E8B57;
  box-shadow: 0 4rpx 16rpx rgba(46, 139, 87, 0.18);
}

.version-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.version-card-badge {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 10rpx;
}

.version-card-badge.current {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
}

.version-card-badge.history {
  background: #F0F0F0;
  color: #666666;
}

.version-card-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.version-item-card.active .version-card-number {
  color: #2E8B57;
}

.version-card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 10rpx;
}

.version-card-summary {
  font-size: 24rpx;
  color: #444444;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.version-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.version-card-changes-count {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.count-icon {
  font-size: 22rpx;
}

.count-text {
  font-size: 22rpx;
  color: #666666;
}

.version-card-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
