/* ==================== 冲泡互动功能通用样式 ==================== */
.interactive-section {
  margin-top: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.interactive-section .section-sub-title {
  display: flex;
  align-items: center;
