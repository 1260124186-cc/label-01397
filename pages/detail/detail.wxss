}

.brewing-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.brewing-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #DAA520;
}

.brewing-extra {
  background: #FAFAFA;
