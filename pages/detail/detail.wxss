  background: #FFFFFF;
  border: 2rpx solid #D8E8DC;
  border-radius: 20rpx;
}

.version-card-action text {
  font-size: 22rpx;
  color: #2E8B57;
  font-weight: 500;
}

.action-arrow {
  font-size: 26rpx;
