/* ==================== 区块链存证详情 ==================== */
.blockchain-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F8FF 100%);
}

.blockchain-detail {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.blockchain-item {
  padding: 16rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.bc-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.bc-value {
  font-size: 26rpx;
  color: #333333;
  word-break: break-all;
}

.bc-value.hash {
  font-family: monospace;
  font-size: 24rpx;
  color: #2E8B57;
}

/* ==================== 返回顶部按钮 ==================== */
.back-top {
  position: fixed;
  right: 32rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.3s ease;
  z-index: 100;
}

.back-top.show {
  opacity: 1;
  transform: scale(1);
}

.back-top:active {
  transform: scale(0.92);
}

.back-top-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ==================== PDF报告弹窗 ==================== */
.pdf-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.pdf-modal.show {
  opacity: 1;
  visibility: visible;
}

.pdf-content {
  width: 90%;
  max-width: 650rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.pdf-modal.show .pdf-content {
  transform: scale(1);
}

.pdf-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
}

.pdf-title {
  font-size: 32rpx;
  font-weight: 600;
}

.pdf-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.pdf-body {
  padding: 32rpx;
  max-height: calc(80vh - 120rpx);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.pdf-institution {
  text-align: center;
  margin-bottom: 24rpx;
}

.pdf-logo {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.pdf-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.pdf-info {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.pdf-row {
  display: flex;
  margin-bottom: 8rpx;
}

.pdf-row:last-child {
  margin-bottom: 0;
}

.pdf-label {
  font-size: 24rpx;
  color: #999999;
  min-width: 140rpx;
}

.pdf-value {
  font-size: 24rpx;
  color: #333333;
}

.pdf-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #E8E8E8, transparent);
  margin: 24rpx 0;
}

.pdf-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.pdf-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666666;
  border-bottom: 1rpx dashed #F0F0F0;
}

.pdf-pass {
  color: #52C41A;
  font-weight: 500;
}

.pdf-footer {
  margin-top: 32rpx;
  text-align: center;
}

.pdf-stamp {
  display: inline-block;
  padding: 16rpx 48rpx;
  border: 4rpx solid #52C41A;
  border-radius: 8rpx;
  color: #52C41A;
  font-size: 32rpx;
  font-weight: 600;
  transform: rotate(-5deg);
  margin-bottom: 16rpx;
}

.pdf-conclusion {
  font-size: 24rpx;
  color: #666666;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #F5F5F0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E8E8E8;
  border-top-color: #2E8B57;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

