  color: #999999;
  padding: 8rpx;
}

.bc-result-body {
  padding: 20rpx 24rpx;
}

.bc-result-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.bc-result-item:last-child {
  border-bottom: none;
