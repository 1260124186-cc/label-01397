  margin-bottom: 12rpx;
}

.brewing-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.brewing-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #DAA520;
}

.brewing-extra {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
}

.extra-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.extra-item:last-child {
  margin-bottom: 0;
}

.extra-label {
  font-size: 26rpx;
  color: #999999;
}

.extra-value {
  font-size: 26rpx;
  color: #333333;
}

.brewing-tips {
