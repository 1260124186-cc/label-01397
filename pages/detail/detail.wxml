  <view class="share-modal cert-modal {{showCertModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeCertModal">
    <view class="share-modal-content cert-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="share-modal-header cert-header">
        <text class="share-modal-title">📜 溯源证书</text>
        <view class="share-modal-close" bindtap="closeCertModal">×</view>
