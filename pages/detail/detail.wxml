        <view class="share-activity-tip">
          <text class="tip-icon">🎁</text>
          <text class="tip-text">{{shareInviteConfig.activityTip || '每邀请1位好友扫码溯源，双方各得好礼！'}}</text>
        </view>

        <view class="share-stats-row">
          <view class="share-stat-item">
            <text class="stat-value">{{shareInviteData.invitedCount || 0}}</text>
            <text class="stat-label">已邀请好友</text>
          </view>
          <view class="share-stat-divider"></view>
          <view class="share-stat-item">
            <text class="stat-value">{{shareInviteConfig.inviterPoints || 100}}</text>
            <text class="stat-label">每次积分</text>
          </view>
          <view class="share-stat-divider"></view>
          <view class="share-stat-item">
            <text class="stat-value">¥{{shareInviteConfig.inviterCoupon && shareInviteConfig.inviterCoupon.value || 20}}</text>
            <text class="stat-label">优惠券</text>
          </view>
        </view>

        <view class="share-action-grid">
          <view class="share-action-card" bindtap="openShareCardModal">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);">
              <text class="action-icon">🖼️</text>
            </view>
            <text class="action-title">生成分享卡</text>
            <text class="action-desc">精美卡片含二维码</text>
          </view>

          <view class="share-action-card" bindtap="openCertModal">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);">
              <text class="action-icon">📜</text>
            </view>
            <text class="action-title">溯源证书</text>
            <text class="action-desc">区块链验真长图</text>
          </view>

          <view class="share-action-card" bindtap="onSaveAllCerts">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #52C41A 0%, #73D13D 100%);">
              <text class="action-icon">💼</text>
            </view>
            <text class="action-title">收藏全部证书</text>
            <text class="action-desc">已收藏 {{certWalletStatus.totalSaved}}/3 张</text>
          </view>

          <view class="share-action-card" bindtap="goCertificateWallet">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #FA8C16 0%, #FFA940 100%);">
              <text class="action-icon">📂</text>
            </view>
            <text class="action-title">证书钱包</text>
            <text class="action-desc">电子质检单夹</text>
          </view>

          <view class="share-action-card" bindtap="doInviteShare">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #1890FF 0%, #40A9FF 100%);">
              <text class="action-icon">💬</text>
            </view>
            <text class="action-title">邀请好友</text>
            <text class="action-desc">双方得积分优惠券</text>
          </view>

          <view class="share-action-card" bindtap="copyShareLink">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #722ED1 0%, #9254DE 100%);">
              <text class="action-icon">🔗</text>
            </view>
            <text class="action-title">复制链接</text>
            <text class="action-desc">一键复制溯源链接</text>
          </view>
        </view>

        <view class="share-rules-box">
          <view class="rules-title">活动规则</view>
          <view wx:for="{{shareInviteConfig.rules}}" wx:key="index" class="rule-item">
            <text class="rule-num">{{index + 1}}</text>
            <text class="rule-text">{{item}}</text>
          </view>
        </view>

        <view wx:if="{{shareInviteData.invitees && shareInviteData.invitees.length > 0}}" class="invitees-list">
          <view class="invitees-title">
            <text>我的邀请记录</text>
            <text class="invitees-count">共{{shareInviteData.invitees.length}}人</text>
          </view>
          <view wx:for="{{shareInviteData.invitees}}" wx:for-item="invitee" wx:key="userId" class="invitee-item">
            <view class="invitee-avatar">👤</view>
            <view class="invitee-info">
              <text class="invitee-name">好友{{index + 1}}</text>
              <text class="invitee-trace">溯源码：{{invitee.traceId}}</text>
            </view>
            <view class="invitee-status">
              <text wx:if="{{invitee.rewarded}}" class="status-done">✓ 已奖励</text>
              <text wx:else class="status-pending">待完成</text>
