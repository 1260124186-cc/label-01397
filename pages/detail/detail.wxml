      <view class="module-content {{moduleCollapsed.blockchain ? 'hidden' : ''}}">

        <!-- 链上验真 -->
        <view class="bc-section bc-verify-section">
          <view class="bc-section-header">
            <text class="bc-section-icon">🔍</text>
            <text class="bc-section-title">链上验真</text>
          </view>
          <view class="bc-verify-content">
            <view class="bc-chain-info">
              <view class="bc-info-row">
                <text class="bc-info-label">存证链</text>
                <text class="bc-info-value">{{traceData.blockchainInfo.chainName}}</text>
              </view>
              <view class="bc-info-row">
                <text class="bc-info-label">区块高度</text>
                <text class="bc-info-value">#{{traceData.blockchainInfo.blockHeight}}</text>
              </view>
              <view class="bc-info-row">
                <text class="bc-info-label">存证时间</text>
                <text class="bc-info-value">{{traceData.blockchainInfo.timestamp}}</text>
              </view>
            </view>

            <!-- 交易哈希（可展开/复制） -->
            <view class="bc-txhash-row">
              <text class="bc-info-label">交易哈希</text>
              <view class="bc-txhash-container">
                <text class="bc-txhash-value" bindtap="toggleTxHashDisplay">
                  {{bcShowTxHashFull ? traceData.blockchainInfo.txHash : traceData.blockchainInfo.txHashShort}}
                </text>
                <text class="bc-txhash-toggle">{{bcShowTxHashFull ? '收起' : '展开'}}</text>
              </view>
            </view>

            <!-- 操作按钮 -->
            <view class="bc-action-btns">
              <view class="bc-btn bc-btn-verify" bindtap="verifyBlockchainEvidence">
                <text class="bc-btn-icon">{{bcVerifying ? '' : '🔍'}}</text>
                <text class="bc-btn-text">{{bcVerifying ? '验证中...' : '验证存证'}}</text>
                <view class="bc-loading-spinner" wx:if="{{bcVerifying}}"></view>
              </view>
              <view class="bc-btn bc-btn-copy" bindtap="copyTxHash">
                <text class="bc-btn-icon">📋</text>
                <text class="bc-btn-text">复制哈希</text>
              </view>
              <view class="bc-btn bc-btn-explorer" bindtap="openBlockExplorer">
                <text class="bc-btn-icon">🌐</text>
                <text class="bc-btn-text">区块浏览器</text>
              </view>
            </view>
          </view>

          <!-- 验证结果弹层 -->
          <view class="bc-verify-result" wx:if="{{bcShowVerifyResult && bcVerifyResult}}">
            <view class="bc-result-header">
              <view class="bc-result-status {{bcVerifyResult.verified ? 'success' : 'fail'}}">
                <text class="bc-result-status-icon">{{bcVerifyResult.verified ? '✅' : '❌'}}</text>
                <text class="bc-result-status-text">{{bcVerifyResult.verified ? '验证通过' : '验证未通过'}}</text>
              </view>
              <text class="bc-result-close" bindtap="closeBlockchainVerifyResult">✕</text>
            </view>
            <view class="bc-result-body" wx:if="{{bcVerifyResult.verified}}">
              <view class="bc-result-item">
                <text class="bc-result-label">交易哈希</text>
                <text class="bc-result-value bc-result-hash">{{bcVerifyResult.txHash}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">存证链</text>
                <text class="bc-result-value">{{bcVerifyResult.chainName}} ({{bcVerifyResult.chainId}})</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">区块高度</text>
                <text class="bc-result-value">#{{bcVerifyResult.blockHeight}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">共识机制</text>
                <text class="bc-result-value">{{bcVerifyResult.consensusType}} · {{bcVerifyResult.nodeCount}}节点</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">上链字段</text>
                <text class="bc-result-value">{{bcVerifyResult.onChainFieldsCount}}项已上链</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">关联产品</text>
                <text class="bc-result-value">{{bcVerifyResult.productName}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">批次号</text>
                <text class="bc-result-value">{{bcVerifyResult.batchNo}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">验证时间</text>
                <text class="bc-result-value">{{bcVerifyResult.verifyTime}}</text>
              </view>
            </view>
            <view class="bc-result-body" wx:else="">
              <text class="bc-result-fail-msg">{{bcVerifyResult.message || '未找到对应记录'}}</text>
            </view>
          </view>
        </view>

        <!-- 存证内容说明 -->
        <view class="bc-section bc-onchain-section">
          <view class="bc-section-header">
            <text class="bc-section-icon">📝</text>
            <text class="bc-section-title">已上链字段</text>
            <text class="bc-onchain-count">{{traceData.blockchainInfo.onChainFields.length}}项</text>
          </view>
          <view class="bc-onchain-list">
            <view class="bc-onchain-item" wx:for="{{traceData.blockchainInfo.onChainFields}}" wx:key="key">
              <view class="bc-onchain-left">
                <view class="bc-onchain-check {{item.onChain ? 'checked' : ''}}">
                  <text wx:if="{{item.onChain}}">✓</text>
                </view>
                <text class="bc-onchain-label">{{item.label}}</text>
              </view>
              <view class="bc-onchain-right">
                <text class="bc-onchain-value">{{item.value}}</text>
                <text class="bc-onchain-tag" wx:if="{{item.onChain}}">已上链</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 防伪联动 -->
        <view class="bc-section bc-anticounter-section">
          <view class="bc-section-header" bindtap="toggleScanRecords">
            <text class="bc-section-icon">🛡️</text>
            <text class="bc-section-title">防伪查询记录</text>
            <text class="bc-scan-count">{{traceData.blockchainInfo.scanRecords.totalQueryCount}}次</text>
            <text class="bc-section-arrow {{bcShowScanRecords ? 'expanded' : ''}}">›</text>
          </view>
          <view class="bc-anticounter-summary">
            <view class="bc-anticounter-stat">
              <text class="bc-stat-number">{{traceData.blockchainInfo.scanRecords.totalQueryCount}}</text>
              <text class="bc-stat-label">累计查询</text>
            </view>
            <view class="bc-anticounter-stat">
              <text class="bc-stat-number">{{traceData.blockchainInfo.scanRecords.records.length}}</text>
              <text class="bc-stat-label">上链记录</text>
            </view>
            <view class="bc-anticounter-stat">
              <text class="bc-stat-number">1</text>
              <text class="bc-stat-label">首次扫码</text>
            </view>
          </view>

          <!-- 扫码记录列表 -->
          <view class="bc-scan-records" wx:if="{{bcShowScanRecords}}">
            <view class="bc-scan-record-item" wx:for="{{traceData.blockchainInfo.scanRecords.records}}" wx:key="time">
              <view class="bc-scan-type-badge {{item.type === 'first' ? 'first' : 'repeat'}}">
                <text>{{item.type === 'first' ? '首' : '复'}}</text>
              </view>
              <view class="bc-scan-info">
                <view class="bc-scan-top">
                  <text class="bc-scan-location">{{item.location}}</text>
                  <text class="bc-scan-type-text">{{item.type === 'first' ? '首次扫码' : '重复扫码'}}</text>
                </view>
                <view class="bc-scan-bottom">
                  <text class="bc-scan-time">{{item.time}}</text>
                  <text class="bc-scan-ip">IP: {{item.ip}}</text>
                </view>
              </view>
            </view>

            <!-- 当前扫码结果 -->
            <view class="bc-current-scan" wx:if="{{bcAntiCounterResult && bcAntiCounterResult.success}}">
              <view class="bc-current-scan-header">
                <text class="bc-current-scan-title">本次查询</text>
                <view class="bc-current-scan-badge {{bcAntiCounterResult.isFirstScan ? 'first' : 'repeat'}}">
                  <text>{{bcAntiCounterResult.isFirstScan ? '首次扫码' : '重复扫码'}}</text>
                </view>
              </view>
              <view class="bc-current-scan-body">
                <text class="bc-current-scan-product">{{bcAntiCounterResult.productName}}</text>
                <text class="bc-current-scan-total">累计查询 {{bcAntiCounterResult.totalQueryCount}} 次</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 时间戳服务 -->
        <view class="bc-section bc-tsa-section">
          <view class="bc-section-header" bindtap="toggleTsaCertificate">
            <text class="bc-section-icon">⏱️</text>
            <text class="bc-section-title">司法级时间戳</text>
            <text class="bc-tsa-badge">TSA</text>
            <text class="bc-section-arrow {{bcShowTsaCert ? 'expanded' : ''}}">›</text>
          </view>
          <view class="bc-tsa-brief">
            <view class="bc-tsa-brief-item">
              <text class="bc-tsa-brief-label">签发机构</text>
              <text class="bc-tsa-brief-value">{{traceData.blockchainInfo.tsaCertificate.issuer}}</text>
            </view>
            <view class="bc-tsa-brief-item">
              <text class="bc-tsa-brief-label">时间戳精度</text>
              <text class="bc-tsa-brief-value">{{traceData.blockchainInfo.tsaCertificate.accuracy}}</text>
            </view>
          </view>

          <!-- TSA证书详情 -->
          <view class="bc-tsa-cert-detail" wx:if="{{bcShowTsaCert && bcTsaCertData}}">
            <view class="bc-tsa-cert-card">
              <view class="bc-tsa-cert-header">
                <text class="bc-tsa-cert-icon">🔏</text>
                <text class="bc-tsa-cert-title">TSA 时间戳证书</text>
              </view>
              <view class="bc-tsa-cert-body">
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">证书编号</text>
                  <view class="bc-tsa-cert-value-row">
                    <text class="bc-tsa-cert-value bc-mono">{{bcTsaCertData.certSerial}}</text>
                    <text class="bc-tsa-cert-copy" bindtap="copyTsaCertSerial">复制</text>
                  </view>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">签名算法</text>
                  <text class="bc-tsa-cert-value">{{bcTsaCertData.algorithm}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">时间戳服务</text>
                  <text class="bc-tsa-cert-value bc-mono">{{bcTsaCertData.tsServer}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">精确时间</text>
                  <text class="bc-tsa-cert-value bc-mono">{{bcTsaCertData.timestamp}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">TSA令牌哈希</text>
                  <text class="bc-tsa-cert-value bc-mono bc-hash-small">{{bcTsaCertData.tsTokenHash}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">存证哈希</text>
                  <text class="bc-tsa-cert-value bc-mono bc-hash-small">{{bcTsaCertData.evidenceHash}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">法律依据</text>
                  <text class="bc-tsa-cert-value bc-legal">{{bcTsaCertData.legalBasis}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">有效期</text>
                  <text class="bc-tsa-cert-value">{{bcTsaCertData.validityPeriod}}</text>
                </view>
              </view>
              <view class="bc-tsa-cert-footer">
                <text class="bc-tsa-cert-verify-hint">此证书由司法级时间戳服务机构签发，具有法律效力</text>
              </view>
            </view>
          </view>
        </view>

      </view>
    </view>

    <!-- ========== 模块9：分享与社交传播 ========== -->
    <view class="card animate-card module-card share-social-card" style="animation-delay: 0.5s;">
      <view class="card-title module-header">
        <view class="title-left">
          <text class="title-icon">📣</text>
          <text>分享与传播</text>
          <view class="title-badge">邀请得好礼</view>
        </view>
      </view>
      <view class="module-content">
        <view class="share-activity-tip">
          <text class="tip-icon">🎁</text>
          <text class="tip-text">{{shareInviteConfig.activityTip || '每邀请1位好友扫码溯源，双方各得好礼！'}}</text>
        </view>

        <view class="share-stats-row">
          <view class="share-stat-item">
            <text class="stat-value">{{shareInviteData.invitedCount || 0}}</text>
            <text class="stat-label">已邀请好友</text>
          </view>
          <view class="share-stat-divider"></view>
          <view class="share-stat-item">
            <text class="stat-value">{{shareInviteConfig.inviterPoints || 100}}</text>
            <text class="stat-label">每次积分</text>
          </view>
          <view class="share-stat-divider"></view>
          <view class="share-stat-item">
            <text class="stat-value">¥{{shareInviteConfig.inviterCoupon && shareInviteConfig.inviterCoupon.value || 20}}</text>
            <text class="stat-label">优惠券</text>
          </view>
        </view>

        <view class="share-action-grid">
          <view class="share-action-card" bindtap="openShareCardModal">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);">
              <text class="action-icon">🖼️</text>
            </view>
            <text class="action-title">生成分享卡</text>
            <text class="action-desc">精美卡片含二维码</text>
          </view>

          <view class="share-action-card" bindtap="openCertModal">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);">
              <text class="action-icon">📜</text>
            </view>
            <text class="action-title">溯源证书</text>
            <text class="action-desc">区块链验真长图</text>
          </view>

          <view class="share-action-card" bindtap="doInviteShare">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #1890FF 0%, #40A9FF 100%);">
              <text class="action-icon">💬</text>
            </view>
            <text class="action-title">邀请好友</text>
            <text class="action-desc">双方得积分优惠券</text>
          </view>

          <view class="share-action-card" bindtap="copyShareLink">
            <view class="action-icon-wrap" style="background: linear-gradient(135deg, #722ED1 0%, #9254DE 100%);">
              <text class="action-icon">🔗</text>
            </view>
            <text class="action-title">复制链接</text>
            <text class="action-desc">一键复制溯源链接</text>
          </view>
        </view>

        <view class="share-rules-box">
          <view class="rules-title">活动规则</view>
          <view wx:for="{{shareInviteConfig.rules}}" wx:key="index" class="rule-item">
            <text class="rule-num">{{index + 1}}</text>
            <text class="rule-text">{{item}}</text>
          </view>
        </view>

        <view wx:if="{{shareInviteData.invitees && shareInviteData.invitees.length > 0}}" class="invitees-list">
          <view class="invitees-title">
            <text>我的邀请记录</text>
            <text class="invitees-count">共{{shareInviteData.invitees.length}}人</text>
          </view>
          <view wx:for="{{shareInviteData.invitees}}" wx:for-item="invitee" wx:key="userId" class="invitee-item">
            <view class="invitee-avatar">👤</view>
            <view class="invitee-info">
              <text class="invitee-name">好友{{index + 1}}</text>
              <text class="invitee-trace">溯源码：{{invitee.traceId}}</text>
            </view>
            <view class="invitee-status">
              <text wx:if="{{invitee.rewarded}}" class="status-done">✓ 已奖励</text>
              <text wx:else class="status-pending">待完成</text>
            </view>
          </view>
        </view>
      </view>
    </view>

  </view>

  <!-- ==================== 返回顶部按钮 ==================== -->
  <view class="back-top {{showBackTop ? 'show' : ''}}" bindtap="scrollToTop" role="button" aria-hidden="{{!showBackTop}}" aria-label="{{i18n.backTop}}">
    <text class="back-top-icon" aria-hidden="true">↑</text>
  </view>

  <!-- ==================== 底部购买操作栏 ==================== -->
  <view class="detail-buy-bar" wx:if="{{traceData}}">
    <view class="buy-bar-item" bindtap="goToShopHome">
      <text class="buy-bar-icon">🏠</text>
      <text class="buy-bar-text">商城首页</text>
    </view>
    <view class="buy-bar-item" bindtap="goToCart">
      <text class="buy-bar-icon">🛒</text>
      <text class="buy-bar-text">购物车</text>
      <view class="buy-bar-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
    <view class="buy-btn buy-btn-same" bindtap="buySameStyle">
      <text>购买同款</text>
    </view>
    <view class="buy-btn buy-btn-again" bindtap="buyAgain">
      <text>再次购买</text>
    </view>
  </view>

  <!-- ==================== PDF报告弹窗 ==================== -->
  <view class="pdf-modal {{showPdfModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closePdfModal">
    <view class="pdf-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="pdf-header {{testChartData.overallPass ? '' : 'danger-header'}}">
        <text class="pdf-title">农残检测报告</text>
        <view class="pdf-close" bindtap="closePdfModal">×</view>
      </view>
      <view class="pdf-body">
        <view class="pdf-institution">
          <view class="pdf-logo">🏛️</view>
          <view class="pdf-name">{{traceData.pesticideTest.institution}}</view>
        </view>
        <view class="pdf-info">
          <view class="pdf-row">
            <text class="pdf-label">报告编号：</text>
            <text class="pdf-value">{{traceData.pesticideTest.reportNo}}</text>
          </view>
          <view class="pdf-row">
            <text class="pdf-label">检测日期：</text>
            <text class="pdf-value">{{traceData.pesticideTest.testDate}}</text>
          </view>
          <view class="pdf-row">
            <text class="pdf-label">国标依据：</text>
            <text class="pdf-value">{{traceData.pesticideTest.standard}}</text>
          </view>
        </view>

        <!-- PDF 异常警告 -->
        <view class="pdf-abnormal-warning" wx:if="{{!testChartData.overallPass}}">
          <text class="pdf-warning-icon">⚠️</text>
          <text class="pdf-warning-text">本次检测存在不合格项</text>
        </view>

        <view class="pdf-divider"></view>
        <view class="pdf-results">
          <view class="pdf-section-title">茶叶检测项目</view>
          <view wx:for="{{testChartData.teaTests}}" wx:key="item" class="pdf-result-item {{item.isPass ? '' : 'abnormal-item'}}">
            <text>{{item.item}}：{{item.displayValue}}{{item.unit}}（限值{{item.limit}}{{item.unit}}）</text>
            <text class="pdf-result-tag {{item.isPass ? 'pdf-pass' : 'pdf-fail'}}">{{item.isPass ? '✓合格' : '✗不合格'}}</text>
          </view>
          <view class="pdf-section-title" style="margin-top: 24rpx;">桂花检测项目</view>
          <view wx:for="{{testChartData.osmanthusTests}}" wx:key="item" class="pdf-result-item {{item.isPass ? '' : 'abnormal-item'}}">
            <text>{{item.item}}：{{item.displayValue}}{{item.unit}}（限值{{item.limit}}{{item.unit}}）</text>
            <text class="pdf-result-tag {{item.isPass ? 'pdf-pass' : 'pdf-fail'}}">{{item.isPass ? '✓合格' : '✗不合格'}}</text>
          </view>
        </view>
        <view class="pdf-footer">
          <view class="pdf-stamp {{testChartData.overallPass ? '' : 'pdf-stamp-danger'}}">{{testChartData.overallPass ? '检验合格' : '存在异常'}}</view>
          <view class="pdf-conclusion">{{traceData.pesticideTest.comparisonTip}}</view>

          <!-- PDF 操作按钮 -->
          <view class="pdf-action-row">
            <view class="pdf-action-btn" bindtap="saveReportToAlbum" catchtap="saveReportToAlbum">
              <text>📸 保存相册</text>
            </view>
            <view class="pdf-action-btn" bindtap="shareReport" catchtap="shareReport">
              <text>📤 转发</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 报告验真弹窗 ==================== -->
  <view class="verify-modal {{showVerifyModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeVerifyModal">
    <view class="verify-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="verify-header">
        <text class="verify-title">🔍 检测报告验真</text>
        <view class="verify-close" bindtap="closeVerifyModal">×</view>
      </view>
      <view class="verify-body">
        <!-- 输入区域 -->
        <view class="verify-input-section">
          <text class="verify-label">请输入报告编号</text>
          <view class="verify-input-wrapper">
            <input
              class="verify-input"
              placeholder="如 NTQC-2025-09876"
              value="{{verifyInput}}"
              bindinput="onVerifyInputChange"
            />
          </view>
          <view class="verify-buttons">
            <view class="verify-btn primary" bindtap="doVerifyReport">
              <text wx:if="{{!verifying}}">立即验真</text>
              <text wx:else>验真中...</text>
            </view>
            <view class="verify-btn secondary" bindtap="openVerifyWebsite">
              <text>官网验真</text>
            </view>
          </view>
        </view>

        <!-- 验真结果 -->
        <view class="verify-result" wx:if="{{verifyResult}}">
          <view class="verify-result-header {{verifyResult.valid ? 'valid' : 'invalid'}}">
            <text class="verify-result-icon">{{verifyResult.valid ? '✅' : '❌'}}</text>
            <text class="verify-result-title">{{verifyResult.valid ? '验真通过' : '验真失败'}}</text>
          </view>
          <view class="verify-result-body" wx:if="{{verifyResult.valid}}">
            <view class="verify-row">
              <text class="verify-row-label">报告编号</text>
              <text class="verify-row-value">{{verifyResult.reportNo}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">产品名称</text>
              <text class="verify-row-value">{{verifyResult.productName}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">批次号</text>
              <text class="verify-row-value">{{verifyResult.batchNo}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">检测机构</text>
              <text class="verify-row-value">{{verifyResult.institution}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">检测日期</text>
              <text class="verify-row-value">{{verifyResult.testDate}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">检测结果</text>
              <text class="verify-row-value {{verifyResult.status === '存在异常项' ? 'danger-text' : ''}}">{{verifyResult.status}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">验真时间</text>
              <text class="verify-row-value">{{verifyResult.verifyTime}}</text>
            </view>
          </view>
          <view class="verify-result-body invalid-body" wx:else>
            <text class="verify-invalid-msg">{{verifyResult.message}}</text>
          </view>
        </view>

        <view class="verify-tip">
          <text class="verify-tip-icon">💡</text>
          <text class="verify-tip-text">报告编号可在检测报告右上角或本页面找到</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 地图标记简介弹窗 ==================== -->
  <view class="map-callout-modal {{showMapCalloutModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeMapCallout" wx:if="{{selectedMapMarker}}">
    <view class="map-callout-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="callout-header" style="background: linear-gradient(135deg, {{selectedMapMarker.color}} 0%, rgba({{selectedMapMarker.color}}, 0.7) 100%);">
        <view class="callout-icon-box">
          <text class="callout-big-icon">{{selectedMapMarker.icon}}</text>
        </view>
        <view class="callout-title-info">
          <text class="callout-title">{{selectedMapMarker.callout.title}}</text>
          <view class="callout-type-tag">
            <text wx:if="{{selectedMapMarker.type === 'teaGarden'}}">🍃 茶树园</text>
            <text wx:elif="{{selectedMapMarker.type === 'osmanthusGarden'}}">{{varietyStyle ? varietyStyle.icon : '🌼'}} 桂花园</text>
            <text wx:elif="{{selectedMapMarker.type === 'factory'}}">🏭 加工厂</text>
            <text wx:else>📍 地点</text>
          </view>
        </view>
        <view class="callout-close" bindtap="closeMapCallout">×</view>
      </view>

      <view class="callout-body">
        <!-- 简介图片 -->
        <view class="callout-images" wx:if="{{selectedMapMarker.callout.images && selectedMapMarker.callout.images.length > 0}}">
          <view
            wx:for="{{selectedMapMarker.callout.images}}"
            wx:key="*this"
            class="callout-image-item"
            data-url="{{item}}"
            bindtap="previewMapCalloutImage"
          >
            <image class="callout-img" src="{{item}}" mode="aspectFill" />
          </view>
        </view>

        <!-- 简介内容 -->
        <view class="callout-desc">
          <text class="desc-label">📍 位置</text>
          <text class="desc-value">经度 {{selectedMapMarker.lng}}, 纬度 {{selectedMapMarker.lat}}</text>
        </view>
        <view class="callout-desc">
          <text class="desc-label">📖 简介</text>
          <text class="desc-value">{{selectedMapMarker.callout.content}}</text>
        </view>

        <!-- 操作按钮 -->
        <view class="callout-action-buttons">
          <view class="callout-btn primary" bindtap="openLocationNavigation">
            <text>🧭 导航前往</text>
          </view>
          <view class="callout-btn secondary" bindtap="closeMapCallout">
            <text>关闭</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 分享卡片弹窗 ==================== -->
  <view class="share-modal {{showShareCardModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeShareCardModal">
    <view class="share-modal-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="share-modal-header">
        <text class="share-modal-title">🖼️ 分享卡片</text>
        <view class="share-modal-close" bindtap="closeShareCardModal">×</view>
      </view>
      <view class="share-modal-body">
        <view class="share-preview-area">
          <canvas type="2d" id="shareCardCanvas" class="share-card-canvas" style="width: 375px; height: 600px;"></canvas>
          <view class="share-loading-mask" wx:if="{{shareCardGenerating}}">
            <view class="loading-spinner small"></view>
            <text>正在生成分享卡片...</text>
          </view>
          <image wx:if="{{shareCardImage}}" class="share-preview-image" src="{{shareCardImage}}" mode="aspectFit" bindtap="previewShareImage" data-url="{{shareCardImage}}" />
        </view>
        <view class="share-tip-text">长按图片可保存或转发给好友</view>
      </view>
      <view class="share-modal-footer">
        <view class="share-footer-btn secondary" bindtap="regenerateShareCard">
          <text>🔄 重新生成</text>
        </view>
        <view class="share-footer-btn primary" bindtap="saveShareCardToAlbum">
          <text>💾 保存到相册</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 溯源证书弹窗 ==================== -->
  <view class="share-modal cert-modal {{showCertModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeCertModal">
    <view class="share-modal-content cert-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="share-modal-header cert-header">
        <text class="share-modal-title">📜 溯源证书</text>
        <view class="share-modal-close" bindtap="closeCertModal">×</view>
      </view>
      <view class="share-modal-body cert-body">
        <scroll-view scroll-y="true" class="cert-scroll">
          <view class="cert-preview-area">
            <canvas type="2d" id="certCanvas" class="cert-canvas" style="width: 375px; height: 1100px;"></canvas>
            <view class="share-loading-mask" wx:if="{{certGenerating}}">
              <view class="loading-spinner small"></view>
              <text>正在生成溯源证书...</text>
            </view>
            <image wx:if="{{certImage}}" class="cert-preview-image" src="{{certImage}}" mode="widthFix" bindtap="previewShareImage" data-url="{{certImage}}" />
          </view>
        </scroll-view>
        <view class="share-tip-text">证书包含区块链验真二维码，可长按保存</view>
      </view>
      <view class="share-modal-footer">
        <view class="share-footer-btn secondary" bindtap="regenerateCert">
          <text>🔄 重新生成</text>
        </view>
        <view class="share-footer-btn primary gold" bindtap="saveCertToAlbum">
          <text>💾 保存到相册</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 邀请奖励弹窗 ==================== -->
  <view class="reward-modal {{showRewardModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeRewardModal">
    <view class="reward-modal-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="reward-celebration">
        <text class="celebration-icon">🎉</text>
        <text class="celebration-title">恭喜获得奖励</text>
      </view>
      <view class="reward-list" wx:if="{{lastRewardResult && lastRewardResult.rewards}}">
        <view wx:if="{{lastRewardResult.rewards.inviter}}" class="reward-item inviter-reward">
          <view class="reward-role">您的奖励</view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.inviter.type === 'points' || lastRewardResult.rewards.inviter.value}}">
            <text class="reward-icon">✨</text>
            <view class="reward-info">
              <text class="reward-name">绿色积分</text>
              <text class="reward-value">+{{lastRewardResult.rewards.inviter.value || lastRewardResult.rewards.inviter}} 分</text>
            </view>
          </view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.inviter.coupon}}">
            <text class="reward-icon">🎫</text>
            <view class="reward-info">
              <text class="reward-name">{{lastRewardResult.rewards.inviter.coupon.name}}</text>
              <text class="reward-value">
                {{lastRewardResult.rewards.inviter.coupon.type === 'cash' ? '¥' + lastRewardResult.rewards.inviter.coupon.value : (lastRewardResult.rewards.inviter.coupon.value * 10) + '折'}}
              </text>
            </view>
          </view>
        </view>
        <view wx:if="{{lastRewardResult.rewards.invitee}}" class="reward-item invitee-reward">
          <view class="reward-role">好友的奖励</view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.invitee.type === 'points' || lastRewardResult.rewards.invitee.value}}">
            <text class="reward-icon">✨</text>
            <view class="reward-info">
              <text class="reward-name">绿色积分</text>
              <text class="reward-value">+{{lastRewardResult.rewards.invitee.value || 50}} 分</text>
            </view>
          </view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.invitee.coupon}}">
            <text class="reward-icon">🎫</text>
            <view class="reward-info">
              <text class="reward-name">{{lastRewardResult.rewards.invitee.coupon.name}}</text>
              <text class="reward-value">
                {{lastRewardResult.rewards.invitee.coupon.type === 'cash' ? '¥' + lastRewardResult.rewards.invitee.coupon.value : (lastRewardResult.rewards.invitee.coupon.value * 10) + '折'}}
              </text>
            </view>
          </view>
        </view>
      </view>
      <view class="reward-actions">
        <view class="reward-action-btn primary" bindtap="closeRewardModal">
          <text>知道了</text>
        </view>
        <view class="reward-action-btn secondary" bindtap="shareAfterReward">
          <text>继续邀请好友</text>
        </view>
      </view>
    </view>
  </view>

</view>

<!-- ==================== 加载状态（降级，骨架屏优先） ==================== -->
<view class="loading-container" wx:if="{{loading && skeletonLoading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">正在加载溯源信息...</text>
</view>
