                <text class="desc-text">{{item.description}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 历史检测报告时间轴 -->
        <view class="history-reports-section" wx:if="{{traceData.pesticideTest.historyReports && traceData.pesticideTest.historyReports.length > 0}}" role="region" aria-label="{{currentLang === 'en-US' ? 'Historical test records' : '历次检测记录'}}">
          <view class="history-header" bindtap="toggleHistoryTimeline" role="button" aria-expanded="{{showHistoryTimeline}}" aria-label="{{currentLang === 'en-US' ? 'Toggle historical test report timeline' : '展开或收起历次检测报告时间轴'}}">
            <view class="history-title">
              <text class="history-icon" aria-hidden="true">📅</text>
              <text role="heading" aria-level="3">{{currentLang === 'en-US' ? 'Historical Reports' : '历次检测记录'}}</text>
              <text class="history-count">{{currentLang === 'en-US' ? 'Total ' : '共 '}}{{traceData.pesticideTest.historyReports.length}}{{currentLang === 'en-US' ? ' reports' : ' 份'}}</text>
            </view>
            <view class="history-toggle {{showHistoryTimeline ? 'expanded' : ''}}" aria-hidden="true">
              <text>▾</text>
            </view>
          </view>
          <view class="history-timeline {{showHistoryTimeline ? 'show' : ''}}" role="list">
            <view
              wx:for="{{traceData.pesticideTest.historyReports}}"
              wx:key="reportNo"
              wx:for-item="report"
              class="timeline-item {{index === 0 ? 'latest' : ''}} {{report.status === '不合格' ? 'abnormal' : ''}} {{activeHistoryIndex === index ? 'active' : ''}}"
              bindtap="viewHistoryReport"
              data-report="{{report}}"
              role="listitem"
              data-status="{{report.status === '不合格' ? 'fail' : 'pass'}}"
              aria-label="{{report.testDate}}，报告编号{{report.reportNo}}，检测结果{{report.status}}"
            >
              <view class="timeline-dot {{report.status === '不合格' ? 'danger' : (report.statusLevel === '优秀' ? 'excellent' : 'good')}}"></view>
              <view class="timeline-line" wx:if="{{index < traceData.pesticideTest.historyReports.length - 1}}"></view>
              <view class="timeline-content">
                <view class="timeline-date">{{report.testDate}}</view>
                <view class="timeline-info">
                  <text class="timeline-report-no">{{report.reportNo}}</text>
                  <view class="timeline-status {{report.status === '不合格' ? 'danger' : (report.statusLevel === '优秀' ? 'excellent' : 'good')}} status-{{report.status === '不合格' ? 'fail' : 'pass'}}" data-status="{{report.status === '不合格' ? 'fail' : 'pass'}}">
                    {{report.status}}
                  </view>
                </view>
                <view class="timeline-meta">
                  <text>{{report.institution}}</text>
                  <text wx:if="{{report.batchNo}}">{{currentLang === 'en-US' ? 'Batch: ' : '批次：'}}{{report.batchNo}}</text>
                </view>
                <view class="timeline-version-link" catchtap="gotoHistoryReportFromChange" data-reportno="{{report.reportNo}}">
                  <text class="version-link-icon">📌</text>
                  <text class="version-link-text">查看对应数据版本变更 ›</text>
                </view>
                <view class="timeline-tag" wx:if="{{index === 0}}">{{currentLang === 'en-US' ? 'Latest' : '最新'}}</view>
              </view>
            </view>
          </view>
        </view>

        <!-- 国标对比提示 -->
        <view class="standard-tip {{testChartData.overallPass ? '' : 'danger'}}" data-status="{{testChartData.overallPass ? 'pass' : 'fail'}}" role="note" aria-label="{{testChartData.overallPass ? (currentLang === 'en-US' ? 'Test result passed' : '检测结果合格') : (currentLang === 'en-US' ? 'Test result has abnormal items' : '检测结果存在异常项')}}">
          <text class="tip-icon" aria-hidden="true">{{testChartData.overallPass ? '✅' : '⚠️'}}</text>
          <text class="tip-text">{{traceData.pesticideTest.comparisonTip}}</text>
        </view>

        <!-- 查看完整报告按钮 -->
        <view class="view-report-btn" bindtap="showPdfReport" role="button" aria-label="{{i18n.pdfBtn}}">
          <text class="btn-icon" aria-hidden="true">📄</text>
          <text>{{currentLang === 'en-US' ? 'View Full Report (PDF Style)' : '查看完整报告（PDF样式）'}}</text>
        </view>
      </view>
    </view>

    <!-- ========== 模块：检样追溯 ========== -->
    <view class="card animate-card module-card sample-trace-module-card {{sampleTraceAbnormalCount > 0 ? 'has-abnormal' : ''}}" id="anchor-sampleTrace" style="animation-delay: 0.38s;" wx:if="{{sampleTraceData}}">
      <view class="card-title module-header" bindtap="toggleModule" data-key="sampleTrace">
        <view class="title-left">
          <text class="title-icon">🧪</text>
          <text>检样追溯</text>
          <view class="title-badge {{sampleTraceAbnormalCount > 0 ? 'warning-badge' : 'green'}}" wx:if="{{sampleTraceData}}">
            {{sampleTraceAbnormalCount > 0 ? '存在异常' : '流转正常'}}
          </view>
        </view>
        <view class="module-toggle {{moduleCollapsed.sampleTrace ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.sampleTrace ? 'hidden' : ''}}">
        <sample-trace
          steps="{{sampleTraceData.steps}}"
          sampleNo="{{sampleTraceData.sampleNo}}"
          reportNo="{{sampleTraceData.reportNo}}"
        />
        <view class="sample-abnormal-warning" wx:if="{{sampleTraceAbnormalCount > 0}}">
          <view class="abnormal-warning-icon">⚠️</view>
          <view class="abnormal-warning-content">
            <view class="abnormal-warning-title">检测样品流转异常</view>
            <view class="abnormal-warning-desc">共 {{sampleTraceAbnormalCount}} 个异常环节，详情请展开查看。如涉及您购买的产品，可点击举报。</view>
          </view>
          <view class="abnormal-warning-action" data-sampleno="{{sampleTraceData.sampleNo}}" data-abnormalreason="样品流转存在异常" bindtap="goToSampleAbnormalReport">
            <text>举报 ›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块7：冲泡建议 ========== -->
    <view class="card animate-card module-card" id="anchor-brew" style="animation-delay: 0.4s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="brew">
        <view class="title-left">
          <text class="title-icon">☕</text>
          <text>冲泡建议</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.brew ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.brew ? 'hidden' : ''}}">

        <view class="brewing-content">
          <view class="brewing-params">
            <view class="brewing-item">
              <view class="brewing-icon">🌡️</view>
              <view class="brewing-label">水温</view>
              <view class="brewing-value">{{traceData.brewingGuide.waterTemp}}</view>
            </view>
            <view class="brewing-item">
              <view class="brewing-icon">⏱️</view>
              <view class="brewing-label">冲泡时长</view>
              <view class="brewing-value">{{traceData.brewingGuide.brewingTime}}</view>
            </view>
            <view class="brewing-item">
              <view class="brewing-icon">🔄</view>
              <view class="brewing-label">续泡次数</view>
              <view class="brewing-value">{{traceData.brewingGuide.rebrewTimes}}</view>
            </view>
          </view>

          <view class="brewing-extra">
            <view class="extra-item">
              <text class="extra-label">推荐用水：</text>
              <text class="extra-value">{{traceData.brewingGuide.waterType}}</text>
            </view>
            <view class="extra-item">
              <text class="extra-label">推荐茶具：</text>
              <text class="extra-value">{{traceData.brewingGuide.teawareType}}</text>
            </view>
          </view>

          <view class="brewing-tips">
            <view class="tips-title">冲泡小贴士</view>
            <view class="tips-list">
              <view
                wx:for="{{traceData.brewingGuide.tips}}"
                wx:key="*this"
                class="tip-item"
              >
                <text class="tip-num">{{index + 1}}</text>
                <text class="tip-text">{{item}}</text>
              </view>
            </view>
          </view>

          <!-- ============ 环境联动：天气水温 + 水质 ============ -->
          <view class="interactive-section env-section">
            <view class="section-sub-title">
              <text class="sub-icon">🌤️</text>
              <text>环境联动</text>
              <view class="sub-actions">
                <text class="sub-action-link" bindtap="goToBrewEnvironment">⚙️ 设置</text>
                <text class="sub-action-link" bindtap="openBrewRecordPage">📒 记录本</text>
              </view>
            </view>

            <view class="env-card">
              <view class="env-weather" wx:if="{{currentWeather}}">
                <view class="weather-left">
                  <text class="weather-emoji">{{currentWeather.weather === '晴' ? '☀️' : currentWeather.weather === '多云' ? '⛅' : currentWeather.weather === '阴' ? '☁️' : '🌧️'}}</text>
                  <view class="weather-texts">
                    <text class="weather-city">{{currentWeather.city}}</text>
                    <text class="weather-temp">{{currentWeather.temp}}℃ · {{currentWeather.weather}}</text>
                  </view>
                </view>
                <view class="weather-tip {{waterTempAdjusted.tempLevel}}" wx:if="{{waterTempAdjusted}}">
                  <text class="tip-value">推荐 {{waterTempAdjusted.recommended}}℃</text>
                  <text class="tip-range">{{waterTempAdjusted.min}}~{{waterTempAdjusted.max}}℃</text>
                </view>
              </view>

              <view class="env-loading" wx:elif="{{weatherLoading}}">
                <text>获取天气中...</text>
              </view>

              <view class="env-hardness">
                <view class="hardness-row">
                  <text class="hardness-label">💧 水质</text>
                  <text class="hardness-value">{{waterHardness === 'soft' ? '软水' : waterHardness === 'hard' ? '硬水' : '中等硬度'}}</text>
                </view>
                <view class="hardness-row" wx:if="{{hardnessAdjustment}}">
                  <text class="hardness-detail">投茶 {{hardnessAdjustment.teaAmount}}g · 时长 {{hardnessAdjustment.duration}}秒</text>
                </view>
              </view>
            </view>

            <view class="brew-round-row">
              <text class="round-label">第</text>
              <view class="round-controls">
                <view class="round-btn" bindtap="decreaseBrewRound">−</view>
                <text class="round-number">{{currentBrewRound}}</text>
                <view class="round-btn" bindtap="increaseBrewRound">+</view>
              </view>
              <text class="round-label">泡</text>
            </view>
          </view>

          <!-- ============ 互动功能 1：冲泡计时器 ============ -->
          <view class="interactive-section" wx:if="{{brewInteractiveConfig}}">
            <view class="section-sub-title">
              <text class="sub-icon">⏱️</text>
              <text>冲泡计时器</text>
            </view>

            <view class="timer-container">
              <view class="water-temp-selector">
                <view
                  wx:for="{{brewInteractiveConfig.waterTempLevels}}"
                  wx:key="key"
                  class="temp-item {{selectedWaterTemp === item.key ? 'active' : ''}}"
                  data-temp="{{item.key}}"
                  bindtap="selectWaterTemp"
                >
                  <text class="temp-icon">{{item.icon}}</text>
                  <text class="temp-label">{{item.label}}</text>
                  <text class="temp-desc">{{item.desc}}</text>
                </view>
              </view>

              <view class="timer-display">
                <view class="timer-circle">
                  <view class="timer-progress" style="--progress: {{timerProgress}}%;"></view>
                  <view class="timer-content">
                    <text class="timer-text">{{timerText}}</text>
                    <text class="timer-label">{{timerRunning ? '冲泡中...' : '准备冲泡'}}</text>
                  </view>
                </view>
              </view>

              <view class="timer-controls">
                <view class="control-btn reset-btn" bindtap="resetBrewTimer">
                  <text>🔄 重置</text>
                </view>
                <view class="control-btn primary-btn {{timerRunning ? 'pause' : 'start'}}" bindtap="toggleBrewTimer">
                  <text wx:if="{{!timerRunning}}">▶️ 开始 2分钟</text>
                  <text wx:else>⏸️ 暂停</text>
                </view>
              </view>
            </view>
          </view>

          <!-- ============ 互动功能 2：分步冲泡向导 ============ -->
          <view class="interactive-section" wx:if="{{brewInteractiveConfig}}">
            <view class="section-sub-title">
              <text class="sub-icon">📖</text>
              <text>分步冲泡向导</text>
            </view>

            <view class="brew-guide-container">
              <view class="brew-step-nav">
                <view
                  wx:for="{{brewInteractiveConfig.brewSteps}}"
                  wx:key="step"
                  class="step-nav-item {{activeBrewStep === index ? 'active' : ''}} {{activeBrewStep > index ? 'completed' : ''}}"
                  data-index="{{index}}"
                  bindtap="selectBrewStep"
                >
                  <view class="step-nav-dot">
                    <text wx:if="{{activeBrewStep > index}}">✓</text>
                    <text wx:else>{{item.step}}</text>
                  </view>
                  <text class="step-nav-name">{{item.name}}</text>
                  <view class="step-nav-line" wx:if="{{index < brewInteractiveConfig.brewSteps.length - 1}}"></view>
                </view>
              </view>

              <view class="brew-step-detail">
                <block wx:if="{{brewInteractiveConfig.brewSteps[activeBrewStep]}}">
                  <view class="step-detail-header">
                    <view class="step-detail-icon">{{brewInteractiveConfig.brewSteps[activeBrewStep].icon}}</view>
                    <view class="step-detail-info">
                      <text class="step-detail-title">{{brewInteractiveConfig.brewSteps[activeBrewStep].title}}</text>
                      <text class="step-detail-desc">{{brewInteractiveConfig.brewSteps[activeBrewStep].desc}}</text>
                    </view>
                  </view>

                  <view class="step-detail-content">
                    <text class="step-detail-text">{{brewInteractiveConfig.brewSteps[activeBrewStep].detail}}</text>
                  </view>

                  <view class="step-detail-tip">
                    <text class="tip-bulb">💡</text>
                    <text class="tip-content">{{brewInteractiveConfig.brewSteps[activeBrewStep].tip}}</text>
                  </view>

                  <view class="step-timer-row" wx:if="{{brewInteractiveConfig.brewSteps[activeBrewStep].duration > 0}}">
                    <view class="step-timer-display">
                      <text class="step-timer-label">本步计时</text>
                      <text class="step-timer-value">{{brewStepTimerText}}</text>
                    </view>
                    <view class="step-timer-controls">
                      <view class="mini-btn" bindtap="resetBrewStepTimer">
                        <text>🔄</text>
                      </view>
                      <view class="mini-btn primary {{brewStepTimerRunning ? '' : 'start'}}" bindtap="toggleBrewStepTimer">
                        <text wx:if="{{!brewStepTimerRunning}}">▶️</text>
                        <text wx:else>⏸️</text>
                      </view>
                    </view>
                  </view>
                </block>
              </view>

              <view class="brew-guide-controls">
                <view class="guide-btn prev-btn {{activeBrewStep === 0 ? 'disabled' : ''}}" bindtap="prevBrewStep">
                  <text>⬅️ 上一步</text>
                </view>
                <view class="guide-btn restart-btn" bindtap="restartBrewGuide">
                  <text>🔄 重新开始</text>
                </view>
                <view class="guide-btn next-btn {{activeBrewStep === brewInteractiveConfig.brewSteps.length - 1 ? 'disabled' : ''}}" bindtap="nextBrewStep">
                  <text>下一步 ➡️</text>
                </view>
              </view>
            </view>
          </view>

          <!-- ============ 互动功能 3：用量计算器 ============ -->
          <view class="interactive-section" wx:if="{{brewInteractiveConfig && dosageResult}}">
            <view class="section-sub-title">
              <text class="sub-icon">⚖️</text>
              <text>用量计算器</text>
            </view>

            <view class="dosage-container">
              <view class="dosage-row">
                <text class="dosage-label">饮用人数</text>
                <view class="people-selector">
                  <view class="people-btn" bindtap="decreasePeople">
                    <text>−</text>
                  </view>
                  <view class="people-count">
                    <text class="count-number">{{dosagePeople}}</text>
                    <text class="count-unit">人</text>
                  </view>
                  <view class="people-btn" bindtap="increasePeople">
                    <text>+</text>
                  </view>
                </view>
              </view>

              <view class="dosage-row">
                <text class="dosage-label">口味浓淡</text>
                <view class="taste-selector">
                  <view
                    class="taste-item {{dosageTaste === 'light' ? 'active' : ''}}"
                    data-taste="light"
                    bindtap="selectTaste"
                  >
                    <text class="taste-icon">🌿</text>
                    <text class="taste-name">清淡</text>
                  </view>
                  <view
                    class="taste-item {{dosageTaste === 'medium' ? 'active' : ''}}"
                    data-taste="medium"
                    bindtap="selectTaste"
                  >
                    <text class="taste-icon">🍵</text>
                    <text class="taste-name">适中</text>
                  </view>
                  <view
                    class="taste-item {{dosageTaste === 'strong' ? 'active' : ''}}"
                    data-taste="strong"
                    bindtap="selectTaste"
                  >
                    <text class="taste-icon">☕</text>
                    <text class="taste-name">浓郁</text>
                  </view>
                </view>
              </view>

              <view class="dosage-result">
                <view class="result-header">
                  <text class="result-title">推荐投茶量</text>
                </view>
                <view class="result-body">
                  <view class="result-main">
                    <text class="result-grams">{{dosageResult.grams}}</text>
                    <text class="result-unit">克</text>
                  </view>
                  <view class="result-extra">
                    <text class="extra-info">约 {{dosageResult.teaspoon}} 茶匙</text>
                  </view>
                </view>
                <view class="result-footer">
                  <text class="result-suggestion">{{dosageResult.suggestion}}</text>
                </view>
              </view>
            </view>
          </view>

        </view>
      </view>
    </view>

    <!-- ========== 冲泡记录保存弹窗 ========== -->
    <view class="brew-save-mask" wx:if="{{showBrewSaveModal}}" bindtap="closeBrewSaveModal">
      <view class="brew-save-modal" catchtap="preventBubble">
        <view class="brew-save-header">
          <text class="brew-save-title">☕ 第{{currentBrewRound}}泡完成</text>
          <text class="brew-save-close" bindtap="closeBrewSaveModal">✕</text>
        </view>

        <view class="brew-save-body">
          <view class="brew-save-info">
            <view class="save-info-row">
              <text class="info-label">水温</text>
              <text class="info-value">{{selectedWaterTemp}}℃</text>
            </view>
            <view class="save-info-row">
              <text class="info-label">水质</text>
              <text class="info-value">{{waterHardness === 'soft' ? '软水' : waterHardness === 'hard' ? '硬水' : '中等硬度'}}</text>
            </view>
            <view class="save-info-row" wx:if="{{hardnessAdjustment}}">
              <text class="info-label">投茶量</text>
              <text class="info-value">{{hardnessAdjustment.teaAmount}}g</text>
            </view>
          </view>

          <view class="brew-rating-row">
            <text class="rating-label">评分</text>
            <view class="rating-stars">
              <text
                wx:for="{{[1,2,3,4,5]}}"
                wx:key="*this"
                class="rating-star {{brewRating >= item ? 'active' : ''}}"
                data-rating="{{item}}"
                bindtap="onBrewRatingTap"
              >{{brewRating >= item ? '★' : '☆'}}</text>
            </view>
          </view>

          <view class="brew-tags-section">
            <view class="tags-label">风味标签</view>
            <view class="selected-tags" wx:if="{{brewTags.length > 0}}">
              <text
                wx:for="{{brewTags}}"
                wx:key="*this"
                class="selected-tag"
                data-tag="{{item}}"
                bindtap="onBrewRemoveTag"
              >{{item}} ✕</text>
            </view>
            <view class="preset-tags">
              <text
                wx:for="{{brewPresetTags}}"
                wx:key="*this"
                class="preset-tag {{brewTags.indexOf(item) > -1 ? 'active' : ''}}"
                data-tag="{{item}}"
                bindtap="onBrewPresetTagTap"
              >{{item}}</text>
            </view>
            <view class="custom-tag-row">
              <input
                class="custom-tag-input"
                placeholder="自定义标签（最多6字）"
                value="{{brewInputTag}}"
                bindinput="onBrewInputTagInput"
                confirm-type="done"
                bindconfirm="onBrewAddInputTag"
              />
              <view class="add-tag-btn" bindtap="onBrewAddInputTag">添加</view>
            </view>
          </view>

          <view class="brew-feeling-section">
            <text class="feeling-label">个人感受</text>
            <textarea
              class="feeling-input"
              placeholder="记录这一泡的口感、香气、回味..."
              value="{{brewFeeling}}"
              bindinput="onBrewFeelingInput"
              maxlength="200"
              auto-height
            />
          </view>
        </view>

        <view class="brew-save-footer">
          <view class="save-btn secondary" bindtap="closeBrewSaveModal">
            <text>稍后再说</text>
          </view>
          <view class="save-btn primary" bindtap="saveBrewRecord">
            <text>📒 保存到记录本</text>
          </view>
          <view class="save-btn highlight" bindtap="generateTastingNoteFromBrew">
            <text>📝 生成品鉴笔记</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 区块链存证详情 ========== -->
    <view class="card animate-card blockchain-card module-card" id="anchor-blockchain" style="animation-delay: 0.45s;" wx:if="{{traceData.blockchainInfo}}">
      <view class="card-title module-header">
        <view class="title-left" bindtap="toggleModule" data-key="blockchain">
          <text class="title-icon">🔗</text>
          <text>区块链存证信息</text>
        </view>
        <view class="title-right-actions">
          <view class="bc-verified-badge" wx:if="{{traceData.blockchainInfo.verifyStatus === '已验证'}}">
            <text class="bc-badge-icon">✓</text>
            <text class="bc-badge-text">已验证</text>
          </view>
          <view
            class="cert-wallet-mini-btn {{certWalletStatus.blockchain ? 'saved' : ''}}"
            catchtap="{{certWalletStatus.blockchain ? 'onRemoveSingleCert' : 'onSaveSingleCert'}}"
            data-type="blockchain"
          >
            <text>{{certWalletStatus.blockchain ? '★ 已收藏' : '☆ 收藏证书'}}</text>
          </view>
          <view class="module-toggle {{moduleCollapsed.blockchain ? 'collapsed' : ''}}" bindtap="toggleModule" data-key="blockchain">
            <text class="toggle-icon">▾</text>
          </view>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.blockchain ? 'hidden' : ''}}">

        <!-- 链上验真 -->
        <view class="bc-section bc-verify-section">
          <view class="bc-section-header">
            <text class="bc-section-icon">🔍</text>
            <text class="bc-section-title">链上验真</text>
          </view>

          <!-- 版本选择器 -->
          <view class="bc-version-selector" wx:if="{{bcVersionTxHashList && bcVersionTxHashList.length > 1}}">
            <scroll-view scroll-x="true" class="bc-version-scroll" enhanced show-scrollbar="{{false}}">
              <view class="bc-version-tabs">
                <view
                  class="bc-version-tab {{activeBcVersion === 'current' ? 'active' : ''}}"
                  bindtap="switchBcVersion"
                  data-version="current"
                >
                  <text class="bc-version-tab-label">当前版本</text>
                  <text class="bc-version-tab-ver">v{{traceData.dataVersion}}</text>
                </view>
                <block wx:for="{{bcVersionTxHashList}}" wx:key="version">
                  <view
                    wx:if="{{index > 0}}"
                    class="bc-version-tab {{activeBcVersion === item.version ? 'active' : ''}}"
                    bindtap="switchBcVersion"
                    data-version="{{item.version}}"
                  >
                    <text class="bc-version-tab-label">历史版本</text>
                    <text class="bc-version-tab-ver">v{{item.version}}</text>
                  </view>
                </block>
              </view>
            </scroll-view>
          </view>

          <view class="bc-verify-content">
            <view class="bc-chain-info">
              <view class="bc-info-row">
                <text class="bc-info-label">存证链</text>
                <text class="bc-info-value">{{traceData.blockchainInfo.chainName}}</text>
              </view>
              <block wx:if="{{activeBcVersion === 'current'}}">
                <view class="bc-info-row">
                  <text class="bc-info-label">区块高度</text>
                  <text class="bc-info-value">#{{traceData.blockchainInfo.blockHeight}}</text>
                </view>
                <view class="bc-info-row">
                  <text class="bc-info-label">存证时间</text>
                  <text class="bc-info-value">{{traceData.blockchainInfo.timestamp}}</text>
                </view>
              </block>
              <block wx:for="{{bcVersionTxHashList}}" wx:key="version">
                <block wx:if="{{activeBcVersion === item.version}}">
                  <view class="bc-info-row">
                    <text class="bc-info-label">区块高度</text>
                    <text class="bc-info-value">#{{item.blockHeight}}</text>
                  </view>
                  <view class="bc-info-row">
                    <text class="bc-info-label">存证时间</text>
                    <text class="bc-info-value">{{item.timestamp}}</text>
                  </view>
                  <view class="bc-info-row">
                    <text class="bc-info-label">数据版本</text>
                    <text class="bc-info-value bc-version-highlight">v{{item.version}}</text>
                  </view>
                </block>
              </block>
            </view>

            <!-- 交易哈希（可展开/复制） -->
            <view class="bc-txhash-row">
              <text class="bc-info-label">交易哈希</text>
              <view class="bc-txhash-container">
                <block wx:if="{{activeBcVersion === 'current'}}">
                  <text class="bc-txhash-value" bindtap="toggleTxHashDisplay">
                    {{bcShowTxHashFull ? traceData.blockchainInfo.txHash : traceData.blockchainInfo.txHashShort}}
                  </text>
                </block>
                <block wx:for="{{bcVersionTxHashList}}" wx:key="version">
                  <block wx:if="{{activeBcVersion === item.version}}">
                    <text class="bc-txhash-value" bindtap="toggleTxHashDisplay">
                      {{bcShowTxHashFull ? item.txHash : item.txHashShort}}
                    </text>
                  </block>
                </block>
                <text class="bc-txhash-toggle">{{bcShowTxHashFull ? '收起' : '展开'}}</text>
              </view>
            </view>

            <!-- 操作按钮 -->
            <view class="bc-action-btns">
              <view class="bc-btn bc-btn-verify" bindtap="verifyBlockchainEvidence">
                <text class="bc-btn-icon">{{bcVerifying ? '' : '🔍'}}</text>
                <text class="bc-btn-text">{{bcVerifying ? '验证中...' : '验证存证'}}</text>
                <view class="bc-loading-spinner" wx:if="{{bcVerifying}}"></view>
              </view>
              <view class="bc-btn bc-btn-copy" bindtap="copyTxHash">
                <text class="bc-btn-icon">📋</text>
                <text class="bc-btn-text">复制哈希</text>
              </view>
              <view class="bc-btn bc-btn-explorer" bindtap="openBlockExplorer">
                <text class="bc-btn-icon">🌐</text>
                <text class="bc-btn-text">区块浏览器</text>
              </view>
            </view>
          </view>

          <!-- 验证结果弹层 -->
          <view class="bc-verify-result" wx:if="{{bcShowVerifyResult && bcVerifyResult}}">
            <view class="bc-result-header">
              <view class="bc-result-status {{bcVerifyResult.verified ? 'success' : 'fail'}}">
                <text class="bc-result-status-icon">{{bcVerifyResult.verified ? '✅' : '❌'}}</text>
                <text class="bc-result-status-text">{{bcVerifyResult.verified ? '验证通过' : '验证未通过'}}</text>
              </view>
              <text class="bc-result-close" bindtap="closeBlockchainVerifyResult">✕</text>
            </view>
            <view class="bc-result-body" wx:if="{{bcVerifyResult.verified}}">
              <view class="bc-result-item">
                <text class="bc-result-label">交易哈希</text>
                <text class="bc-result-value bc-result-hash">{{bcVerifyResult.txHash}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">存证链</text>
                <text class="bc-result-value">{{bcVerifyResult.chainName}} ({{bcVerifyResult.chainId}})</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">区块高度</text>
                <text class="bc-result-value">#{{bcVerifyResult.blockHeight}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">共识机制</text>
                <text class="bc-result-value">{{bcVerifyResult.consensusType}} · {{bcVerifyResult.nodeCount}}节点</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">上链字段</text>
                <text class="bc-result-value">{{bcVerifyResult.onChainFieldsCount}}项已上链</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">关联产品</text>
                <text class="bc-result-value">{{bcVerifyResult.productName}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">批次号</text>
                <text class="bc-result-value">{{bcVerifyResult.batchNo}}</text>
              </view>
              <view class="bc-result-item">
                <text class="bc-result-label">验证时间</text>
                <text class="bc-result-value">{{bcVerifyResult.verifyTime}}</text>
              </view>
            </view>
            <view class="bc-result-body" wx:else="">
              <text class="bc-result-fail-msg">{{bcVerifyResult.message || '未找到对应记录'}}</text>
            </view>
          </view>
        </view>

        <!-- 存证内容说明 -->
        <view class="bc-section bc-onchain-section">
          <view class="bc-section-header">
            <text class="bc-section-icon">📝</text>
            <text class="bc-section-title">已上链字段</text>
            <text class="bc-onchain-count">{{traceData.blockchainInfo.onChainFields.length}}项</text>
          </view>
          <view class="bc-onchain-list">
            <view class="bc-onchain-item" wx:for="{{traceData.blockchainInfo.onChainFields}}" wx:key="key">
              <view class="bc-onchain-left">
                <view class="bc-onchain-check {{item.onChain ? 'checked' : ''}}">
                  <text wx:if="{{item.onChain}}">✓</text>
                </view>
                <text class="bc-onchain-label">{{item.label}}</text>
              </view>
              <view class="bc-onchain-right">
                <text class="bc-onchain-value">{{item.value}}</text>
                <text class="bc-onchain-tag" wx:if="{{item.onChain}}">已上链</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 防伪联动 -->
        <view class="bc-section bc-anticounter-section">
          <view class="bc-section-header" bindtap="toggleScanRecords">
            <text class="bc-section-icon">🛡️</text>
            <text class="bc-section-title">防伪查询记录</text>
            <text class="bc-scan-count">{{traceData.blockchainInfo.scanRecords.totalQueryCount}}次</text>
            <text class="bc-section-arrow {{bcShowScanRecords ? 'expanded' : ''}}">›</text>
          </view>
          <view class="bc-anticounter-summary">
            <view class="bc-anticounter-stat">
              <text class="bc-stat-number">{{traceData.blockchainInfo.scanRecords.totalQueryCount}}</text>
              <text class="bc-stat-label">累计查询</text>
            </view>
            <view class="bc-anticounter-stat">
              <text class="bc-stat-number">{{traceData.blockchainInfo.scanRecords.records.length}}</text>
              <text class="bc-stat-label">上链记录</text>
            </view>
            <view class="bc-anticounter-stat">
              <text class="bc-stat-number">1</text>
              <text class="bc-stat-label">首次扫码</text>
            </view>
          </view>

          <!-- 扫码记录列表 -->
          <view class="bc-scan-records" wx:if="{{bcShowScanRecords}}">
            <view class="bc-scan-record-item" wx:for="{{traceData.blockchainInfo.scanRecords.records}}" wx:key="time">
              <view class="bc-scan-type-badge {{item.type === 'first' ? 'first' : 'repeat'}}">
                <text>{{item.type === 'first' ? '首' : '复'}}</text>
              </view>
              <view class="bc-scan-info">
                <view class="bc-scan-top">
                  <text class="bc-scan-location">{{item.location}}</text>
                  <text class="bc-scan-type-text">{{item.type === 'first' ? '首次扫码' : '重复扫码'}}</text>
                </view>
                <view class="bc-scan-bottom">
                  <text class="bc-scan-time">{{item.time}}</text>
                  <text class="bc-scan-ip">IP: {{item.ip}}</text>
                </view>
              </view>
            </view>

            <!-- 当前扫码结果 -->
            <view class="bc-current-scan" wx:if="{{bcAntiCounterResult && bcAntiCounterResult.success}}">
              <view class="bc-current-scan-header">
                <text class="bc-current-scan-title">本次查询</text>
                <view class="bc-current-scan-badge {{bcAntiCounterResult.isFirstScan ? 'first' : 'repeat'}}">
                  <text>{{bcAntiCounterResult.isFirstScan ? '首次扫码' : '重复扫码'}}</text>
                </view>
              </view>
              <view class="bc-current-scan-body">
                <text class="bc-current-scan-product">{{bcAntiCounterResult.productName}}</text>
                <text class="bc-current-scan-total">累计查询 {{bcAntiCounterResult.totalQueryCount}} 次</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 时间戳服务 -->
        <view class="bc-section bc-tsa-section">
          <view class="bc-section-header" bindtap="toggleTsaCertificate">
            <text class="bc-section-icon">⏱️</text>
            <text class="bc-section-title">司法级时间戳</text>
            <text class="bc-tsa-badge">TSA</text>
            <text class="bc-section-arrow {{bcShowTsaCert ? 'expanded' : ''}}">›</text>
          </view>
          <view class="bc-tsa-brief">
            <view class="bc-tsa-brief-item">
              <text class="bc-tsa-brief-label">签发机构</text>
              <text class="bc-tsa-brief-value">{{traceData.blockchainInfo.tsaCertificate.issuer}}</text>
            </view>
            <view class="bc-tsa-brief-item">
              <text class="bc-tsa-brief-label">时间戳精度</text>
              <text class="bc-tsa-brief-value">{{traceData.blockchainInfo.tsaCertificate.accuracy}}</text>
            </view>
          </view>

          <!-- TSA证书详情 -->
          <view class="bc-tsa-cert-detail" wx:if="{{bcShowTsaCert && bcTsaCertData}}">
            <view class="bc-tsa-cert-card">
              <view class="bc-tsa-cert-header">
                <text class="bc-tsa-cert-icon">🔏</text>
                <text class="bc-tsa-cert-title">TSA 时间戳证书</text>
              </view>
              <view class="bc-tsa-cert-body">
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">证书编号</text>
                  <view class="bc-tsa-cert-value-row">
                    <text class="bc-tsa-cert-value bc-mono">{{bcTsaCertData.certSerial}}</text>
                    <text class="bc-tsa-cert-copy" bindtap="copyTsaCertSerial">复制</text>
                  </view>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">签名算法</text>
                  <text class="bc-tsa-cert-value">{{bcTsaCertData.algorithm}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">时间戳服务</text>
                  <text class="bc-tsa-cert-value bc-mono">{{bcTsaCertData.tsServer}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">精确时间</text>
                  <text class="bc-tsa-cert-value bc-mono">{{bcTsaCertData.timestamp}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">TSA令牌哈希</text>
                  <text class="bc-tsa-cert-value bc-mono bc-hash-small">{{bcTsaCertData.tsTokenHash}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">存证哈希</text>
                  <text class="bc-tsa-cert-value bc-mono bc-hash-small">{{bcTsaCertData.evidenceHash}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">法律依据</text>
                  <text class="bc-tsa-cert-value bc-legal">{{bcTsaCertData.legalBasis}}</text>
                </view>
                <view class="bc-tsa-cert-item">
                  <text class="bc-tsa-cert-label">有效期</text>
                  <text class="bc-tsa-cert-value">{{bcTsaCertData.validityPeriod}}</text>
                </view>
              </view>
              <view class="bc-tsa-cert-footer">
                <text class="bc-tsa-cert-verify-hint">此证书由司法级时间戳服务机构签发，具有法律效力</text>
              </view>
            </view>
          </view>
        </view>

      </view>
    </view>

    <!-- ========== 模块9：社区评价 ========== -->
    <view class="card animate-card module-card reviews-card" id="anchor-reviews" style="animation-delay: 0.5s;" wx:if="{{reviewData}}">
      <view class="card-title module-header">
        <view class="title-left" bindtap="toggleModule" data-key="reviews">
          <text class="title-icon">⭐</text>
          <text>用户评价</text>
          <view class="title-badge reviews-badge">{{reviewData.summary.totalCount}}条评价</view>
        </view>
        <view class="title-right-actions">
          <view class="review-write-btn" bindtap="openReviewModal">
            <text>✍️ 写评价</text>
          </view>
          <view class="module-toggle {{moduleCollapsed.reviews ? 'collapsed' : ''}}" bindtap="toggleModule" data-key="reviews">
            <text class="toggle-icon">▾</text>
          </view>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.reviews ? 'hidden' : ''}}">

        <!-- 评价概览 -->
        <view class="review-overview">
          <view class="review-score-main">
            <text class="score-number">{{weightedAverageRating || reviewData.summary.averageRating}}</text>
            <view class="score-stars">
              <text wx:for="{{5}}" wx:key="index" class="star {{index < (weightedAverageRating || reviewData.summary.averageRating) ? 'filled' : 'empty'}}">★</text>
            </view>
            <text class="score-count">{{reviewData.summary.totalCount}}人评价</text>
            <view class="trust-badge-main" wx:if="{{weightedAverageRating > 0}}">
              <text class="trust-badge-icon">⚖️</text>
              <text class="trust-badge-text">信任加权</text>
            </view>
          </view>

          <!-- 维度评分 -->
          <view class="review-dimensions">
            <view class="dimension-item" wx:for="{{ratingDimensions}}" wx:key="key">
              <view class="dimension-header">
                <text class="dimension-icon">{{item.icon}}</text>
                <text class="dimension-name">{{item.name}}</text>
                <text class="dimension-score">{{reviewData.summary.dimensionAverages[item.key]}}</text>
              </view>
              <view class="dimension-bar">
                <view class="dimension-bar-fill" style="width: {{reviewData.summary.dimensionAverages[item.key] * 20}}%;"></view>
              </view>
            </view>
          </view>

          <!-- 口感标签统计 -->
          <view class="review-tag-stats">
            <text class="tag-stats-title">口感标签：</text>
            <view class="tag-stats-list">
              <view class="tag-stat-item" wx:for="{{reviewData.summary.tagStats}}" wx:key="tag">
                <text class="tag-stat-name">{{item.tag}}</text>
                <text class="tag-stat-count">({{item.count}})</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 评分分布 -->
        <view class="review-rating-dist">
          <text class="dist-title">评分分布</text>
          <view class="dist-bars">
            <view class="dist-bar-item" wx:for="{{reviewData.summary.ratingDistribution}}" wx:key="rating" wx:for-item="dist">
              <text class="dist-rating">{{dist.rating}}星</text>
              <view class="dist-bar-container">
                <view class="dist-bar-fill" style="width: {{dist.percent}}%;"></view>
              </view>
              <text class="dist-percent">{{dist.percent}}%</text>
            </view>
          </view>
        </view>

        <!-- 筛选和排序 -->
        <view class="review-filter-bar">
          <scroll-view scroll-x="true" class="filter-scroll">
            <view class="filter-tabs">
              <view class="filter-tab {{reviewFilter === 'all' ? 'active' : ''}}" bindtap="onReviewFilterChange" data-filter="all">
                <text>全部({{reviewData.summary.totalCount}})</text>
              </view>
              <view class="filter-tab {{reviewFilter === 'verified' ? 'active' : ''}}" bindtap="onTrustFilterChange" data-filter="verified">
                <text class="verified-filter-icon">✓</text>
                <text>已验真</text>
              </view>
              <view class="filter-tab {{reviewFilter === 'image' ? 'active' : ''}}" bindtap="onReviewFilterChange" data-filter="image">
                <text>晒图({{reviewData.summary.hasImageCount}})</text>
              </view>
              <view class="filter-tab {{reviewFilter === 'good' ? 'active' : ''}}" bindtap="onReviewFilterChange" data-filter="good">
                <text>好评</text>
              </view>
              <view class="filter-tab {{reviewFilter === 'mid' ? 'active' : ''}}" bindtap="onReviewFilterChange" data-filter="mid">
                <text>中评</text>
              </view>
              <view class="filter-tab {{reviewFilter === 'bad' ? 'active' : ''}}" bindtap="onReviewFilterChange" data-filter="bad">
                <text>差评</text>
              </view>
            </view>
          </scroll-view>
          <view class="sort-dropdown">
            <text class="sort-label">排序：</text>
            <picker mode="selector" range="{{reviewSortLabels}}" value="{{reviewSortIndex}}" bindchange="onReviewSortChange">
              <view class="sort-value">
                <text>{{reviewSortLabels[reviewSortIndex] || '综合排序'}}</text>
                <text class="sort-arrow">▾</text>
              </view>
            </picker>
          </view>
        </view>

        <!-- 从笔记发布入口 -->
        <view class="publish-from-note-bar" wx:if="{{!hasSubmittedReview}}">
          <view class="publish-note-tip">
            <text class="note-icon">📝</text>
            <text class="note-tip-text">已写品鉴笔记？一键发布为评价</text>
          </view>
          <view class="publish-note-btn" bindtap="openNotePublishModal">
            <text>发布</text>
          </view>
        </view>

        <!-- 已验证标识提示 -->
        <view class="scan-verified-tip" wx:if="{{isScanVerified && !hasSubmittedReview}}">
          <text class="verified-icon">✓</text>
          <text class="verified-text">您已扫码验真，评价将显示「已验真购买」标识</text>
        </view>

        <!-- 评价列表 -->
        <view class="review-list">
          <block wx:for="{{processedReviews}}" wx:key="id" wx:for-item="review">
            <view class="review-item {{review.isPinned ? 'pinned' : ''}} {{review.isQuality ? 'quality' : ''}}">
              <!-- 置顶/优质标识 -->
              <view class="review-badges" wx:if="{{review.isPinned || review.isQuality}}">
                <view class="review-badge pinned" wx:if="{{review.isPinned}}">
                  <text>📌 置顶</text>
                </view>
                <view class="review-badge quality" wx:if="{{review.isQuality}}">
                  <text>🏆 优质评价</text>
                </view>
              </view>

              <!-- 审核状态 -->
              <view class="review-audit-status pending" wx:if="{{review.auditStatus === 'pending'}}">
                <text>⏳ 审核中</text>
              </view>
              <view class="review-audit-status rejected" wx:if="{{review.auditStatus === 'rejected'}}">
                <text>⚠️ 未通过审核</text>
              </view>

              <!-- 用户信息 -->
              <view class="review-user">
                <image class="user-avatar" src="{{review.userAvatar}}" mode="aspectFill" />
                <view class="user-info">
                  <view class="user-name-row">
                    <text class="user-name">{{review.userName}}</text>
                    <view class="user-level" wx:if="{{review.userLevel > 0}}">
                      <text>Lv.{{review.userLevel}}</text>
                    </view>
                    <view class="trust-level-badge" wx:if="{{review.trustLevel}}" style="background: {{review.trustLevel.color}}20; border-color: {{review.trustLevel.color}};">
                      <text class="trust-level-icon" style="color: {{review.trustLevel.color}};">{{review.trustLevel.icon}}</text>
                      <text class="trust-level-name" style="color: {{review.trustLevel.color}};">{{review.trustLevel.name}}</text>
                    </view>
                  </view>
                  <view class="review-meta">
                    <view class="review-rating-small">
                      <text wx:for="{{5}}" wx:key="index" class="star-small {{index < review.rating ? 'filled' : 'empty'}}">★</text>
                    </view>
                    <text class="review-time">{{review.createTime}}</text>
                    <view class="review-trust-weight" wx:if="{{review.qualityScore}}">
                      <text class="trust-weight-label">质量分:</text>
                      <text class="trust-weight-value">{{review.qualityScore}}</text>
                    </view>
                  </view>
                </view>
                <view class="review-more" bindtap="openReportModal" data-review-id="{{review.id}}">
                  <text>⋯</text>
                </view>
              </view>

              <!-- 订单信息 -->
              <view class="review-order-info" wx:if="{{review.orderInfo}}">
                <text class="order-sku">规格：{{review.orderInfo.sku}}</text>
                <text class="order-time">购买时间：{{review.orderInfo.buyTime}}</text>
              </view>

              <!-- 维度评分 -->
              <view class="review-dimensions-small" wx:if="{{review.dimensions}}">
                <view class="dim-small-item" wx:for="{{ratingDimensions}}" wx:key="key" wx:for-item="dim">
                  <text class="dim-small-name">{{dim.name}}:</text>
                  <text class="dim-small-score">{{review.dimensions[dim.key]}}</text>
                </view>
              </view>

              <!-- 口感标签 -->
              <view class="review-taste-tags" wx:if="{{review.tasteTags && review.tasteTags.length > 0}}">
                <view class="taste-tag" wx:for="{{review.tasteTags}}" wx:key="*this" wx:for-item="tag">
                  <text>{{tag}}</text>
                </view>
              </view>

              <!-- 评价内容 -->
              <view class="review-content">
                <text>{{review.content}}</text>
              </view>

              <!-- 晒图 -->
              <view class="review-images" wx:if="{{review.images && review.images.length > 0}}">
                <image
                  wx:for="{{review.images}}"
                  wx:key="*this"
                  wx:for-item="img"
                  class="review-image"
                  src="{{img}}"
                  mode="aspectFill"
                  bindtap="previewReviewDetailImage"
                  data-src="{{img}}"
                  data-urls="{{review.images}}"
                />
              </view>

              <!-- 品牌官方回复 -->
              <view class="brand-reply" wx:if="{{review.brandReply}}">
                <view class="brand-reply-header">
                  <text class="brand-reply-icon">🏢</text>
                  <text class="brand-reply-name">{{review.brandReply.replierName}}</text>
                  <view class="official-badge" wx:if="{{review.brandReply.isOfficial}}">
                    <text>官方</text>
                  </view>
                  <text class="brand-reply-time">{{review.brandReply.replyTime}}</text>
                </view>
                <view class="brand-reply-content">
                  <text>{{review.brandReply.content}}</text>
                </view>
              </view>

              <!-- 操作栏 -->
              <view class="review-actions">
                <view class="action-btn like {{review.isLiked ? 'liked' : ''}}" bindtap="onLikeReview" data-review-id="{{review.id}}">
                  <text class="action-icon">{{review.isLiked ? '❤️' : '🤍'}}</text>
                  <text class="action-text">{{review.likeCount}}</text>
                </view>
                <view class="action-btn comment">
                  <text class="action-icon">💬</text>
                  <text class="action-text">{{review.commentCount}}</text>
                </view>
                <view class="action-btn brand-reply-btn" bindtap="openBrandReplyModal" data-review-id="{{review.id}}">
                  <text class="action-icon">🏢</text>
                  <text class="action-text">品牌回复</text>
                </view>
              </view>
            </view>
          </block>

          <!-- 无评价提示 -->
          <view class="review-empty" wx:if="{{!reviewData.reviews || reviewData.reviews.length === 0}}">
            <text class="empty-icon">📝</text>
            <text class="empty-text">暂无评价，快来发表第一条评价吧！</text>
            <view class="empty-btn" bindtap="openReviewModal">
              <text>写评价</text>
            </view>
          </view>
        </view>

      </view>
    </view>

