        <view class="callout-icon-box">
          <text class="callout-big-icon">{{selectedMapMarker.icon}}</text>
        </view>
        <view class="callout-title-info">
          <text class="callout-title">{{selectedMapMarker.callout.title}}</text>
          <view class="callout-type-tag">
            <text wx:if="{{selectedMapMarker.type === 'teaGarden'}}">🍃 茶树园</text>
            <text wx:elif="{{selectedMapMarker.type === 'osmanthusGarden'}}">{{varietyStyle ? varietyStyle.icon : '🌼'}} 桂花园</text>
            <text wx:elif="{{selectedMapMarker.type === 'factory'}}">🏭 加工厂</text>
            <text wx:else>📍 地点</text>
          </view>
