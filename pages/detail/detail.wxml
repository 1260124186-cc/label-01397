          >
            <text>{{certWalletStatus.testReport ? '★ 已收藏' : '☆ 收藏证书'}}</text>
          </view>
          <view class="module-toggle {{moduleCollapsed.test ? 'collapsed' : ''}}" aria-hidden="true" bindtap="toggleModule" data-key="test">
