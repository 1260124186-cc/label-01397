  <view class="reward-modal {{showRewardModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeRewardModal">
    <view class="reward-modal-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="reward-celebration">
        <text class="celebration-icon">🎉</text>
        <text class="celebration-title">恭喜获得奖励</text>
      </view>
      <view class="reward-list" wx:if="{{lastRewardResult && lastRewardResult.rewards}}">
        <view wx:if="{{lastRewardResult.rewards.inviter}}" class="reward-item inviter-reward">
          <view class="reward-role">您的奖励</view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.inviter.type === 'points' || lastRewardResult.rewards.inviter.value}}">
            <text class="reward-icon">✨</text>
            <view class="reward-info">
              <text class="reward-name">绿色积分</text>
              <text class="reward-value">+{{lastRewardResult.rewards.inviter.value || lastRewardResult.rewards.inviter}} 分</text>
            </view>
          </view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.inviter.coupon}}">
            <text class="reward-icon">🎫</text>
            <view class="reward-info">
              <text class="reward-name">{{lastRewardResult.rewards.inviter.coupon.name}}</text>
              <text class="reward-value">
                {{lastRewardResult.rewards.inviter.coupon.type === 'cash' ? '¥' + lastRewardResult.rewards.inviter.coupon.value : (lastRewardResult.rewards.inviter.coupon.value * 10) + '折'}}
              </text>
            </view>
          </view>
        </view>
        <view wx:if="{{lastRewardResult.rewards.invitee}}" class="reward-item invitee-reward">
          <view class="reward-role">好友的奖励</view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.invitee.type === 'points' || lastRewardResult.rewards.invitee.value}}">
            <text class="reward-icon">✨</text>
            <view class="reward-info">
              <text class="reward-name">绿色积分</text>
              <text class="reward-value">+{{lastRewardResult.rewards.invitee.value || 50}} 分</text>
            </view>
          </view>
          <view class="reward-detail" wx:if="{{lastRewardResult.rewards.invitee.coupon}}">
            <text class="reward-icon">🎫</text>
            <view class="reward-info">
              <text class="reward-name">{{lastRewardResult.rewards.invitee.coupon.name}}</text>
              <text class="reward-value">
                {{lastRewardResult.rewards.invitee.coupon.type === 'cash' ? '¥' + lastRewardResult.rewards.invitee.coupon.value : (lastRewardResult.rewards.invitee.coupon.value * 10) + '折'}}
              </text>
            </view>
          </view>
        </view>
      </view>
      <view class="reward-actions">
        <view class="reward-action-btn primary" bindtap="closeRewardModal">
          <text>知道了</text>
        </view>
        <view class="reward-action-btn secondary" bindtap="shareAfterReward">
          <text>继续邀请好友</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 评价弹窗 ==================== -->
  <view class="review-modal {{showReviewModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeReviewModal">
    <view class="review-modal-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="review-modal-header">
        <text class="review-modal-title">✍️ 发表评价</text>
        <view class="review-modal-close" bindtap="closeReviewModal">×</view>
      </view>

      <scroll-view scroll-y="true" class="review-modal-body">
        <!-- 总体评分 -->
        <view class="form-section">
          <text class="form-label">总体评分</text>
          <view class="rating-stars-large">
            <view
              wx:for="{{5}}"
              wx:key="index"
              class="star-large {{index < reviewForm.overallRating ? 'filled' : 'empty'}}"
              bindtap="onOverallRatingChange"
              data-rating="{{index + 1}}"
            >
              <text>★</text>
            </view>
            <text class="rating-text">{{reviewForm.overallRating === 5 ? '非常满意' : (reviewForm.overallRating === 4 ? '满意' : (reviewForm.overallRating === 3 ? '一般' : (reviewForm.overallRating === 2 ? '不满意' : '非常不满意')))}}</text>
          </view>
        </view>

        <!-- 维度评分 -->
        <view class="form-section">
          <text class="form-label">详细评分</text>
          <view class="dimension-ratings">
            <view class="dimension-rating-item" wx:for="{{ratingDimensions}}" wx:key="key">
              <view class="dimension-rating-header">
                <text class="dimension-rating-icon">{{item.icon}}</text>
                <text class="dimension-rating-name">{{item.name}}</text>
              </view>
              <view class="dimension-rating-stars">
                <view
                  wx:for="{{5}}"
                  wx:key="*this"
                  wx:for-item="starIdx"
                  class="star-small {{starIdx < reviewForm.dimensionRatings[item.key] ? 'filled' : 'empty'}}"
                  bindtap="onDimensionRatingChange"
                  data-dimension="{{item.key}}"
                  data-rating="{{starIdx + 1}}"
                >
                  <text>★</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 口感标签 -->
        <view class="form-section">
          <text class="form-label">口感标签（可多选）</text>
          <view class="taste-tags-select">
            <view
              wx:for="{{tasteTags}}"
              wx:key="key"
              class="taste-tag-select {{reviewForm.selectedTags.indexOf(item.name) > -1 ? 'selected' : ''}}"
              bindtap="onTasteTagToggle"
              data-tag="{{item.name}}"
              style="border-color: {{item.color}}; {{reviewForm.selectedTags.indexOf(item.name) > -1 ? 'background: ' + item.color + '20;' : ''}}"
            >
              <text class="tag-icon">{{item.icon}}</text>
              <text class="tag-name">{{item.name}}</text>
            </view>
          </view>
        </view>

        <!-- 评价内容 -->
        <view class="form-section">
          <text class="form-label">评价内容</text>
          <textarea
            class="review-textarea"
            placeholder="分享您的真实感受，帮助其他茶友做出选择~"
            maxlength="500"
            value="{{reviewForm.content}}"
            bindinput="onReviewContentInput"
            auto-height
          />
          <text class="textarea-count">{{reviewForm.content.length}}/500</text>
        </view>

        <!-- 上传图片 -->
        <view class="form-section">
          <text class="form-label">晒图（最多9张）</text>
          <view class="image-upload-grid">
            <view
              wx:for="{{reviewForm.images}}"
              wx:key="*this"
              wx:for-item="img"
              wx:for-index="imgIndex"
              class="uploaded-image-item"
            >
              <image
                class="uploaded-image"
                src="{{img}}"
                mode="aspectFill"
                bindtap="previewReviewImage"
                data-index="{{imgIndex}}"
              />
              <view class="remove-image-btn" bindtap="removeReviewImage" data-index="{{imgIndex}}">×</view>
            </view>
            <view
              class="add-image-btn"
              bindtap="chooseReviewImages"
              wx:if="{{reviewForm.images.length < 9}}"
            >
              <text class="add-icon">+</text>
              <text class="add-text">添加图片</text>
            </view>
          </view>
        </view>

        <!-- 审核提示 -->
        <view class="audit-tip">
          <text class="tip-icon">💡</text>
          <text class="tip-text">评价将经过审核后展示，请遵守社区规范，文明发言</text>
        </view>
      </scroll-view>

      <view class="review-modal-footer">
        <view class="review-submit-btn" bindtap="submitReview">
          <text>提交评价</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 举报弹窗 ==================== -->
  <view class="report-modal {{showReportModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeReportModal">
    <view class="report-modal-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="report-modal-header">
        <text class="report-modal-title">⚠️ 举报评价</text>
        <view class="report-modal-close" bindtap="closeReportModal">×</view>
      </view>

      <view class="report-modal-body">
        <!-- 举报原因 -->
        <view class="form-section">
          <text class="form-label">请选择举报原因</text>
          <view class="report-reason-list">
            <view
              wx:for="{{reportReasons}}"
              wx:key="key"
              class="report-reason-item {{reportForm.reason === item.key ? 'selected' : ''}}"
              bindtap="onReportReasonSelect"
              data-reason="{{item.key}}"
            >
              <view class="reason-radio">
                <view class="radio-inner" wx:if="{{reportForm.reason === item.key}}"></view>
              </view>
              <text class="reason-text">{{item.name}}</text>
            </view>
          </view>
        </view>

        <!-- 补充说明 -->
        <view class="form-section">
          <text class="form-label">补充说明（选填）</text>
          <textarea
            class="report-textarea"
            placeholder="请详细描述举报原因..."
            maxlength="200"
            value="{{reportForm.content}}"
            bindinput="onReportContentInput"
          />
          <text class="textarea-count">{{reportForm.content.length}}/200</text>
        </view>

        <!-- 提示 -->
        <view class="report-tip">
          <text class="tip-icon">🔒</text>
          <text class="tip-text">您的举报信息将被严格保密，我们会在24小时内处理</text>
        </view>
      </view>

      <view class="report-modal-footer">
        <view class="report-cancel-btn" bindtap="closeReportModal">
          <text>取消</text>
        </view>
        <view class="report-submit-btn" bindtap="submitReport">
          <text>提交举报</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 审核提示弹窗 ==================== -->
  <view class="audit-tip-modal {{showAuditTip ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeAuditTip">
    <view class="audit-tip-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="audit-tip-header">
        <text class="audit-tip-icon">⏳</text>
        <text class="audit-tip-title">评价审核中</text>
      </view>
      <view class="audit-tip-body">
        <text class="audit-tip-text">您的评价已提交，正在进行人工审核。审核通过后将公开显示，请耐心等待。</text>
        <view class="audit-tip-reason">
          <text class="reason-title">审核原因：</text>
          <text class="reason-text">短时间内评价频率较高，为保障评价真实性需人工审核</text>
        </view>
      </view>
      <view class="audit-tip-footer">
        <view class="audit-tip-confirm-btn" bindtap="closeAuditTip">
          <text>我知道了</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 从笔记发布为评价弹窗 ==================== -->
  <view class="note-publish-modal {{showNotePublishModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeNotePublishModal">
    <view class="note-publish-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="note-publish-header">
        <text class="note-publish-title">📝 发布笔记为评价</text>
        <view class="note-publish-close" bindtap="closeNotePublishModal">×</view>
      </view>
      <scroll-view scroll-y="true" class="note-publish-body" wx:if="{{notePublishData}}">
        <view class="note-publish-preview">
          <view class="preview-label">评价预览</view>
          <view class="preview-rating">
            <text class="preview-rating-label">评分：</text>
            <text wx:for="{{5}}" wx:key="index" class="preview-star {{index < notePublishData.rating ? 'filled' : 'empty'}}">★</text>
            <text class="preview-rating-value">{{notePublishData.rating}}.0</text>
          </view>
          <view class="preview-dimensions" wx:if="{{notePublishData.dimensions}}">
            <view class="preview-dim-item" wx:for="{{ratingDimensions}}" wx:key="key" wx:for-item="dim">
              <text class="preview-dim-name">{{dim.name}}：</text>
              <text class="preview-dim-value">{{notePublishData.dimensions[dim.key]}}分</text>
            </view>
          </view>
          <view class="preview-tags" wx:if="{{notePublishData.tasteTags && notePublishData.tasteTags.length > 0}}">
            <text class="preview-tags-label">口感标签：</text>
            <view class="preview-tag-list">
              <view class="preview-tag" wx:for="{{notePublishData.tasteTags}}" wx:key="*this" wx:for-item="tag">
                <text>{{tag}}</text>
              </view>
            </view>
          </view>
          <view class="preview-content">
            <text class="preview-content-label">评价内容：</text>
            <text class="preview-content-text">{{notePublishData.content}}</text>
          </view>
          <view class="preview-trust" wx:if="{{notePublishData.trustLevel}}">
            <text class="preview-trust-label">信任级别：</text>
            <view class="preview-trust-badge" style="background: {{notePublishData.trustLevel.color}}20; border-color: {{notePublishData.trustLevel.color}};">
              <text class="preview-trust-icon" style="color: {{notePublishData.trustLevel.color}};">{{notePublishData.trustLevel.icon}}</text>
              <text class="preview-trust-name" style="color: {{notePublishData.trustLevel.color}};">{{notePublishData.trustLevel.name}}</text>
            </view>
          </view>
        </view>
        <view class="note-publish-tip">
          <text class="tip-icon">💡</text>
          <text class="tip-text">发布后，您的品鉴笔记内容将作为评价公开显示</text>
        </view>
      </scroll-view>
      <view class="note-publish-footer">
        <view class="note-publish-cancel-btn" bindtap="closeNotePublishModal">
          <text>取消</text>
        </view>
        <view class="note-publish-confirm-btn" bindtap="publishReviewFromNote">
          <text>发布评价</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 变更详情弹窗（字段级 diff） ==================== -->
  <view class="changelog-modal {{showChangeLogModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeChangeLogModal">
    <view class="changelog-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="changelog-header">
        <view class="changelog-title-row">
          <text class="changelog-title-icon">📝</text>
          <text class="changelog-title">数据变更详情</text>
        </view>
        <view class="changelog-close" bindtap="closeChangeLogModal">×</view>
      </view>

      <scroll-view scroll-y="true" class="changelog-body" wx:if="{{currentChangeLogVersion}}">
        <!-- 版本摘要 -->
        <view class="changelog-version-summary">
          <view class="changelog-version-badge">v{{currentChangeLogVersion.version}}</view>
          <view class="changelog-version-meta">
            <text class="changelog-version-time">{{currentChangeLogVersion.timestamp}}</text>
            <text class="changelog-version-author" wx:if="{{currentChangeLogVersion.updatedBy}}">· {{currentChangeLogVersion.updatedBy}}</text>
          </view>
          <view class="changelog-version-desc" wx:if="{{currentChangeLogVersion.summary}}">
            {{currentChangeLogVersion.summary}}
          </view>
          <view class="changelog-version-report" wx:if="{{currentChangeLogVersion.reportNo}}" bindtap="gotoHistoryReportFromChange" data-reportno="{{currentChangeLogVersion.reportNo}}">
            <text class="report-link-icon">📄</text>
            <text class="report-link-text">关联报告：{{currentChangeLogVersion.reportNo}} ›</text>
          </view>
          <view class="changelog-version-bc" wx:if="{{currentChangeLogVersion.txHash}}">
            <text class="bc-link-icon">🔗</text>
            <text class="bc-link-text">交易哈希：{{currentChangeLogVersion.txHashShort}}</text>
          </view>
        </view>

        <!-- 字段级 diff 列表 -->
        <view class="field-changes-section" wx:if="{{currentChangeLogVersion.fieldChanges && currentChangeLogVersion.fieldChanges.length > 0}}">
          <view class="section-header">
            <text class="section-icon">📊</text>
            <text class="section-title">字段变更明细（{{currentChangeLogVersion.fieldChanges.length}}项）</text>
          </view>
          <view class="field-changes-list">
            <block wx:for="{{currentChangeLogVersion.fieldChanges}}" wx:key="fieldPath">
              <view class="field-change-item">
                <view class="field-change-header">
                  <text class="field-category-tag {{item.category === '农残检测' ? 'test' : (item.category === '基础信息' ? 'basic' : 'other')}}">
                    {{item.category}}
                  </text>
                  <text class="field-change-type {{item.changeType === 'add' ? 'add' : (item.changeType === 'delete' ? 'delete' : 'update')}}">
                    {{item.changeType === 'add' ? '新增' : (item.changeType === 'delete' ? '删除' : '更新')}}
                  </text>
                </view>
                <view class="field-change-label">{{item.fieldLabel}}</view>
                <view class="field-change-values">
                  <block wx:if="{{item.changeType !== 'add'}}">
                    <view class="value-box old">
                      <text class="value-label">变更前</text>
                      <text class="value-text">{{item.oldValue}}{{item.unit ? ' ' + item.unit : ''}}</text>
                    </view>
                  </block>
                  <view class="value-arrow" wx:if="{{item.changeType === 'update'}}">→</view>
                  <block wx:if="{{item.changeType !== 'delete'}}">
                    <view class="value-box new">
                      <text class="value-label">变更后</text>
                      <text class="value-text">{{item.newValue}}{{item.unit ? ' ' + item.unit : ''}}</text>
                    </view>
                  </block>
                </view>
              </view>
            </block>
          </view>
        </view>
        <view class="no-changes-tip" wx:else>
          <text class="no-changes-icon">ℹ️</text>
          <text class="no-changes-text">该版本无字段级变更记录</text>
        </view>
      </scroll-view>

      <view class="changelog-footer">
        <view class="changelog-confirm-btn" bindtap="closeChangeLogModal">
          <text>我知道了</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 历史版本列表弹窗（只读） ==================== -->
  <view class="version-history-modal {{showVersionHistoryModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeVersionHistory">
    <view class="version-history-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="version-history-header">
        <view class="version-history-title-row">
          <text class="version-history-title-icon">📚</text>
          <text class="version-history-title">历史版本</text>
        </view>
        <view class="version-history-close" bindtap="closeVersionHistory">×</view>
      </view>

      <view class="version-history-readonly-tip" wx:if="{{isViewingHistoryVersion}}">
        <text class="readonly-icon">👁️</text>
        <text class="readonly-text">您正在查看历史版本（只读模式）</text>
        <view class="back-current-btn" bindtap="restoreCurrentVersion">返回当前版本</view>
      </view>

      <scroll-view scroll-y="true" class="version-history-body">
        <view class="version-timeline">
          <block wx:for="{{versionHistoryList}}" wx:key="version">
            <view class="version-timeline-item {{selectedVersionIndex === index ? 'selected' : ''}}">
              <view class="timeline-dot {{index === 0 ? 'latest' : ''}}"></view>
              <view class="timeline-line" wx:if="{{index < versionHistoryList.length - 1}}"></view>
              <view class="version-item-card {{selectedVersionIndex === index ? 'active' : ''}}" bindtap="selectHistoryVersion" data-index="{{index}}">
                <view class="version-card-header">
                  <view class="version-card-badge {{index === 0 ? 'current' : 'history'}}">
                    {{index === 0 ? '当前版本' : '历史版本'}}
                  </view>
                  <view class="version-card-number">v{{item.version}}</view>
                </view>
                <view class="version-card-meta">
                  <text class="version-card-time">🕒 {{item.timestamp}}</text>
                  <text class="version-card-author" wx:if="{{item.updatedBy}}">· {{item.updatedBy}}</text>
                </view>
                <view class="version-card-summary" wx:if="{{item.summary}}">{{item.summary}}</view>
                <view class="version-card-footer">
                  <view class="version-card-changes-count" wx:if="{{item.fieldChanges}}">
                    <text class="count-icon">📝</text>
                    <text class="count-text">{{item.fieldChanges.length}}项变更</text>
                  </view>
                  <view class="version-card-action" catchtap="openVersionChangeLog" data-version="{{item}}">
                    <text>查看变更</text>
                    <text class="action-arrow">›</text>
                  </view>
                </view>
                <view class="version-card-bc-info" wx:if="{{item.txHash}}">
                  <text class="bc-info-icon">🔗</text>
                  <text class="bc-info-text">{{item.txHashShort}}</text>
                </view>
              </view>
            </view>
          </block>
        </view>
      </scroll-view>

      <view class="version-history-footer" wx:if="{{!isViewingHistoryVersion}}">
        <view class="version-history-cancel-btn" bindtap="closeVersionHistory">
          <text>关闭</text>
        </view>
      </view>
      <view class="version-history-footer" wx:else>
        <view class="version-history-back-btn" bindtap="restoreCurrentVersion">
          <text>返回当前版本</text>
        </view>
      </view>
    </view>
  </view>

</view>

<!-- ==================== 加载状态（降级，骨架屏优先） ==================== -->
<view class="loading-container" wx:if="{{loading && skeletonLoading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">正在加载溯源信息...</text>
</view>
