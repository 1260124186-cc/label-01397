                    <text>🌡️ {{record.temperature}}℃</text>
                  </view>
                  <view class="comp-record-operator">👤 {{record.operator}}</view>
                </view>
              </view>
              <view class="records-col">
                <view class="records-col-header silver">银桂（{{processComparisonData.recordsComparison.silver.length}}次）</view>
                <view
                  wx:for="{{processComparisonData.recordsComparison.silver}}"
                  wx:for-item="record"
                  wx:key="round"
                  class="comp-record-item silver-record"
                >
                  <view class="comp-record-round">第{{record.round}}窨</view>
                  <view class="comp-record-info">
                    <text>⏱️ {{record.duration}}h</text>
                    <text>🌡️ {{record.temperature}}℃</text>
                  </view>
                  <view class="comp-record-operator">👤 {{record.operator}}</view>
                </view>
