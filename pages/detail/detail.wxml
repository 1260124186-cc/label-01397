    <!-- ========== 模块6：农残检测 ========== -->
    <view class="card animate-card module-card test-module-card {{testChartData.overallPass ? '' : 'test-abnormal-card'}}" id="anchor-test" role="region" aria-label="{{i18n.tabTitleTest}}" style="animation-delay: 0.35s;">
      <view class="card-title module-header">
        <view class="title-left" bindtap="toggleModule" data-key="test" role="button" aria-expanded="{{!moduleCollapsed.test}}" aria-label="{{i18n.tabTitleTest}}">
          <text class="title-icon" aria-hidden="true">🔬</text>
          <text role="heading" aria-level="2">{{i18n.tabTitleTest}}</text>
          <view class="title-badge {{testChartData.overallPass ? 'status-badge-pass' : 'status-badge-fail'}} status-badge {{testChartData.overallPass ? '' : 'danger'}}" wx:if="{{traceData.pesticideTest}}" data-status="{{testChartData.overallPass ? 'pass' : 'fail'}}">
            {{testChartData.overallPass ? (currentLang === 'en-US' ? 'All Passed' : '全部合格' : (currentLang === 'en-US' ? 'Abnormal' : '存在异常'}}
          </view>
        </view>
        <view class="title-right-actions">
          <view
            class="cert-wallet-mini-btn {{certWalletStatus.testReport ? 'saved' : ''}}"
