<!--
  桂花茶溯源小程序 - 溯源详情页
  功能：完整展示溯源信息（基础信息、树龄、窨制工艺、绿色溯源、农残检测、冲泡建议）
-->

<!-- ==================== 阅读进度条 ==================== -->
<view class="reading-progress" wx:if="{{!skeletonLoading}}">
  <view class="progress-bar" style="width: {{readingProgress}}%;"></view>
</view>

<!-- ==================== 骨架屏 ==================== -->
<view class="skeleton-container" wx:if="{{skeletonLoading}}">
  <view class="skeleton-header">
    <view class="skeleton-avatar shimmer"></view>
    <view class="skeleton-title shimmer" style="width: 200rpx;"></view>
    <view class="skeleton-subtitle shimmer" style="width: 160rpx;"></view>
  </view>
  
  <view class="skeleton-content">
    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 40%;"></view>
      <view class="skeleton-grid">
        <view class="skeleton-grid-item shimmer"></view>
        <view class="skeleton-grid-item shimmer"></view>
        <view class="skeleton-grid-item shimmer"></view>
        <view class="skeleton-grid-item shimmer"></view>
      </view>
    </view>
    
    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 30%;"></view>
      <view class="skeleton-line shimmer" style="width: 80%;"></view>
      <view class="skeleton-line shimmer" style="width: 60%;"></view>
    </view>
    
    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 35%;"></view>
      <view class="skeleton-params">
        <view class="skeleton-param shimmer"></view>
        <view class="skeleton-param shimmer"></view>
        <view class="skeleton-param shimmer"></view>
        <view class="skeleton-param shimmer"></view>
      </view>
    </view>
    
    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 45%;"></view>
      <view class="skeleton-image shimmer"></view>
      <view class="skeleton-line shimmer" style="width: 70%;"></view>
    </view>
  </view>
</view>

<view class="page-container {{showPdfModal ? 'no-scroll' : ''}}" style="{{showPdfModal ? 'top: -' + scrollTop + 'px;' : ''}}" wx:if="{{!skeletonLoading && traceData}}">
  
  <!-- ==================== 顶部产品概览 ==================== -->
  <view class="product-header">
    <view class="header-bg-pattern"></view>
    <view class="product-info">
      <view class="product-icon">
        <text wx:if="{{traceData.osmanthusInfo.variety === '金桂'}}">🌼</text>
        <text wx:else>🌸</text>
      </view>
      <view class="product-name">{{traceData.basicInfo.productName}}</view>
      <view class="product-batch">批次号：{{traceData.basicInfo.batchNo}}</view>
      
      <!-- 区块链存证标识 -->
      <view class="blockchain-badge" wx:if="{{traceData.blockchainInfo}}">
        <view class="badge-icon">🔗</view>
        <view class="badge-text">
          <text class="badge-title">区块链存证</text>
          <text class="badge-desc">数据真实可查・不可篡改</text>
        </view>
        <view class="badge-status">{{traceData.blockchainInfo.verifyStatus}}</view>
      </view>
    </view>
  </view>

  <!-- ==================== 锚点 Tab 导航栏 ==================== -->
  <view class="anchor-tab-bar {{anchorSticky ? 'sticky' : ''}}" id="anchor-tab-bar">
    <scroll-view scroll-x="true" class="anchor-scroll" enhanced show-scrollbar="{{false}}">
      <view class="anchor-tabs">
        <view 
          wx:for="{{anchorTabs}}" 
          wx:key="key"
          class="anchor-tab-item {{activeAnchor === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          data-index="{{index}}"
          bindtap="onAnchorTap"
        >
          <text class="anchor-tab-icon">{{item.icon}}</text>
          <text class="anchor-tab-label">{{item.label}}</text>
          <view class="anchor-tab-indicator" wx:if="{{activeAnchor === item.key}}"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ==================== 主要内容区域 ==================== -->
  <view class="main-content">
    
    <!-- ========== 模块1：基础信息 ========== -->
    <view class="card animate-card module-card" id="anchor-basic" style="animation-delay: 0.1s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="basic">
        <view class="title-left">
          <text class="title-icon">📋</text>
          <text>基础信息</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.basic ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.basic ? 'hidden' : ''}}">
        <view class="info-grid">
          <view class="info-item">
            <view class="info-label">溯源ID</view>
            <view class="info-value highlight" bindtap="copyTraceId">
              {{traceData.basicInfo.traceId}}
              <text class="copy-icon">📋</text>
            </view>
          </view>
          <view class="info-item">
            <view class="info-label">批次号</view>
            <view class="info-value">{{traceData.basicInfo.batchNo}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">采摘时间</view>
            <view class="info-value">{{traceData.basicInfo.pickTime}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">出厂时间</view>
            <view class="info-value">{{traceData.basicInfo.productionTime}}</view>
          </view>
        </view>
        
        <!-- 产地图片（懒加载） -->
        <view class="module-image-wrapper" id="img-origin">
          <block wx:if="{{lazyImageMap.originImage}}">
            <image 
              class="module-image" 
              src="{{traceData.images.originImage}}" 
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">📍 产地实拍</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🖼️</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块2：树龄信息（核心特色） ========== -->
    <view class="card animate-card tree-age-card module-card" id="anchor-treeAge" style="animation-delay: 0.15s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="treeAge">
        <view class="title-left">
          <text class="title-icon">🌳</text>
          <text>树龄信息</text>
          <view class="title-badge">核心特色</view>
        </view>
        <view class="module-toggle {{moduleCollapsed.treeAge ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.treeAge ? 'hidden' : ''}}">
        <view class="tree-age-content">
          <view class="tree-item">
            <view class="tree-icon tea-tree">🍃</view>
            <view class="tree-info">
              <view class="tree-type">茶树龄</view>
              <view class="tree-age">
                <text class="age-number">{{traceData.treeAge.teaTreeAge}}</text>
                <text class="age-unit">年</text>
              </view>
              <view class="tree-location">产地：{{traceData.treeAge.teaTreeLocation}}</view>
            </view>
          </view>
          <view class="tree-divider"></view>
          <view class="tree-item">
            <view class="tree-icon osmanthus-tree">🌼</view>
            <view class="tree-info">
              <view class="tree-type">桂花树龄</view>
              <view class="tree-age">
                <text class="age-number">{{traceData.treeAge.osmanthusTreeAge}}</text>
                <text class="age-unit">年</text>
              </view>
              <view class="tree-location">产地：{{traceData.treeAge.osmanthusTreeLocation}}</view>
            </view>
          </view>
        </view>
        
        <!-- 茶树产地图片（懒加载） -->
        <view class="module-image-wrapper" id="img-tea-origin">
          <block wx:if="{{lazyImageMap.teaOriginImage}}">
            <image 
              class="module-image" 
              src="{{traceData.images.teaOriginImage}}" 
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">🍃 百年茶树产地</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🍃</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块3：桂花信息 ========== -->
    <view class="card animate-card module-card" style="animation-delay: 0.2s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="osmanthus">
        <view class="title-left">
          <text class="title-icon">🌸</text>
          <text>桂花信息</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.osmanthus ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.osmanthus ? 'hidden' : ''}}">
        <view class="osmanthus-content">
          <view class="osmanthus-variety">
            <view class="variety-badge {{traceData.osmanthusInfo.variety === '金桂' ? 'golden' : 'silver'}}">
              {{traceData.osmanthusInfo.variety}}
            </view>
          </view>
          <view class="info-grid">
            <view class="info-item">
              <view class="info-label">产地</view>
              <view class="info-value">{{traceData.osmanthusInfo.origin}}</view>
            </view>
            <view class="info-item">
              <view class="info-label">采摘时间</view>
              <view class="info-value">{{traceData.osmanthusInfo.pickTime}}</view>
            </view>
            <view class="info-item">
              <view class="info-label">花色</view>
              <view class="info-value">{{traceData.osmanthusInfo.color}}</view>
            </view>
            <view class="info-item">
              <view class="info-label">香气特点</view>
              <view class="info-value">{{traceData.osmanthusInfo.fragrance}}</view>
            </view>
          </view>
        </view>
        
        <!-- 桂花产地图片（懒加载） -->
        <view class="module-image-wrapper" id="img-osmanthus-origin">
          <block wx:if="{{lazyImageMap.osmanthusOriginImage}}">
            <image 
              class="module-image" 
              src="{{traceData.images.osmanthusOriginImage}}" 
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">🌸 桂花产地</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🌸</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块4：窨制工艺（核心模块） ========== -->
    <view class="card animate-card module-card" id="anchor-process" style="animation-delay: 0.25s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="process">
        <view class="title-left">
          <text class="title-icon">🫖</text>
          <text>窨制工艺</text>
          <view class="title-badge gold">核心工艺</view>
        </view>
        <view class="module-toggle {{moduleCollapsed.process ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.process ? 'hidden' : ''}}">
        
        <!-- 工艺参数 -->
        <view class="process-params">
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.scentingTimes}}</view>
            <view class="param-label">窨制次数</view>
          </view>
          <view class="param-divider"></view>
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.scentingDuration}}h</view>
            <view class="param-label">每次时长</view>
          </view>
          <view class="param-divider"></view>
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.temperature}}℃</view>
            <view class="param-label">窨制温度</view>
          </view>
          <view class="param-divider"></view>
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.ratio}}</view>
            <view class="param-label">花茶配比</view>
          </view>
        </view>
        
        <!-- 环境参数 -->
        <view class="env-params">
          <view class="env-item">
            <text class="env-icon">💧</text>
            <text>湿度：{{traceData.scentingProcess.humidity}}%</text>
          </view>
          <view class="env-item">
            <text class="env-icon">✨</text>
            <text>洁净度：{{traceData.scentingProcess.workshopCleanliness}}</text>
          </view>
        </view>
        
        <!-- 工艺图片（懒加载） -->
        <view class="module-image-wrapper" id="img-process">
          <block wx:if="{{lazyImageMap.processImage}}">
            <image 
              class="module-image" 
              src="{{traceData.images.processImage}}" 
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">🫖 窨制工艺车间</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🫖</text>
          </view>
        </view>
        
        <!-- 工艺流程图 -->
        <view class="process-flow">
          <view class="flow-title">工艺流程图</view>
          <view class="flow-steps">
            <view 
              wx:for="{{traceData.scentingProcess.processSteps}}" 
              wx:key="step"
              class="flow-step {{activeProcessStep === index ? 'active' : ''}}"
              data-index="{{index}}"
              bindtap="toggleProcessStep"
            >
              <view class="step-icon">{{item.icon}}</view>
              <view class="step-name">{{item.name}}</view>
              <view class="step-arrow" wx:if="{{index < traceData.scentingProcess.processSteps.length - 1}}">→</view>
            </view>
          </view>
          <!-- 步骤详情（点击展开） -->
          <view class="step-detail" wx:if="{{activeProcessStep >= 0}}">
            <view class="detail-icon">{{traceData.scentingProcess.processSteps[activeProcessStep].icon}}</view>
            <view class="detail-text">
              <view class="detail-name">{{traceData.scentingProcess.processSteps[activeProcessStep].name}}</view>
              <view class="detail-desc">{{traceData.scentingProcess.processSteps[activeProcessStep].desc}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块5：绿色溯源（新增核心模块） ========== -->
    <view class="card animate-card green-card module-card" id="anchor-green" style="animation-delay: 0.3s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="green">
        <view class="title-left">
          <text class="title-icon">♻️</text>
          <text>绿色溯源</text>
          <view class="title-badge green">环保认证</view>
        </view>
        <view class="module-toggle {{moduleCollapsed.green ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.green ? 'hidden' : ''}}">
        
        <!-- 认证证书图片（懒加载） -->
        <view class="module-image-wrapper" id="img-cert">
          <block wx:if="{{lazyImageMap.certImage}}">
            <image 
              class="module-image" 
              src="{{traceData.images.certImage}}" 
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">📜 环保认证证书</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">📜</text>
          </view>
        </view>
        
        <!-- 生态种植 -->
        <view class="green-section">
          <view class="green-header">
            <text class="green-icon">{{traceData.greenTrace.ecoPlanting.icon}}</text>
            <text class="green-title">{{traceData.greenTrace.ecoPlanting.title}}</text>
            <view class="green-cert">{{traceData.greenTrace.ecoPlanting.certification}}</view>
          </view>
          <view class="green-records">
            <view 
              wx:for="{{traceData.greenTrace.ecoPlanting.records}}" 
              wx:key="*this"
              class="record-item"
            >
              <text class="record-check">✓</text>
              <text>{{item}}</text>
            </view>
          </view>
        </view>
        
        <!-- 环保包装 -->
        <view class="green-section">
          <view class="green-header">
            <text class="green-icon">{{traceData.greenTrace.ecoPacking.icon}}</text>
            <text class="green-title">{{traceData.greenTrace.ecoPacking.title}}</text>
            <view class="green-cert">{{traceData.greenTrace.ecoPacking.certification}}</view>
          </view>
          <view class="green-records">
            <view 
              wx:for="{{traceData.greenTrace.ecoPacking.records}}" 
              wx:key="*this"
              class="record-item"
            >
              <text class="record-check">✓</text>
              <text>{{item}}</text>
            </view>
          </view>
        </view>
        
        <!-- 绿色物流 -->
        <view class="green-section">
          <view class="green-header">
            <text class="green-icon">{{traceData.greenTrace.ecoLogistics.icon}}</text>
            <text class="green-title">{{traceData.greenTrace.ecoLogistics.title}}</text>
            <view class="green-reduction">{{traceData.greenTrace.ecoLogistics.carbonReduction}}</view>
          </view>
          <view class="green-records">
            <view 
              wx:for="{{traceData.greenTrace.ecoLogistics.records}}" 
              wx:key="*this"
              class="record-item"
            >
              <text class="record-check">✓</text>
              <text>{{item}}</text>
            </view>
          </view>
        </view>
        
        <!-- 数据安全提示 -->
        <view class="privacy-notice">
          <text class="privacy-icon">🔒</text>
          <text class="privacy-text">数据加密存储，不收集无关个人信息，符合《个人信息保护法》</text>
        </view>
      </view>
    </view>

    <!-- ========== 模块6：农残检测 ========== -->
    <view class="card animate-card module-card test-module-card {{testChartData.overallPass ? '' : 'test-abnormal-card'}}" id="anchor-test" style="animation-delay: 0.35s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="test">
        <view class="title-left">
          <text class="title-icon">🔬</text>
          <text>农残检测</text>
          <view class="title-badge {{testChartData.overallPass ? '' : 'danger'}}" wx:if="{{traceData.pesticideTest}}">
            {{testChartData.overallPass ? '全部合格' : '存在异常'}}
          </view>
        </view>
        <view class="module-toggle {{moduleCollapsed.test ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.test ? 'hidden' : ''}}">
        
        <!-- 异常警告横幅 -->
        <view class="abnormal-warning-banner" wx:if="{{!testChartData.overallPass}}">
          <view class="warning-icon">⚠️</view>
          <view class="warning-content">
            <view class="warning-title">检测结果异常</view>
            <view class="warning-desc">本次检测存在不合格项，请谨慎食用</view>
          </view>
        </view>

        <!-- 检测机构信息 -->
        <view class="test-institution">
          <view class="institution-icon">🏛️</view>
          <view class="institution-info">
            <view class="institution-name">{{traceData.pesticideTest.institution}}</view>
            <view class="institution-meta">
              <text bindtap="copyReportNo">报告编号：{{traceData.pesticideTest.reportNo}} 📋</text>
              <text>检测日期：{{traceData.pesticideTest.testDate}}</text>
            </view>
          </view>
        </view>

        <!-- 操作按钮组：保存 / 转发 / 验真 -->
        <view class="test-action-buttons">
          <view class="action-btn" bindtap="saveReportToAlbum">
            <text class="action-icon">📸</text>
            <text class="action-text">保存相册</text>
          </view>
          <view class="action-btn" bindtap="shareReport">
            <text class="action-icon">📤</text>
            <text class="action-text">转发好友</text>
          </view>
          <view class="action-btn" bindtap="openVerifyModal">
            <text class="action-icon">✅</text>
            <text class="action-text">报告验真</text>
          </view>
        </view>

        <!-- 国标对比总览 -->
        <view class="standard-overview">
          <view class="overview-label">
            <text class="overview-icon">📊</text>
            <text>国标 GB 2763-2021 对比</text>
          </view>
          <view class="overview-badge {{testChartData.overallPass ? 'pass' : 'fail'}}">
            {{testChartData.overallPass ? '全部达标' : '部分超标'}}
          </view>
        </view>
        
        <!-- 茶叶检测结果：国标对比进度条图表 -->
        <view class="test-results">
          <view class="test-category">
            <text class="category-icon">🍃</text>
            <text>茶叶农残检测</text>
          </view>
          
          <!-- 进度条图表 -->
          <view class="progress-chart">
            <view 
              wx:for="{{testChartData.teaTests}}" 
              wx:key="item"
              class="progress-item {{item.level}}"
            >
              <view class="progress-header">
                <text class="progress-name">{{item.item}}</text>
                <view class="progress-status {{item.isPass ? 'pass' : 'fail'}}">
                  {{item.status}}
                </view>
              </view>
              <view class="progress-bar-container">
                <view class="progress-bar-bg">
                  <view class="progress-bar-fill {{item.level}}" style="width: {{item.percent}}%;"></view>
                  <view class="progress-limit-line" style="left: 100%;"></view>
                </view>
                <view class="progress-labels">
                  <text class="progress-value">检测值：{{item.displayValue}}{{item.unit}}</text>
                  <text class="progress-limit">限值：{{item.limit}}{{item.unit}}</text>
                </view>
                <view class="progress-multiple" wx:if="{{item.isPass}}">
                  <text class="multiple-label">低于限值</text>
                  <text class="multiple-value">{{item.multiple}}倍</text>
                </view>
              </view>
              <!-- 异常说明 -->
              <view class="abnormal-desc" wx:if="{{!item.isPass && item.description}}">
                <text class="desc-icon">⚠️</text>
                <text class="desc-text">{{item.description}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 桂花检测结果：国标对比进度条图表 -->
        <view class="test-results">
          <view class="test-category">
            <text class="category-icon">🌸</text>
            <text>桂花农残检测</text>
          </view>
          
          <!-- 进度条图表 -->
          <view class="progress-chart">
            <view 
              wx:for="{{testChartData.osmanthusTests}}" 
              wx:key="item"
              class="progress-item {{item.level}}"
            >
              <view class="progress-header">
                <text class="progress-name">{{item.item}}</text>
                <view class="progress-status {{item.isPass ? 'pass' : 'fail'}}">
                  {{item.status}}
                </view>
              </view>
              <view class="progress-bar-container">
                <view class="progress-bar-bg">
                  <view class="progress-bar-fill {{item.level}}" style="width: {{item.percent}}%;"></view>
                  <view class="progress-limit-line" style="left: 100%;"></view>
                </view>
                <view class="progress-labels">
                  <text class="progress-value">检测值：{{item.displayValue}}{{item.unit}}</text>
                  <text class="progress-limit">限值：{{item.limit}}{{item.unit}}</text>
                </view>
                <view class="progress-multiple" wx:if="{{item.isPass}}">
                  <text class="multiple-label">低于限值</text>
                  <text class="multiple-value">{{item.multiple}}倍</text>
                </view>
              </view>
              <!-- 异常说明 -->
              <view class="abnormal-desc" wx:if="{{!item.isPass && item.description}}">
                <text class="desc-icon">⚠️</text>
                <text class="desc-text">{{item.description}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 历史检测报告时间轴 -->
        <view class="history-reports-section" wx:if="{{traceData.pesticideTest.historyReports && traceData.pesticideTest.historyReports.length > 0}}">
          <view class="history-header" bindtap="toggleHistoryTimeline">
            <view class="history-title">
              <text class="history-icon">📅</text>
              <text>历次检测记录</text>
              <text class="history-count">共 {{traceData.pesticideTest.historyReports.length}} 份</text>
            </view>
            <view class="history-toggle {{showHistoryTimeline ? 'expanded' : ''}}">
              <text>▾</text>
            </view>
          </view>
          <view class="history-timeline {{showHistoryTimeline ? 'show' : ''}}">
            <view 
              wx:for="{{traceData.pesticideTest.historyReports}}" 
              wx:key="reportNo"
              class="timeline-item {{index === 0 ? 'latest' : ''}} {{item.status === '不合格' ? 'abnormal' : ''}}"
              bindtap="viewHistoryReport"
              data-report="{{item}}"
            >
              <view class="timeline-dot {{item.status === '不合格' ? 'danger' : (item.statusLevel === '优秀' ? 'excellent' : 'good')}}"></view>
              <view class="timeline-line" wx:if="{{index < traceData.pesticideTest.historyReports.length - 1}}"></view>
              <view class="timeline-content">
                <view class="timeline-date">{{item.testDate}}</view>
                <view class="timeline-info">
                  <text class="timeline-report-no">{{item.reportNo}}</text>
                  <view class="timeline-status {{item.status === '不合格' ? 'danger' : (item.statusLevel === '优秀' ? 'excellent' : 'good')}}">
                    {{item.status}}
                  </view>
                </view>
                <view class="timeline-meta">
                  <text>{{item.institution}}</text>
                  <text wx:if="{{item.batchNo}}">批次：{{item.batchNo}}</text>
                </view>
                <view class="timeline-tag" wx:if="{{index === 0}}">最新</view>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 国标对比提示 -->
        <view class="standard-tip {{testChartData.overallPass ? '' : 'danger'}}">
          <text class="tip-icon">{{testChartData.overallPass ? '✅' : '⚠️'}}</text>
          <text class="tip-text">{{traceData.pesticideTest.comparisonTip}}</text>
        </view>
        
        <!-- 查看完整报告按钮 -->
        <view class="view-report-btn" bindtap="showPdfReport">
          <text class="btn-icon">📄</text>
          <text>查看完整报告（PDF样式）</text>
        </view>
      </view>
    </view>

    <!-- ========== 模块7：冲泡建议 ========== -->
    <view class="card animate-card module-card" id="anchor-brew" style="animation-delay: 0.4s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="brew">
        <view class="title-left">
          <text class="title-icon">☕</text>
          <text>冲泡建议</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.brew ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.brew ? 'hidden' : ''}}">
        
        <view class="brewing-content">
          <view class="brewing-params">
            <view class="brewing-item">
              <view class="brewing-icon">🌡️</view>
              <view class="brewing-label">水温</view>
              <view class="brewing-value">{{traceData.brewingGuide.waterTemp}}</view>
            </view>
            <view class="brewing-item">
              <view class="brewing-icon">⏱️</view>
              <view class="brewing-label">冲泡时长</view>
              <view class="brewing-value">{{traceData.brewingGuide.brewingTime}}</view>
            </view>
            <view class="brewing-item">
              <view class="brewing-icon">🔄</view>
              <view class="brewing-label">续泡次数</view>
              <view class="brewing-value">{{traceData.brewingGuide.rebrewTimes}}</view>
            </view>
          </view>
          
          <view class="brewing-extra">
            <view class="extra-item">
              <text class="extra-label">推荐用水：</text>
              <text class="extra-value">{{traceData.brewingGuide.waterType}}</text>
            </view>
            <view class="extra-item">
              <text class="extra-label">推荐茶具：</text>
              <text class="extra-value">{{traceData.brewingGuide.teawareType}}</text>
            </view>
          </view>
          
          <view class="brewing-tips">
            <view class="tips-title">冲泡小贴士</view>
            <view class="tips-list">
              <view 
                wx:for="{{traceData.brewingGuide.tips}}" 
                wx:key="*this"
                class="tip-item"
              >
                <text class="tip-num">{{index + 1}}</text>
                <text class="tip-text">{{item}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 区块链存证详情 ========== -->
    <view class="card animate-card blockchain-card module-card" id="anchor-blockchain" style="animation-delay: 0.45s;" wx:if="{{traceData.blockchainInfo}}">
      <view class="card-title module-header" bindtap="toggleModule" data-key="blockchain">
        <view class="title-left">
          <text class="title-icon">🔗</text>
          <text>区块链存证信息</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.blockchain ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.blockchain ? 'hidden' : ''}}">
        <view class="blockchain-detail">
          <view class="blockchain-item">
            <text class="bc-label">存证链</text>
            <text class="bc-value">{{traceData.blockchainInfo.chainName}}</text>
          </view>
          <view class="blockchain-item">
            <text class="bc-label">区块高度</text>
            <text class="bc-value">{{traceData.blockchainInfo.blockHeight}}</text>
          </view>
          <view class="blockchain-item">
            <text class="bc-label">交易哈希</text>
            <text class="bc-value hash">{{traceData.blockchainInfo.txHash}}</text>
          </view>
          <view class="blockchain-item">
            <text class="bc-label">存证时间</text>
            <text class="bc-value">{{traceData.blockchainInfo.timestamp}}</text>
          </view>
        </view>
      </view>
    </view>

  </view>

  <!-- ==================== 返回顶部按钮 ==================== -->
  <view class="back-top {{showBackTop ? 'show' : ''}}" bindtap="scrollToTop">
    <text class="back-top-icon">↑</text>
  </view>

  <!-- ==================== PDF报告弹窗 ==================== -->
  <view class="pdf-modal {{showPdfModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closePdfModal">
    <view class="pdf-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="pdf-header {{testChartData.overallPass ? '' : 'danger-header'}}">
        <text class="pdf-title">农残检测报告</text>
        <view class="pdf-close" bindtap="closePdfModal">×</view>
      </view>
      <view class="pdf-body">
        <view class="pdf-institution">
          <view class="pdf-logo">🏛️</view>
          <view class="pdf-name">{{traceData.pesticideTest.institution}}</view>
        </view>
        <view class="pdf-info">
          <view class="pdf-row">
            <text class="pdf-label">报告编号：</text>
            <text class="pdf-value">{{traceData.pesticideTest.reportNo}}</text>
          </view>
          <view class="pdf-row">
            <text class="pdf-label">检测日期：</text>
            <text class="pdf-value">{{traceData.pesticideTest.testDate}}</text>
          </view>
          <view class="pdf-row">
            <text class="pdf-label">国标依据：</text>
            <text class="pdf-value">{{traceData.pesticideTest.standard}}</text>
          </view>
        </view>

        <!-- PDF 异常警告 -->
        <view class="pdf-abnormal-warning" wx:if="{{!testChartData.overallPass}}">
          <text class="pdf-warning-icon">⚠️</text>
          <text class="pdf-warning-text">本次检测存在不合格项</text>
        </view>

        <view class="pdf-divider"></view>
        <view class="pdf-results">
          <view class="pdf-section-title">茶叶检测项目</view>
          <view wx:for="{{testChartData.teaTests}}" wx:key="item" class="pdf-result-item {{item.isPass ? '' : 'abnormal-item'}}">
            <text>{{item.item}}：{{item.displayValue}}{{item.unit}}（限值{{item.limit}}{{item.unit}}）</text>
            <text class="pdf-result-tag {{item.isPass ? 'pdf-pass' : 'pdf-fail'}}">{{item.isPass ? '✓合格' : '✗不合格'}}</text>
          </view>
          <view class="pdf-section-title" style="margin-top: 24rpx;">桂花检测项目</view>
          <view wx:for="{{testChartData.osmanthusTests}}" wx:key="item" class="pdf-result-item {{item.isPass ? '' : 'abnormal-item'}}">
            <text>{{item.item}}：{{item.displayValue}}{{item.unit}}（限值{{item.limit}}{{item.unit}}）</text>
            <text class="pdf-result-tag {{item.isPass ? 'pdf-pass' : 'pdf-fail'}}">{{item.isPass ? '✓合格' : '✗不合格'}}</text>
          </view>
        </view>
        <view class="pdf-footer">
          <view class="pdf-stamp {{testChartData.overallPass ? '' : 'pdf-stamp-danger'}}">{{testChartData.overallPass ? '检验合格' : '存在异常'}}</view>
          <view class="pdf-conclusion">{{traceData.pesticideTest.comparisonTip}}</view>
          
          <!-- PDF 操作按钮 -->
          <view class="pdf-action-row">
            <view class="pdf-action-btn" bindtap="saveReportToAlbum" catchtap="saveReportToAlbum">
              <text>📸 保存相册</text>
            </view>
            <view class="pdf-action-btn" bindtap="shareReport" catchtap="shareReport">
              <text>📤 转发</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 报告验真弹窗 ==================== -->
  <view class="verify-modal {{showVerifyModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closeVerifyModal">
    <view class="verify-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="verify-header">
        <text class="verify-title">🔍 检测报告验真</text>
        <view class="verify-close" bindtap="closeVerifyModal">×</view>
      </view>
      <view class="verify-body">
        <!-- 输入区域 -->
        <view class="verify-input-section">
          <text class="verify-label">请输入报告编号</text>
          <view class="verify-input-wrapper">
            <input 
              class="verify-input" 
              placeholder="如 NTQC-2025-09876" 
              value="{{verifyInput}}"
              bindinput="onVerifyInputChange"
            />
          </view>
          <view class="verify-buttons">
            <view class="verify-btn primary" bindtap="doVerifyReport">
              <text wx:if="{{!verifying}}">立即验真</text>
              <text wx:else>验真中...</text>
            </view>
            <view class="verify-btn secondary" bindtap="openVerifyWebsite">
              <text>官网验真</text>
            </view>
          </view>
        </view>

        <!-- 验真结果 -->
        <view class="verify-result" wx:if="{{verifyResult}}">
          <view class="verify-result-header {{verifyResult.valid ? 'valid' : 'invalid'}}">
            <text class="verify-result-icon">{{verifyResult.valid ? '✅' : '❌'}}</text>
            <text class="verify-result-title">{{verifyResult.valid ? '验真通过' : '验真失败'}}</text>
          </view>
          <view class="verify-result-body" wx:if="{{verifyResult.valid}}">
            <view class="verify-row">
              <text class="verify-row-label">报告编号</text>
              <text class="verify-row-value">{{verifyResult.reportNo}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">产品名称</text>
              <text class="verify-row-value">{{verifyResult.productName}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">批次号</text>
              <text class="verify-row-value">{{verifyResult.batchNo}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">检测机构</text>
              <text class="verify-row-value">{{verifyResult.institution}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">检测日期</text>
              <text class="verify-row-value">{{verifyResult.testDate}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">检测结果</text>
              <text class="verify-row-value {{verifyResult.status === '存在异常项' ? 'danger-text' : ''}}">{{verifyResult.status}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">验真时间</text>
              <text class="verify-row-value">{{verifyResult.verifyTime}}</text>
            </view>
          </view>
          <view class="verify-result-body invalid-body" wx:else>
            <text class="verify-invalid-msg">{{verifyResult.message}}</text>
          </view>
        </view>

        <view class="verify-tip">
          <text class="verify-tip-icon">💡</text>
          <text class="verify-tip-text">报告编号可在检测报告右上角或本页面找到</text>
        </view>
      </view>
    </view>
  </view>

</view>

<!-- ==================== 加载状态（降级，骨架屏优先） ==================== -->
<view class="loading-container" wx:if="{{loading && skeletonLoading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">正在加载溯源信息...</text>
</view>
