<!--
  桂花茶溯源小程序 - 溯源详情页
  功能：完整展示溯源信息（基础信息、树龄、窨制工艺、绿色溯源、农残检测、冲泡建议）
-->

<!-- ==================== 阅读进度条 ==================== -->
<view class="reading-progress" wx:if="{{!skeletonLoading}}">
  <view class="progress-bar" style="width: {{readingProgress}}%;"></view>
</view>

<!-- ==================== 版本更新 Toast ==================== -->
<view class="version-update-toast" wx:if="{{showVersionUpdateToast && versionUpdateInfo}}" bindtap="viewVersionChangesFromToast">
  <view class="toast-content">
    <view class="toast-icon">🔄</view>
    <view class="toast-text">
      <view class="toast-title">检测报告已更新</view>
      <view class="toast-desc">v{{versionUpdateInfo.oldVersion}} → v{{versionUpdateInfo.newVersion}} · {{versionUpdateInfo.lastUpdatedAt}}</view>
    </view>
    <view class="toast-action">
      <text class="toast-action-text">查看变更</text>
      <text class="toast-action-arrow">›</text>
    </view>
  </view>
  <view class="toast-close" catchtap="closeVersionUpdateToast">✕</view>
</view>

<!-- ==================== 骨架屏 ==================== -->
<view class="skeleton-container" wx:if="{{skeletonLoading}}">
  <view class="skeleton-header">
    <view class="skeleton-avatar shimmer"></view>
    <view class="skeleton-title shimmer" style="width: 200rpx;"></view>
    <view class="skeleton-subtitle shimmer" style="width: 160rpx;"></view>
  </view>

  <view class="skeleton-content">
    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 40%;"></view>
      <view class="skeleton-grid">
        <view class="skeleton-grid-item shimmer"></view>
        <view class="skeleton-grid-item shimmer"></view>
        <view class="skeleton-grid-item shimmer"></view>
        <view class="skeleton-grid-item shimmer"></view>
      </view>
    </view>

    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 30%;"></view>
      <view class="skeleton-line shimmer" style="width: 80%;"></view>
      <view class="skeleton-line shimmer" style="width: 60%;"></view>
    </view>

    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 35%;"></view>
      <view class="skeleton-params">
        <view class="skeleton-param shimmer"></view>
        <view class="skeleton-param shimmer"></view>
        <view class="skeleton-param shimmer"></view>
        <view class="skeleton-param shimmer"></view>
      </view>
    </view>

    <view class="skeleton-card">
      <view class="skeleton-line shimmer" style="width: 45%;"></view>
      <view class="skeleton-image shimmer"></view>
      <view class="skeleton-line shimmer" style="width: 70%;"></view>
    </view>
  </view>
</view>

<view class="page-container {{showPdfModal ? 'no-scroll' : ''}} {{a11yClasses}}" style="{{showPdfModal ? 'top: -' + scrollTop + 'px;' : ''}}" wx:if="{{!skeletonLoading && traceData}}">

  <!-- ==================== 顶部产品概览 ==================== -->
  <view class="product-header">
    <view class="header-bg-pattern"></view>
    <view class="product-info">
      <view class="product-icon variety-icon-{{varietyStyle.key}}" wx:if="{{varietyStyle}}">
        <text>{{varietyStyle.icon}}</text>
      </view>
      <view class="product-icon" wx:else>
        <text>🌸</text>
      </view>
      <view class="product-name">{{traceData.basicInfo.productName}}</view>
      <view class="product-batch">批次号：{{traceData.basicInfo.batchNo}}</view>

      <!-- 区块链存证标识 -->
      <view class="blockchain-badge" wx:if="{{traceData.blockchainInfo}}">
        <view class="badge-icon">🔗</view>
        <view class="badge-text">
          <text class="badge-title">区块链存证</text>
          <text class="badge-desc">数据真实可查・不可篡改</text>
        </view>
        <view class="badge-status">{{traceData.blockchainInfo.verifyStatus}}</view>
      </view>
    </view>
  </view>

  <!-- ==================== 锚点 Tab 导航栏 ==================== -->
  <view class="anchor-tab-bar {{anchorSticky ? 'sticky' : ''}}" id="anchor-tab-bar" role="tablist" aria-label="{{currentLang === 'en-US' ? 'Module navigation' : '模块导航'}}">
    <scroll-view scroll-x="true" class="anchor-scroll" enhanced show-scrollbar="{{false}}">
      <view class="anchor-tabs">
        <view
          wx:for="{{anchorTabs}}"
          wx:key="key"
          class="anchor-tab-item {{activeAnchor === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          data-index="{{index}}"
          bindtap="onAnchorTap"
          role="tab"
          aria-current="{{activeAnchor === item.key}}"
          aria-selected="{{activeAnchor === item.key}}"
          aria-label="{{item.label}}"
        >
          <text class="anchor-tab-icon" aria-hidden="true">{{item.icon}}</text>
          <text class="anchor-tab-label">{{item.label}}</text>
          <view class="anchor-tab-indicator" wx:if="{{activeAnchor === item.key}}" aria-hidden="true"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ==================== 主要内容区域 ==================== -->
  <view class="main-content">

    <!-- ========== 储存风险预警 ========== -->
    <view class="storage-risk-card animate-card" wx:if="{{storageRiskData && storageRiskData.hasRisk}}" bindtap="viewStorageRiskDetail">
      <view class="storage-risk-icon">⚠️</view>
      <view class="storage-risk-content">
        <view class="storage-risk-title">储存风险预警</view>
        <view class="storage-risk-desc">检测到物流过程最高温度 {{storageRiskData.maxTemp}}℃（超过 {{storageRiskData.warningThreshold}}℃），可能影响茶叶品质</view>
      </view>
      <view class="storage-risk-arrow">›</view>
    </view>

    <!-- ========== 模块1：基础信息 ========== -->
    <view class="card animate-card module-card" id="anchor-basic" style="animation-delay: 0.1s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="basic">
        <view class="title-left">
          <text class="title-icon">📋</text>
          <text>基础信息</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.basic ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.basic ? 'hidden' : ''}}">
        <view class="info-grid">
          <view class="info-item">
            <view class="info-label">溯源ID</view>
            <view class="info-value highlight" bindtap="copyTraceId">
              {{traceData.basicInfo.traceId}}
              <text class="copy-icon">📋</text>
            </view>
          </view>
          <view class="info-item">
            <view class="info-label">批次号</view>
            <view class="info-value">{{traceData.basicInfo.batchNo}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">采摘时间</view>
            <view class="info-value">{{traceData.basicInfo.pickTime}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">出厂时间</view>
            <view class="info-value">{{traceData.basicInfo.productionTime}}</view>
          </view>
        </view>

        <!-- 数据版本信息 -->
        <view class="version-info-section">
          <view class="version-info-row" bindtap="openVersionHistory">
            <view class="version-info-left">
              <text class="version-icon">📌</text>
              <view class="version-info-text">
                <view class="version-label">数据版本</view>
                <view class="version-value">v{{traceData.dataVersion}} · {{traceData.lastUpdatedAt}}</view>
              </view>
            </view>
            <view class="version-info-right">
              <text class="version-history-link">历史版本 ›</text>
            </view>
          </view>
          <view class="version-change-btn" bindtap="openChangeLogModal">
            <text class="change-btn-icon">📝</text>
            <text class="change-btn-text">查看变更记录</text>
          </view>
        </view>

        <!-- 产地图片（懒加载） -->
        <view class="module-image-wrapper" id="img-origin">
          <block wx:if="{{lazyImageMap.originImage}}">
            <image
              class="module-image"
              src="{{traceData.images.originImage}}"
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">📍 产地实拍</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🖼️</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 保质期与最佳品饮期 ========== -->
    <view class="card animate-card module-card shelf-life-card" id="anchor-shelfLife" wx:if="{{shelfLifeData}}" style="animation-delay: 0.12s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="shelfLife">
        <view class="title-left">
          <text class="title-icon">📅</text>
          <text>保质期与储存</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.shelfLife ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.shelfLife ? 'hidden' : ''}}">

        <!-- 状态标签 -->
        <view class="shelf-life-status">
          <view class="status-badge" style="background: {{shelfLifeData.statusColor}};">
            <text class="status-icon">
              <block wx:if="{{shelfLifeData.status === 'fresh'}}">🌱</block>
              <block wx:elif="{{shelfLifeData.status === 'best'}}">✨</block>
              <block wx:elif="{{shelfLifeData.status === 'declining'}}">⏰</block>
              <block wx:else>🚫</block>
            </text>
            <text class="status-text">{{shelfLifeData.statusLabel}}</text>
          </view>
          <view class="status-remaining" wx:if="{{shelfLifeData.status !== 'expired'}}">
            剩余 <text class="remaining-days">{{shelfLifeData.remainingDays}}</text> 天保质期
          </view>
          <view class="status-remaining expired" wx:else>已超出保质期</view>
        </view>

        <!-- 保质期总进度条 -->
        <view class="shelf-life-section">
          <view class="section-label">保质周期进度</view>
          <view class="progress-track">
            <view class="progress-fill" style="width: {{shelfLifeData.overallProgress}}%; background: {{shelfLifeData.statusColor}};"></view>
            <view class="progress-marker" style="left: {{shelfLifeData.bestTasteStartProgress}}%;">
              <view class="marker-dot"></view>
              <view class="marker-label">最佳期开始</view>
            </view>
            <view class="progress-marker" style="left: {{shelfLifeData.bestTasteEndProgress}}%;">
              <view class="marker-dot orange"></view>
              <view class="marker-label">最佳期结束</view>
            </view>
          </view>
          <view class="progress-dates">
            <text class="date-text">{{shelfLifeData.productionDate}} 出厂</text>
            <text class="date-text">{{shelfLifeData.bestBeforeDate}} 到期</text>
          </view>
        </view>

        <!-- 最佳品饮期进度条 -->
        <view class="shelf-life-section">
          <view class="section-label">最佳品饮期进度</view>
          <view class="best-taste-track">
            <view class="best-taste-gradient">
              <view class="best-taste-fill" style="width: {{shelfLifeData.bestTasteProgress}}%;"></view>
              <view class="best-taste-cursor" style="left: {{shelfLifeData.bestTasteProgress}}%;">
                <view class="cursor-dot"></view>
              </view>
            </view>
          </view>
          <view class="progress-meta">
            <text class="meta-text">已进入最佳期 {{shelfLifeData.elapsedDays > shelfLifeData.bestTasteStartDays ? (shelfLifeData.elapsedDays - shelfLifeData.bestTasteStartDays) : 0}} 天</text>
            <text class="meta-text highlight" wx:if="{{shelfLifeData.daysUntilBestEnd > 0 && shelfLifeData.daysUntilBestEnd <= 30}}">
              📢 距最佳期结束仅 {{shelfLifeData.daysUntilBestEnd}} 天
            </text>
            <text class="meta-text" wx:elif="{{shelfLifeData.daysUntilBestEnd > 0}}">
              最佳期剩余 {{shelfLifeData.daysUntilBestEnd}} 天
            </text>
          </view>
        </view>

        <!-- 订阅提醒开关 -->
        <view class="shelf-life-subscribe" bindtap="toggleShelfLifeSubscription">
          <view class="subscribe-left">
            <view class="subscribe-icon">🔔</view>
            <view class="subscribe-info">
              <view class="subscribe-title">开启最佳品饮期提醒</view>
              <view class="subscribe-desc">到期前30天将向您推送通知</view>
            </view>
          </view>
          <view class="subscribe-switch {{shelfLifeSubscribed ? 'on' : ''}}">
            <view class="switch-knob"></view>
          </view>
        </view>

        <!-- 储存条件 -->
        <view class="shelf-life-section">
          <view class="section-label">储存条件</view>
          <view class="storage-condition">
            <text class="condition-icon">💧</text>
            <text class="condition-text">{{shelfLifeData.storageCondition}}</text>
          </view>
        </view>

        <!-- 储存小贴士 -->
        <view class="shelf-life-section">
          <view class="section-label">储存小贴士</view>
          <view class="storage-tips">
            <view class="tip-item" wx:for="{{shelfLifeData.storageTips}}" wx:key="*this">
              <text class="tip-icon">💡</text>
              <text class="tip-text">{{item}}</text>
            </view>
          </view>
        </view>

      </view>
    </view>

    <!-- ========== 模块2：树龄信息（核心特色） ========== -->
    <view class="card animate-card tree-age-card module-card" id="anchor-treeAge" style="animation-delay: 0.15s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="treeAge">
        <view class="title-left">
          <text class="title-icon">🌳</text>
          <text>树龄信息</text>
          <view class="title-badge">核心特色</view>
        </view>
        <view class="module-toggle {{moduleCollapsed.treeAge ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.treeAge ? 'hidden' : ''}}">
        <view class="tree-age-content">
          <view class="tree-item">
            <view class="tree-icon tea-tree">🍃</view>
            <view class="tree-info">
              <view class="tree-type">茶树龄</view>
              <view class="tree-age">
                <text class="age-number">{{traceData.treeAge.teaTreeAge}}</text>
                <text class="age-unit">年</text>
              </view>
              <view class="tree-location">产地：{{traceData.treeAge.teaTreeLocation}}</view>
            </view>
          </view>
          <view class="tree-divider"></view>
          <view class="tree-item">
            <view class="tree-icon osmanthus-tree">🌼</view>
            <view class="tree-info">
              <view class="tree-type">桂花树龄</view>
              <view class="tree-age">
                <text class="age-number">{{traceData.treeAge.osmanthusTreeAge}}</text>
                <text class="age-unit">年</text>
              </view>
              <view class="tree-location">产地：{{traceData.treeAge.osmanthusTreeLocation}}</view>
            </view>
          </view>
        </view>

        <!-- 茶树产地图片（懒加载） -->
        <view class="module-image-wrapper" id="img-tea-origin">
          <block wx:if="{{lazyImageMap.teaOriginImage}}">
            <image
              class="module-image"
              src="{{traceData.images.teaOriginImage}}"
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">🍃 百年茶树产地</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🍃</text>
          </view>
        </view>

        <!-- ========== 树龄故事 Tab ========== -->
        <view class="tree-story-section" wx:if="{{traceData.treeStory}}">
          <view class="tree-story-header">
            <text class="story-title-icon">📖</text>
            <text class="story-title">{{traceData.treeStory.title}}</text>
          </view>

          <!-- 故事 Tab 切换 -->
          <view class="story-tab-bar">
            <view class="story-tab-item {{activeStoryTab === 'tea' ? 'active' : ''}}" data-tab="tea" bindtap="switchStoryTab">
              <text class="tab-icon">🍃</text>
              <text>古茶树</text>
            </view>
            <view class="story-tab-item {{activeStoryTab === 'osmanthus' ? 'active' : ''}}" data-tab="osmanthus" bindtap="switchStoryTab">
              <text class="tab-icon">🌼</text>
              <text>桂花树</text>
            </view>
          </view>

          <!-- 古茶树故事 -->
          <block wx:if="{{activeStoryTab === 'tea' && traceData.treeStory.teaTree}}">
            <view class="story-detail-card">
              <view class="story-meta-grid">
                <view class="meta-item">
                  <text class="meta-label">栽植年代</text>
                  <text class="meta-value highlight">{{traceData.treeStory.teaTree.plantYear}}</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">树龄</text>
                  <text class="meta-value">{{traceData.treeStory.teaTree.age}}年</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">树高</text>
                  <text class="meta-value">{{traceData.treeStory.teaTree.height}}</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">冠幅</text>
                  <text class="meta-value">{{traceData.treeStory.teaTree.crown}}</text>
                </view>
              </view>
              <view class="story-location-tag">
                <text>📍 {{traceData.treeStory.teaTree.location}}</text>
              </view>
              <view class="story-content">
                <text class="story-text">{{traceData.treeStory.teaTree.story}}</text>
              </view>
            </view>

            <!-- 历史事件时间轴 -->
            <view class="history-timeline-section">
              <view class="section-sub-title">
                <text class="sub-icon">📜</text>
                <text>历史大事记</text>
              </view>
              <view class="history-timeline">
                <view wx:for="{{traceData.treeStory.teaTree.historicalRecords}}" wx:key="year" class="history-timeline-item" data-record="{{item}}" bindtap="viewHistoryEventDetail">
                  <view class="history-dot" style="background: {{varietyStyle ? varietyStyle.color : '#2E8B57'}};">
                    <text class="history-dot-icon">{{historyTypeIconMap[item.type] || '📌'}}</text>
                  </view>
                  <view class="history-line" wx:if="{{index < traceData.treeStory.teaTree.historicalRecords.length - 1}}"></view>
                  <view class="history-content">
                    <text class="history-year">{{item.year}}</text>
                    <text class="history-event">{{item.event}}</text>
                  </view>
                </view>
              </view>
            </view>

            <!-- 养护记录 -->
            <view class="maintenance-section">
              <view class="section-sub-title">
                <text class="sub-icon">🌿</text>
                <text>养护记录</text>
              </view>
              <view class="maintenance-list">
                <view wx:for="{{traceData.treeStory.teaTree.maintenanceRecords}}" wx:key="date" class="maintenance-card" data-record="{{item}}" bindtap="viewMaintenanceDetail">
                  <view class="maint-header">
                    <text class="maint-date">{{item.date}}</text>
                    <text class="maint-type-badge" style="border-color: {{varietyStyle ? varietyStyle.borderColor : '#2E8B57'}}; color: {{varietyStyle ? varietyStyle.color : '#2E8B57'}};">{{item.type}}</text>
                  </view>
                  <view class="maint-content">{{item.content}}</view>
                  <view class="maint-footer">
                    <text class="maint-operator">👤 {{item.operator}}</text>
                    <text class="maint-photos" wx:if="{{item.photos}}">📷 {{item.photos}}张</text>
                  </view>
                </view>
              </view>
            </view>
          </block>

          <!-- 桂花树故事 -->
          <block wx:if="{{activeStoryTab === 'osmanthus' && traceData.treeStory.osmanthusTree}}">
            <view class="story-detail-card osmanthus-card" wx:if="{{varietyStyle}}" style="background: {{varietyStyle.lightBg}};">
              <view class="story-meta-grid">
                <view class="meta-item">
                  <text class="meta-label">栽植年代</text>
                  <text class="meta-value highlight" style="color: {{varietyStyle.color}};">{{traceData.treeStory.osmanthusTree.plantYear}}</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">树龄</text>
                  <text class="meta-value">{{traceData.treeStory.osmanthusTree.age}}年</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">树高</text>
                  <text class="meta-value">{{traceData.treeStory.osmanthusTree.height}}</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">冠幅</text>
                  <text class="meta-value">{{traceData.treeStory.osmanthusTree.crown}}</text>
                </view>
              </view>
              <view class="story-location-tag">
                <text>📍 {{traceData.treeStory.osmanthusTree.location}}</text>
              </view>
              <view class="story-content">
                <text class="story-text">{{traceData.treeStory.osmanthusTree.story}}</text>
              </view>
            </view>

            <view class="story-detail-card osmanthus-card" wx:else>
              <view class="story-meta-grid">
                <view class="meta-item">
                  <text class="meta-label">栽植年代</text>
                  <text class="meta-value highlight">{{traceData.treeStory.osmanthusTree.plantYear}}</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">树龄</text>
                  <text class="meta-value">{{traceData.treeStory.osmanthusTree.age}}年</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">树高</text>
                  <text class="meta-value">{{traceData.treeStory.osmanthusTree.height}}</text>
                </view>
                <view class="meta-item">
                  <text class="meta-label">冠幅</text>
                  <text class="meta-value">{{traceData.treeStory.osmanthusTree.crown}}</text>
                </view>
              </view>
              <view class="story-location-tag">
                <text>📍 {{traceData.treeStory.osmanthusTree.location}}</text>
              </view>
              <view class="story-content">
                <text class="story-text">{{traceData.treeStory.osmanthusTree.story}}</text>
              </view>
            </view>

            <!-- 桂花树养护记录 -->
            <view class="maintenance-section">
              <view class="section-sub-title">
                <text class="sub-icon">🌿</text>
                <text>养护与采摘记录</text>
              </view>
              <view class="maintenance-list">
                <view wx:for="{{traceData.treeStory.osmanthusTree.maintenanceRecords}}" wx:key="date" class="maintenance-card" data-record="{{item}}" bindtap="viewMaintenanceDetail">
                  <view class="maint-header">
                    <text class="maint-date">{{item.date}}</text>
                    <text class="maint-type-badge" style="border-color: {{varietyStyle ? varietyStyle.borderColor : '#DAA520'}}; color: {{varietyStyle ? varietyStyle.color : '#DAA520'}};">{{item.type}}</text>
                  </view>
                  <view class="maint-content">{{item.content}}</view>
                  <view class="maint-footer">
                    <text class="maint-operator">👤 {{item.operator}}</text>
                    <text class="maint-photos" wx:if="{{item.photos}}">📷 {{item.photos}}张</text>
                  </view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- ========== 模块3：产地地理信息（新增核心模块） ========== -->
    <view class="card animate-card location-card module-card" id="anchor-location" style="animation-delay: 0.22s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="location">
        <view class="title-left">
          <text class="title-icon">📍</text>
          <text>产地地理信息</text>
          <view class="title-badge" style="background: {{varietyStyle ? varietyStyle.bgGradient : 'linear-gradient(135deg, #2E8B57, #3CB371)'}};">实景展示</view>
        </view>
        <view class="module-toggle {{moduleCollapsed.location ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.location ? 'hidden' : ''}}">

        <!-- 卫星/实景照片轮播 -->
        <view class="scenic-swiper-section" wx:if="{{traceData.scenicPhotos}}">
          <view class="section-sub-title">
            <text class="sub-icon">🗺️</text>
            <text>{{traceData.scenicPhotos.title}}</text>
          </view>
          <swiper
            class="scenic-swiper"
            indicator-dots="{{true}}"
            autoplay="{{traceData.scenicPhotos.autoPlay}}"
            interval="{{traceData.scenicPhotos.interval}}"
            circular="{{true}}"
            bindchange="onScenicChange"
            indicator-color="rgba(255,255,255,0.4)"
            indicator-active-color="#FFFFFF"
          >
            <swiper-item wx:for="{{traceData.scenicPhotos.photos}}" wx:key="url" data-url="{{item.url}}" bindtap="previewScenicImage">
              <view class="swiper-slide-item">
                <image class="scenic-image" src="{{item.url}}" mode="aspectFill" />
                <view class="scenic-caption">
                  <text class="caption-type-tag" wx:if="{{item.type === 'aerial'}}">🛰️ 航拍</text>
                  <text class="caption-type-tag" wx:elif="{{item.type === 'detail'}}">📸 特写</text>
                  <text class="caption-type-tag" wx:elif="{{item.type === 'people'}}">👤 人文</text>
                  <text class="caption-text">{{item.caption}}</text>
                </view>
              </view>
            </swiper-item>
          </swiper>
          <view class="swiper-counter">
            {{currentScenicIndex + 1}} / {{traceData.scenicPhotos.photos.length}}
          </view>
        </view>

        <!-- 地图模块：map 组件 -->
        <view class="map-section" wx:if="{{traceData.locationMap}}">
          <view class="section-sub-title">
            <text class="sub-icon">🏞️</text>
            <text>产地地图 · 点击标记查看简介</text>
            <view class="map-layer-toggle" catchtap="toggleMapLayer">
              <text>{{mapLayerType === 'standard' ? '🛰️ 切换卫星图' : '🗺️ 切换标准图'}}</text>
            </view>
          </view>

          <map
            id="locationMap"
            class="trace-map"
            latitude="{{traceData.locationMap.centerLat}}"
            longitude="{{traceData.locationMap.centerLng}}"
            scale="{{traceData.locationMap.scale}}"
            markers="{{traceData.locationMap.markers}}"
            show-location="{{false}}"
            enable-3D="{{true}}"
            enable-zoom="{{true}}"
            enable-scroll="{{true}}"
            enable-rotate="{{false}}"
            enable-satellite="{{mapLayerType === 'satellite'}}"
            bindmarkertap="onMapMarkerTap"
            subkey=""
          ></map>

          <!-- 地图图例 -->
          <view class="map-legend" wx:if="{{showMapLegend}}">
            <view class="legend-item">
              <view class="legend-dot legend-tea"></view>
              <text>茶树园</text>
            </view>
            <view class="legend-item">
              <view class="legend-dot legend-osm" style="background: {{varietyStyle ? varietyStyle.color : '#DAA520'}};"></view>
              <text>{{traceData.osmanthusInfo.variety}}园</text>
            </view>
            <view class="legend-item">
              <view class="legend-dot legend-fac"></view>
              <text>加工厂</text>
            </view>
          </view>
        </view>

        <!-- 采摘当日天气关联 -->
        <view class="weather-section" wx:if="{{traceData.pickWeather}}">
          <view class="section-sub-title">
            <text class="sub-icon">🌤️</text>
            <text>采摘当日天气 · 增强可信度</text>
          </view>

          <view class="weather-grid">
            <!-- 茶叶采摘天气 -->
            <view class="weather-card" data-type="teaPick" bindtap="viewWeatherDetail">
              <view class="weather-header">
                <text class="weather-title-icon">🍃</text>
                <text class="weather-card-title">茶叶采摘</text>
              </view>
              <view class="weather-main">
                <text class="weather-icon-big">{{traceData.pickWeather.teaPick.weatherIcon}}</text>
                <view class="weather-info">
                  <text class="weather-temp">{{traceData.pickWeather.teaPick.temperature}}</text>
                  <text class="weather-desc">{{traceData.pickWeather.teaPick.weather}}</text>
                </view>
              </view>
              <view class="weather-meta-row">
                <text class="meta-chip">💧 {{traceData.pickWeather.teaPick.humidity}}</text>
                <text class="meta-chip">🌬️ {{traceData.pickWeather.teaPick.wind}}</text>
              </view>
              <view class="weather-footer">
                <text class="weather-date">📅 {{traceData.pickWeather.teaPick.date}}</text>
                <text class="weather-location">📍 {{traceData.pickWeather.teaPick.location}}</text>
              </view>
              <view class="weather-quality-bar">
                <text class="air-quality">{{traceData.pickWeather.teaPick.airQuality}}</text>
              </view>
            </view>

            <!-- 桂花采摘天气 -->
            <view class="weather-card" data-type="osmanthusPick" bindtap="viewWeatherDetail">
              <view class="weather-header" wx:if="{{varietyStyle}}" style="border-bottom-color: {{varietyStyle.borderColor}};">
                <text class="weather-title-icon">{{varietyStyle.icon}}</text>
                <text class="weather-card-title">{{traceData.osmanthusInfo.variety}}采摘</text>
              </view>
              <view class="weather-header" wx:else>
                <text class="weather-title-icon">🌼</text>
                <text class="weather-card-title">桂花采摘</text>
              </view>
              <view class="weather-main">
                <text class="weather-icon-big">{{traceData.pickWeather.osmanthusPick.weatherIcon}}</text>
                <view class="weather-info">
                  <text class="weather-temp">{{traceData.pickWeather.osmanthusPick.temperature}}</text>
                  <text class="weather-desc">{{traceData.pickWeather.osmanthusPick.weather}}</text>
                </view>
              </view>
              <view class="weather-meta-row">
                <text class="meta-chip">💧 {{traceData.pickWeather.osmanthusPick.humidity}}</text>
                <text class="meta-chip">🌬️ {{traceData.pickWeather.osmanthusPick.wind}}</text>
              </view>
              <view class="weather-footer">
                <text class="weather-date">📅 {{traceData.pickWeather.osmanthusPick.date}}</text>
                <text class="weather-location">📍 {{traceData.pickWeather.osmanthusPick.location}}</text>
              </view>
              <view class="weather-quality-bar">
                <text class="air-quality">{{traceData.pickWeather.osmanthusPick.airQuality}}</text>
              </view>
            </view>
          </view>

          <view class="weather-note" wx:if="{{traceData.pickWeather.teaPick.note}}">
            <text class="note-icon">💡</text>
            <text class="note-text">{{traceData.pickWeather.teaPick.note}}</text>
          </view>
        </view>

      </view>
    </view>

    <!-- ========== 模块4：桂花信息 ========== -->
    <view class="card animate-card module-card" style="animation-delay: 0.2s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="osmanthus">
        <view class="title-left">
          <text class="title-icon">🌸</text>
          <text>桂花信息</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.osmanthus ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.osmanthus ? 'hidden' : ''}}">
        <view class="osmanthus-content">
          <view class="osmanthus-variety">
            <view class="variety-badge variety-{{varietyStyle.key}}" wx:if="{{varietyStyle}}" style="background: {{varietyStyle.bgGradient}};">
              <text class="variety-badge-icon">{{varietyStyle.icon}}</text>
              {{traceData.osmanthusInfo.variety}}
            </view>
            <view class="variety-badge silver" wx:else>
              {{traceData.osmanthusInfo.variety}}
            </view>
            <view class="variety-description" wx:if="{{varietyStyle}}">
              <text class="desc-icon">✨</text>
              {{varietyStyle.description}}
            </view>
          </view>
          <view class="info-grid">
            <view class="info-item">
              <view class="info-label">产地</view>
              <view class="info-value">{{traceData.osmanthusInfo.origin}}</view>
            </view>
            <view class="info-item">
              <view class="info-label">采摘时间</view>
              <view class="info-value">{{traceData.osmanthusInfo.pickTime}}</view>
            </view>
            <view class="info-item">
              <view class="info-label">花色</view>
              <view class="info-value">{{traceData.osmanthusInfo.color}}</view>
            </view>
            <view class="info-item">
              <view class="info-label">香气特点</view>
              <view class="info-value">{{traceData.osmanthusInfo.fragrance}}</view>
            </view>
          </view>
        </view>

        <!-- 桂花产地图片（懒加载） -->
        <view class="module-image-wrapper" id="img-osmanthus-origin">
          <block wx:if="{{lazyImageMap.osmanthusOriginImage}}">
            <image
              class="module-image"
              src="{{traceData.images.osmanthusOriginImage}}"
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">🌸 桂花产地</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🌸</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块4：窨制工艺（核心模块） ========== -->
    <view class="card animate-card module-card" id="anchor-process" style="animation-delay: 0.25s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="process">
        <view class="title-left">
          <text class="title-icon">🫖</text>
          <text>窨制工艺</text>
          <view class="title-badge gold">核心工艺</view>
        </view>
        <view class="module-toggle {{moduleCollapsed.process ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.process ? 'hidden' : ''}}">

        <!-- 工艺参数 -->
        <view class="process-params">
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.scentingTimes}}</view>
            <view class="param-label">窨制次数</view>
          </view>
          <view class="param-divider"></view>
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.scentingDuration}}h</view>
            <view class="param-label">每次时长</view>
          </view>
          <view class="param-divider"></view>
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.temperature}}℃</view>
            <view class="param-label">窨制温度</view>
          </view>
          <view class="param-divider"></view>
          <view class="param-item">
            <view class="param-value">{{traceData.scentingProcess.ratio}}</view>
            <view class="param-label">花茶配比</view>
          </view>
        </view>

        <!-- 窨制班组信息 -->
        <view class="team-info-card" wx:if="{{traceData.scentingProcess.teaMasterTeam}}" bindtap="goToTeaMaster" data-teamid="{{traceData.scentingProcess.teaMasterTeam.teamId}}">
          <view class="team-info-left">
            <view class="team-icon">👨‍🍳</view>
            <view class="team-info-content">
              <view class="team-info-title">
                <text>本次窨制由 </text>
                <text class="team-name-highlight">{{traceData.scentingProcess.teaMasterTeam.teamName}}</text>
                <text> 完成</text>
                <text class="team-link-arrow">›</text>
              </view>
              <view class="team-info-sub">
                <text class="team-master-tag">{{traceData.scentingProcess.teaMasterTeam.leaderQualification}}</text>
                <text class="team-master-name">{{traceData.scentingProcess.teaMasterTeam.leaderNameMasked}}</text>
                <text class="team-master-exp"> · {{traceData.scentingProcess.teaMasterTeam.leaderExperienceYears}}年经验</text>
              </view>
            </view>
          </view>
          <view class="team-info-right">
            <text class="team-cta">查看档案</text>
          </view>
        </view>

        <!-- 环境参数 -->
        <view class="env-params">
          <view class="env-item">
            <text class="env-icon">💧</text>
            <text>湿度：{{traceData.scentingProcess.humidity}}%</text>
          </view>
          <view class="env-item">
            <text class="env-icon">✨</text>
            <text>洁净度：{{traceData.scentingProcess.workshopCleanliness}}</text>
          </view>
        </view>

        <!-- 工艺图片（懒加载） -->
        <view class="module-image-wrapper" id="img-process">
          <block wx:if="{{lazyImageMap.processImage}}">
            <image
              class="module-image"
              src="{{traceData.images.processImage}}"
              mode="aspectFill"
              lazy-load="true"
            />
            <view class="image-caption">🫖 窨制工艺车间</view>
          </block>
          <view wx:else class="image-placeholder shimmer">
            <text class="placeholder-icon">🫖</text>
          </view>
        </view>

        <!-- 工艺模块 Tab 导航 -->
        <view class="process-tab-bar">
          <view
            class="process-tab-item {{activeProcessTab === 'records' ? 'active' : ''}}"
            data-tab="records"
            bindtap="switchProcessTab"
          >
            <text class="tab-icon">📋</text>
            <text class="tab-label">窨制记录</text>
          </view>
          <view
            class="process-tab-item {{activeProcessTab === 'flow' ? 'active' : ''}}"
            data-tab="flow"
            bindtap="switchProcessTab"
          >
            <text class="tab-icon">🎬</text>
            <text class="tab-label">工艺流程</text>
          </view>
          <view
            class="process-tab-item {{activeProcessTab === 'comparison' ? 'active' : ''}}"
            data-tab="comparison"
            bindtap="switchProcessTab"
          >
            <text class="tab-icon">⚖️</text>
            <text class="tab-label">工艺对比</text>
          </view>
        </view>

        <!-- Tab 1：窨制独立记录 -->
        <view class="process-tab-content" wx:if="{{activeProcessTab === 'records'}}">
          <view class="records-title">
            <text class="records-title-icon">📝</text>
            <text class="records-title-text">每次窨制独立记录</text>
          </view>

          <!-- 窨制记录时间轴 -->
          <view class="scenting-records-timeline">
            <view
              wx:for="{{traceData.scentingProcess.scentingRecords}}"
              wx:key="round"
              class="record-timeline-item {{activeScentingRecord === index ? 'active' : ''}}"
              data-index="{{index}}"
              data-record="{{item}}"
              bindtap="selectScentingRecord"
              bindlongpress="viewScentingRecordDetail"
            >
              <view class="record-round-badge">
                <text class="round-num">{{item.round}}</text>
              </view>
              <view class="record-line" wx:if="{{index < traceData.scentingProcess.scentingRecords.length - 1}}"></view>
            </view>
          </view>

          <!-- 当前选中记录详情卡片 -->
          <view class="record-detail-card" wx:if="{{traceData.scentingProcess.scentingRecords[activeScentingRecord]}}">
            <view class="record-detail-header">
              <view class="record-round-tag">第{{traceData.scentingProcess.scentingRecords[activeScentingRecord].round}}次窨制</view>
              <view class="record-note">{{traceData.scentingProcess.scentingRecords[activeScentingRecord].note}}</view>
            </view>
            <view class="record-detail-grid">
              <view class="record-detail-item">
                <text class="detail-item-icon">⏱️</text>
                <text class="detail-item-label">窨制时长</text>
                <text class="detail-item-value">{{traceData.scentingProcess.scentingRecords[activeScentingRecord].duration}}小时</text>
              </view>
              <view class="record-detail-item">
                <text class="detail-item-icon">🌡️</text>
                <text class="detail-item-label">窨制温度</text>
                <text class="detail-item-value">{{traceData.scentingProcess.scentingRecords[activeScentingRecord].temperature}}℃</text>
              </view>
              <view class="record-detail-item">
                <text class="detail-item-icon">💧</text>
                <text class="detail-item-label">环境湿度</text>
                <text class="detail-item-value">{{traceData.scentingProcess.scentingRecords[activeScentingRecord].humidity}}%</text>
              </view>
              <view class="record-detail-item">
                <text class="detail-item-icon">👤</text>
                <text class="detail-item-label">操作人</text>
                <text class="detail-item-value">{{traceData.scentingProcess.scentingRecords[activeScentingRecord].operator}}</text>
              </view>
            </view>
            <view class="record-detail-footer">
              <text class="record-timestamp">📅 {{traceData.scentingProcess.scentingRecords[activeScentingRecord].timestamp}}</text>
            </view>
          </view>

          <!-- 工艺多媒体展示 -->
          <view class="process-media-section">
            <view class="media-section-title">
              <text class="media-title-icon">🖼️</text>
              <text class="media-title-text">工艺多媒体</text>
            </view>
            <view class="media-grid">
              <view
                wx:for="{{traceData.scentingProcess.processSteps}}"
                wx:key="step"
                class="media-item"
                data-url="{{item.mediaUrl}}"
                bindtap="previewProcessImage"
              >
                <image class="media-image" src="{{item.mediaUrl}}" mode="aspectFill" />
                <view class="media-overlay">
                  <text class="media-step-icon">{{item.icon}}</text>
                  <text class="media-step-name">{{item.name}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- Tab 2：横向时间轴动画 -->
        <view class="process-tab-content" wx:if="{{activeProcessTab === 'flow'}}">
          <view class="timeline-section-title">
            <text class="timeline-title-icon">🎬</text>
            <text class="timeline-title-text">工艺流程图 - 动画演示</text>
          </view>

          <!-- 时间轴控制栏 -->
          <view class="timeline-controls">
            <view class="control-btn" bindtap="prevTimelineStep">
              <text>⏮️</text>
            </view>
            <view class="control-btn primary" bindtap="{{timelinePlaying ? 'pauseTimelineAnimation' : 'startTimelineAnimation'}}">
              <text wx:if="{{!timelinePlaying}}">▶️ 播放</text>
              <text wx:else>⏸️ 暂停</text>
            </view>
            <view class="control-btn" bindtap="nextTimelineStep">
              <text>⏭️</text>
            </view>
            <view class="control-btn" bindtap="resetTimelineAnimation">
              <text>🔄</text>
            </view>
            <view class="control-btn speed-btn" bindtap="changeTimelineSpeed">
              <text>⚡</text>
              <text class="speed-label">{{timelineSpeed === 1000 ? '快' : timelineSpeed === 2000 ? '中' : '慢'}}</text>
            </view>
          </view>

          <!-- 横向时间轴 -->
          <view class="horizontal-timeline">
            <view class="timeline-track">
              <view
                wx:for="{{traceData.scentingProcess.processSteps}}"
                wx:key="step"
                class="timeline-step {{timelineActiveStep === index ? 'active' : ''}} {{timelineActiveStep > index ? 'completed' : ''}}"
                data-index="{{index}}"
                bindtap="onTimelineStepTap"
              >
                <view class="timeline-step-dot">
                  <text class="step-dot-icon">{{item.icon}}</text>
                </view>
                <view class="timeline-step-label">{{item.name}}</view>
                <view class="timeline-connector" wx:if="{{index < traceData.scentingProcess.processSteps.length - 1}}"></view>
              </view>
            </view>
          </view>

          <!-- 当前步骤详情卡片（带动画） -->
          <view class="timeline-step-detail" wx:if="{{timelineActiveStep >= 0}}">
            <view class="timeline-detail-icon">{{traceData.scentingProcess.processSteps[timelineActiveStep].icon}}</view>
            <view class="timeline-detail-content">
              <view class="timeline-detail-step">
                <text class="step-number">步骤 {{timelineActiveStep + 1}}/{{traceData.scentingProcess.processSteps.length}}</text>
                <text class="step-name-large">{{traceData.scentingProcess.processSteps[timelineActiveStep].name}}</text>
              </view>
              <view class="timeline-detail-desc">{{traceData.scentingProcess.processSteps[timelineActiveStep].desc}}</view>
            </view>
            <image
              class="timeline-detail-image"
              src="{{traceData.scentingProcess.processSteps[timelineActiveStep].mediaUrl}}"
              mode="aspectFill"
              data-url="{{traceData.scentingProcess.processSteps[timelineActiveStep].mediaUrl}}"
              bindtap="previewProcessImage"
            />
          </view>

          <!-- 提示信息 -->
          <view class="timeline-tip">
            <text class="tip-icon">💡</text>
            <text class="tip-text">点击步骤可跳转到对应位置，长按窨制记录可查看详情</text>
          </view>
        </view>

        <!-- Tab 3：工艺对比 -->
        <view class="process-tab-content" wx:if="{{activeProcessTab === 'comparison' && processComparisonData}}">
          <view class="comparison-section-title">
            <text class="comparison-title-icon">⚖️</text>
            <text class="comparison-title-text">{{processComparisonData.title}}</text>
          </view>

          <!-- 对比概览卡片 -->
          <view class="comparison-overview">
            <view class="comparison-col golden">
              <view class="col-header">
                <text class="col-icon">🌼</text>
                <text class="col-name">{{processComparisonData.summary.golden.name}}</text>
              </view>
              <view class="col-stats">
                <view class="stat-item">
                  <text class="stat-value">{{processComparisonData.summary.golden.scentingTimes}}</text>
                  <text class="stat-label">窨制次数</text>
                </view>
                <view class="stat-item">
                  <text class="stat-value">{{processComparisonData.summary.golden.totalDuration}}h</text>
                  <text class="stat-label">总时长</text>
                </view>
                <view class="stat-item">
                  <text class="stat-value">{{processComparisonData.summary.golden.avgTemperature}}℃</text>
                  <text class="stat-label">平均温度</text>
                </view>
              </view>
            </view>
            <view class="comparison-vs">
              <text>VS</text>
            </view>
            <view class="comparison-col silver">
              <view class="col-header">
                <text class="col-icon">🌸</text>
                <text class="col-name">{{processComparisonData.summary.silver.name}}</text>
              </view>
              <view class="col-stats">
                <view class="stat-item">
                  <text class="stat-value">{{processComparisonData.summary.silver.scentingTimes}}</text>
                  <text class="stat-label">窨制次数</text>
                </view>
                <view class="stat-item">
                  <text class="stat-value">{{processComparisonData.summary.silver.totalDuration}}h</text>
                  <text class="stat-label">总时长</text>
                </view>
                <view class="stat-item">
