            {{testChartData.overallPass ? (currentLang === 'en-US' ? 'All Within Limit' : '全部达标' : (currentLang === 'en-US' ? 'Some Over Limit' : '部分超标'}}
          </view>
        </view>

        <!-- 茶叶检测结果：国标对比进度条图表 -->
        <view class="test-results" role="region" aria-label="{{currentLang === 'en-US' ? 'Tea pesticide residue test results' : '茶叶农残检测结果'}}">
          <view class="test-category">
            <text class="category-icon" aria-hidden="true">🍃</text>
            <text role="heading" aria-level="3">{{currentLang === 'en-US' ? 'Tea Pesticide Test' : '茶叶农残检测'}}</text>
          </view>

          <!-- 进度条图表 -->
          <view class="progress-chart" role="list">
            <view
              wx:for="{{testChartData.teaTests}}"
              wx:key="item"
              class="progress-item {{item.level}} {{item.levelClass}}"
              data-status="{{item.a11yStatus}}"
              role="listitem"
              aria-label="{{item.item}}，检测值{{item.displayValue}}{{item.unit}}，限值{{item.limit}}{{item.unit}}，{{item.status}}"
            >
              <view class="progress-header">
                <text class="progress-name">{{item.item}}</text>
                <view class="progress-status {{item.isPass ? 'pass' : 'fail'}} {{item.statusClass}}" data-status="{{item.a11yStatus}}">
                  {{item.status}}
                </view>
              </view>
              <view class="progress-bar-container">
                <view class="progress-bar-bg">
                  <view class="progress-bar-fill {{item.level}} {{item.progressClass}}" style="width: {{item.percent}}%;"></view>
                  <view class="progress-limit-line" style="left: 100%;"></view>
                </view>
                <view class="progress-labels">
                  <text class="progress-value">{{i18n.measuredValueLabel}}：{{item.displayValue}}{{item.unit}}</text>
                  <text class="progress-limit">{{i18n.gbLimitLabel}}：{{item.limit}}{{item.unit}}</text>
                </view>
                <view class="progress-multiple" wx:if="{{item.isPass}}">
                  <text class="multiple-label">{{currentLang === 'en-US' ? 'Below limit by' : '低于限值'}}</text>
                  <text class="multiple-value">{{item.multiple}}{{currentLang === 'en-US' ? 'x' : '倍'}}</text>
                </view>
              </view>
              <!-- 异常说明 -->
              <view class="abnormal-desc" wx:if="{{!item.isPass && item.description}}" role="note">
                <text class="desc-icon" aria-hidden="true">⚠️</text>
                <text class="desc-text">{{item.description}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 桂花检测结果：国标对比进度条图表 -->
        <view class="test-results" role="region" aria-label="{{currentLang === 'en-US' ? 'Osmanthus pesticide residue test results' : '桂花农残检测结果'}}">
          <view class="test-category">
            <text class="category-icon" aria-hidden="true">🌸</text>
            <text role="heading" aria-level="3">{{currentLang === 'en-US' ? 'Osmanthus Pesticide Test' : '桂花农残检测'}}</text>
          </view>

          <!-- 进度条图表 -->
          <view class="progress-chart" role="list">
            <view
              wx:for="{{testChartData.osmanthusTests}}"
              wx:key="item"
              class="progress-item {{item.level}} {{item.levelClass}}"
              data-status="{{item.a11yStatus}}"
              role="listitem"
              aria-label="{{item.item}}，检测值{{item.displayValue}}{{item.unit}}，限值{{item.limit}}{{item.unit}}，{{item.status}}"
            >
              <view class="progress-header">
                <text class="progress-name">{{item.item}}</text>
                <view class="progress-status {{item.isPass ? 'pass' : 'fail'}} {{item.statusClass}}" data-status="{{item.a11yStatus}}">
                  {{item.status}}
                </view>
              </view>
              <view class="progress-bar-container">
                <view class="progress-bar-bg">
                  <view class="progress-bar-fill {{item.level}} {{item.progressClass}}" style="width: {{item.percent}}%;"></view>
                  <view class="progress-limit-line" style="left: 100%;"></view>
                </view>
                <view class="progress-labels">
                  <text class="progress-value">{{i18n.measuredValueLabel}}：{{item.displayValue}}{{item.unit}}</text>
                  <text class="progress-limit">{{i18n.gbLimitLabel}}：{{item.limit}}{{item.unit}}</text>
                </view>
                <view class="progress-multiple" wx:if="{{item.isPass}}">
                  <text class="multiple-label">{{currentLang === 'en-US' ? 'Below limit by' : '低于限值'}}</text>
                  <text class="multiple-value">{{item.multiple}}{{currentLang === 'en-US' ? 'x' : '倍'}}</text>
                </view>
              </view>
              <!-- 异常说明 -->
              <view class="abnormal-desc" wx:if="{{!item.isPass && item.description}}" role="note">
                <text class="desc-icon" aria-hidden="true">⚠️</text>
                <text class="desc-text">{{item.description}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 历史检测报告时间轴 -->
        <view class="history-reports-section" wx:if="{{traceData.pesticideTest.historyReports && traceData.pesticideTest.historyReports.length > 0}}" role="region" aria-label="{{currentLang === 'en-US' ? 'Historical test records' : '历次检测记录'}}">
          <view class="history-header" bindtap="toggleHistoryTimeline" role="button" aria-expanded="{{showHistoryTimeline}}" aria-label="{{currentLang === 'en-US' ? 'Toggle historical test report timeline' : '展开或收起历次检测报告时间轴'}}">
            <view class="history-title">
              <text class="history-icon" aria-hidden="true">📅</text>
              <text role="heading" aria-level="3">{{currentLang === 'en-US' ? 'Historical Reports' : '历次检测记录'}}</text>
              <text class="history-count">{{currentLang === 'en-US' ? 'Total ' : '共 '}}{{traceData.pesticideTest.historyReports.length}}{{currentLang === 'en-US' ? ' reports' : ' 份'}}</text>
            </view>
            <view class="history-toggle {{showHistoryTimeline ? 'expanded' : ''}}" aria-hidden="true">
              <text>▾</text>
            </view>
          </view>
          <view class="history-timeline {{showHistoryTimeline ? 'show' : ''}}" role="list">
            <view
              wx:for="{{traceData.pesticideTest.historyReports}}"
              wx:key="reportNo"
              class="timeline-item {{index === 0 ? 'latest' : ''}} {{item.status === '不合格' ? 'abnormal' : ''}}"
              bindtap="viewHistoryReport"
              data-report="{{item}}"
              role="listitem"
              data-status="{{item.status === '不合格' ? 'fail' : 'pass'}}"
              aria-label="{{item.testDate}}，报告编号{{item.reportNo}}，检测结果{{item.status}}"
            >
              <view class="timeline-dot {{item.status === '不合格' ? 'danger' : (item.statusLevel === '优秀' ? 'excellent' : 'good')}}"></view>
              <view class="timeline-line" wx:if="{{index < traceData.pesticideTest.historyReports.length - 1}}"></view>
              <view class="timeline-content">
                <view class="timeline-date">{{item.testDate}}</view>
                <view class="timeline-info">
                  <text class="timeline-report-no">{{item.reportNo}}</text>
                  <view class="timeline-status {{item.status === '不合格' ? 'danger' : (item.statusLevel === '优秀' ? 'excellent' : 'good')}} status-{{item.status === '不合格' ? 'fail' : 'pass'}}" data-status="{{item.status === '不合格' ? 'fail' : 'pass'}}">
                    {{item.status}}
                  </view>
                </view>
                <view class="timeline-meta">
                  <text>{{item.institution}}</text>
                  <text wx:if="{{item.batchNo}}">{{currentLang === 'en-US' ? 'Batch: ' : '批次：'}}{{item.batchNo}}</text>
                </view>
                <view class="timeline-tag" wx:if="{{index === 0}}">{{currentLang === 'en-US' ? 'Latest' : '最新'}}</view>
              </view>
            </view>
          </view>
        </view>

        <!-- 国标对比提示 -->
        <view class="standard-tip {{testChartData.overallPass ? '' : 'danger'}}" data-status="{{testChartData.overallPass ? 'pass' : 'fail'}}" role="note" aria-label="{{testChartData.overallPass ? (currentLang === 'en-US' ? 'Test result passed' : '检测结果合格') : (currentLang === 'en-US' ? 'Test result has abnormal items' : '检测结果存在异常项')}}">
          <text class="tip-icon" aria-hidden="true">{{testChartData.overallPass ? '✅' : '⚠️'}}</text>
          <text class="tip-text">{{traceData.pesticideTest.comparisonTip}}</text>
        </view>

        <!-- 查看完整报告按钮 -->
        <view class="view-report-btn" bindtap="showPdfReport" role="button" aria-label="{{i18n.pdfBtn}}">
          <text class="btn-icon" aria-hidden="true">📄</text>
          <text>{{currentLang === 'en-US' ? 'View Full Report (PDF Style)' : '查看完整报告（PDF样式）'}}</text>
        </view>
      </view>
    </view>

    <!-- ========== 模块7：冲泡建议 ========== -->
    <view class="card animate-card module-card" id="anchor-brew" style="animation-delay: 0.4s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="brew">
        <view class="title-left">
          <text class="title-icon">☕</text>
          <text>冲泡建议</text>
        </view>
        <view class="module-toggle {{moduleCollapsed.brew ? 'collapsed' : ''}}">
          <text class="toggle-icon">▾</text>
        </view>
      </view>
      <view class="module-content {{moduleCollapsed.brew ? 'hidden' : ''}}">

        <view class="brewing-content">
          <view class="brewing-params">
            <view class="brewing-item">
              <view class="brewing-icon">🌡️</view>
              <view class="brewing-label">水温</view>
              <view class="brewing-value">{{traceData.brewingGuide.waterTemp}}</view>
            </view>
            <view class="brewing-item">
              <view class="brewing-icon">⏱️</view>
              <view class="brewing-label">冲泡时长</view>
              <view class="brewing-value">{{traceData.brewingGuide.brewingTime}}</view>
            </view>
            <view class="brewing-item">
              <view class="brewing-icon">🔄</view>
              <view class="brewing-label">续泡次数</view>
              <view class="brewing-value">{{traceData.brewingGuide.rebrewTimes}}</view>
            </view>
          </view>

          <view class="brewing-extra">
            <view class="extra-item">
              <text class="extra-label">推荐用水：</text>
              <text class="extra-value">{{traceData.brewingGuide.waterType}}</text>
            </view>
            <view class="extra-item">
              <text class="extra-label">推荐茶具：</text>
              <text class="extra-value">{{traceData.brewingGuide.teawareType}}</text>
            </view>
          </view>

          <view class="brewing-tips">
            <view class="tips-title">冲泡小贴士</view>
            <view class="tips-list">
              <view
                wx:for="{{traceData.brewingGuide.tips}}"
                wx:key="*this"
                class="tip-item"
              >
                <text class="tip-num">{{index + 1}}</text>
                <text class="tip-text">{{item}}</text>
              </view>
            </view>
          </view>

          <!-- ============ 互动功能 1：冲泡计时器 ============ -->
          <view class="interactive-section" wx:if="{{brewInteractiveConfig}}">
            <view class="section-sub-title">
              <text class="sub-icon">⏱️</text>
              <text>冲泡计时器</text>
            </view>

            <view class="timer-container">
              <view class="water-temp-selector">
                <view
                  wx:for="{{brewInteractiveConfig.waterTempLevels}}"
                  wx:key="key"
                  class="temp-item {{selectedWaterTemp === item.key ? 'active' : ''}}"
                  data-temp="{{item.key}}"
                  bindtap="selectWaterTemp"
                >
                  <text class="temp-icon">{{item.icon}}</text>
                  <text class="temp-label">{{item.label}}</text>
                  <text class="temp-desc">{{item.desc}}</text>
                </view>
              </view>

              <view class="timer-display">
                <view class="timer-circle">
                  <view class="timer-progress" style="--progress: {{timerProgress}}%;"></view>
                  <view class="timer-content">
                    <text class="timer-text">{{timerText}}</text>
                    <text class="timer-label">{{timerRunning ? '冲泡中...' : '准备冲泡'}}</text>
                  </view>
                </view>
              </view>

              <view class="timer-controls">
                <view class="control-btn reset-btn" bindtap="resetBrewTimer">
                  <text>🔄 重置</text>
                </view>
                <view class="control-btn primary-btn {{timerRunning ? 'pause' : 'start'}}" bindtap="toggleBrewTimer">
                  <text wx:if="{{!timerRunning}}">▶️ 开始 2分钟</text>
                  <text wx:else>⏸️ 暂停</text>
                </view>
              </view>
            </view>
          </view>

          <!-- ============ 互动功能 2：分步冲泡向导 ============ -->
          <view class="interactive-section" wx:if="{{brewInteractiveConfig}}">
            <view class="section-sub-title">
              <text class="sub-icon">📖</text>
              <text>分步冲泡向导</text>
            </view>

            <view class="brew-guide-container">
              <view class="brew-step-nav">
                <view
                  wx:for="{{brewInteractiveConfig.brewSteps}}"
                  wx:key="step"
                  class="step-nav-item {{activeBrewStep === index ? 'active' : ''}} {{activeBrewStep > index ? 'completed' : ''}}"
                  data-index="{{index}}"
                  bindtap="selectBrewStep"
                >
                  <view class="step-nav-dot">
                    <text wx:if="{{activeBrewStep > index}}">✓</text>
                    <text wx:else>{{item.step}}</text>
                  </view>
                  <text class="step-nav-name">{{item.name}}</text>
                  <view class="step-nav-line" wx:if="{{index < brewInteractiveConfig.brewSteps.length - 1}}"></view>
                </view>
              </view>

              <view class="brew-step-detail">
                <block wx:if="{{brewInteractiveConfig.brewSteps[activeBrewStep]}}">
                  <view class="step-detail-header">
                    <view class="step-detail-icon">{{brewInteractiveConfig.brewSteps[activeBrewStep].icon}}</view>
                    <view class="step-detail-info">
                      <text class="step-detail-title">{{brewInteractiveConfig.brewSteps[activeBrewStep].title}}</text>
                      <text class="step-detail-desc">{{brewInteractiveConfig.brewSteps[activeBrewStep].desc}}</text>
                    </view>
                  </view>

                  <view class="step-detail-content">
                    <text class="step-detail-text">{{brewInteractiveConfig.brewSteps[activeBrewStep].detail}}</text>
                  </view>

                  <view class="step-detail-tip">
                    <text class="tip-bulb">💡</text>
                    <text class="tip-content">{{brewInteractiveConfig.brewSteps[activeBrewStep].tip}}</text>
                  </view>

                  <view class="step-timer-row" wx:if="{{brewInteractiveConfig.brewSteps[activeBrewStep].duration > 0}}">
                    <view class="step-timer-display">
                      <text class="step-timer-label">本步计时</text>
                      <text class="step-timer-value">{{brewStepTimerText}}</text>
                    </view>
                    <view class="step-timer-controls">
                      <view class="mini-btn" bindtap="resetBrewStepTimer">
                        <text>🔄</text>
                      </view>
                      <view class="mini-btn primary {{brewStepTimerRunning ? '' : 'start'}}" bindtap="toggleBrewStepTimer">
                        <text wx:if="{{!brewStepTimerRunning}}">▶️</text>
                        <text wx:else>⏸️</text>
                      </view>
                    </view>
                  </view>
                </block>
              </view>

              <view class="brew-guide-controls">
                <view class="guide-btn prev-btn {{activeBrewStep === 0 ? 'disabled' : ''}}" bindtap="prevBrewStep">
                  <text>⬅️ 上一步</text>
                </view>
                <view class="guide-btn restart-btn" bindtap="restartBrewGuide">
                  <text>🔄 重新开始</text>
                </view>
                <view class="guide-btn next-btn {{activeBrewStep === brewInteractiveConfig.brewSteps.length - 1 ? 'disabled' : ''}}" bindtap="nextBrewStep">
                  <text>下一步 ➡️</text>
                </view>
              </view>
            </view>
          </view>

          <!-- ============ 互动功能 3：用量计算器 ============ -->
          <view class="interactive-section" wx:if="{{brewInteractiveConfig && dosageResult}}">
            <view class="section-sub-title">
              <text class="sub-icon">⚖️</text>
              <text>用量计算器</text>
            </view>

            <view class="dosage-container">
              <view class="dosage-row">
                <text class="dosage-label">饮用人数</text>
                <view class="people-selector">
                  <view class="people-btn" bindtap="decreasePeople">
                    <text>−</text>
                  </view>
                  <view class="people-count">
                    <text class="count-number">{{dosagePeople}}</text>
                    <text class="count-unit">人</text>
                  </view>
                  <view class="people-btn" bindtap="increasePeople">
                    <text>+</text>
                  </view>
                </view>
              </view>

              <view class="dosage-row">
                <text class="dosage-label">口味浓淡</text>
                <view class="taste-selector">
                  <view
                    class="taste-item {{dosageTaste === 'light' ? 'active' : ''}}"
                    data-taste="light"
                    bindtap="selectTaste"
                  >
                    <text class="taste-icon">🌿</text>
                    <text class="taste-name">清淡</text>
                  </view>
                  <view
                    class="taste-item {{dosageTaste === 'medium' ? 'active' : ''}}"
                    data-taste="medium"
                    bindtap="selectTaste"
                  >
                    <text class="taste-icon">🍵</text>
                    <text class="taste-name">适中</text>
                  </view>
                  <view
                    class="taste-item {{dosageTaste === 'strong' ? 'active' : ''}}"
                    data-taste="strong"
                    bindtap="selectTaste"
                  >
                    <text class="taste-icon">☕</text>
                    <text class="taste-name">浓郁</text>
                  </view>
                </view>
              </view>

              <view class="dosage-result">
                <view class="result-header">
                  <text class="result-title">推荐投茶量</text>
                </view>
                <view class="result-body">
                  <view class="result-main">
                    <text class="result-grams">{{dosageResult.grams}}</text>
                    <text class="result-unit">克</text>
                  </view>
                  <view class="result-extra">
                    <text class="extra-info">约 {{dosageResult.teaspoon}} 茶匙</text>
                  </view>
                </view>
                <view class="result-footer">
                  <text class="result-suggestion">{{dosageResult.suggestion}}</text>
                </view>
              </view>
            </view>
          </view>

        </view>
      </view>
    </view>

    <!-- ========== 区块链存证详情 ========== -->
    <view class="card animate-card blockchain-card module-card" id="anchor-blockchain" style="animation-delay: 0.45s;" wx:if="{{traceData.blockchainInfo}}">
      <view class="card-title module-header" bindtap="toggleModule" data-key="blockchain">
        <view class="title-left">
          <text class="title-icon">🔗</text>
          <text>区块链存证信息</text>
        </view>
        <view class="title-right">
          <view class="bc-verified-badge" wx:if="{{traceData.blockchainInfo.verifyStatus === '已验证'}}">
            <text class="bc-badge-icon">✓</text>
            <text class="bc-badge-text">已验证</text>
          </view>
          <view class="module-toggle {{moduleCollapsed.blockchain ? 'collapsed' : ''}}">
            <text class="toggle-icon">▾</text>
          </view>
        </view>
