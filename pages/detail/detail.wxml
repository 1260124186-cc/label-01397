        <!-- 环保包装 -->
        <view class="green-section">
          <view class="green-header">
            <text class="green-icon">{{traceData.greenTrace.ecoPacking.icon}}</text>
            <text class="green-title">{{traceData.greenTrace.ecoPacking.title}}</text>
            <view class="green-cert">{{traceData.greenTrace.ecoPacking.certification}}</view>
          </view>
          <view class="green-records">
            <view
              wx:for="{{traceData.greenTrace.ecoPacking.records}}"
              wx:key="*this"
              class="record-item"
            >
              <text class="record-check">✓</text>
              <text>{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 绿色物流 -->
        <view class="green-section">
          <view class="green-header">
            <text class="green-icon">{{traceData.greenTrace.ecoLogistics.icon}}</text>
            <text class="green-title">{{traceData.greenTrace.ecoLogistics.title}}</text>
            <view class="green-reduction">{{traceData.greenTrace.ecoLogistics.carbonReduction}}</view>
          </view>
          <view class="green-records">
            <view
              wx:for="{{traceData.greenTrace.ecoLogistics.records}}"
              wx:key="*this"
              class="record-item"
            >
              <text class="record-check">✓</text>
              <text>{{item}}</text>
            </view>
          </view>
        </view>

        <view class="green-trace-entry" bindtap="goGreenTrace">
          <view class="green-trace-entry-left">
            <text class="green-trace-entry-icon">🍃</text>
            <view class="green-trace-entry-text">
              <text class="green-trace-entry-title">查看详细绿色溯源</text>
              <text class="green-trace-entry-desc">认证证书 · 碳足迹 · 回收指引 · 绿色积分</text>
            </view>
          </view>
          <text class="green-trace-entry-arrow">›</text>
        </view>

        <!-- 数据安全提示 -->
        <view class="privacy-notice">
          <text class="privacy-icon">🔒</text>
          <text class="privacy-text">数据加密存储，不收集无关个人信息，符合《个人信息保护法》</text>
        </view>
      </view>
    </view>

    <!-- ========== 模块6：农残检测 ========== -->
    <view class="card animate-card module-card test-module-card {{testChartData.overallPass ? '' : 'test-abnormal-card'}}" id="anchor-test" role="region" aria-label="{{i18n.tabTitleTest}}" style="animation-delay: 0.35s;">
      <view class="card-title module-header" bindtap="toggleModule" data-key="test" role="button" aria-expanded="{{!moduleCollapsed.test}}" aria-label="{{i18n.tabTitleTest}}">
        <view class="title-left">
