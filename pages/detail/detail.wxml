<!--
  桂花茶溯源小程序 - 溯源详情页
  功能：完整展示溯源信息（基础信息、树龄、窨制工艺、绿色溯源、农残检测、冲泡建议）
-->

<view class="page-container {{showPdfModal ? 'no-scroll' : ''}}" wx:if="{{!loading && traceData}}">
  
  <!-- ==================== 顶部产品概览 ==================== -->
  <view class="product-header">
    <view class="header-bg-pattern"></view>
    <view class="product-info">
      <view class="product-icon">
        <text wx:if="{{traceData.osmanthusInfo.variety === '金桂'}}">🌼</text>
        <text wx:else>🌸</text>
      </view>
      <view class="product-name">{{traceData.basicInfo.productName}}</view>
      <view class="product-batch">批次号：{{traceData.basicInfo.batchNo}}</view>
      
      <!-- 区块链存证标识 -->
      <view class="blockchain-badge" wx:if="{{traceData.blockchainInfo}}">
        <view class="badge-icon">🔗</view>
        <view class="badge-text">
          <text class="badge-title">区块链存证</text>
          <text class="badge-desc">数据真实可查・不可篡改</text>
        </view>
        <view class="badge-status">{{traceData.blockchainInfo.verifyStatus}}</view>
      </view>
    </view>
  </view>

  <!-- ==================== 主要内容区域 ==================== -->
  <view class="main-content">
    
    <!-- ========== 模块1：基础信息 ========== -->
    <view class="card animate-card" style="animation-delay: 0.1s;">
      <view class="card-title">
        <text class="title-icon">📋</text>
        <text>基础信息</text>
      </view>
      <view class="info-grid">
        <view class="info-item">
          <view class="info-label">溯源ID</view>
          <view class="info-value highlight" bindtap="copyTraceId">
            {{traceData.basicInfo.traceId}}
            <text class="copy-icon">📋</text>
          </view>
        </view>
        <view class="info-item">
          <view class="info-label">批次号</view>
          <view class="info-value">{{traceData.basicInfo.batchNo}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">采摘时间</view>
          <view class="info-value">{{traceData.basicInfo.pickTime}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">出厂时间</view>
          <view class="info-value">{{traceData.basicInfo.productionTime}}</view>
        </view>
      </view>
    </view>

    <!-- ========== 模块2：树龄信息（核心特色） ========== -->
    <view class="card animate-card tree-age-card" style="animation-delay: 0.15s;">
      <view class="card-title">
        <text class="title-icon">🌳</text>
        <text>树龄信息</text>
        <view class="title-badge">核心特色</view>
      </view>
      <view class="tree-age-content">
        <view class="tree-item">
          <view class="tree-icon tea-tree">🍃</view>
          <view class="tree-info">
            <view class="tree-type">茶树龄</view>
            <view class="tree-age">
              <text class="age-number">{{traceData.treeAge.teaTreeAge}}</text>
              <text class="age-unit">年</text>
            </view>
            <view class="tree-location">产地：{{traceData.treeAge.teaTreeLocation}}</view>
          </view>
        </view>
        <view class="tree-divider"></view>
        <view class="tree-item">
          <view class="tree-icon osmanthus-tree">🌼</view>
          <view class="tree-info">
            <view class="tree-type">桂花树龄</view>
            <view class="tree-age">
              <text class="age-number">{{traceData.treeAge.osmanthusTreeAge}}</text>
              <text class="age-unit">年</text>
            </view>
            <view class="tree-location">产地：{{traceData.treeAge.osmanthusTreeLocation}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块3：桂花信息 ========== -->
    <view class="card animate-card" style="animation-delay: 0.2s;">
      <view class="card-title">
        <text class="title-icon">🌸</text>
        <text>桂花信息</text>
      </view>
      <view class="osmanthus-content">
        <view class="osmanthus-variety">
          <view class="variety-badge {{traceData.osmanthusInfo.variety === '金桂' ? 'golden' : 'silver'}}">
            {{traceData.osmanthusInfo.variety}}
          </view>
        </view>
        <view class="info-grid">
          <view class="info-item">
            <view class="info-label">产地</view>
            <view class="info-value">{{traceData.osmanthusInfo.origin}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">采摘时间</view>
            <view class="info-value">{{traceData.osmanthusInfo.pickTime}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">花色</view>
            <view class="info-value">{{traceData.osmanthusInfo.color}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">香气特点</view>
            <view class="info-value">{{traceData.osmanthusInfo.fragrance}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块4：窨制工艺（核心模块） ========== -->
    <view class="card animate-card" style="animation-delay: 0.25s;">
      <view class="card-title">
        <text class="title-icon">🫖</text>
        <text>窨制工艺</text>
        <view class="title-badge gold">核心工艺</view>
      </view>
      
      <!-- 工艺参数 -->
      <view class="process-params">
        <view class="param-item">
          <view class="param-value">{{traceData.scentingProcess.scentingTimes}}</view>
          <view class="param-label">窨制次数</view>
        </view>
        <view class="param-divider"></view>
        <view class="param-item">
          <view class="param-value">{{traceData.scentingProcess.scentingDuration}}h</view>
          <view class="param-label">每次时长</view>
        </view>
        <view class="param-divider"></view>
        <view class="param-item">
          <view class="param-value">{{traceData.scentingProcess.temperature}}℃</view>
          <view class="param-label">窨制温度</view>
        </view>
        <view class="param-divider"></view>
        <view class="param-item">
          <view class="param-value">{{traceData.scentingProcess.ratio}}</view>
          <view class="param-label">花茶配比</view>
        </view>
      </view>
      
      <!-- 环境参数 -->
      <view class="env-params">
        <view class="env-item">
          <text class="env-icon">💧</text>
          <text>湿度：{{traceData.scentingProcess.humidity}}%</text>
        </view>
        <view class="env-item">
          <text class="env-icon">✨</text>
          <text>洁净度：{{traceData.scentingProcess.workshopCleanliness}}</text>
        </view>
      </view>
      
      <!-- 工艺流程图 -->
      <view class="process-flow">
        <view class="flow-title">工艺流程图</view>
        <view class="flow-steps">
          <view 
            wx:for="{{traceData.scentingProcess.processSteps}}" 
            wx:key="step"
            class="flow-step {{activeProcessStep === index ? 'active' : ''}}"
            data-index="{{index}}"
            bindtap="toggleProcessStep"
          >
            <view class="step-icon">{{item.icon}}</view>
            <view class="step-name">{{item.name}}</view>
            <view class="step-arrow" wx:if="{{index < traceData.scentingProcess.processSteps.length - 1}}">→</view>
          </view>
        </view>
        <!-- 步骤详情（点击展开） -->
        <view class="step-detail" wx:if="{{activeProcessStep >= 0}}">
          <view class="detail-icon">{{traceData.scentingProcess.processSteps[activeProcessStep].icon}}</view>
          <view class="detail-text">
            <view class="detail-name">{{traceData.scentingProcess.processSteps[activeProcessStep].name}}</view>
            <view class="detail-desc">{{traceData.scentingProcess.processSteps[activeProcessStep].desc}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 模块5：绿色溯源（新增核心模块） ========== -->
    <view class="card animate-card green-card" style="animation-delay: 0.3s;">
      <view class="card-title">
        <text class="title-icon">♻️</text>
        <text>绿色溯源</text>
        <view class="title-badge green">环保认证</view>
      </view>
      
      <!-- 生态种植 -->
      <view class="green-section">
        <view class="green-header">
          <text class="green-icon">{{traceData.greenTrace.ecoPlanting.icon}}</text>
          <text class="green-title">{{traceData.greenTrace.ecoPlanting.title}}</text>
          <view class="green-cert">{{traceData.greenTrace.ecoPlanting.certification}}</view>
        </view>
        <view class="green-records">
          <view 
            wx:for="{{traceData.greenTrace.ecoPlanting.records}}" 
            wx:key="*this"
            class="record-item"
          >
            <text class="record-check">✓</text>
            <text>{{item}}</text>
          </view>
        </view>
      </view>
      
      <!-- 环保包装 -->
      <view class="green-section">
        <view class="green-header">
          <text class="green-icon">{{traceData.greenTrace.ecoPacking.icon}}</text>
          <text class="green-title">{{traceData.greenTrace.ecoPacking.title}}</text>
          <view class="green-cert">{{traceData.greenTrace.ecoPacking.certification}}</view>
        </view>
        <view class="green-records">
          <view 
            wx:for="{{traceData.greenTrace.ecoPacking.records}}" 
            wx:key="*this"
            class="record-item"
          >
            <text class="record-check">✓</text>
            <text>{{item}}</text>
          </view>
        </view>
      </view>
      
      <!-- 绿色物流 -->
      <view class="green-section">
        <view class="green-header">
          <text class="green-icon">{{traceData.greenTrace.ecoLogistics.icon}}</text>
          <text class="green-title">{{traceData.greenTrace.ecoLogistics.title}}</text>
          <view class="green-reduction">{{traceData.greenTrace.ecoLogistics.carbonReduction}}</view>
        </view>
        <view class="green-records">
          <view 
            wx:for="{{traceData.greenTrace.ecoLogistics.records}}" 
            wx:key="*this"
            class="record-item"
          >
            <text class="record-check">✓</text>
            <text>{{item}}</text>
          </view>
        </view>
      </view>
      
      <!-- 数据安全提示 -->
      <view class="privacy-notice">
        <text class="privacy-icon">🔒</text>
        <text class="privacy-text">数据加密存储，不收集无关个人信息，符合《个人信息保护法》</text>
      </view>
    </view>

    <!-- ========== 模块6：农残检测 ========== -->
    <view class="card animate-card" style="animation-delay: 0.35s;">
      <view class="card-title">
        <text class="title-icon">🔬</text>
        <text>农残检测</text>
      </view>
      
      <!-- 检测机构信息 -->
      <view class="test-institution">
        <view class="institution-icon">🏛️</view>
        <view class="institution-info">
          <view class="institution-name">{{traceData.pesticideTest.institution}}</view>
          <view class="institution-meta">
            <text>报告编号：{{traceData.pesticideTest.reportNo}}</text>
            <text>检测日期：{{traceData.pesticideTest.testDate}}</text>
          </view>
        </view>
      </view>
      
      <!-- 茶叶检测结果 -->
      <view class="test-results">
        <view class="test-category">
          <text class="category-icon">🍃</text>
          <text>茶叶农残检测</text>
        </view>
        <view class="test-table">
          <view class="table-header">
            <text class="th-item">检测项</text>
            <text class="th-value">检测值</text>
            <text class="th-limit">国标限值</text>
            <text class="th-status">结果</text>
          </view>
          <view 
            wx:for="{{traceData.pesticideTest.teaTests}}" 
            wx:key="item"
            class="table-row"
          >
            <text class="td-item">{{item.item}}</text>
            <text class="td-value">{{item.value}}{{item.unit}}</text>
            <text class="td-limit">{{item.limit}}{{item.unit}}</text>
            <text class="td-status pass">{{item.status}}</text>
          </view>
        </view>
      </view>
      
      <!-- 桂花检测结果 -->
      <view class="test-results">
        <view class="test-category">
          <text class="category-icon">🌸</text>
          <text>桂花农残检测</text>
        </view>
        <view class="test-table">
          <view class="table-header">
            <text class="th-item">检测项</text>
            <text class="th-value">检测值</text>
            <text class="th-limit">国标限值</text>
            <text class="th-status">结果</text>
          </view>
          <view 
            wx:for="{{traceData.pesticideTest.osmanthusTests}}" 
            wx:key="item"
            class="table-row"
          >
            <text class="td-item">{{item.item}}</text>
            <text class="td-value">{{item.value}}{{item.unit}}</text>
            <text class="td-limit">{{item.limit}}{{item.unit}}</text>
            <text class="td-status pass">{{item.status}}</text>
          </view>
        </view>
      </view>
      
      <!-- 国标对比提示 -->
      <view class="standard-tip">
        <text class="tip-icon">✅</text>
        <text class="tip-text">{{traceData.pesticideTest.comparisonTip}}</text>
      </view>
      
      <!-- 查看完整报告按钮 -->
      <view class="view-report-btn" bindtap="showPdfReport">
        <text class="btn-icon">📄</text>
        <text>查看完整报告（PDF样式）</text>
      </view>
    </view>

    <!-- ========== 模块7：冲泡建议 ========== -->
    <view class="card animate-card" style="animation-delay: 0.4s;">
      <view class="card-title">
        <text class="title-icon">☕</text>
        <text>冲泡建议</text>
      </view>
      
      <view class="brewing-content">
        <view class="brewing-params">
          <view class="brewing-item">
            <view class="brewing-icon">🌡️</view>
            <view class="brewing-label">水温</view>
            <view class="brewing-value">{{traceData.brewingGuide.waterTemp}}</view>
          </view>
          <view class="brewing-item">
            <view class="brewing-icon">⏱️</view>
            <view class="brewing-label">冲泡时长</view>
            <view class="brewing-value">{{traceData.brewingGuide.brewingTime}}</view>
          </view>
          <view class="brewing-item">
            <view class="brewing-icon">🔄</view>
            <view class="brewing-label">续泡次数</view>
            <view class="brewing-value">{{traceData.brewingGuide.rebrewTimes}}</view>
          </view>
        </view>
        
        <view class="brewing-extra">
          <view class="extra-item">
            <text class="extra-label">推荐用水：</text>
            <text class="extra-value">{{traceData.brewingGuide.waterType}}</text>
          </view>
          <view class="extra-item">
            <text class="extra-label">推荐茶具：</text>
            <text class="extra-value">{{traceData.brewingGuide.teawareType}}</text>
          </view>
        </view>
        
        <view class="brewing-tips">
          <view class="tips-title">冲泡小贴士</view>
          <view class="tips-list">
            <view 
              wx:for="{{traceData.brewingGuide.tips}}" 
              wx:key="*this"
              class="tip-item"
            >
              <text class="tip-num">{{index + 1}}</text>
              <text class="tip-text">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 区块链存证详情 ========== -->
    <view class="card animate-card blockchain-card" style="animation-delay: 0.45s;" wx:if="{{traceData.blockchainInfo}}">
      <view class="card-title">
        <text class="title-icon">🔗</text>
        <text>区块链存证信息</text>
      </view>
      <view class="blockchain-detail">
        <view class="blockchain-item">
          <text class="bc-label">存证链</text>
          <text class="bc-value">{{traceData.blockchainInfo.chainName}}</text>
        </view>
        <view class="blockchain-item">
          <text class="bc-label">区块高度</text>
          <text class="bc-value">{{traceData.blockchainInfo.blockHeight}}</text>
        </view>
        <view class="blockchain-item">
          <text class="bc-label">交易哈希</text>
          <text class="bc-value hash">{{traceData.blockchainInfo.txHash}}</text>
        </view>
        <view class="blockchain-item">
          <text class="bc-label">存证时间</text>
          <text class="bc-value">{{traceData.blockchainInfo.timestamp}}</text>
        </view>
      </view>
    </view>

  </view>

  <!-- ==================== 返回顶部按钮 ==================== -->
  <view class="back-top {{showBackTop ? 'show' : ''}}" bindtap="scrollToTop">
    <text class="back-top-icon">↑</text>
  </view>

  <!-- ==================== PDF报告弹窗 ==================== -->
  <view class="pdf-modal {{showPdfModal ? 'show' : ''}}" catchtouchmove="preventBubble" bindtap="closePdfModal">
    <view class="pdf-content" catchtap="preventBubble" catchtouchmove="preventBubble">
      <view class="pdf-header">
        <text class="pdf-title">农残检测报告</text>
        <view class="pdf-close" bindtap="closePdfModal">×</view>
      </view>
      <view class="pdf-body">
        <view class="pdf-institution">
          <view class="pdf-logo">🏛️</view>
          <view class="pdf-name">{{traceData.pesticideTest.institution}}</view>
        </view>
        <view class="pdf-info">
          <view class="pdf-row">
            <text class="pdf-label">报告编号：</text>
            <text class="pdf-value">{{traceData.pesticideTest.reportNo}}</text>
          </view>
          <view class="pdf-row">
            <text class="pdf-label">检测日期：</text>
            <text class="pdf-value">{{traceData.pesticideTest.testDate}}</text>
          </view>
          <view class="pdf-row">
            <text class="pdf-label">国标依据：</text>
            <text class="pdf-value">{{traceData.pesticideTest.standard}}</text>
          </view>
        </view>
        <view class="pdf-divider"></view>
        <view class="pdf-results">
          <view class="pdf-section-title">茶叶检测项目</view>
          <view wx:for="{{traceData.pesticideTest.teaTests}}" wx:key="item" class="pdf-result-item">
            <text>{{item.item}}：{{item.value}}{{item.unit}}（限值{{item.limit}}{{item.unit}}）</text>
            <text class="pdf-pass">✓合格</text>
          </view>
          <view class="pdf-section-title" style="margin-top: 24rpx;">桂花检测项目</view>
          <view wx:for="{{traceData.pesticideTest.osmanthusTests}}" wx:key="item" class="pdf-result-item">
            <text>{{item.item}}：{{item.value}}{{item.unit}}（限值{{item.limit}}{{item.unit}}）</text>
            <text class="pdf-pass">✓合格</text>
          </view>
        </view>
        <view class="pdf-footer">
          <view class="pdf-stamp">检验合格</view>
          <view class="pdf-conclusion">{{traceData.pesticideTest.comparisonTip}}</view>
        </view>
      </view>
    </view>
  </view>

</view>

<!-- ==================== 加载状态 ==================== -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">正在加载溯源信息...</text>
</view>
