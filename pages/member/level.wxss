.level-page {
  min-height: 100vh;
  background: #F5F5F0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.level-header {
  position: relative;
  padding: 40rpx 32rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 50%, #228B22 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(218,165,32,0.15) 0%, transparent 40%);
}

.header-content {
  position: relative;
  z-index: 1;
}

.current-level {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 3rpx solid;
}

.level-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.level-name {
  font-size: 36rpx;
  font-weight: 700;
}

.points-info {
  text-align: center;
}

.current-points {
  font-size: 80rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.points-unit {
  font-size: 28rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.level-progress-section {
  margin-top: 24rpx;
}

.progress-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-needed {
  color: #FFD700;
  font-weight: 600;
}

.progress-bar {
  width: 400rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
  margin: 0 auto;
}

.progress {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.max-level-tip {
  font-size: 28rpx;
  color: #FFD700;
  font-weight: 600;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.levels-section {
  padding: 0 32rpx 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.levels-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.level-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  border: 3rpx solid #E8E8E8;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  opacity: 0.6;
}

.level-card.active {
  border-width: 3rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  opacity: 1;
}

.level-card.achieved {
  opacity: 0.8;
}

.level-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.level-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}

.badge-icon {
  font-size: 32rpx;
}

.badge-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.level-threshold {
  font-size: 24rpx;
  color: #999999;
}

.benefits-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.benefit-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.benefit-text {
  font-size: 26rpx;
  color: #666666;
}

.current-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.achieved-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  background: #E8F5E9;
  color: #2E8B57;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.rules-section {
  padding: 0 32rpx 32rpx;
}

.rules-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-content {
  flex: 1;
  min-width: 0;
}

.rule-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.rule-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.rule-points {
  font-size: 28rpx;
  font-weight: 700;
  color: #DAA520;
}

.rule-desc {
  font-size: 24rpx;
  color: #999999;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-btn {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(218, 165, 32, 0.3);
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.bottom-space {
  height: 40rpx;
}
