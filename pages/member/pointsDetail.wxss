.points-detail-page {
  min-height: 100vh;
  background: #F5F5F0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.stats-header {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 50%, #228B22 100%);
  padding: 40rpx 32rpx 60rpx;
  position: relative;
}

.stats-header::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(218,165,32,0.15) 0%, transparent 40%);
}

.total-points {
  text-align: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.points-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.mini-stats {
  display: flex;
  gap: 32rpx;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.mini-stat-item {
  text-align: center;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.mini-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.mini-stat-value.income {
  color: #FFD700;
}

.mini-stat-value.expense {
  color: #FFB6C1;
}

.mini-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.tabs-section {
  padding: 0 32rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 2;
}

.tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #999999;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
}

.history-section {
  padding: 32rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

.history-day-group {
  margin-bottom: 32rpx;
}

.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.day-date {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.day-summary {
  display: flex;
  gap: 20rpx;
}

.day-earned {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: 600;
}

.day-spent {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.day-items {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.history-item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-icon.earn {
  background: rgba(46, 139, 87, 0.1);
}

.item-icon.spend {
  background: rgba(255, 107, 107, 0.1);
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-desc {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  font-size: 22rpx;
  color: #999999;
}

.item-points {
  font-size: 32rpx;
  font-weight: 700;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.item-points.earn {
  color: #2E8B57;
}

.item-points.spend {
  color: #FF6B6B;
}

.records-section {
  padding: 0 32rpx 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #DAA520 0%, #FFD700 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.record-points {
  font-size: 24rpx;
  font-weight: 600;
  color: #DAA520;
}

.record-type {
  font-size: 22rpx;
  color: #2E8B57;
  background: rgba(46, 139, 87, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-status.pending {
  color: #FF8C00;
  background: rgba(255, 140, 0, 0.1);
}

.record-status.registered {
  color: #2E8B57;
  background: rgba(46, 139, 87, 0.1);
}

.record-date {
  font-size: 22rpx;
  color: #999999;
}

.bottom-space {
  height: 40rpx;
}
