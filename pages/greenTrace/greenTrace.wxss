  padding-top: 12rpx;
  border-top: 1rpx solid #F0F0F0;
}

.chart-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #8C8C8C;
}

.chart-legend-item .legend-line {
  width: 28rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.chart-legend-item .legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.chart-legend-item .legend-dot.abnormal {
  background: #FF4D4F;
  box-shadow: 0 0 6rpx rgba(255, 77, 79, 0.4);
}

.chart-legend-item .legend-text {
  color: #595959;
}

/* 年度时间轴卡片 */
.year-timeline-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.timeline-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.timeline-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.year-tabs {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  padding-bottom: 16rpx;
  margin-bottom: 24rpx;
}

.year-tabs::-webkit-scrollbar {
  display: none;
}

.year-tab-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 20rpx;
  background: #FAFAFA;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.2s ease;
  min-width: 96rpx;
}

.year-tab-item.active {
  background: linear-gradient(135deg, #2E8B57, #52C41A);
  border-color: #2E8B57;
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.25);
}

.year-tab-item.has-abnormal {
  border-color: #FFCCC7;
}

.year-tab-item.has-abnormal.active {
  border-color: #2E8B57;
}

.year-tab-year {
  font-size: 26rpx;
  font-weight: 700;
  color: #595959;
  margin-bottom: 4rpx;
}

.year-tab-item.active .year-tab-year {
  color: #FFFFFF;
}

.year-tab-level {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  background: #F0F0F0;
  color: #8C8C8C;
  font-weight: 500;
}

.year-tab-item.active .year-tab-level {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.year-tab-level.excellent {
  background: rgba(82, 196, 26, 0.12);
  color: #389E0D;
}

.year-tab-item.active .year-tab-level.excellent {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.year-tab-level.good {
  background: rgba(24, 144, 255, 0.12);
  color: #096DD9;
}

.year-tab-item.active .year-tab-level.good {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.year-tab-abnormal {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FFF1F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  border: 2rpx solid #FFCCC7;
}

/* 年度记录详情 */
.year-record-detail {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.yrd-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed #E8E8E8;
}

.yrd-year-badge {
  font-size: 28rpx;
  font-weight: 700;
  color: #262626;
}

.yrd-level-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.yrd-level-badge.excellent {
  background: linear-gradient(135deg, #52C41A, #73D13D);
  color: #FFFFFF;
}

.yrd-level-badge.good {
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  color: #FFFFFF;
}

.yrd-meta-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.yrd-meta-item {
  flex: 1;
}

.yrd-meta-label {
  display: block;
  font-size: 22rpx;
  color: #8C8C8C;
  margin-bottom: 4rpx;
}

.yrd-meta-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #262626;
}

.yrd-meta-value.batch {
  color: #2E8B57;
  font-family: monospace;
}

.yrd-indicators-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
  margin-left: -8rpx;
  margin-right: -8rpx;
}

.yrd-indicator-item {
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 18rpx;
  width: calc(50% - 16rpx);
  margin: 0 8rpx 16rpx;
  box-sizing: border-box;
}

.yrd-ind-header {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 10rpx;
}

.yrd-ind-icon {
  font-size: 24rpx;
}

.yrd-ind-name {
  font-size: 24rpx;
  color: #595959;
  font-weight: 500;
}

.yrd-ind-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #262626;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.yrd-ind-value.ph {
  color: #52C41A;
}

.yrd-ind-value.organic {
  color: #DAA520;
}

.yrd-ind-bar {
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.yrd-ind-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.yrd-ind-fill.ph {
  background: linear-gradient(90deg, #95DE64, #52C41A);
}

.yrd-ind-fill.organic {
  background: linear-gradient(90deg, #FFD666, #DAA520);
}

.yrd-ind-fill.nitrogen {
  background: linear-gradient(90deg, #69C0FF, #1890FF);
}

.yrd-ind-fill.phosphorus {
  background: linear-gradient(90deg, #FF9C6E, #FA8C16);
}

.yrd-ind-fill.potassium {
  background: linear-gradient(90deg, #B37FEB, #722ED1);
}

.yrd-ind-note {
  font-size: 20rpx;
  color: #BFBFBF;
}

/* 重金属抽检 */
.yrd-heavymetal-section {
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.yrd-hm-header {
  font-size: 26rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
}

.yrd-hm-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.yrd-hm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.yrd-hm-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  width: 160rpx;
}

.yrd-hm-name {
  font-size: 24rpx;
  color: #595959;
  font-weight: 500;
}

.yrd-hm-status {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(82, 196, 26, 0.12);
  color: #389E0D;
  font-weight: 500;
}

.yrd-hm-right {
  flex: 1;
  min-width: 0;
}

.yrd-hm-bar-track {
  height: 10rpx;
  background: #F5F5F5;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.yrd-hm-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #95DE64, #52C41A);
  border-radius: 5rpx;
  transition: width 0.5s ease;
}

.yrd-hm-values {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.yrd-hm-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #389E0D;
}

.yrd-hm-limit {
  font-size: 20rpx;
  color: #BFBFBF;
}

/* 异常事件卡片 */
.yrd-abnormal-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 20rpx;
  border: 2rpx solid #FFCCC7;
}

.abnormal-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
}

.abnormal-card-header.mild {
  background: linear-gradient(135deg, #FFF7E6, #FFE7BA);
}

.abnormal-card-header.moderate {
  background: linear-gradient(135deg, #FFF1F0, #FFCCC7);
}

.abnormal-card-header.severe {
  background: linear-gradient(135deg, #FFF1F0, #FFA39E);
}

.abnormal-card-icon {
  width: 56rpx;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.abnormal-card-info {
  flex: 1;
  min-width: 0;
}

.abnormal-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #CF1322;
  margin-bottom: 6rpx;
}

.abnormal-card-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 22rpx;
  color: #8C8C8C;
}

.impact-level-tag {
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.impact-level-tag.mild {
  background: #FFF7E6;
  color: #D46B08;
  border: 1rpx solid #FFD591;
}

.impact-level-tag.moderate {
  background: #FFF1F0;
  color: #CF1322;
  border: 1rpx solid #FFCCC7;
}

.impact-level-tag.severe {
  background: #FFF1F0;
  color: #A8071A;
  border: 1rpx solid #FFA39E;
}

.abnormal-card-desc,
.abnormal-card-impact,
.abnormal-card-batches {
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #FFF1F0;
}

.desc-label,
.impact-label,
.batch-impact-title {
  display: block;
  font-size: 22rpx;
  color: #8C8C8C;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.desc-text,
.impact-text {
  font-size: 24rpx;
  color: #595959;
  line-height: 1.6;
}

.batch-impact-title {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #595959;
}

.batch-impact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 14rpx;
  background: #FFFBF0;
  border-radius: 10rpx;
  margin-bottom: 8rpx;
}

.batch-impact-item:last-child {
  margin-bottom: 0;
}

.bi-batch {
  font-size: 24rpx;
  font-weight: 600;
  color: #D46B08;
  font-family: monospace;
}

.bi-impact {
  font-size: 22rpx;
  color: #8C8C8C;
}

.yrd-impact-note-card {
  display: flex;
  align-items: flex-start;
  background: #F6FFED;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-top: 20rpx;
}

.yrd-impact-note-card .note-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.yrd-impact-note-card .note-text {
  font-size: 24rpx;
  color: #389E0D;
  line-height: 1.6;
  font-weight: 500;
}

/* 土壤改良措施时间轴 */
.improvement-timeline-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.im-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.im-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.im-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.im-list {
  display: flex;
  flex-direction: column;
}

.im-item {
  display: flex;
  gap: 20rpx;
}

.im-year-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
  flex-shrink: 0;
}

.im-year {
  font-size: 24rpx;
  font-weight: 700;
  color: #2E8B57;
  margin-bottom: 8rpx;
}

.im-dot {
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #52C41A, #2E8B57);
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.4);
  z-index: 2;
}

.im-line {
  flex: 1;
  width: 3rpx;
  background: linear-gradient(180deg, #B7EB8F, #E8E8E8);
  margin: 4rpx 0;
}

.im-content-col {
  flex: 1;
  padding-bottom: 24rpx;
}

.im-content {
  font-size: 26rpx;
  color: #595959;
  line-height: 1.6;
  padding: 14rpx 18rpx;
  background: linear-gradient(135deg, #F6FFED, #FFFFFF);
  border-radius: 12rpx;
  border: 1rpx solid #D9F7BE;
}
