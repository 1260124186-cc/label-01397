.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F5F0 0%, #FAFAF5 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

.product-banner {
  position: relative;
  padding: 48rpx 32rpx 64rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 50%, #228B22 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image:
    radial-gradient(circle at 15% 25%, rgba(255,255,255,0.1) 0%, transparent 40%),
    radial-gradient(circle at 85% 75%, rgba(218,165,32,0.15) 0%, transparent 35%);
}

.banner-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.banner-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.active .tab-label {
  color: #2E8B57;
  font-weight: 600;
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 24rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.tab-indicator {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #2E8B57, #52C41A);
  border-radius: 3rpx;
}

.tab-content {
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.section-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.cert-section, .carbon-section, .water-section, .biodiversity-section, .recycling-section, .points-section, .soil-health-section {
  animation: fadeInUp 0.3s ease;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== 证书卡片 ===== */
.cert-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.cert-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.cert-card:active {
  transform: scale(0.98);
}

.cert-thumb-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.cert-thumb {
  width: 100%;
  height: 100%;
}

.cert-type-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 20rpx;
  color: #FFFFFF;
  padding: 4rpx 0;
}

.cert-type-badge.organic {
  background: rgba(82, 196, 26, 0.9);
}

.cert-type-badge.greenPacking {
  background: rgba(46, 139, 87, 0.9);
}

.cert-type-badge.greenFood {
  background: rgba(218, 165, 32, 0.9);
}

.cert-type-badge.recyclable {
  background: rgba(114, 46, 209, 0.9);
}

.cert-info {
  flex: 1;
  min-width: 0;
}

.cert-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cert-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cert-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.cert-status.valid {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.cert-status.expired {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.cert-org {
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cert-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.cert-verify-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #F8FFF8, #F5F5F0);
  border: 2rpx solid rgba(46, 139, 87, 0.2);
  border-radius: 16rpx;
}

.verify-entry-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.verify-entry-text {
  font-size: 28rpx;
  color: #2E8B57;
  font-weight: 500;
}

/* ===== 碳足迹 ===== */
.carbon-overview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.carbon-total {
  text-align: center;
}

.carbon-total-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #2E8B57;
}

.carbon-total-unit {
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
}

.carbon-reduction {
  text-align: center;
}

.reduction-badge {
  display: flex;
  align-items: center;
  background: rgba(82, 196, 26, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 8rpx;
}

.reduction-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.reduction-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #52C41A;
}

.reduction-desc {
  font-size: 22rpx;
  color: #999999;
}

.carbon-chart-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 24rpx;
}

.chart-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.carbon-canvas {
  width: 300px;
  height: 300px;
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666666;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-name {
  font-weight: 500;
}

.legend-value {
  color: #2E8B57;
  font-weight: 500;
}

.legend-percent {
  color: #999999;
}

.industry-comparison {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.comparison-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.comparison-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.comparison-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.comparison-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comparison-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.comp-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.comp-bar-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.comp-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comp-bar-label {
  font-size: 22rpx;
  color: #666666;
  width: 100rpx;
  flex-shrink: 0;
}

.comp-bar-label.industry {
  color: #999999;
}

.comp-bar-track {
  flex: 1;
  height: 20rpx;
  background: #F0F0F0;
  border-radius: 10rpx;
  overflow: hidden;
}

.comp-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.6s ease;
  min-width: 4rpx;
}

.comp-bar-fill.product {
  opacity: 0.9;
}

.comp-bar-fill.industry {
  background: linear-gradient(90deg, #E8E8E8, #D0D0D0);
}

.comp-bar-value {
  font-size: 22rpx;
  color: #666666;
  width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}

.carbon-note {
  display: flex;
  align-items: flex-start;
  background: rgba(82, 196, 26, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
}

.note-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.note-text {
  font-size: 26rpx;
  color: #52C41A;
  line-height: 1.6;
  font-weight: 500;
}

