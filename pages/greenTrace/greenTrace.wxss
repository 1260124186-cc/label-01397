/* ===== 弹窗通用 ===== */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: modalFadeIn 0.3s ease;
}

@keyframes modalFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.cert-modal-content, .verify-modal-content {
  width: 90%;
  max-width: 650rpx;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.cert-modal-header, .verify-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
}

.cert-modal-title, .verify-modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.cert-modal-close, .verify-modal-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.cert-modal-body, .verify-modal-body {
  padding: 32rpx;
  max-height: calc(85vh - 120rpx);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.cert-modal-image-wrapper {
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  margin-bottom: 24rpx;
}

.cert-modal-image {
  width: 100%;
  height: 400rpx;
}

.cert-modal-zoom-hint {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.cert-modal-detail {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.cert-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #F0F0F0;
}

.cert-detail-row:last-child {
  border-bottom: none;
}

.cert-detail-label {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
}

.cert-detail-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  max-width: 360rpx;
  word-break: break-all;
}

.cert-no {
  color: #2E8B57;
}

.cert-detail-value.valid {
  color: #52C41A;
}

.cert-detail-value.expired {
  color: #FF4D4F;
}

.cert-modal-actions {
  display: flex;
  gap: 16rpx;
}

.cert-verify-btn, .cert-copy-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.cert-verify-btn {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
}

.cert-copy-btn {
  background: linear-gradient(135deg, #F8FFF8, #F5F5F0);
  color: #2E8B57;
  border: 1rpx solid rgba(46, 139, 87, 0.3);
}

