/* ===== 生物多样性 ===== */
.bio-index-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #E6F7FF 0%, #BAE7FF 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(24, 144, 255, 0.2);
}

.bio-index-ring {
  width: 140rpx;
  height: 140rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.2);
}

.bio-index-score {
  font-size: 48rpx;
  font-weight: 700;
  color: #1890FF;
  line-height: 1.1;
}

.bio-index-label {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.bio-index-info {
  flex: 1;
  min-width: 0;
}

.bio-level-badge {
  display: inline-block;
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.bio-level-badge.excellent {
  background: rgba(82, 196, 26, 0.15);
  color: #52C41A;
}

.bio-level-badge.good {
  background: rgba(24, 144, 255, 0.15);
  color: #1890FF;
}

.bio-index-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.bio-summary-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.bio-summary-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 28rpx;
  margin-left: -8rpx;
  margin-right: -8rpx;
}

.bio-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 16rpx 8rpx;
  background: #F8FBFF;
  border-radius: 16rpx;
  border: 1rpx solid rgba(24, 144, 255, 0.1);
  width: calc(25% - 16rpx);
  margin: 0 8rpx 16rpx;
  box-sizing: border-box;
}

.bio-stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.bio-stat-num {
  font-size: 36rpx;
  font-weight: 700;
