  line-height: 1.2;
}

.bio-stat-label {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.bio-summary-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bio-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx dashed #F0F0F0;
}

.bio-meta-row:last-child {
  border-bottom: none;
}

.bio-meta-label {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.bio-meta-value {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
}

.bio-monitor-count-card {
