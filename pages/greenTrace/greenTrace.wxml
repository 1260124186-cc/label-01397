<view class="page-container">

  <view class="product-banner">
    <view class="banner-bg"></view>
    <view class="banner-content">
      <view class="banner-icon">🍃</view>
      <view class="banner-title">绿色溯源</view>
      <view class="banner-subtitle">{{productName}}</view>
    </view>
  </view>

  <view class="tab-bar">
    <view 
      wx:for="{{tabs}}" 
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-label">{{item.label}}</text>
      <view class="tab-indicator" wx:if="{{activeTab === item.key}}"></view>
    </view>
  </view>

  <view class="tab-content">

    <!-- ========== 认证证书 ========== -->
    <view class="cert-section" wx:if="{{activeTab === 'certificate'}}">
      <view class="section-header">
        <text class="section-icon">📜</text>
        <text class="section-title">认证证书</text>
      </view>
      <view class="section-desc">点击证书缩略图查看大图，支持证书编号验真</view>

      <view class="cert-grid">
        <view 
          wx:for="{{certificates}}" 
          wx:key="id"
          class="cert-card"
          data-cert="{{item}}"
          bindtap="showCertDetail"
        >
          <view class="cert-thumb-wrapper">
            <image class="cert-thumb" src="{{item.thumbnail}}" mode="aspectFill" />
            <view class="cert-type-badge {{item.type}}">{{item.type === 'organic' ? '有机' : item.type === 'greenPacking' ? '绿包' : item.type === 'greenFood' ? '绿食' : '回收'}}</view>
          </view>
          <view class="cert-info">
            <view class="cert-name">{{item.name}}</view>
            <view class="cert-meta">
              <text class="cert-status {{item.status === '有效' ? 'valid' : 'expired'}}">{{item.status}}</text>
              <text class="cert-org">{{item.issueOrg}}</text>
            </view>
          </view>
          <view class="cert-arrow">›</view>
        </view>
      </view>

      <view class="cert-verify-entry" bindtap="openCertVerifyModal">
        <text class="verify-entry-icon">🔍</text>
        <text class="verify-entry-text">证书编号验真</text>
      </view>
    </view>

    <!-- ========== 碳足迹计算器 ========== -->
    <view class="carbon-section" wx:if="{{activeTab === 'carbon' && carbonFootprint}}">
      <view class="section-header">
        <text class="section-icon">🌍</text>
        <text class="section-title">碳足迹计算器</text>
      </view>

      <view class="carbon-overview">
        <view class="carbon-total">
          <view class="carbon-total-value">{{carbonFootprint.totalEmission}}</view>
          <view class="carbon-total-unit">{{carbonFootprint.unit}}</view>
        </view>
        <view class="carbon-reduction">
          <view class="reduction-badge">
            <text class="reduction-icon">📉</text>
            <text class="reduction-value">-{{carbonFootprint.reductionPercent}}%</text>
          </view>
          <view class="reduction-desc">较行业均值</view>
        </view>
      </view>

      <view class="carbon-chart-card">
        <view class="chart-title">各环节碳排放占比</view>
        <view class="chart-wrapper">
          <canvas type="2d" id="carbonCanvas" class="carbon-canvas"></canvas>
        </view>

        <view class="chart-legend">
          <view 
            wx:for="{{carbonFootprint.stages}}" 
            wx:key="name"
            class="legend-item"
          >
            <view class="legend-dot" style="background-color: {{item.color}};"></view>
            <text class="legend-name">{{item.name}}</text>
            <text class="legend-value">{{item.value}}kg</text>
            <text class="legend-percent">{{item.percent}}%</text>
          </view>
        </view>
      </view>

      <view class="industry-comparison">
        <view class="comparison-header">
          <text class="comparison-icon">📊</text>
          <text class="comparison-title">与行业均值对比</text>
        </view>
        <view class="comparison-bars">
          <view 
            wx:for="{{carbonFootprint.stages}}" 
            wx:key="name"
            class="comparison-item"
          >
            <view class="comp-label">{{item.name}}</view>
            <view class="comp-bar-group">
              <view class="comp-bar-row">
                <text class="comp-bar-label">本产品</text>
                <view class="comp-bar-track">
                  <view class="comp-bar-fill product" style="width: {{(item.value / carbonFootprint.industryAvg.totalEmission) * 100}}%; background-color: {{item.color}};"></view>
                </view>
                <text class="comp-bar-value">{{item.value}}</text>
              </view>
              <view class="comp-bar-row">
                <text class="comp-bar-label industry">行业均值</text>
                <view class="comp-bar-track">
                  <view class="comp-bar-fill industry" style="width: {{(carbonFootprint.industryAvg.stages[index].value / carbonFootprint.industryAvg.totalEmission) * 100}}%;"></view>
                </view>
                <text class="comp-bar-value">{{carbonFootprint.industryAvg.stages[index].value}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="carbon-note">
        <text class="note-icon">💡</text>
        <text class="note-text">{{carbonFootprint.comparisonNote}}</text>
      </view>
    </view>

    <!-- ========== 水足迹 ========== -->
    <view class="water-section" wx:if="{{activeTab === 'water' && waterFootprint}}">
      <view class="section-header">
        <text class="section-icon">💧</text>
        <text class="section-title">水足迹</text>
      </view>

      <view class="water-overview">
        <view class="water-total">
          <view class="water-total-value">{{waterFootprint.totalUsage}}</view>
          <view class="water-total-unit">{{waterFootprint.unit}}</view>
        </view>
        <view class="water-saving">
          <view class="saving-badge">
            <text class="saving-icon">📉</text>
            <text class="saving-value">-{{waterFootprint.savingPercent}}%</text>
          </view>
          <view class="saving-desc">较行业均值</view>
        </view>
      </view>

      <view class="water-chart-card">
        <view class="chart-title">各环节用水占比</view>
        <view class="chart-wrapper">
          <canvas type="2d" id="waterCanvas" class="water-canvas"></canvas>
        </view>

        <view class="chart-legend">
          <view 
            wx:for="{{waterFootprint.stages}}" 
            wx:key="name"
            class="legend-item"
          >
            <view class="legend-dot" style="background-color: {{item.color}};"></view>
            <text class="legend-name">{{item.name}}</text>
            <text class="legend-value">{{item.value}}L</text>
            <text class="legend-percent">{{item.percent}}%</text>
          </view>
        </view>
      </view>

      <view class="water-industry-comparison">
        <view class="comparison-header">
          <text class="comparison-icon">📊</text>
          <text class="comparison-title">单位产品耗水 vs 行业均值</text>
        </view>
        <view class="comparison-bars">
          <view 
            wx:for="{{waterFootprint.stages}}" 
            wx:key="name"
            class="comparison-item"
          >
            <view class="comp-label">{{item.name}}</view>
            <view class="comp-bar-group">
              <view class="comp-bar-row">
                <text class="comp-bar-label">本产品</text>
                <view class="comp-bar-track">
                  <view class="comp-bar-fill product" style="width: {{(item.value / waterFootprint.industryAvg.totalUsage) * 100}}%; background-color: {{item.color}};"></view>
                </view>
                <text class="comp-bar-value">{{item.value}}L</text>
              </view>
              <view class="comp-bar-row">
                <text class="comp-bar-label industry">行业均值</text>
                <view class="comp-bar-track">
                  <view class="comp-bar-fill industry" style="width: {{(waterFootprint.industryAvg.stages[index].value / waterFootprint.industryAvg.totalUsage) * 100}}%;"></view>
                </view>
                <text class="comp-bar-value">{{waterFootprint.industryAvg.stages[index].value}}L</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="water-monitor-card">
        <view class="monitor-header">
          <text class="monitor-icon">📡</text>
          <text class="monitor-title">水表监测点</text>
        </view>
        <view class="monitor-list">
          <view 
            wx:for="{{waterFootprint.monitorPoints}}" 
            wx:key="id"
            class="monitor-item"
          >
            <view class="monitor-dot {{item.status === 'online' ? 'online' : 'offline'}}"></view>
            <view class="monitor-info">
              <view class="monitor-name">{{item.name}}</view>
              <view class="monitor-location">{{item.location}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="water-note">
        <text class="note-icon">💡</text>
        <text class="note-text">{{waterFootprint.comparisonNote}}</text>
      </view>

      <view class="data-source-tag">
        <text class="ds-icon">📡</text>
        <text class="ds-text">数据来源：{{waterFootprint.dataSource}}</text>
      </view>
    </view>

    <!-- ========== 生物多样性 ========== -->
    <view class="biodiversity-section" wx:if="{{activeTab === 'biodiversity' && biodiversity}}">
      <view class="section-header">
        <text class="section-icon">🦜</text>
        <text class="section-title">生物多样性</text>
      </view>

      <view class="bio-index-card">
        <view class="bio-index-ring">
          <view class="bio-index-score">{{biodiversity.indexScore}}</view>
          <view class="bio-index-label">多样性指数</view>
        </view>
        <view class="bio-index-info">
          <view class="bio-level-badge {{biodiversity.indexLevel === '优秀' ? 'excellent' : 'good'}}">{{biodiversity.indexLevel}}</view>
          <view class="bio-index-desc">{{biodiversity.indexDesc}}</view>
        </view>
      </view>

      <view class="bio-summary-card">
        <view class="bio-summary-grid">
          <view class="bio-stat-item">
            <view class="bio-stat-icon">🦅</view>
            <view class="bio-stat-num">{{biodiversity.monitoringSummary.birdSpecies}}</view>
            <view class="bio-stat-label">鸟类物种</view>
          </view>
          <view class="bio-stat-item">
            <view class="bio-stat-icon">🐝</view>
            <view class="bio-stat-num">{{biodiversity.monitoringSummary.insectSpecies}}</view>
            <view class="bio-stat-label">昆虫物种</view>
          </view>
          <view class="bio-stat-item">
            <view class="bio-stat-icon">🌿</view>
            <view class="bio-stat-num">{{biodiversity.monitoringSummary.plantSpecies}}</view>
            <view class="bio-stat-label">植物物种</view>
          </view>
          <view class="bio-stat-item">
            <view class="bio-stat-icon">🔬</view>
            <view class="bio-stat-num">{{biodiversity.monitoringSummary.totalSpecies}}</view>
            <view class="bio-stat-label">物种总数</view>
          </view>
        </view>
        <view class="bio-summary-meta">
          <view class="bio-meta-row">
            <text class="bio-meta-label">监测范围</text>
            <text class="bio-meta-value">{{biodiversity.monitoringSummary.monitoringArea}}</text>
          </view>
          <view class="bio-meta-row">
            <text class="bio-meta-label">监测时段</text>
            <text class="bio-meta-value">{{biodiversity.monitoringSummary.monitoringDuration}}</text>
          </view>
          <view class="bio-meta-row">
            <text class="bio-meta-label">监测频率</text>
            <text class="bio-meta-value">{{biodiversity.monitoringSummary.monitoringFrequency}}</text>
          </view>
        </view>
      </view>

      <view class="bio-monitor-count-card">
        <view class="bmc-title">🔭 监测次数统计</view>
        <view class="bmc-bars">
          <view class="bmc-bar-item">
            <view class="bmc-bar-label">🦅 鸟类监测</view>
            <view class="bmc-bar-track">
              <view class="bmc-bar-fill bird" style="width: {{(biodiversity.monitoringStats.birdMonitorCount / 60) * 100}}%;"></view>
            </view>
            <view class="bmc-bar-num">{{biodiversity.monitoringStats.birdMonitorCount}}次</view>
          </view>
          <view class="bmc-bar-item">
            <view class="bmc-bar-label">🐝 昆虫监测</view>
            <view class="bmc-bar-track">
              <view class="bmc-bar-fill insect" style="width: {{(biodiversity.monitoringStats.insectMonitorCount / 60) * 100}}%;"></view>
            </view>
            <view class="bmc-bar-num">{{biodiversity.monitoringStats.insectMonitorCount}}次</view>
          </view>
          <view class="bmc-bar-item">
            <view class="bmc-bar-label">🌿 植物调查</view>
            <view class="bmc-bar-track">
              <view class="bmc-bar-fill plant" style="width: {{(biodiversity.monitoringStats.plantSurveyCount / 60) * 100}}%;"></view>
            </view>
            <view class="bmc-bar-num">{{biodiversity.monitoringStats.plantSurveyCount}}次</view>
          </view>
        </view>
      </view>

      <view class="bio-key-species-card">
        <view class="bks-title">🦋 重点物种</view>
        <view class="bks-list">
          <view 
            wx:for="{{biodiversity.keySpecies}}" 
            wx:key="name"
            class="bks-item"
          >
            <view class="bks-icon">{{item.icon}}</view>
            <view class="bks-info">
              <view class="bks-name">{{item.name}}</view>
              <view class="bks-meta">
                <text class="bks-category">{{item.category}}</text>
                <text class="bks-divider">·</text>
                <text class="bks-protection">{{item.protection}}</text>
              </view>
            </view>
            <view class="bks-trend {{item.trend === '增长' ? 'up' : item.trend === '偶见' ? 'rare' : 'stable'}}">
              {{item.trend}}
            </view>
          </view>
        </view>
      </view>

      <view class="bio-recent-monitor-card">
        <view class="brm-title">📋 近期监测记录</view>
        <view class="brm-list">
          <view 
            wx:for="{{biodiversity.recentMonitoring}}" 
            wx:key="date"
            class="brm-item"
          >
            <view class="brm-header">
              <view class="brm-type-badge {{item.type === '鸟类' ? 'bird' : 'insect'}}">{{item.type}}</view>
              <view class="brm-date">{{item.date}}</view>
              <view class="brm-weather">{{item.weather}}</view>
            </view>
            <view class="brm-observer">{{item.observer}}</view>
            <view class="brm-findings">
              <view 
                wx:for="{{item.findings}}" 
                wx:for-item="finding" 
                wx:key="species"
                class="brm-finding-item"
              >
                <view class="brm-species">{{finding.species}}</view>
                <view class="brm-detail">
                  <text class="brm-count">{{finding.count}}只</text>
                  <text class="brm-divider">·</text>
                  <text class="brm-status {{finding.status === '常驻' ? 'resident' : finding.status === '稀有' ? 'rare' : 'occasional'}}">{{finding.status}}</text>
                </view>
                <view class="brm-habitat">{{finding.habitat}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="data-source-tag">
        <text class="ds-icon">📡</text>
        <text class="ds-text">数据来源：{{biodiversity.dataSource}}</text>
      </view>
    </view>

    <!-- ========== 包装回收指引 ========== -->
    <view class="recycling-section" wx:if="{{activeTab === 'recycling' && recyclingGuide}}">
      <view class="section-header">
        <text class="section-icon">♻️</text>
        <text class="section-title">包装回收指引</text>
      </view>

      <view class="material-card">
        <view class="material-icon">📦</view>
        <view class="material-info">
          <view class="material-type">包装材质：{{recyclingGuide.materialType}}</view>
          <view class="material-recyclable {{recyclingGuide.recyclable ? 'yes' : 'no'}}">
            {{recyclingGuide.recyclable ? '✓ 可回收' : '✗ 不可回收'}}
          </view>
        </view>
      </view>

      <view class="recycling-steps">
        <view class="steps-title">分类回收步骤</view>
        <view 
          wx:for="{{recyclingGuide.steps}}" 
          wx:key="step"
          class="step-item"
        >
          <view class="step-number-wrapper">
            <view class="step-number">{{item.step}}</view>
            <view class="step-line" wx:if="{{index < recyclingGuide.steps.length - 1}}"></view>
          </view>
          <view class="step-content">
            <view class="step-header">
              <text class="step-icon">{{item.icon}}</text>
              <text class="step-title">{{item.title}}</text>
            </view>
            <view class="step-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>

      <view class="nearby-section">
        <view class="nearby-header">
          <text class="nearby-icon">📍</text>
          <text class="nearby-title">附近回收点</text>
        </view>
        <view class="nearby-list">
          <view 
            wx:for="{{recyclingGuide.nearbyPoints}}" 
            wx:key="name"
            class="nearby-item"
            data-point="{{item}}"
            bindtap="openRecyclingPoint"
          >
            <view class="nearby-info">
              <view class="nearby-name">{{item.name}}</view>
              <view class="nearby-address">{{item.address}}</view>
            </view>
            <view class="nearby-action">
              <view class="nearby-distance">{{item.distance}}</view>
              <view class="nearby-nav-btn">
                <text>导航</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 公益基金 ========== -->
    <view class="eco-fund-section" wx:if="{{activeTab === 'ecoFund'}}">
      <view class="section-header">
        <text class="section-icon">💚</text>
        <text class="section-title">产区生态基金</text>
        <view class="compliance-link" bindtap="openCharityQualification">
          <text>资质公示 ›</text>
        </view>
      </view>
      <view class="section-desc">扫码即可捐赠一元，让每一杯茶都成为一份善意</view>

      <!-- 批次定向捐赠提示 -->
      <view class="batch-donation-banner" wx:if="{{hasBatchDonation && batchDonationConfig}}">
        <view class="banner-icon-wrap">
          <text class="banner-icon">🌼</text>
        </view>
        <view class="banner-info">
          <view class="banner-title">{{batchDonationConfig.targetProjectName}}</view>
          <view class="banner-desc">{{batchDonationConfig.description}}</view>
          <view class="banner-match">
            <text class="match-tag">🎁 {{batchDonationConfig.matchRatio}}配捐</text>
            <text class="match-note">{{batchDonationConfig.matchNote}}</text>
          </view>
        </view>
      </view>

      <!-- 基金总览统计 -->
      <view class="fund-stats-card" wx:if="{{donationStats}}">
        <view class="fund-stat-item">
          <view class="stat-num">¥{{donationStats.totalRaised}}</view>
          <view class="stat-label">累计筹集</view>
        </view>
        <view class="stat-divider"></view>
        <view class="fund-stat-item">
          <view class="stat-num">{{donationStats.donorCount}}</view>
          <view class="stat-label">爱心人数</view>
        </view>
        <view class="stat-divider" wx:if="{{hasBatchDonation}}"></view>
        <view class="fund-stat-item" wx:if="{{hasBatchDonation}}">
          <view class="stat-num">¥{{donationStats.batchRaised}}</view>
          <view class="stat-label">本批次定向</view>
        </view>
      </view>

      <!-- 基金项目展示 -->
      <view class="projects-title">📢 基金用途说明</view>
      <view class="fund-projects">
        <view 
          wx:for="{{fundProjects}}" 
          wx:key="key"
          class="project-card {{selectedProjectKey === item.key ? 'selected' : ''}}"
          data-key="{{item.key}}"
          bindtap="selectProject"
        >
          <view class="project-header">
            <view class="project-icon" style="background: {{item.color}}15; color: {{item.color}};">
              <text>{{item.icon}}</text>
            </view>
            <view class="project-name">{{item.name}}</view>
            <view class="project-select-indicator" wx:if="{{selectedProjectKey === item.key}}">✓</view>
          </view>
          <view class="project-desc">{{item.description}}</view>
          <view class="project-progress">
            <view class="progress-track">
              <view class="progress-fill" style="width: {{item.progress}}%; background: {{item.color}};"></view>
            </view>
            <view class="progress-info">
              <text class="progress-percent" style="color: {{item.color}};">{{item.progress}}%</text>
              <text class="progress-text">¥{{item.raised}} / ¥{{item.target}}</text>
            </view>
          </view>
          <view class="project-impact">
            <text class="impact-icon">💡</text>
            <text class="impact-text">{{item.impactMetric}}</text>
          </view>
          <view class="project-area">
            <text class="area-icon">📍</text>
            <text class="area-text">{{item.targetArea}}</text>
          </view>
        </view>
      </view>

      <!-- 最近捐赠动态 -->
      <view class="recent-donors-card" wx:if="{{recentDonors.length > 0}}">
        <view class="recent-title">❤️ 最近爱心榜</view>
        <view class="donor-list">
          <view wx:for="{{recentDonors}}" wx:key="time" class="donor-item">
            <view class="donor-avatar">🧑</view>
            <view class="donor-info">
              <view class="donor-name">{{item.name}}</view>
              <view class="donor-message" wx:if="{{item.message}}">「{{item.message}}」</view>
            </view>
            <view class="donor-right">
              <view class="donor-amount">¥{{item.amount}}</view>
              <view class="donor-time">{{item.time}}</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 捐赠入口按钮 -->
      <view class="donate-entry" bindtap="openDonationModal">
        <view class="donate-btn-main">
          <text class="btn-icon">💝</text>
          <text class="btn-text">扫码捐一元</text>
        </view>
        <view class="donate-tips">
          <text>🔒 由</text>
          <text class="tip-highlight" bindtap="openCharityQualification">中华环境保护基金会</text>
          <text>监管 · 可开捐赠票据</text>
        </view>
      </view>

      <!-- 我的贡献 -->
      <view class="my-contribution-card" wx:if="{{userDonationStats && userDonationStats.totalCount > 0}}">
        <view class="my-contrib-title">🎖️ 我的公益贡献</view>
        <view class="my-contrib-stats">
          <view class="my-stat-item">
            <view class="my-stat-num">{{userDonationStats.totalCount}}</view>
            <view class="my-stat-label">捐赠次数</view>
          </view>
          <view class="my-stat-divider"></view>
          <view class="my-stat-item">
            <view class="my-stat-num">¥{{userDonationStats.totalAmount}}</view>
            <view class="my-stat-label">累计金额</view>
          </view>
          <view class="my-stat-divider"></view>
          <view class="my-stat-item go-wallet" bindtap="goCertificateWallet">
            <view class="my-stat-num">📜</view>
            <view class="my-stat-label">我的证书</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 绿色积分 ========== -->
    <view class="points-section" wx:if="{{activeTab === 'points'}}">
      <view class="section-header">
        <text class="section-icon">🌟</text>
        <text class="section-title">绿色积分</text>
      </view>

      <view class="points-card" wx:if="{{userLevel}}">
        <view class="points-level-section">
          <view class="level-icon-wrapper">
            <text class="level-icon">{{userLevel.icon}}</text>
          </view>
          <view class="level-info">
            <view class="level-name">{{userLevel.name}}</view>
            <view class="level-progress-bar">
              <view class="level-progress-fill" style="width: {{userLevel.progress}}%;"></view>
            </view>
            <view class="level-next" wx:if="{{userLevel.nextLevel}}">
              距离{{userLevel.nextLevel}}还需{{userLevel.nextLevelPoints - userLevel.currentPoints}}积分
            </view>
            <view class="level-max" wx:else>
              已达最高等级
            </view>
          </view>
        </view>
        <view class="points-total-section">
          <view class="points-total-value">{{greenPointsData.totalPoints}}</view>
          <view class="points-total-label">环保积分</view>
        </view>
      </view>

      <view class="points-rules-card">
        <view class="rules-title">积分规则</view>
        <view class="rules-list">
          <view class="rule-item">
            <view class="rule-action">📋 查看溯源信息</view>
            <view class="rule-points">+10积分/次</view>
            <view class="rule-limit">每日上限50</view>
          </view>
          <view class="rule-item">
            <view class="rule-action">🌍 查看碳足迹</view>
            <view class="rule-points">+5积分/次</view>
            <view class="rule-limit">每日上限25</view>
          </view>
          <view class="rule-item">
            <view class="rule-action">♻️ 查看回收指引</view>
            <view class="rule-points">+5积分/次</view>
            <view class="rule-limit">每日上限25</view>
          </view>
          <view class="rule-item">
            <view class="rule-action">📜 查看认证证书</view>
            <view class="rule-points">+3积分/次</view>
            <view class="rule-limit">每日上限15</view>
          </view>
          <view class="rule-item">
            <view class="rule-action">📤 分享绿色溯源</view>
            <view class="rule-points">+15积分/次</view>
            <view class="rule-limit">每日上限45</view>
          </view>
        </view>
      </view>

      <view class="level-config-card">
        <view class="level-config-title">会员等级</view>
        <view class="level-config-list">
          <view class="level-config-item {{userLevel && userLevel.level === 1 ? 'current' : ''}}">
            <text class="lc-icon">🌱</text>
            <text class="lc-name">环保新手</text>
            <text class="lc-points">0积分</text>
          </view>
          <view class="level-config-item {{userLevel && userLevel.level === 2 ? 'current' : ''}}">
            <text class="lc-icon">🌿</text>
            <text class="lc-name">环保达人</text>
            <text class="lc-points">100积分</text>
          </view>
          <view class="level-config-item {{userLevel && userLevel.level === 3 ? 'current' : ''}}">
            <text class="lc-icon">🌳</text>
            <text class="lc-name">环保先锋</text>
            <text class="lc-points">500积分</text>
          </view>
          <view class="level-config-item {{userLevel && userLevel.level === 4 ? 'current' : ''}}">
            <text class="lc-icon">🌍</text>
            <text class="lc-name">环保大使</text>
            <text class="lc-points">1000积分</text>
          </view>
        </view>
      </view>

      <view class="points-history-section">
        <view class="history-header" bindtap="togglePointsDetail">
          <text class="history-title">积分记录</text>
          <text class="history-toggle {{showPointsDetail ? 'expanded' : ''}}">▾</text>
        </view>
        <view class="history-list {{showPointsDetail ? 'show' : ''}}" wx:if="{{pointsHistory.length > 0}}">
          <view 
            wx:for="{{pointsHistory}}" 
            wx:key="timestamp"
            class="history-item"
          >
            <view class="history-desc">{{item.desc}}</view>
            <view class="history-meta">
              <text class="history-time">{{item.timestamp}}</text>
              <text class="history-points +{{item.points}}">+{{item.points}}</text>
            </view>
          </view>
        </view>
        <view class="history-empty" wx:else>
          <text>暂无积分记录</text>
        </view>
      </view>
    </view>

  </view>

  <!-- 证书详情弹窗 -->
  <view class="modal-overlay" wx:if="{{showCertModal}}" catchtap="closeCertModal">
    <view class="cert-modal-content" catchtap="preventBubble">
      <view class="cert-modal-header">
        <text class="cert-modal-title">证书详情</text>
        <view class="cert-modal-close" bindtap="closeCertModal">×</view>
      </view>
      <view class="cert-modal-body" wx:if="{{selectedCert}}">
        <view class="cert-modal-image-wrapper" data-url="{{selectedCert.fullImage}}" bindtap="previewCertImage">
          <image class="cert-modal-image" src="{{selectedCert.fullImage}}" mode="aspectFit" />
          <view class="cert-modal-zoom-hint">点击查看大图</view>
        </view>
        <view class="cert-modal-detail">
          <view class="cert-detail-row">
            <text class="cert-detail-label">证书名称</text>
            <text class="cert-detail-value">{{selectedCert.name}}</text>
          </view>
          <view class="cert-detail-row">
            <text class="cert-detail-label">证书编号</text>
            <text class="cert-detail-value cert-no" bindtap="copyCertNo">{{selectedCert.certNo}} 📋</text>
          </view>
          <view class="cert-detail-row">
            <text class="cert-detail-label">颁发机构</text>
            <text class="cert-detail-value">{{selectedCert.issueOrg}}</text>
          </view>
          <view class="cert-detail-row">
            <text class="cert-detail-label">颁发日期</text>
            <text class="cert-detail-value">{{selectedCert.issueDate}}</text>
          </view>
          <view class="cert-detail-row">
            <text class="cert-detail-label">有效期至</text>
            <text class="cert-detail-value">{{selectedCert.validUntil}}</text>
          </view>
          <view class="cert-detail-row">
            <text class="cert-detail-label">证书状态</text>
            <text class="cert-detail-value {{selectedCert.status === '有效' ? 'valid' : 'expired'}}">{{selectedCert.status}}</text>
          </view>
        </view>
        <view class="cert-modal-actions">
          <view class="cert-verify-btn" bindtap="openCertVerifyModal">
            <text>🔍 证书验真</text>
          </view>
          <view class="cert-copy-btn" bindtap="copyCertNo">
            <text>📋 复制编号</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 证书验真弹窗 -->
  <view class="modal-overlay" wx:if="{{showVerifyCertModal}}" catchtap="closeVerifyCertModal">
    <view class="verify-modal-content" catchtap="preventBubble">
      <view class="verify-modal-header">
        <text class="verify-modal-title">🔍 证书编号验真</text>
        <view class="verify-modal-close" bindtap="closeVerifyCertModal">×</view>
      </view>
      <view class="verify-modal-body">
        <view class="verify-input-section">
          <text class="verify-label">请输入证书编号</text>
          <view class="verify-input-wrapper">
            <input 
              class="verify-input" 
              placeholder="如 ORG-CERT-2025-GH001" 
              value="{{certVerifyInput}}"
              bindinput="onCertVerifyInputChange"
            />
          </view>
          <view class="verify-buttons">
            <view class="verify-btn primary" bindtap="doVerifyCertificate">
              <text>{{certVerifying ? '验证中...' : '立即验真'}}</text>
            </view>
          </view>
        </view>
        <view class="verify-result" wx:if="{{certVerifyResult}}">
          <view class="verify-result-header {{certVerifyResult.valid ? 'valid' : 'invalid'}}">
            <text class="verify-result-icon">{{certVerifyResult.valid ? '✅' : '❌'}}</text>
            <text class="verify-result-title">{{certVerifyResult.valid ? '验证通过' : '验证未通过'}}</text>
          </view>
          <view class="verify-result-body" wx:if="{{certVerifyResult.valid}}">
            <view class="verify-row">
              <text class="verify-row-label">证书编号</text>
              <text class="verify-row-value">{{certVerifyResult.certNo}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">证书名称</text>
              <text class="verify-row-value">{{certVerifyResult.certName}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">颁发机构</text>
              <text class="verify-row-value">{{certVerifyResult.issueOrg}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">关联产品</text>
              <text class="verify-row-value">{{certVerifyResult.productName}}</text>
            </view>
            <view class="verify-row">
              <text class="verify-row-label">验证时间</text>
              <text class="verify-row-value">{{certVerifyResult.verifyTime}}</text>
            </view>
          </view>
          <view class="verify-result-body invalid-body" wx:else>
            <text class="verify-invalid-msg">{{certVerifyResult.message}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 捐赠弹窗 -->
  <view class="modal-overlay donation-modal" wx:if="{{showDonationModal}}" catchtap="closeDonationModal">
    <view class="donation-modal-content" catchtap="preventBubbleDonation">
      <view class="donation-modal-header">
        <text class="donation-modal-title">💝 公益捐赠</text>
        <view class="donation-modal-close" bindtap="closeDonationModal">×</view>
      </view>

      <block wx:if="{{!donationResult}}">
        <view class="donation-modal-body">

          <!-- 批次定向提示 -->
          <view class="donation-batch-tip" wx:if="{{hasBatchDonation && batchDonationConfig}}">
            <text class="batch-tip-icon">🎯</text>
            <view class="batch-tip-content">
              <view class="batch-tip-title">批次定向支持</view>
              <view class="batch-tip-desc">{{batchDonationConfig.description}}</view>
            </view>
          </view>

          <!-- 项目选择 -->
          <view class="donation-section-title">选择捐赠项目</view>
          <view class="donation-project-list">
            <view
              wx:for="{{fundProjects}}"
              wx:key="key"
              class="donation-project-item {{selectedProjectKey === item.key ? 'active' : ''}}"
              data-key="{{item.key}}"
              bindtap="selectProject"
            >
              <view class="dpi-icon" style="background: {{item.color}}15; color: {{item.color}};">{{item.icon}}</view>
              <view class="dpi-name">{{item.name}}</view>
              <view class="dpi-check" wx:if="{{selectedProjectKey === item.key}}">✓</view>
            </view>
          </view>

          <!-- 金额选择 -->
          <view class="donation-section-title">选择捐赠金额</view>
          <view class="donation-amount-list">
            <view
              wx:for="{{[1, 5, 10, 50]}}"
              wx:key="*this"
              class="donation-amount-item {{selectedAmount === item ? 'active' : ''}}"
              data-amount="{{item}}"
              bindtap="selectAmount"
            >
              <text class="da-symbol">¥</text>
              <text class="da-value">{{item}}</text>
            </view>
          </view>

          <!-- 信息填写 -->
          <view class="donation-section-title">您的信息（选填）</view>
          <view class="donation-input-group">
            <view class="donation-input-row">
              <text class="di-label">昵称</text>
              <input
                class="di-input"
                placeholder="默认：爱心人士"
                placeholder-class="di-placeholder"
                value="{{donorName}}"
                bindinput="onDonorNameInput"
                maxlength="20"
              />
            </view>
            <view class="donation-input-row">
              <text class="di-label">留言</text>
              <input
                class="di-input"
                placeholder="留下您的祝福..."
                placeholder-class="di-placeholder"
                value="{{donorMessage}}"
                bindinput="onDonorMessageInput"
                maxlength="50"
              />
            </view>
          </view>

          <!-- 合规提示 -->
          <view class="donation-compliance">
            <view class="compliance-row">
              <text class="compliance-icon">🛡️</text>
              <text class="compliance-text">捐赠资金由</text>
              <text class="compliance-link" bindtap="openCharityQualification">中华环境保护基金会</text>
              <text class="compliance-text">监管</text>
            </view>
            <view class="compliance-row">
              <text class="compliance-icon">📄</text>
              <text class="compliance-text">可凭捐赠凭证申请公益捐赠票据，支持个税抵扣</text>
            </view>
            <view class="compliance-row">
              <text class="compliance-icon">🎖️</text>
              <text class="compliance-text">捐赠成功后将自动生成公益捐赠证书存入证书钱包</text>
            </view>
          </view>

        </view>

        <view class="donation-modal-footer">
          <view class="donation-confirm-btn {{isDonating ? 'disabled' : ''}}" bindtap="doDonation">
            <text wx:if="{{!isDonating}}">确认捐赠 ¥{{selectedAmount}}</text>
            <text wx:else>捐赠中...</text>
          </view>
          <view class="donation-summary-row">
            <text class="ds-text">您捐赠的 ¥{{selectedAmount}} 将用于</text>
            <text
              wx:for="{{fundProjects}}"
              wx:key="key"
              wx:if="{{item.key === selectedProjectKey}}"
              class="ds-highlight"
            >{{item.name}}</text>
          </view>
        </view>
      </block>

      <!-- 捐赠成功 -->
      <block wx:else>
        <view class="donation-success-body">
          <view class="success-icon-wrap">
            <text class="success-icon">🎉</text>
          </view>
          <view class="success-title">感谢您的爱心捐赠！</view>
          <view class="success-amount">¥{{donationResult.donationRecord.amount}}</view>
          <view class="success-info-card">
            <view class="si-row">
              <text class="si-label">捐赠项目</text>
              <text class="si-value">{{donationResult.donationRecord.projectName}}</text>
            </view>
            <view class="si-divider"></view>
            <view class="si-row">
              <text class="si-label">凭证编号</text>
              <text class="si-value mono">{{donationResult.donationRecord.orderNo}}</text>
            </view>
            <view class="si-divider"></view>
            <view class="si-row" wx:if="{{donationResult.certificate}}">
              <text class="si-label">证书编号</text>
              <text class="si-value mono">{{donationResult.certificate.certNo}}</text>
            </view>
          </view>
          <view class="success-match-tip" wx:if="{{hasBatchDonation && batchDonationConfig}}">
            <text>🎁 </text>
            <text class="smt-text">{{batchDonationConfig.matchNote}}</text>
          </view>
        </view>
        <view class="donation-success-footer">
          <view class="success-btn secondary" bindtap="applyInvoice">
            <text>申请票据</text>
          </view>
          <view class="success-btn primary" bindtap="viewDonationCert">
            <text>查看证书</text>
          </view>
        </view>
      </block>

    </view>
  </view>

</view>
