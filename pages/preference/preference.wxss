/* ============================================================
   桂花茶溯源小程序 - 口味偏好问卷页面样式
   页面路径：pages/preference/preference.wxss
   ============================================================ */

/* ===== 页面整体容器 ===== */
.pref-page {
  min-height: 100vh;
  padding-bottom: 200rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F3E8FF 0%, #E8F5E9 40%, #F5F5F5 100%);
  background-attachment: fixed;
}

/* ============================================================
   问卷状态样式
   ============================================================ */

/* ===== 进度条区域 ===== */
.progress-section {
  padding: 40rpx 40rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(114, 46, 209, 0.08);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #722ED1;
  font-weight: 600;
}

.progress-count {
  font-size: 28rpx;
  color: #52C41A;
  font-weight: 600;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #73D13D 0%, #52C41A 100%);
  border-radius: 8rpx;
  transition: width 0.4s ease-out;
}

.progress-percent {
  font-size: 24rpx;
  color: #52C41A;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

/* ===== 步骤圆点 ===== */
.step-dots {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 0 10rpx;
  height: 80rpx;
}

.step-dot {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  flex-shrink: 0;
}

.dot-inner {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 4rpx solid #D9D9D9;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.step-dot.done .dot-inner {
  background: #52C41A;
  border-color: #52C41A;
}

.step-dot.active .dot-inner {
  background: #52C41A;
  border-color: #52C41A;
  box-shadow: 0 0 0 10rpx rgba(82, 196, 26, 0.15);
  animation: dotPulse 1.5s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% {
    box-shadow: 0 0 0 10rpx rgba(82, 196, 26, 0.15);
  }
  50% {
    box-shadow: 0 0 0 16rpx rgba(82, 196, 26, 0.08);
  }
}

.dot-check,
.dot-num,
.dot-num-empty {
  position: relative;
  z-index: 3;
  font-size: 24rpx;
  font-weight: 600;
}

.dot-check {
  color: #FFFFFF;
  font-size: 28rpx;
}

.dot-num {
  color: #FFFFFF;
}

.dot-num-empty {
  color: #999999;
}

/* 步骤连接线 */
.step-line {
  position: absolute;
  top: 28rpx;
  height: 4rpx;
  background: #E8E8E8;
  z-index: 1;
  overflow: hidden;
}

.step-line-fill {
  height: 100%;
  background: #52C41A;
  transition: width 0.4s ease-out;
}

/* ===== 题目卡片 ===== */
.question-card {
  margin: 40rpx;
  padding: 50rpx 40rpx 40rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(114, 46, 209, 0.1);
  position: relative;
}

.question-icon {
  position: absolute;
  top: -36rpx;
  left: 40rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #F3E8FF 0%, #D3ADF7 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(114, 46, 209, 0.2);
}

.question-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #262626;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.question-desc {
  font-size: 28rpx;
  color: #8C8C8C;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* ===== 选项卡片 ===== */
.option-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-card {
  position: relative;
  display: flex;
  align-items: stretch;
  background: #FAFAFA;
  border: 3rpx solid #F0F0F0;
  border-radius: 24rpx;
  overflow: hidden;
  transition: all 0.3s ease;
}

.option-card.option-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.12);
  border-color: #B7EB8F;
}

.option-card.selected {
  background: #F6FFED;
  border-color: #52C41A;
  box-shadow: 0 8rpx 32rpx rgba(82, 196, 26, 0.15);
  transform: translateY(-2rpx);
}

.option-left-border {
  width: 8rpx;
  flex-shrink: 0;
  background: transparent;
  transition: background 0.3s ease;
}

.option-left-border.active-border {
  background: linear-gradient(180deg, #73D13D 0%, #389E0D 100%);
}

.option-content {
  flex: 1;
  padding: 28rpx 24rpx;
  min-width: 0;
}

.option-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.option-card.selected .option-label {
  color: #389E0D;
}

.option-desc {
  font-size: 24rpx;
  color: #8C8C8C;
  line-height: 1.5;
}

.option-check-wrap {
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D9D9D9;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  color: transparent;
  font-size: 26rpx;
  font-weight: 700;
}

.option-check.checked {
  background: linear-gradient(135deg, #73D13D 0%, #52C41A 100%);
  border-color: #52C41A;
  color: #FFFFFF;
}

/* ===== 底部导航按钮 ===== */
.nav-btn-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 40rpx 48rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  z-index: 100;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.prev-btn {
  flex: 1;
  height: 96rpx;
  background: #F5F5F5;
  border: 2rpx solid #E8E8E8;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 30rpx;
  color: #595959;
  font-weight: 500;
  transition: all 0.2s ease;
}

.prev-btn.placeholder {
  visibility: hidden;
}

.prev-btn.btn-hover {
  background: #EEEEEE;
  transform: scale(0.98);
}

.prev-icon {
  font-size: 32rpx;
}

.next-btn {
  flex: 1.5;
  height: 96rpx;
  background: linear-gradient(135deg, #73D13D 0%, #389E0D 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
  transition: all 0.2s ease;
}

.next-btn.disabled {
  background: linear-gradient(135deg, #D9D9D9 0%, #BFBFBF 100%);
  box-shadow: none;
  color: #8C8C8C;
}

.next-btn.btn-hover:not(.disabled) {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.25);
}

.next-icon {
  font-size: 32rpx;
  font-weight: 600;
}

/* ============================================================
   结果页状态样式
   ============================================================ */

/* ===== 成功提示 ===== */
.result-success-tip {
  margin: 40rpx 40rpx 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #F6FFED 0%, #D9F7BE 100%);
  border: 2rpx solid #B7EB8F;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.success-icon {
  font-size: 40rpx;
  animation: sparkle 2s ease-in-out infinite;
}

@keyframes sparkle {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.1) rotate(-5deg); }
  50% { transform: scale(1) rotate(0deg); }
  75% { transform: scale(1.1) rotate(5deg); }
}

.success-text {
  font-size: 30rpx;
  color: #389E0D;
  font-weight: 600;
}

/* ===== 推荐标题 ===== */
.result-header {
  padding: 48rpx 40rpx 24rpx;
  text-align: center;
  position: relative;
}

.result-tagline {
  font-size: 44rpx;
  font-weight: 800;
  color: #262626;
  line-height: 1.4;
  background: linear-gradient(135deg, #722ED1 0%, #52C41A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.result-decoration {
  margin: 24rpx auto 0;
  width: 120rpx;
  height: 6rpx;
  background: linear-gradient(90deg, transparent 0%, #722ED1 30%, #52C41A 70%, transparent 100%);
  border-radius: 3rpx;
}

/* ===== 推荐理由卡片 ===== */
.reason-card {
  margin: 24rpx 40rpx;
  padding: 32rpx;
  background: #FFFBF0;
  border: 2rpx solid #FFE7BA;
  border-radius: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.reason-icon {
  font-size: 44rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reason-content {
  flex: 1;
  min-width: 0;
}

.reason-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #D46B08;
  margin-bottom: 12rpx;
}

.reason-text {
  font-size: 28rpx;
  color: #874D00;
  line-height: 1.7;
}

/* ===== 区块通用 ===== */
.section-wrap {
  margin: 48rpx 40rpx 0;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #262626;
}

.section-icon {
  font-size: 36rpx;
}

.section-count {
  font-size: 24rpx;
  color: #8C8C8C;
  padding: 6rpx 16rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
}

/* ===== 茶食搭配卡片 ===== */
.pairing-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
  transition: all 0.3s ease;
}

.pairing-card.card-hover {
  transform: translateY(-6rpx);
  box-shadow: 0 16rpx 48rpx rgba(82, 196, 26, 0.15);
}

.pairing-header {
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.pairing-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  backdrop-filter: blur(10rpx);
}

.pairing-header-info {
  flex: 1;
  min-width: 0;
}

.pairing-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.pairing-tagline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.pairing-body {
  padding: 32rpx;
}

.pairing-intro {
  font-size: 28rpx;
  color: #595959;
  line-height: 1.7;
  margin-bottom: 28rpx;
  padding: 20rpx 24rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  border-left: 6rpx solid #722ED1;
}

/* 推荐食品 */
.food-section {
  margin-bottom: 28rpx;
}

.food-label {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-bottom: 16rpx;
}

.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.food-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #F6FFED;
  border: 2rpx solid #B7EB8F;
  border-radius: 32rpx;
}

.food-emoji {
  font-size: 28rpx;
}

.food-name {
  font-size: 26rpx;
  color: #389E0D;
  font-weight: 500;
}

.food-price {
  font-size: 24rpx;
  color: #F5222D;
  font-weight: 600;
}

/* 搭配卡片操作按钮 */
.pairing-actions {
  display: flex;
  gap: 20rpx;
}

.detail-btn {
  flex: 1;
  height: 80rpx;
  background: #F5F5F5;
  border: 2rpx solid #E8E8E8;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #595959;
  font-weight: 500;
  transition: all 0.2s ease;
}

.detail-btn.btn-hover {
  background: #EEEEEE;
  transform: scale(0.98);
}

.add-cart-btn {
  flex: 1.2;
  height: 80rpx;
  background: linear-gradient(135deg, #73D13D 0%, #52C41A 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(82, 196, 26, 0.25);
  transition: all 0.2s ease;
}

.add-cart-btn.btn-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.2);
}

.cart-icon {
  font-size: 30rpx;
}

/* ===== 礼盒卡片 ===== */
.giftbox-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
  transition: all 0.3s ease;
}

.giftbox-card.card-hover {
  transform: translateY(-6rpx);
  box-shadow: 0 16rpx 48rpx rgba(114, 46, 209, 0.15);
}

.giftbox-image-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFE7BA 100%);
}

.giftbox-image {
  width: 100%;
  height: 100%;
}

.giftbox-tags {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.giftbox-tag {
  padding: 6rpx 18rpx;
  background: rgba(114, 46, 209, 0.9);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.giftbox-body {
  padding: 32rpx;
}

.giftbox-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #262626;
  margin-bottom: 10rpx;
  line-height: 1.3;
}

.giftbox-subtitle {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-bottom: 18rpx;
  line-height: 1.5;
}

.giftbox-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.giftbox-rating {
  font-size: 26rpx;
  color: #FA8C16;
  font-weight: 600;
}

.giftbox-sold {
  font-size: 24rpx;
  color: #8C8C8C;
}

.giftbox-price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 28rpx;
}

.price-left {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  flex-wrap: wrap;
}

.price-symbol {
  font-size: 28rpx;
  color: #F5222D;
  font-weight: 600;
}

.price-value {
  font-size: 48rpx;
  color: #F5222D;
  font-weight: 800;
  line-height: 1;
}

.price-member {
  font-size: 24rpx;
  color: #722ED1;
  font-weight: 600;
  padding: 4rpx 12rpx;
  background: #F9F0FF;
  border-radius: 16rpx;
  margin-left: 10rpx;
}

.price-original {
  font-size: 24rpx;
  color: #BFBFBF;
  text-decoration: line-through;
}

.giftbox-actions {
  display: flex;
  gap: 20rpx;
}

/* ===== 结果页操作按钮 ===== */
.result-btn-section {
  padding: 48rpx 40rpx 32rpx;
}

.primary-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #722ED1 0%, #531DAB 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 34rpx;
  color: #FFFFFF;
  font-weight: 700;
  box-shadow: 0 12rpx 36rpx rgba(114, 46, 209, 0.3);
  transition: all 0.2s ease;
  margin-bottom: 24rpx;
}

.primary-btn.btn-hover {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(114, 46, 209, 0.25);
}

.primary-icon {
  font-size: 36rpx;
}

.secondary-row {
  display: flex;
  gap: 20rpx;
}

.secondary-btn {
  flex: 1;
  height: 84rpx;
  background: #FFFFFF;
  border: 2rpx solid #D9D9D9;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #595959;
  font-weight: 500;
  transition: all 0.2s ease;
}

.secondary-btn.btn-hover {
  border-color: #722ED1;
  color: #722ED1;
  background: #FAF5FF;
}

.reset-btn {
  flex: 1;
  height: 84rpx;
  background: #F5F5F5;
  border: 2rpx solid #E8E8E8;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8C8C8C;
  font-weight: 500;
  transition: all 0.2s ease;
}

.reset-btn.btn-hover {
  background: #EEEEEE;
  color: #595959;
}

/* ===== 底部提示 ===== */
.footer-tip {
  padding: 32rpx 40rpx 48rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #BFBFBF;
  line-height: 1.6;
}

/* ===== 按钮通用 hover 效果 ===== */
.btn-hover {
  opacity: 0.9;
}
