.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F5F0 0%, #FAFAF5 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

.hero-section {
  position: relative;
  height: 500rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(46,139,87,0.3) 0%, rgba(0,0,0,0.5) 100%);
}

.hero-content {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.hero-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.hero-brand {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
  margin-bottom: 16rpx;
}

.hero-slogan {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  text-align: center;
  padding: 0 60rpx;
}

.main-content {
  padding: 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.section-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.section-text-block {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-paragraph {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  text-indent: 2em;
}

.timeline {
  display: flex;
  flex-direction: column;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  min-height: 120rpx;
}

.timeline-left {
  width: 100rpx;
  flex-shrink: 0;
  text-align: right;
  padding-right: 20rpx;
  padding-top: 4rpx;
}

.timeline-year {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E8B57;
}

.timeline-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 48rpx;
}

.timeline-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(46,139,87,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dot-icon {
  font-size: 24rpx;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  min-height: 40rpx;
  background: rgba(46,139,87,0.2);
  margin: 8rpx 0;
}

.timeline-right {
  flex: 1;
  padding-left: 20rpx;
  padding-bottom: 32rpx;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.values-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.value-item {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  text-align: center;
}

.value-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.value-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.value-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

.cta-section {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}

.cta-text {
  font-size: 30rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 28rpx;
  line-height: 1.6;
}

.cta-btn {
  display: inline-block;
  background: #FFFFFF;
  color: #2E8B57;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 64rpx;
  border-radius: 40rpx;
}

.cta-btn:active {
  opacity: 0.9;
}

.footer-section {
  padding: 40rpx 32rpx 60rpx;
  text-align: center;
}

.footer-text {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666666;
}

.eco-icon {
  margin: 0 12rpx;
}
