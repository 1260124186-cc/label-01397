.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: env(safe-area-inset-bottom);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  font-size: 48rpx;
  color: #2E8B57;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #909399;
  margin-top: 20rpx;
}

.lottery-header {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.lottery-status-bar {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.lottery-status-bar .status-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  color: #fff;
}

.lottery-status-bar .status-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.lottery-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #303133;
  margin-bottom: 16rpx;
}

.lottery-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 8rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #606266;
}

.section-card {
  background: #fff;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-header {
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #EBEEF5;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-toggle {
  margin-left: auto;
  font-size: 28rpx;
  color: #C0C4CC;
}

.section-content {
  padding: 24rpx 30rpx;
}

.draw-info .info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F6FC;
}

.info-label {
  font-size: 26rpx;
  color: #909399;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #303133;
  flex: 1;
  word-break: break-all;
}

.seed-value,
.hash-value {
  font-family: 'Menlo', 'Courier New', monospace;
  font-size: 24rpx;
  color: #409EFF;
}

.copy-btn {
  font-size: 28rpx;
  padding: 4rpx 12rpx;
  margin-left: 12rpx;
}

.draw-candidates,
.draw-result {
  margin-top: 24rpx;
}

.candidates-title,
.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
}

.batch-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.batch-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #F2F6FC;
  color: #606266;
  border: 1rpx solid #DCDFE6;
}

.batch-tag.highlight {
  background: #FFF8E1;
  color: #E6A23C;
  border-color: #E6A23C;
  font-weight: 600;
}

.batch-tag.selected {
  background: #F0F9EB;
  color: #67C23A;
  border-color: #67C23A;
  font-weight: 600;
}

.batch-tag.selected.highlight {
  background: #E1F3D8;
  color: #2E8B57;
  border-color: #2E8B57;
}

.draw-verify-hint {
  display: flex;
  align-items: flex-start;
  margin-top: 24rpx;
  padding: 20rpx;
  background: #F0F9EB;
  border-radius: 12rpx;
  border-left: 6rpx solid #67C23A;
}

.hint-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.hint-text {
  font-size: 24rpx;
  color: #606266;
  line-height: 1.6;
}

.media-buttons {
  display: flex;
  gap: 24rpx;
}

.media-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #DCDFE6;
}

.media-btn.live-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A24 100%);
  border-color: #EE5A24;
}

.media-btn.replay-btn {
  background: linear-gradient(135deg, #409EFF 0%, #337ECC 100%);
  border-color: #337ECC;
}

.media-btn.disabled-btn {
  background: #F2F6FC;
  border-color: #E4E7ED;
}

.media-btn .media-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.media-btn .media-label {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.media-btn.disabled-btn .media-label {
  color: #909399;
  font-weight: 400;
}

.media-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #909399;
  text-align: center;
}

.witness-count {
  font-size: 24rpx;
  color: #409EFF;
  margin-left: 12rpx;
  background: #ECF5FF;
  padding: 2rpx 14rpx;
  border-radius: 10rpx;
}

.witness-list {
  margin-bottom: 20rpx;
}

.witness-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F6FC;
}

.witness-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ECF5FF;
  color: #409EFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.witness-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.witness-name {
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
}

.witness-phone {
  font-size: 24rpx;
  color: #909399;
  margin-top: 4rpx;
}

.witness-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.witness-status.attended {
  background: #F0F9EB;
  color: #67C23A;
}

.witness-status.pending {
  background: #FDF6EC;
  color: #E6A23C;
}

.no-witnesses {
  text-align: center;
  padding: 30rpx 0;
  color: #909399;
  font-size: 26rpx;
}

.witness-register-btn {
  margin-top: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #fff;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.witness-full-hint {
  text-align: center;
  padding: 20rpx;
  color: #909399;
  font-size: 26rpx;
}

.result-date {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 20rpx;
}

.batch-result {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.batch-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.batch-no {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
}

.conclusion-badge,
.result-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.conclusion-badge.pass,
.result-badge.pass {
  background: #F0F9EB;
  color: #67C23A;
}

.conclusion-badge.fail,
.result-badge.fail {
  background: #FEF0F0;
  color: #F56C6C;
}

.test-items {
  margin-top: 12rpx;
}

.test-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  font-size: 24rpx;
  border-bottom: 1rpx solid #EBEEF5;
}

.test-name {
  width: 160rpx;
  color: #606266;
  flex-shrink: 0;
}

.test-value {
  flex: 1;
  color: #303133;
  font-weight: 500;
}

.test-limit {
  color: #909399;
  margin-right: 12rpx;
}

.test-status {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.test-status.pass {
  background: #F0F9EB;
  color: #67C23A;
}

.test-status.fail {
  background: #FEF0F0;
  color: #F56C6C;
}

.report-no-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #909399;
}

.bc-verified {
  font-size: 22rpx;
  color: #67C23A;
  margin-left: 12rpx;
  background: #F0F9EB;
  padding: 2rpx 14rpx;
  border-radius: 10rpx;
}

.bc-info .info-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F2F6FC;
}

.on-chain-data {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #F0F9EB;
  border-radius: 12rpx;
}

.chain-data-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
}

.chain-data-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #E1F3D8;
  font-size: 24rpx;
}

.chain-label {
  width: 160rpx;
  color: #606266;
  flex-shrink: 0;
}

.chain-value {
  flex: 1;
  color: #303133;
  word-break: break-all;
}

.chain-badge {
  font-size: 20rpx;
  color: #67C23A;
  background: #E1F3D8;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.bc-actions {
  margin-top: 20rpx;
  text-align: center;
}

.bc-btn {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #409EFF 0%, #337ECC 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.narrative-card {
  margin-bottom: 40rpx;
}

.narrative-text {
  font-size: 28rpx;
  color: #303133;
  line-height: 1.8;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #FFFBF0;
  border-radius: 12rpx;
  border-left: 6rpx solid #E6A23C;
}

.narrative-points {
  margin-top: 16rpx;
}

.point-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}

.point-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.point-text {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.6;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #EBEEF5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
}

.modal-close {
  font-size: 36rpx;
  color: #909399;
  padding: 4rpx 12rpx;
}

.modal-body {
  padding: 30rpx;
}

.result-body {
  text-align: center;
  padding: 50rpx 30rpx;
}

.result-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.result-message {
  font-size: 30rpx;
  color: #303133;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #606266;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #DCDFE6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #303133;
  box-sizing: border-box;
}

.form-hint {
  font-size: 22rpx;
  color: #909399;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #EBEEF5;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
}

.cancel-btn {
  color: #909399;
  border-right: 1rpx solid #EBEEF5;
}

.confirm-btn {
  color: #2E8B57;
  font-weight: 600;
}

.confirm-btn.disabled {
  color: #C0C4CC;
}

.brand-action-card {
  background: #FFFBF0;
  border: 1rpx solid #FFE4B5;
}

.status-progress {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.progress-step .step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #E0E0E0;
  margin-bottom: 8rpx;
}

.progress-step.active .step-dot {
  background: #2E8B57;
  box-shadow: 0 0 0 6rpx rgba(46, 139, 87, 0.2);
}

.progress-step .step-label {
  font-size: 22rpx;
  color: #909399;
}

.progress-step.active .step-label {
  color: #2E8B57;
  font-weight: 600;
}

.progress-line {
  flex: 1;
  height: 4rpx;
  background: #E0E0E0;
  margin: 0 4rpx;
  margin-bottom: 36rpx;
}

.progress-line.active {
  background: #2E8B57;
}

.advance-btn {
  padding: 24rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #fff;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.advance-hint {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #909399;
}
