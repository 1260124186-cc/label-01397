.container {
  min-height: 100vh;
  padding: 24rpx;
  background: #F5F5F0;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #2E8B57;
}

.input-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.batch-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.preset-row {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  flex-wrap: wrap;
}

.preset-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}

.preset-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preset-btn {
  padding: 8rpx 20rpx;
  background: rgba(46, 139, 87, 0.08);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #2E8B57;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-outline {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  border: 2rpx solid #2E8B57;
  color: #2E8B57;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-primary {
  flex: 2;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-header .card-title {
  margin-bottom: 0;
}

.download-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #DAA520, #F0C75E);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  border: 2rpx solid #F0F0F0;
  border-radius: 16rpx;
  padding: 24rpx;
}

.result-item.valid {
  border-color: rgba(82, 196, 26, 0.3);
  background: #FAFFFA;
}

.result-item.invalid {
  border-color: rgba(255, 77, 79, 0.3);
  background: #FFFAFA;
}

.result-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.batch-no {
  font-size: 30rpx;
  font-weight: 700;
  color: #1B5E3A;
}

.valid-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.valid-tag.ok {
  background: #F6FFED;
  color: #52C41A;
}

.valid-tag.fail {
  background: #FFF0F0;
  color: #FF4D4F;
}

.result-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  padding: 6rpx 0;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  width: 160rpx;
}

.info-value {
  font-size: 24rpx;
  color: #333;
}

.cert-section {
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: rgba(218, 165, 32, 0.05);
  border-radius: 12rpx;
}

.cert-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.cert-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cert-item {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #fff;
  border: 1rpx solid #E8E8E8;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #333;
}

.cert-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.trace-btn {
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(46, 139, 87, 0.08), rgba(60, 179, 113, 0.08));
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #2E8B57;
  font-weight: 500;
}

.invalid-tip {
  text-align: center;
  padding: 20rpx;
  color: #FF4D4F;
  font-size: 26rpx;
}
