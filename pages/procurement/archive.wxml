<view class="container">
  <view class="header-card">
    <view class="header-info">
      <view class="header-title">质检文件归档</view>
      <view class="header-sub">已归档 {{filteredList.length}} 份质检报告</view>
    </view>
    <view class="archive-btn" wx:if="{{canArchive}}" bindtap="openArchiveModal">
      <text class="btn-icon">+</text>
      <text>新增归档</text>
    </view>
  </view>

  <view class="card">
    <view class="search-bar">
      <input class="search-input" placeholder="搜索批次号/产品/报告编号" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="doSearch" />
    </view>
    <view class="tabs">
      <view class="tab {{activeTab === item.key ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="key" bindtap="switchTab" data-tab="{{item.key}}">
        {{item.label}}
      </view>
    </view>

    <view class="archive-list">
      <view class="empty-tip" wx:if="{{filteredList.length === 0}}">暂无质检归档</view>
      <view class="archive-item" wx:for="{{filteredList}}" wx:key="id" bindtap="viewArchiveDetail" data-id="{{item.id}}">
        <view class="archive-header">
          <view class="archive-batch">{{item.batchNo}}</view>
          <view class="archive-result result-{{item.result}}">{{item.resultLabel}}</view>
        </view>
        <view class="archive-product">{{item.productName}}</view>
        <view class="archive-meta">
          <view class="meta-item">
            <text class="meta-label">报告编号：</text>
            <text class="meta-value">{{item.inspectionReportId}}</text>
          </view>
          <view class="meta-item">
            <text class="meta-label">质检日期：</text>
            <text class="meta-value">{{item.inspectionDate}}</text>
          </view>
        </view>
        <view class="archive-score">
          <view class="score-label">综合评分</view>
          <view class="score-value">{{item.overallScore}}<text class="score-unit">分</text></view>
          <view class="score-bar">
            <view class="score-bar-fill" style="width: {{item.overallScore}}%"></view>
          </view>
        </view>
        <view class="archive-footer">
          <view class="footer-info">
            <text class="footer-label">质检员：</text>
            <text class="footer-value">{{item.inspector}}</text>
            <text class="footer-divider">|</text>
            <text class="footer-label">归档：</text>
            <text class="footer-value">{{item.archivedBy}}</text>
          </view>
          <view class="footer-docs">{{item.documents.length}} 份文件</view>
        </view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showArchiveModal}}" bindtap="closeArchiveModal"></view>
  <view class="modal-content" wx:if="{{showArchiveModal}}">
    <view class="modal-header">
      <text class="modal-title">新增质检归档</text>
      <text class="modal-close" bindtap="closeArchiveModal">✕</text>
    </view>
    <scroll-view class="modal-body" scroll-y>
      <view class="form-item">
        <text class="form-label">批次号 <text class="required">*</text></text>
        <input class="form-input" placeholder="如 GH202503" value="{{archiveForm.batchNo}}" bindinput="onFormInput" data-field="batchNo" />
      </view>
      <view class="form-item">
        <text class="form-label">产品名称 <text class="required">*</text></text>
        <input class="form-input" placeholder="如 金桂花茶" value="{{archiveForm.productName}}" bindinput="onFormInput" data-field="productName" />
      </view>
      <view class="form-item">
        <text class="form-label">质检日期 <text class="required">*</text></text>
        <picker mode="date" value="{{archiveForm.inspectionDate}}" bindchange="onDateChange">
          <view class="form-input picker-input">{{archiveForm.inspectionDate}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">质检结果 <text class="required">*</text></text>
        <view class="result-select">
          <view class="result-option {{archiveForm.result === 'passed' ? 'selected' : ''}}" bindtap="onResultSelect" data-result="passed">
            <text class="option-dot"></text>合格
          </view>
          <view class="result-option {{archiveForm.result === 'failed' ? 'selected' : ''}}" bindtap="onResultSelect" data-result="failed">
            <text class="option-dot"></text>不合格
          </view>
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">综合评分 (0-100) <text class="required">*</text></text>
        <input class="form-input" type="number" placeholder="请输入评分" value="{{archiveForm.overallScore}}" bindinput="onFormInput" data-field="overallScore" />
      </view>
      <view class="form-item">
        <text class="form-label">备注</text>
        <textarea class="form-textarea" placeholder="可选，质检备注说明" value="{{archiveForm.remark}}" bindinput="onFormInput" data-field="remark" maxlength="200"></textarea>
      </view>
    </scroll-view>
    <view class="modal-footer">
      <button class="btn-outline" bindtap="closeArchiveModal">取消</button>
      <button class="btn-primary" bindtap="doArchive">确认归档</button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showDetailModal}}" bindtap="closeDetailModal"></view>
  <view class="modal-content detail-modal" wx:if="{{showDetailModal}}">
    <view class="modal-header">
      <text class="modal-title">质检报告详情</text>
      <text class="modal-close" bindtap="closeDetailModal">✕</text>
    </view>
    <scroll-view class="modal-body" scroll-y>
      <view class="detail-section">
        <view class="detail-section-title">基本信息</view>
        <view class="detail-grid">
          <view class="detail-item">
            <text class="detail-label">批次号</text>
            <text class="detail-value link" catchtap="viewBatch" data-batch="{{currentArchive.batchNo}}">{{currentArchive.batchNo}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">产品名称</text>
            <text class="detail-value">{{currentArchive.productName}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">报告编号</text>
            <text class="detail-value">{{currentArchive.inspectionReportId}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">质检日期</text>
            <text class="detail-value">{{currentArchive.inspectionDate}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">质检结果</text>
            <text class="detail-value result-{{currentArchive.result}}">{{currentArchive.resultLabel}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">质检员</text>
            <text class="detail-value">{{currentArchive.inspector}}</text>
          </view>
        </view>
      </view>

      <view class="detail-section">
        <view class="detail-section-title">综合评分</view>
        <view class="detail-score-wrap">
          <view class="detail-score">{{currentArchive.overallScore}}<text class="score-unit">分</text></view>
          <view class="detail-score-bar">
            <view class="detail-score-fill" style="width: {{currentArchive.overallScore}}%"></view>
          </view>
        </view>
      </view>

      <view class="detail-section" wx:if="{{currentArchive.items && currentArchive.items.length > 0}}">
        <view class="detail-section-title">质检明细</view>
        <view class="items-list">
          <view class="item-row" wx:for="{{currentArchive.items}}" wx:key="name">
            <view class="item-name">{{item.name}}</view>
            <view class="item-standard">标准：{{item.standard}}</view>
            <view class="item-right">
              <text class="item-score">{{item.score}}分</text>
              <text class="item-result {{item.result === '合格' ? 'pass' : 'fail'}}">{{item.result}}</text>
            </view>
            <view class="item-remark" wx:if="{{item.remark}}">{{item.remark}}</view>
          </view>
        </view>
      </view>

      <view class="detail-section" wx:if="{{currentArchive.documents && currentArchive.documents.length > 0}}">
        <view class="detail-section-title">归档文件 ({{currentArchive.documents.length}}份)</view>
        <view class="doc-list">
          <view class="doc-item" wx:for="{{currentArchive.documents}}" wx:key="name">
            <view class="doc-icon">📄</view>
            <view class="doc-info">
              <view class="doc-name">{{item.name}}</view>
              <view class="doc-size">{{item.size}}</view>
            </view>
          </view>
        </view>
        <view class="download-link" catchtap="downloadReport" data-batch="{{currentArchive.batchNo}}">
          下载全部检测报告 →
        </view>
      </view>

      <view class="detail-section" wx:if="{{currentArchive.remark}}">
        <view class="detail-section-title">备注</view>
        <view class="detail-remark">{{currentArchive.remark}}</view>
      </view>

      <view class="detail-section">
        <view class="detail-section-title">归档信息</view>
        <view class="archive-info">
          <text>归档人：{{currentArchive.archivedBy}}</text>
          <text>归档时间：{{currentArchive.archiveTime}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
