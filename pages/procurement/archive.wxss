.container {
  min-height: 100vh;
  padding: 24rpx;
  background: #F5F5F0;
  box-sizing: border-box;
}

.header-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.archive-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 32rpx;
  color: #fff;
  font-size: 26rpx;
}

.btn-icon {
  font-size: 30rpx;
  font-weight: 700;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: #F5F5F0;
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tab {
  padding: 12rpx 28rpx;
  background: #F5F5F0;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
}

.tab.active {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #fff;
}

.archive-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-tip {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.archive-item {
  padding: 24rpx;
  background: #FAFAF7;
  border: 1rpx solid #F0F0F0;
  border-radius: 16rpx;
}

.archive-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.archive-batch {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.archive-result {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.archive-result.result-passed {
  background: #F6FFED;
  color: #52C41A;
}

.archive-result.result-failed {
  background: #FFF1F0;
  color: #FF4D4F;
}

.archive-product {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.archive-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 22rpx;
}

.meta-label {
  color: #999;
}

.meta-value {
  color: #333;
}

.archive-score {
  padding: 16rpx 20rpx;
  background: rgba(218, 165, 32, 0.08);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.score-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #DAA520;
  margin-bottom: 10rpx;
}

.score-unit {
  font-size: 22rpx;
  font-weight: 400;
  margin-left: 4rpx;
}

.score-bar {
  height: 8rpx;
  background: rgba(218, 165, 32, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.score-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #DAA520, #F4C542);
  border-radius: 4rpx;
}

.archive-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx dashed #E8E8E8;
}

.footer-info {
  font-size: 22rpx;
  color: #999;
}

.footer-label {
  color: #999;
}

.footer-value {
  color: #666;
}

.footer-divider {
  margin: 0 10rpx;
  color: #DDD;
}

.footer-docs {
  font-size: 22rpx;
  color: #2E8B57;
  padding: 4rpx 14rpx;
  background: rgba(46, 139, 87, 0.08);
  border-radius: 12rpx;
}

.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
}

.modal-content.detail-modal {
  max-height: 90vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  flex: 1;
  overflow: hidden;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #FF4D4F;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
}

.picker-input {
  color: #333;
}

.form-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 16rpx 20rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.result-select {
  display: flex;
  gap: 20rpx;
}

.result-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.option-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid #CCC;
  display: inline-block;
}

.result-option.selected {
  border-color: #2E8B57;
  background: rgba(46, 139, 87, 0.06);
  color: #2E8B57;
  font-weight: 500;
}

.result-option.selected .option-dot {
  background: #2E8B57;
  border-color: #2E8B57;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.modal-footer .btn-outline,
.modal-footer .btn-primary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.modal-footer .btn-outline {
  background: #F5F5F0;
  color: #666;
  border: none;
}

.modal-footer .btn-primary {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #fff;
  border: none;
}

.detail-section {
  margin-bottom: 28rpx;
}

.detail-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  padding-left: 14rpx;
  border-left: 6rpx solid #2E8B57;
  margin-bottom: 16rpx;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx;
  background: #FAFAF7;
  border-radius: 12rpx;
}

.detail-item {
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #999;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.detail-value.link {
  color: #2E8B57;
  text-decoration: underline;
}

.detail-value.result-passed {
  color: #52C41A;
}

.detail-value.result-failed {
  color: #FF4D4F;
}

.detail-score-wrap {
  padding: 20rpx;
  background: rgba(218, 165, 32, 0.08);
  border-radius: 12rpx;
}

.detail-score {
  font-size: 48rpx;
  font-weight: 700;
  color: #DAA520;
  margin-bottom: 12rpx;
}

.detail-score .score-unit {
  font-size: 24rpx;
  font-weight: 400;
  margin-left: 6rpx;
}

.detail-score-bar {
  height: 10rpx;
  background: rgba(218, 165, 32, 0.2);
  border-radius: 5rpx;
  overflow: hidden;
}

.detail-score-fill {
  height: 100%;
  background: linear-gradient(90deg, #DAA520, #F4C542);
  border-radius: 5rpx;
}

.items-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.item-row {
  padding: 16rpx;
  background: #FAFAF7;
  border-radius: 12rpx;
}

.item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.item-standard {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.item-right {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.item-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #DAA520;
}

.item-result {
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.item-result.pass {
  background: #F6FFED;
  color: #52C41A;
}

.item-result.fail {
  background: #FFF1F0;
  color: #FF4D4F;
}

.item-remark {
  font-size: 22rpx;
  color: #666;
  padding-top: 8rpx;
  border-top: 1rpx dashed #EEE;
}

.doc-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.doc-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #FAFAF7;
  border-radius: 12rpx;
}

.doc-icon {
  font-size: 36rpx;
}

.doc-info {
  flex: 1;
}

.doc-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.doc-size {
  font-size: 22rpx;
  color: #999;
}

.download-link {
  padding: 16rpx;
  background: rgba(46, 139, 87, 0.06);
  border: 2rpx solid rgba(46, 139, 87, 0.2);
  border-radius: 12rpx;
  text-align: center;
  color: #2E8B57;
  font-size: 26rpx;
  font-weight: 500;
}

.detail-remark {
  padding: 16rpx;
  background: #FAFAF7;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.archive-info {
  padding: 16rpx;
  background: #FAFAF7;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}
