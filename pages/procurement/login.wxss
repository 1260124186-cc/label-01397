.container {
  min-height: 100vh;
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F5F0 40%);
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-box {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 24rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
}

.logo-icon {
  font-size: 72rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1B5E3A;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
}

.login-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #2E8B57;
  background: #fff;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.25);
}

.btn-login[disabled] {
  opacity: 0.6;
}

.sample-section {
  margin-bottom: 40rpx;
}

.sample-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.sample-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.sample-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.sample-item:last-child {
  border-bottom: none;
}

.sample-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FFD700, #DAA520);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.sample-info {
  flex: 1;
  min-width: 0;
}

.sample-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.sample-role {
  font-size: 24rpx;
  color: #2E8B57;
  margin-bottom: 4rpx;
}

.sample-account {
  font-size: 22rpx;
  color: #999;
}

.sample-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 12rpx;
}

.enterprise-types {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  flex-wrap: wrap;
}

.ent-type {
  padding: 12rpx 24rpx;
  background: rgba(46, 139, 87, 0.08);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #2E8B57;
}
