<view class="knowledge-list">
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索文章、品种、工艺..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="onSearchClear">✕</text>
    </view>
  </view>

  <scroll-view class="category-tabs" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{currentCategoryKey === item.key ? 'active' : ''}}"
        style="{{currentCategoryKey === item.key ? 'background:' + item.color + ';' : ''}}"
        data-key="{{item.key}}"
        bindtap="onCategoryTap"
      >
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="sort-bar">
    <view
      class="sort-item {{sortBy === 'newest' ? 'active' : ''}}"
      data-sort="newest"
      bindtap="onSortChange"
    >最新发布</view>
    <view
      class="sort-item {{sortBy === 'popular' ? 'active' : ''}}"
      data-sort="popular"
      bindtap="onSortChange"
    >最多阅读</view>
    <view
      class="sort-item {{sortBy === 'liked' ? 'active' : ''}}"
      data-sort="liked"
      bindtap="onSortChange"
    >最受欢迎</view>
    <view class="sort-count">共 {{articles.length}} 篇</view>
  </view>

  <view class="articles-wrap" wx:if="{{articles.length > 0}}">
    <view
      wx:for="{{articles}}"
      wx:key="id"
      class="article-card"
      data-id="{{item.id}}"
      bindtap="onArticleTap"
    >
      <image class="article-cover" src="{{item.coverImage}}" mode="aspectFill"></image>
      <view class="article-content">
        <view class="article-title">{{item.title}}</view>
        <view class="article-subtitle">{{item.subtitle}}</view>
        <view class="article-tags">
          <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag-item">#{{tag}}</text>
        </view>
        <view class="article-footer">
          <view class="article-meta">
            <text class="meta-author">{{item.author}}</text>
            <text class="meta-dot">·</text>
            <text class="meta-time">{{item.publishTime}}</text>
          </view>
          <view class="article-actions">
            <text class="meta-stat">👁 {{item.readCount}}</text>
            <text class="meta-stat">❤️ {{item.likeCount}}</text>
            <view
              class="fav-btn {{item.isFavorite ? 'active' : ''}}"
              catchtap="onFavoriteToggle"
              data-id="{{item.id}}"
            >
              <text>{{item.isFavorite ? '★' : '☆'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-wrap" wx:if="{{!loading && articles.length === 0}}">
    <text class="empty-icon">📭</text>
    <view class="empty-title">暂无相关文章</view>
    <view class="empty-desc">试试切换栏目或修改搜索关键词</view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="end-tip" wx:if="{{!loading && articles.length > 0 && noMore}}">
    — 已经到底啦 —
  </view>
</view>
