.env-page {
  padding: 20rpx 24rpx 140rpx;
  background: #F5F5F0;
  min-height: 100vh;
}

.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #2E8B57;
}

.weather-loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.weather-card {
  background: linear-gradient(135deg, #4A90D9 0%, #2E8B57 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  color: #fff;
}

.weather-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.weather-city {
  display: flex;
  flex-direction: column;
}

.city-name {
  font-size: 36rpx;
  font-weight: 600;
}

.weather-text {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 6rpx;
}

.temp-value {
  font-size: 72rpx;
  font-weight: 300;
}

.weather-detail {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 24rpx;
}

.city-search {
  display: flex;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 8rpx;
}

.city-input {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 8rpx;
  color: #333;
  font-size: 26rpx;
}

.search-btn {
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: #ffffff;
  color: #2E8B57;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.temp-tip {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #E8F5E9;
}

.temp-tip.hot { background: #FFF3E0; }
.temp-tip.warm { background: #FFF8E1; }
.temp-tip.comfortable { background: #E8F5E9; }
.temp-tip.cool { background: #E3F2FD; }
.temp-tip.cold { background: #EDE7F6; }

.temp-tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.temp-tip-range {
  font-size: 32rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-bottom: 8rpx;
}

.temp-tip-reason {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.hardness-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hardness-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.hardness-option.active {
  border-color: #2E8B57;
  background: #E8F5E9;
}

.hardness-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.hardness-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.hardness-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  flex: 2;
}

.hardness-tip {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.hardness-tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.hardness-tip-row {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 6rpx;
}

.hardness-tip-reason {
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
  line-height: 1.6;
}

.nav-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #DAA520;
  font-weight: 500;
}

.arrow {
  font-size: 36rpx;
  font-weight: 300;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.confirm-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2E8B57 0%, #1E6B3F 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}
