<!--
  桂花茶溯源小程序 - 首页
  功能：品牌展示、扫码溯源、手动输入查询、批量查询、扫码历史
-->

<view class="page-container {{pageLoaded ? 'page-loaded' : ''}} {{pageClass}}">

  <!-- 剪贴板识别弹窗 -->
  <view wx:if="{{showClipboardModal}}" class="modal-overlay" catchtap="handleClipboardCancel" role="dialog" aria-label="{{i18n.clipboardTitle}}">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <view class="modal-icon">📋</view>
        <view class="modal-title">{{i18n.clipboardTitle}}</view>
      </view>
      <view class="modal-body">
        <text>{{i18n.clipboardDesc}}</text>
        <view class="clipboard-id">{{clipboardTraceId}}</view>
        <text class="modal-tip">是否立即查询该产品的溯源信息？</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn modal-btn-cancel" bindtap="handleClipboardCancel" role="button" aria-label="{{i18n.clipboardClose}}">{{i18n.clipboardClose}}</button>
        <button class="modal-btn modal-btn-confirm" bindtap="handleClipboardConfirm" role="button" aria-label="{{i18n.clipboardGoto}}">{{i18n.clipboardGoto}}</button>
      </view>
    </view>
  </view>

  <!-- ==================== 扫码引导动画弹窗 ==================== -->
  <view wx:if="{{showScanGuide}}" class="modal-overlay scan-guide-overlay" catchtap="closeScanGuide">
    <view class="scan-guide-modal" catchtap="preventBubble">
      <view class="scan-guide-close" bindtap="closeScanGuide">×</view>
      <view class="scan-guide-header">
        <view class="scan-guide-header-icon">📱</view>
        <view class="scan-guide-header-title">扫码溯源使用指南</view>
        <view class="scan-guide-header-subtitle">3步轻松查询产品溯源信息</view>
      </view>
      <view class="scan-guide-steps">
        <view
          wx:for="{{scanGuideSteps}}"
          wx:key="step"
          class="scan-guide-step {{scanGuideStep >= index ? 'active' : ''}} {{scanGuideStep === index ? 'current' : ''}}"
        >
          <view class="step-indicator">
            <view class="step-dot">{{item.icon}}</view>
            <view class="step-line" wx:if="{{index < scanGuideSteps.length - 1}}"></view>
          </view>
          <view class="step-content-area">
            <view class="step-title-text">{{item.title}}</view>
            <view class="step-desc-text">{{item.desc}}</view>
          </view>
        </view>
      </view>
      <view class="scan-guide-animation">
        <view class="guide-phone-frame">
          <view class="guide-phone-screen">
            <view class="guide-scan-icon-mini">
              <view class="guide-scan-line-anim"></view>
            </view>
            <view class="guide-scan-text-mini">扫码溯源</view>
          </view>
        </view>
      </view>
      <view class="scan-guide-footer">
        <view class="scan-guide-btn" bindtap="nextScanGuideStep">
          <text wx:if="{{scanGuideStep < scanGuideSteps.length - 1}}">下一步</text>
          <text wx:else>知道了，去扫码</text>
        </view>
        <view class="scan-guide-skip" bindtap="closeScanGuide">跳过引导</view>
      </view>
    </view>
  </view>

  <!-- ==================== 顶部品牌视觉区域 ==================== -->
  <view class="header-section" role="banner">
    <view class="header-bg">
      <view class="header-pattern"></view>
    </view>

    <!-- 无障碍设置入口按钮（右上角） -->
    <view
      class="a11y-entry-btn"
      bindtap="openA11yPanel"
      role="button"
      aria-label="{{i18n.a11ySettings}}"
    >
      <text class="a11y-entry-icon">♿</text>
      <text wx:if="{{currentLang === 'en-US'}}" class="a11y-entry-label">A11y</text>
      <text wx:else class="a11y-entry-label">无障碍</text>
    </view>

    <view class="brand-container">
      <view class="brand-icon" aria-hidden="true">
        <text class="osmanthus-icon">🌼</text>
      </view>

      <view class="brand-title" role="heading" aria-level="1">{{brandName}}</view>

      <view class="brand-subtitle" aria-hidden="true">
        <text class="eco-leaf">🍃</text>
        <text>{{currentLang === 'en-US' ? 'Trace the green journey of every tea leaf' : '追溯每一片茶叶的绿色旅程'}}</text>
        <text class="eco-leaf">🍃</text>
      </view>
    </view>
  </view>

  <!-- ==================== 主要功能区域 ==================== -->
  <view class="main-section">

    <!-- ==================== 轮播 Banner 区域 ==================== -->
    <view class="banner-section">
      <swiper
        class="banner-swiper"
        autoplay="{{true}}"
        interval="{{4000}}"
        duration="{{500}}"
        circular="{{true}}"
        bindchange="onBannerChange"
        indicator-dots="{{true}}"
        indicator-color="rgba(255,255,255,0.4)"
        indicator-active-color="#FFFFFF"
      >
        <swiper-item
          wx:for="{{bannerList}}"
          wx:key="id"
          data-index="{{index}}"
          bindtap="onBannerTap"
        >
          <view class="banner-slide">
            <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
            <view class="banner-overlay"></view>
            <view class="banner-content-wrapper">
              <view class="banner-tag {{item.type}}">{{item.tag}}</view>
              <view class="banner-title-text">{{item.title}}</view>
              <view class="banner-subtitle-text">{{item.subtitle}}</view>
            </view>
          </view>
        </swiper-item>
      </swiper>
      <view class="banner-counter">{{currentBanner + 1}}/{{bannerList.length}}</view>
    </view>

    <!-- ==================== 公告栏区域 ==================== -->
    <view class="announcement-bar" bindtap="onAnnouncementTap" role="region" aria-label="公告栏，点击查看详情">
      <view class="announcement-icon-row" aria-hidden="true">
        <view class="announcement-label {{announcementList[currentAnnouncement].type === 'recall' ? 'recall' : ''}}">{{announcementList[currentAnnouncement].icon}}</view>
      </view>
      <view class="announcement-scroll {{announcementAnimation ? 'animating' : ''}}">
        <view class="announcement-text {{announcementList[currentAnnouncement].type === 'recall' ? 'recall' : ''}}">
          {{announcementList[currentAnnouncement].text}}
        </view>
      </view>
      <view class="announcement-arrow" aria-hidden="true">›</view>
    </view>

    <!-- 扫码溯源主按钮 -->
    <view class="scan-card" bindtap="handleScanCode" role="button" aria-label="{{i18n.scanBtn}}">
      <view class="scan-icon-wrapper" aria-hidden="true">
        <view class="scan-icon">
          <view class="scan-icon-inner">
            <view class="scan-corner scan-corner-tl"></view>
            <view class="scan-corner scan-corner-tr"></view>
            <view class="scan-corner scan-corner-bl"></view>
            <view class="scan-corner scan-corner-br"></view>
            <view class="scan-line"></view>
          </view>
        </view>
      </view>
      <view class="scan-text">
        <text class="scan-title">{{currentLang === 'en-US' ? 'Scan & Trace Osmanthus Tea' : '桂花茶扫码溯源'}}</text>
        <text class="scan-desc">{{currentLang === 'en-US' ? 'Scan QR / Barcode, support Mini Program code' : '扫描二维码/条形码，支持小程序码'}}</text>
      </view>
      <view class="scan-arrow" aria-hidden="true">›</view>
    </view>

    <!-- ==================== 功能卡片区域（可点击联动） ==================== -->
    <view class="feature-section" role="region" aria-label="溯源功能卡片导航">
      <view class="section-title" role="heading" aria-level="2">
        <view class="title-icon" aria-hidden="true">🔍</view>
        <text>{{currentLang === 'en-US' ? 'Traceability Features' : '溯源功能'}}</text>
      </view>

      <view class="feature-grid">
        <view
          wx:for="{{featureCards}}"
          wx:key="key"
          class="feature-item feature-card-clickable"
          data-card="{{item}}"
          bindtap="onFeatureCardTap"
          role="button"
          aria-label="{{item.name}}，{{item.desc}}"
        >
          <view class="feature-icon" aria-hidden="true" style="background: linear-gradient(135deg, {{item.color}}, {{item.color}}88);">
            <text>{{item.icon}}</text>
          </view>
          <view class="feature-name">{{item.name}}</view>
          <view class="feature-desc">{{item.desc}}</view>
          <view class="feature-card-arrow" wx:if="{{item.type === 'brand'}}" aria-hidden="true">›</view>
        </view>
      </view>
    </view>

    <!-- ==================== 茶食搭配与节日礼盒专区 ==================== -->
    <section class="pairing-festival-section">
      <view class="section-title">
        <view class="title-icon">🍵</view>
        <text>茶食搭配 · 节日礼盒</text>
      </view>
      
      <!-- 节日礼盒快捷入口 -->
      <view wx:if="{{currentFestival.current}}" class="festival-shortcut-card" bindtap="onFestivalShortcutTap" data-festival="{{currentFestival.current.festivalKey}}">
        <image class="festival-bg-img" src="{{currentFestival.current.coverImage}}" mode="aspectFill" />
        <view class="festival-overlay"></view>
        <view class="festival-content">
          <view class="festival-icon">{{currentFestival.current.icon}}</view>
          <view class="festival-info">
            <view class="festival-name">{{currentFestival.current.festivalName}}限定</view>
            <view class="festival-tagline">{{currentFestival.current.tagline}}</view>
            <view class="festival-date">{{currentFestival.current.date}}</view>
          </view>
          <view class="festival-action">
            <text class="festival-action-text">立即选购</text>
            <text class="festival-arrow">›</text>
          </view>
        </view>
      </view>
      
      <!-- 快速搭配入口 3个小卡片 -->
      <view class="quick-pairing-grid">
        <view class="quick-pairing-card" bindtap="onQuickPairingTap" data-variety="jin-gui">
          <view class="qp-icon qp-jin-gui">🌼</view>
          <view class="qp-name">金桂配糕点</view>
          <view class="qp-desc">浓香+甜点</view>
        </view>
        <view class="quick-pairing-card" bindtap="onQuickPairingTap" data-variety="yin-gui">
          <view class="qp-icon qp-yin-gui">🌸</view>
          <view class="qp-name">银桂配凉菜</view>
          <view class="qp-desc">清香+爽口</view>
        </view>
        <view class="quick-pairing-card" bindtap="onPreferenceShortcutTap">
          <view class="qp-icon qp-pref">🎯</view>
          <view class="qp-name">为我推荐</view>
          <view class="qp-desc">定制专属</view>
        </view>
      </view>
    </section>

    <!-- ==================== 品牌视频区域 ==================== -->
    <view class="brand-video-section" role="region" aria-label="{{i18n.brandStoryTitle}}">
      <view class="section-title" role="heading" aria-level="2">
        <view class="title-icon" aria-hidden="true">🎬</view>
        <text>{{i18n.brandStoryTitle}}</text>
      </view>
      <view class="video-card">
        <video
          id="brandVideo"
          class="brand-video"
          src="{{brandVideo.src}}"
          poster="{{brandVideo.poster}}"
          bindplay="onVideoPlay"
          bindpause="onVideoPause"
          bindended="onVideoEnded"
          show-center-play-btn="{{true}}"
          show-play-btn="{{true}}"
          controls="{{true}}"
          object-fit="cover"
          enable-progress-gesture="{{true}}"
          autoplay="{{false}}"
          loop="{{false}}"
          muted="{{false}}"
          aria-label="{{brandVideo.title}}"
        ></video>
        <view class="video-info">
          <view class="video-title">{{brandVideo.title}}</view>
          <view class="video-duration" aria-hidden="true">⏱ {{brandVideo.duration}}</view>
        </view>
      </view>
    </view>

    <!-- 手动输入区域 -->
    <view class="manual-section" role="region" aria-label="{{i18n.quickInputTitle}}">
      <view class="manual-toggle" bindtap="toggleInputArea" role="button" aria-expanded="{{showInputArea}}" aria-label="{{i18n.quickInputTitle}}">
        <text class="manual-toggle-text">{{i18n.quickInputTitle}}</text>
        <text class="manual-toggle-icon {{showInputArea ? 'rotate' : ''}}" aria-hidden="true">▼</text>
      </view>

      <view class="manual-input-area {{showInputArea ? 'show' : ''}}">
        <view class="input-wrapper">
          <input
            class="trace-input"
            type="text"
            placeholder="{{i18n.inputPlaceholder}}"
            placeholder-class="input-placeholder"
            value="{{inputTraceId}}"
            bindinput="onInputChange"
            maxlength="20"
            confirm-type="search"
            bindconfirm="handleManualQuery"
            aria-label="{{i18n.inputPlaceholder}}"
          />
          <button class="query-btn" bindtap="handleManualQuery" role="button" aria-label="{{i18n.searchBtn}}">{{i18n.searchBtn}}</button>
        </view>

        <view class="test-ids">
          <text class="test-label">{{currentLang === 'en-US' ? 'Demo IDs:' : '测试ID：'}}</text>
          <view class="test-id-btns" role="group">
            <view
              wx:for="{{testIds}}"
              wx:key="*this"
              class="test-id-btn"
              data-id="{{item}}"
              bindtap="fillTestId"
              role="button"
              aria-label="{{currentLang === 'en-US' ? 'Use demo ID ' : '使用示例ID'}}{{item}}"
            >{{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 批量查询区域 -->
    <view class="manual-section" role="region" aria-label="{{i18n.quickInputBatchTitle}}">
      <view class="manual-toggle" bindtap="toggleBatchArea" role="button" aria-expanded="{{showBatchArea}}" aria-label="{{i18n.quickInputBatchTitle}}">
        <text class="manual-toggle-text">📦 {{i18n.quickInputBatchTitle}}</text>
        <text class="manual-toggle-icon {{showBatchArea ? 'rotate' : ''}}" aria-hidden="true">▼</text>
      </view>

      <view class="manual-input-area {{showBatchArea ? 'show' : ''}}">
        <view class="input-wrapper">
          <input
            class="trace-input"
            type="text"
            placeholder="{{i18n.batchPlaceholder}}"
            placeholder-class="input-placeholder"
            value="{{inputBatchNo}}"
            bindinput="onBatchInputChange"
            maxlength="10"
            confirm-type="search"
            bindconfirm="handleBatchQuery"
            aria-label="{{i18n.batchPlaceholder}}"
          />
          <button class="query-btn batch-btn" bindtap="handleBatchQuery" role="button" aria-label="{{i18n.batchSearchBtn}}">{{i18n.batchSearchBtn}}</button>
        </view>

        <view class="test-ids">
          <text class="test-label">{{currentLang === 'en-US' ? 'Demo batches:' : '测试批次：'}}</text>
          <view class="test-id-btns" role="group">
            <view
              wx:for="{{testBatchNos}}"
              wx:key="*this"
              class="test-id-btn batch-test-btn"
              data-batch="{{item}}"
              bindtap="fillTestBatchNo"
              role="button"
              aria-label="{{currentLang === 'en-US' ? 'Use demo batch ' : '使用示例批次'}}{{item}}"
            >{{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== 扫码历史区域 ==================== -->
    <view wx:if="{{showHistory}}" class="history-section" role="region" aria-label="{{i18n.historyTitle}}">
      <view class="section-title" role="heading" aria-level="2">
        <view class="title-icon" aria-hidden="true">⏰</view>
        <text>{{i18n.historyTitle}}</text>
        <view class="clear-history-btn" bindtap="clearAllHistory" role="button" aria-label="{{currentLang === 'en-US' ? 'Clear all history' : '清空扫码历史'}}">{{currentLang === 'en-US' ? 'Clear' : '清空'}}</view>
      </view>

      <view class="history-list" role="list">
        <view
          class="history-item"
          wx:for="{{scanHistory}}"
          wx:key="id"
          data-traceid="{{item.traceId}}"
          bindtap="viewHistoryItem"
          role="listitem"
          aria-label="{{item.productName}}，溯源ID{{item.traceId}}，{{item.formatTime}}"
        >
          <view class="history-icon" aria-hidden="true">🌼</view>
          <view class="history-info">
            <view class="history-name">{{item.productName}}</view>
            <view class="history-meta">
              <text class="history-id">{{item.traceId}}</text>
              <text class="history-time">{{item.formatTime}}</text>
            </view>
          </view>
          <view class="history-actions">
            <view
              class="delete-btn"
              catchtap="deleteHistoryItem"
              data-id="{{item.id}}"
              role="button"
              aria-label="{{currentLang === 'en-US' ? 'Delete this history' : '删除该条历史'}}"
            >×</view>
          </view>
          <view class="history-arrow" aria-hidden="true">›</view>
        </view>
      </view>
    </view>

    <!-- ==================== 区块链存证提示 ==================== -->
    <view class="blockchain-banner" role="note" aria-label="区块链存证技术，数据真实可查不可篡改">
      <view class="blockchain-icon" aria-hidden="true">
        <text>🔗</text>
      </view>
      <view class="blockchain-text">
        <text class="blockchain-title">{{currentLang === 'en-US' ? 'Blockchain Proof' : '区块链存证技术'}}</text>
        <text class="blockchain-desc">{{currentLang === 'en-US' ? 'Verifiable & Tamper-proof Data' : '数据真实可查、不可篡改'}}</text>
      </view>
      <view class="blockchain-badge" role="status">
        <text>{{currentLang === 'en-US' ? 'Certified' : '已认证'}}</text>
      </view>
    </view>
  </view>

  <!-- ==================== 底部信息 ==================== -->
  <view class="footer-section" role="contentinfo">
    <view class="footer-text" aria-hidden="true">
      <text class="eco-icon">🍃</text>
      <text>一茶一品 · 品质溯源</text>
      <text class="eco-icon">🍃</text>
    </view>
    <view class="footer-tip">{{currentLang === 'en-US' ? 'Data securely stored, protecting your privacy' : '数据安全存储，保护您的隐私'}}</view>
  </view>

  <!-- ==================== 无障碍与多语言设置弹窗 ==================== -->
  <view wx:if="{{showA11yPanel}}" class="modal-overlay a11y-overlay" catchtap="closeA11yPanel" role="dialog" aria-modal="true" aria-label="{{i18n.a11yTitle}}">
    <view class="a11y-modal" catchtap="preventBubble">
      <view class="a11y-modal-header">
        <view class="a11y-modal-title" role="heading" aria-level="1">
          <text class="a11y-title-icon" aria-hidden="true">♿</text>
          <text>{{i18n.a11yTitle}}</text>
        </view>
        <view class="a11y-modal-close" bindtap="closeA11yPanel" role="button" aria-label="{{i18n.closeBtn}}">×</view>
      </view>

      <scroll-view scroll-y class="a11y-modal-body">

        <!-- 语言切换 -->
        <view class="a11y-row a11y-row-block">
          <view class="a11y-label">
            <text class="a11y-label-icon" aria-hidden="true">🌐</text>
            <view class="a11y-label-stack">
              <text class="a11y-label-text">{{i18n.languageLabel}}</text>
              <text class="a11y-label-desc">{{currentLang === 'en-US' ? 'Switch UI language' : '切换界面显示语言，支持茶叶出口场景'}}</text>
            </view>
          </view>
          <view class="a11y-options" role="radiogroup" aria-label="{{i18n.languageLabel}}">
            <view
              wx:for="{{availableLanguages}}"
              wx:key="code"
              class="a11y-option {{currentLang === item.code ? 'active' : ''}}"
              data-lang="{{item.code}}"
              bindtap="handleSelectLanguage"
              role="radio"
              aria-checked="{{currentLang === item.code}}"
              aria-label="{{item.label}}"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <!-- 字号调节 -->
        <view class="a11y-row a11y-row-block">
          <view class="a11y-label">
            <text class="a11y-label-icon" aria-hidden="true">🔠</text>
            <view class="a11y-label-stack">
              <text class="a11y-label-text">{{i18n.fontLabel}}</text>
              <text class="a11y-label-desc">{{currentLang === 'en-US' ? 'Care mode & extra large fonts' : '关怀版/特大字号，适合视力不佳人群'}}</text>
            </view>
          </view>
          <view class="a11y-options" role="radiogroup" aria-label="{{i18n.fontLabel}}">
            <view
              wx:for="{{availableFontSizes}}"
              wx:key="key"
              class="a11y-option {{currentFontSize === item.key ? 'active' : ''}}"
              data-size="{{item.key}}"
              bindtap="handleSelectFontSize"
              role="radio"
              aria-checked="{{currentFontSize === item.key}}"
              aria-label="{{currentLang === 'en-US' ? item.labelEn : item.labelZh}}"
            >
              {{currentLang === 'en-US' ? item.labelEn : item.labelZh}}
            </view>
          </view>
        </view>

        <!-- 色弱模式开关 -->
        <view class="a11y-row a11y-row-block">
          <view class="a11y-label">
            <text class="a11y-label-icon" aria-hidden="true">🎨</text>
            <view class="a11y-label-stack">
              <text class="a11y-label-text">{{i18n.colorWeakLabel}}</text>
              <text class="a11y-label-desc">{{i18n.colorWeakDesc}}</text>
            </view>
          </view>
          <view
            class="a11y-switch {{currentColorWeak ? 'on' : ''}}"
            bindtap="handleToggleColorWeak"
            role="switch"
            aria-checked="{{currentColorWeak}}"
            aria-label="{{i18n.colorWeakLabel}}"
          >
            <view class="a11y-switch-dot" aria-hidden="true"></view>
          </view>
        </view>

        <!-- 使用说明 -->
        <view class="a11y-tips">
          <view class="a11y-tips-title" role="heading" aria-level="2">
            <text aria-hidden="true">💡</text>
            <text>{{currentLang === 'en-US' ? 'Tips' : '使用提示'}}</text>
          </view>
          <view class="a11y-tips-item">
            <text class="a11y-tip-bullet" aria-hidden="true">•</text>
            <text>{{currentLang === 'en-US' ? 'English mode optimizes for tea export scenarios' : '英文模式下对出口茶叶专业术语进行优化翻译'}}</text>
          </view>
          <view class="a11y-tips-item">
            <text class="a11y-tip-bullet" aria-hidden="true">•</text>
            <text>{{currentLang === 'en-US' ? 'Care mode increases font size by 50%' : '关怀版字号比标准字号放大约 50%'}}</text>
          </view>
          <view class="a11y-tips-item">
            <text class="a11y-tip-bullet" aria-hidden="true">•</text>
            <text>{{currentLang === 'en-US' ? 'Color weak mode adds icons & patterns to status' : '色弱模式下合格/不合格会额外显示图标和图案，不只靠颜色区分'}}</text>
          </view>
          <view class="a11y-tips-item">
            <text class="a11y-tip-bullet" aria-hidden="true">•</text>
            <text>{{currentLang === 'en-US' ? 'Screen reader friendly with full aria semantics' : '所有模块按钮均补充了 aria 语义，支持屏幕阅读器朗读'}}</text>
          </view>
        </view>

      </scroll-view>

      <view class="a11y-modal-footer">
        <view class="a11y-confirm-btn" bindtap="closeA11yPanel" role="button" aria-label="{{i18n.closeBtn}}">
          {{i18n.closeBtn}}
        </view>
      </view>
    </view>
  </view>
  
</view>
