<!--
  桂花茶溯源小程序 - 首页
  功能：品牌展示、扫码溯源、手动输入查询
-->

<view class="page-container {{pageLoaded ? 'page-loaded' : ''}}">
  
  <!-- ==================== 顶部品牌视觉区域 ==================== -->
  <view class="header-section">
    <!-- 品牌装饰背景 -->
    <view class="header-bg">
      <view class="header-pattern"></view>
    </view>
    
    <!-- 品牌主视觉 -->
    <view class="brand-container">
      <!-- 桂花图标 -->
      <view class="brand-icon">
        <text class="osmanthus-icon">🌼</text>
      </view>
      
      <!-- 品牌名称 -->
      <view class="brand-title">{{brandName}}</view>
      
      <!-- 品牌副标题 -->
      <view class="brand-subtitle">
        <text class="eco-leaf">🍃</text>
        <text>追溯每一片茶叶的绿色旅程</text>
        <text class="eco-leaf">🍃</text>
      </view>
    </view>
  </view>

  <!-- ==================== 主要功能区域 ==================== -->
  <view class="main-section">
    
    <!-- 扫码溯源主按钮 -->
    <view class="scan-card" bindtap="handleScanCode">
      <view class="scan-icon-wrapper">
        <view class="scan-icon">
          <!-- 扫码图标 -->
          <view class="scan-icon-inner">
            <view class="scan-corner scan-corner-tl"></view>
            <view class="scan-corner scan-corner-tr"></view>
            <view class="scan-corner scan-corner-bl"></view>
            <view class="scan-corner scan-corner-br"></view>
            <view class="scan-line"></view>
          </view>
        </view>
      </view>
      <view class="scan-text">
        <text class="scan-title">桂花茶扫码溯源</text>
        <text class="scan-desc">扫描产品二维码，查看完整溯源信息</text>
      </view>
      <view class="scan-arrow">›</view>
    </view>

    <!-- 手动输入区域 -->
    <view class="manual-section">
      <!-- 展开/收起切换 -->
      <view class="manual-toggle" bindtap="toggleInputArea">
        <text class="manual-toggle-text">手动输入溯源ID</text>
        <text class="manual-toggle-icon {{showInputArea ? 'rotate' : ''}}">▼</text>
      </view>
      
      <!-- 输入区域（可展开） -->
      <view class="manual-input-area {{showInputArea ? 'show' : ''}}">
        <view class="input-wrapper">
          <input 
            class="trace-input" 
            type="text" 
            placeholder="请输入溯源ID（如：G001）"
            placeholder-class="input-placeholder"
            value="{{inputTraceId}}"
            bindinput="onInputChange"
            maxlength="20"
            confirm-type="search"
            bindconfirm="handleManualQuery"
          />
          <button class="query-btn" bindtap="handleManualQuery">查询</button>
        </view>
        
        <!-- 测试ID快捷按钮 -->
        <view class="test-ids">
          <text class="test-label">测试ID：</text>
          <view class="test-id-btns">
            <view 
              wx:for="{{testIds}}" 
              wx:key="*this" 
              class="test-id-btn"
              data-id="{{item}}"
              bindtap="fillTestId"
            >{{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== 功能说明卡片 ==================== -->
    <view class="feature-section">
      <view class="section-title">
        <view class="title-icon">🔍</view>
        <text>溯源功能</text>
      </view>
      
      <view class="feature-grid">
        <!-- 功能1：产地溯源 -->
        <view class="feature-item">
          <view class="feature-icon" style="background: linear-gradient(135deg, #2E8B57, #3CB371);">
            <text>🌱</text>
          </view>
          <view class="feature-name">产地溯源</view>
          <view class="feature-desc">茶树与桂花产地信息</view>
        </view>
        
        <!-- 功能2：工艺追踪 -->
        <view class="feature-item">
          <view class="feature-icon" style="background: linear-gradient(135deg, #DAA520, #F0C75E);">
            <text>🫖</text>
          </view>
          <view class="feature-name">工艺追踪</view>
          <view class="feature-desc">窨制工艺全流程</view>
        </view>
        
        <!-- 功能3：绿色认证 -->
        <view class="feature-item">
          <view class="feature-icon" style="background: linear-gradient(135deg, #52C41A, #95DE64);">
            <text>♻️</text>
          </view>
          <view class="feature-name">绿色认证</view>
          <view class="feature-desc">生态种植与环保包装</view>
        </view>
        
        <!-- 功能4：检测报告 -->
        <view class="feature-item">
          <view class="feature-icon" style="background: linear-gradient(135deg, #1890FF, #69C0FF);">
            <text>📋</text>
          </view>
          <view class="feature-name">检测报告</view>
          <view class="feature-desc">农残检测安全保障</view>
        </view>
      </view>
    </view>

    <!-- ==================== 区块链存证提示 ==================== -->
    <view class="blockchain-banner">
      <view class="blockchain-icon">
        <text>🔗</text>
      </view>
      <view class="blockchain-text">
        <text class="blockchain-title">区块链存证技术</text>
        <text class="blockchain-desc">数据真实可查、不可篡改</text>
      </view>
      <view class="blockchain-badge">
        <text>已认证</text>
      </view>
    </view>
  </view>

  <!-- ==================== 底部信息 ==================== -->
  <view class="footer-section">
    <view class="footer-text">
      <text class="eco-icon">🍃</text>
      <text>一茶一品 · 品质溯源</text>
      <text class="eco-icon">🍃</text>
    </view>
    <view class="footer-tip">数据安全存储，保护您的隐私</view>
  </view>
  
</view>
