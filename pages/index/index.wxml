<!--
  桂花茶溯源小程序 - 首页
  功能：品牌展示、扫码溯源、手动输入查询、批量查询、扫码历史
-->

<view class="page-container {{pageLoaded ? 'page-loaded' : ''}}">
  
  <!-- 剪贴板识别弹窗 -->
  <view wx:if="{{showClipboardModal}}" class="modal-overlay" catchtap="handleClipboardCancel">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <view class="modal-icon">📋</view>
        <view class="modal-title">检测到溯源ID</view>
      </view>
      <view class="modal-body">
        <text>剪贴板中检测到有效溯源ID：</text>
        <view class="clipboard-id">{{clipboardTraceId}}</view>
        <text class="modal-tip">是否立即查询该产品的溯源信息？</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn modal-btn-cancel" bindtap="handleClipboardCancel">取消</button>
        <button class="modal-btn modal-btn-confirm" bindtap="handleClipboardConfirm">立即查询</button>
      </view>
    </view>
  </view>

  <!-- ==================== 扫码引导动画弹窗 ==================== -->
  <view wx:if="{{showScanGuide}}" class="modal-overlay scan-guide-overlay" catchtap="closeScanGuide">
    <view class="scan-guide-modal" catchtap="preventBubble">
      <view class="scan-guide-close" bindtap="closeScanGuide">×</view>
      <view class="scan-guide-header">
        <view class="scan-guide-header-icon">📱</view>
        <view class="scan-guide-header-title">扫码溯源使用指南</view>
        <view class="scan-guide-header-subtitle">3步轻松查询产品溯源信息</view>
      </view>
      <view class="scan-guide-steps">
        <view 
          wx:for="{{scanGuideSteps}}" 
          wx:key="step"
          class="scan-guide-step {{scanGuideStep >= index ? 'active' : ''}} {{scanGuideStep === index ? 'current' : ''}}"
        >
          <view class="step-indicator">
            <view class="step-dot">{{item.icon}}</view>
            <view class="step-line" wx:if="{{index < scanGuideSteps.length - 1}}"></view>
          </view>
          <view class="step-content-area">
            <view class="step-title-text">{{item.title}}</view>
            <view class="step-desc-text">{{item.desc}}</view>
          </view>
        </view>
      </view>
      <view class="scan-guide-animation">
        <view class="guide-phone-frame">
          <view class="guide-phone-screen">
            <view class="guide-scan-icon-mini">
              <view class="guide-scan-line-anim"></view>
            </view>
            <view class="guide-scan-text-mini">扫码溯源</view>
          </view>
        </view>
      </view>
      <view class="scan-guide-footer">
        <view class="scan-guide-btn" bindtap="nextScanGuideStep">
          <text wx:if="{{scanGuideStep < scanGuideSteps.length - 1}}">下一步</text>
          <text wx:else>知道了，去扫码</text>
        </view>
        <view class="scan-guide-skip" bindtap="closeScanGuide">跳过引导</view>
      </view>
    </view>
  </view>

  <!-- ==================== 顶部品牌视觉区域 ==================== -->
  <view class="header-section">
    <view class="header-bg">
      <view class="header-pattern"></view>
    </view>
    
    <view class="brand-container">
      <view class="brand-icon">
        <text class="osmanthus-icon">🌼</text>
      </view>
      
      <view class="brand-title">{{brandName}}</view>
      
      <view class="brand-subtitle">
        <text class="eco-leaf">🍃</text>
        <text>追溯每一片茶叶的绿色旅程</text>
        <text class="eco-leaf">🍃</text>
      </view>
    </view>
  </view>

  <!-- ==================== 主要功能区域 ==================== -->
  <view class="main-section">
    
    <!-- ==================== 轮播 Banner 区域 ==================== -->
    <view class="banner-section">
      <swiper 
        class="banner-swiper" 
        autoplay="{{true}}" 
        interval="{{4000}}" 
        duration="{{500}}" 
        circular="{{true}}"
        bindchange="onBannerChange"
        indicator-dots="{{true}}"
        indicator-color="rgba(255,255,255,0.4)"
        indicator-active-color="#FFFFFF"
      >
        <swiper-item 
          wx:for="{{bannerList}}" 
          wx:key="id"
          data-index="{{index}}"
          bindtap="onBannerTap"
        >
          <view class="banner-slide">
            <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
            <view class="banner-overlay"></view>
            <view class="banner-content-wrapper">
              <view class="banner-tag {{item.type}}">{{item.tag}}</view>
              <view class="banner-title-text">{{item.title}}</view>
              <view class="banner-subtitle-text">{{item.subtitle}}</view>
            </view>
          </view>
        </swiper-item>
      </swiper>
      <view class="banner-counter">{{currentBanner + 1}}/{{bannerList.length}}</view>
    </view>

    <!-- ==================== 公告栏区域 ==================== -->
    <view class="announcement-bar" bindtap="onAnnouncementTap">
      <view class="announcement-icon-row">
        <view class="announcement-label {{announcementList[currentAnnouncement].type === 'recall' ? 'recall' : ''}}">{{announcementList[currentAnnouncement].icon}}</view>
      </view>
      <view class="announcement-scroll {{announcementAnimation ? 'animating' : ''}}">
        <view class="announcement-text {{announcementList[currentAnnouncement].type === 'recall' ? 'recall' : ''}}">
          {{announcementList[currentAnnouncement].text}}
        </view>
      </view>
      <view class="announcement-arrow">›</view>
    </view>

    <!-- 扫码溯源主按钮 -->
    <view class="scan-card" bindtap="handleScanCode">
      <view class="scan-icon-wrapper">
        <view class="scan-icon">
          <view class="scan-icon-inner">
            <view class="scan-corner scan-corner-tl"></view>
            <view class="scan-corner scan-corner-tr"></view>
            <view class="scan-corner scan-corner-bl"></view>
            <view class="scan-corner scan-corner-br"></view>
            <view class="scan-line"></view>
          </view>
        </view>
      </view>
      <view class="scan-text">
        <text class="scan-title">桂花茶扫码溯源</text>
        <text class="scan-desc">扫描二维码/条形码，支持小程序码</text>
      </view>
      <view class="scan-arrow">›</view>
    </view>

    <!-- ==================== 功能卡片区域（可点击联动） ==================== -->
    <view class="feature-section">
      <view class="section-title">
        <view class="title-icon">🔍</view>
        <text>溯源功能</text>
      </view>
      
      <view class="feature-grid">
        <view 
          wx:for="{{featureCards}}" 
          wx:key="key"
          class="feature-item feature-card-clickable"
          data-card="{{item}}"
          bindtap="onFeatureCardTap"
        >
          <view class="feature-icon" style="background: linear-gradient(135deg, {{item.color}}, {{item.color}}88);">
            <text>{{item.icon}}</text>
          </view>
          <view class="feature-name">{{item.name}}</view>
          <view class="feature-desc">{{item.desc}}</view>
          <view class="feature-card-arrow" wx:if="{{item.type === 'brand'}}">›</view>
        </view>
      </view>
    </view>

    <!-- ==================== 品牌视频区域 ==================== -->
    <view class="brand-video-section">
      <view class="section-title">
        <view class="title-icon">🎬</view>
        <text>品牌故事</text>
      </view>
      <view class="video-card">
        <video
          id="brandVideo"
          class="brand-video"
          src="{{brandVideo.src}}"
          poster="{{brandVideo.poster}}"
          bindplay="onVideoPlay"
          bindpause="onVideoPause"
          bindended="onVideoEnded"
          show-center-play-btn="{{true}}"
          show-play-btn="{{true}}"
          controls="{{true}}"
          object-fit="cover"
          enable-progress-gesture="{{true}}"
          autoplay="{{false}}"
          loop="{{false}}"
          muted="{{false}}"
        ></video>
        <view class="video-info">
          <view class="video-title">{{brandVideo.title}}</view>
          <view class="video-duration">⏱ {{brandVideo.duration}}</view>
        </view>
      </view>
    </view>

    <!-- 手动输入区域 -->
    <view class="manual-section">
      <view class="manual-toggle" bindtap="toggleInputArea">
        <text class="manual-toggle-text">手动输入溯源ID</text>
        <text class="manual-toggle-icon {{showInputArea ? 'rotate' : ''}}">▼</text>
      </view>
      
      <view class="manual-input-area {{showInputArea ? 'show' : ''}}">
        <view class="input-wrapper">
          <input 
            class="trace-input" 
            type="text" 
            placeholder="请输入溯源ID（如：G001）"
            placeholder-class="input-placeholder"
            value="{{inputTraceId}}"
            bindinput="onInputChange"
            maxlength="20"
            confirm-type="search"
            bindconfirm="handleManualQuery"
          />
          <button class="query-btn" bindtap="handleManualQuery">查询</button>
        </view>
        
        <view class="test-ids">
          <text class="test-label">测试ID：</text>
          <view class="test-id-btns">
            <view 
              wx:for="{{testIds}}" 
              wx:key="*this" 
              class="test-id-btn"
              data-id="{{item}}"
              bindtap="fillTestId"
            >{{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 批量查询区域 -->
    <view class="manual-section">
      <view class="manual-toggle" bindtap="toggleBatchArea">
        <text class="manual-toggle-text">📦 按批次号查询</text>
        <text class="manual-toggle-icon {{showBatchArea ? 'rotate' : ''}}">▼</text>
      </view>
      
      <view class="manual-input-area {{showBatchArea ? 'show' : ''}}">
        <view class="input-wrapper">
          <input 
            class="trace-input" 
            type="text" 
            placeholder="请输入批次号（如：GH202503）"
            placeholder-class="input-placeholder"
            value="{{inputBatchNo}}"
            bindinput="onBatchInputChange"
            maxlength="10"
            confirm-type="search"
            bindconfirm="handleBatchQuery"
          />
          <button class="query-btn batch-btn" bindtap="handleBatchQuery">查询批次</button>
        </view>
        
        <view class="test-ids">
          <text class="test-label">测试批次：</text>
          <view class="test-id-btns">
            <view 
              wx:for="{{testBatchNos}}" 
              wx:key="*this" 
              class="test-id-btn batch-test-btn"
              data-batch="{{item}}"
              bindtap="fillTestBatchNo"
            >{{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== 扫码历史区域 ==================== -->
    <view wx:if="{{showHistory}}" class="history-section">
      <view class="section-title">
        <view class="title-icon">⏰</view>
        <text>扫码历史</text>
        <view class="clear-history-btn" bindtap="clearAllHistory">清空</view>
      </view>
      
      <view class="history-list">
        <view 
          class="history-item" 
          wx:for="{{scanHistory}}" 
          wx:key="id"
          data-traceid="{{item.traceId}}"
          bindtap="viewHistoryItem"
        >
          <view class="history-icon">🌼</view>
          <view class="history-info">
            <view class="history-name">{{item.productName}}</view>
            <view class="history-meta">
              <text class="history-id">{{item.traceId}}</text>
              <text class="history-time">{{item.formatTime}}</text>
            </view>
          </view>
          <view class="history-actions">
            <view 
              class="delete-btn" 
              catchtap="deleteHistoryItem"
              data-id="{{item.id}}"
            >×</view>
          </view>
          <view class="history-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- ==================== 区块链存证提示 ==================== -->
    <view class="blockchain-banner">
      <view class="blockchain-icon">
        <text>🔗</text>
      </view>
      <view class="blockchain-text">
        <text class="blockchain-title">区块链存证技术</text>
        <text class="blockchain-desc">数据真实可查、不可篡改</text>
      </view>
      <view class="blockchain-badge">
        <text>已认证</text>
      </view>
    </view>
  </view>

  <!-- ==================== 底部信息 ==================== -->
  <view class="footer-section">
    <view class="footer-text">
      <text class="eco-icon">🍃</text>
      <text>一茶一品 · 品质溯源</text>
      <text class="eco-icon">🍃</text>
    </view>
    <view class="footer-tip">数据安全存储，保护您的隐私</view>
  </view>
  
</view>
