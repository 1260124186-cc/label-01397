/**
 * 桂花茶溯源小程序 - 首页样式
 * 色系：青色(#2E8B57) + 金色(#DAA520)
 */

/* ==================== 页面容器 ==================== */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-bg-primary) 0%, var(--color-bg-elevated) 100%);
  padding-bottom: env(safe-area-inset-bottom);
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.4s ease, background-color 0.3s ease;
}

.page-container.page-loaded {
  opacity: 1;
  transform: translateY(0);
}

/* ==================== 顶部品牌区域 ==================== */
.header-section {
  position: relative;
  padding: 60rpx 40rpx 80rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--gradient-header);
  border-radius: 0 0 60rpx 60rpx;
}

.header-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(218,165,32,0.15) 0%, transparent 40%);
}

.brand-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.osmanthus-icon {
  font-size: 60rpx;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.brand-subtitle {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.eco-leaf {
  margin: 0 12rpx;
  font-size: 24rpx;
}

/* ==================== 主要功能区域 ==================== */
.main-section {
  padding: 0 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

/* 扫码卡片 */
.scan-card {
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border-light);
  margin-bottom: 32rpx;
  transition: all 0.3s ease;
}

page.theme-dark .scan-card {
  border-color: var(--color-border);
}

.scan-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.scan-icon-wrapper {
  margin-right: 28rpx;
}

.scan-icon {
  width: 100rpx;
  height: 100rpx;
  background: var(--gradient-primary);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.scan-icon-inner {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}

.scan-corner {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-color: #FFFFFF;
  border-style: solid;
}

.scan-corner-tl {
  top: 0;
  left: 0;
  border-width: 4rpx 0 0 4rpx;
}

.scan-corner-tr {
  top: 0;
  right: 0;
  border-width: 4rpx 4rpx 0 0;
}

.scan-corner-bl {
  bottom: 0;
  left: 0;
  border-width: 0 0 4rpx 4rpx;
}

.scan-corner-br {
  bottom: 0;
  right: 0;
  border-width: 0 4rpx 4rpx 0;
}

.scan-line {
  position: absolute;
  top: 50%;
  left: 4rpx;
  right: 4rpx;
  height: 4rpx;
  background: #DAA520;
  animation: scanMove 2s ease-in-out infinite;
}

@keyframes scanMove {
  0%, 100% {
    top: 20%;
    opacity: 1;
  }
  50% {
    top: 80%;
    opacity: 0.6;
  }
}

.scan-text {
  flex: 1;
}

.scan-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.scan-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

.scan-arrow {
  font-size: 48rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ==================== 手动输入区域 ==================== */
.manual-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.manual-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.manual-toggle-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.manual-toggle-icon {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.3s ease;
}

.manual-toggle-icon.rotate {
  transform: rotate(180deg);
}

.manual-input-area {
  max-height: 0;
  overflow: hidden;
  transition: all 0.3s ease;
  opacity: 0;
}

.manual-input-area.show {
  max-height: 300rpx;
  margin-top: 28rpx;
  opacity: 1;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 36rpx;
  padding: 8rpx 8rpx 8rpx 16rpx;
  border: 2rpx solid #E8E8E8;
}

.trace-input {
  flex: 1;
  height: 64rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
}

.input-placeholder {
  color: #CCCCCC;
  font-size: 26rpx;
}

.query-btn {
  height: 56rpx;
  line-height: 56rpx;
  background: linear-gradient(135deg, #DAA520, #F0C75E);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 28rpx;
  padding: 0 16rpx;
  margin: 0;
  margin-left: 8rpx;
  border: none;
  flex-shrink: 0;
  width:200rpx !important;
}

.query-btn::after {
  border: none;
}

.test-ids {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.test-label {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.test-id-btns {
  display: flex;
  gap: 16rpx;
}

.test-id-btn {
  padding: 8rpx 24rpx;
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
  font-size: 24rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.test-id-btn:active {
  background: rgba(46, 139, 87, 0.2);
}

/* ==================== 功能说明区域 ==================== */
.feature-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.feature-item {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.feature-item:active {
  transform: scale(0.98);
  background: #F5F5F5;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 36rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999999;
}

/* ==================== 区块链存证横幅 ==================== */
.blockchain-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(46, 139, 87, 0.08), rgba(218, 165, 32, 0.08));
  border: 2rpx solid rgba(46, 139, 87, 0.2);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 32rpx;
}

.blockchain-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #2E8B57, #DAA520);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.blockchain-text {
  flex: 1;
}

.blockchain-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-bottom: 4rpx;
}

.blockchain-desc {
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.blockchain-badge {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* ==================== 底部信息 ==================== */
.footer-section {
  padding: 40rpx 32rpx 60rpx;
  text-align: center;
}

.footer-text {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.eco-icon {
  margin: 0 12rpx;
}

.footer-tip {
  font-size: 22rpx;
  color: #999999;
}

/* ==================== 剪贴板弹窗 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  z-index: 9999;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-body {
  padding: 0 32rpx 32rpx;
  text-align: center;
}

.modal-body text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.clipboard-id {
  display: inline-block;
  margin: 20rpx 0;
  padding: 16rpx 32rpx;
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  letter-spacing: 2rpx;
}

.modal-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #F0F0F0;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 30rpx;
  border: none;
  background: transparent;
  margin: 0;
  padding: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #999999;
  border-right: 2rpx solid #F0F0F0;
}

.modal-btn-confirm {
  color: #2E8B57;
  font-weight: 600;
}

/* ==================== 批量查询按钮 ==================== */
.batch-btn {
  background: linear-gradient(135deg, #2E8B57, #3CB371) !important;
  width: 220rpx !important;
}

.batch-test-btn {
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
}

.batch-test-btn:active {
  background: rgba(46, 139, 87, 0.2);
}

/* ==================== 扫码历史区域 ==================== */
.history-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.history-section .section-title {
  position: relative;
}

.clear-history-btn {
  position: absolute;
  right: 0;
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: 400;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 77, 79, 0.1);
}

.clear-history-btn:active {
  background: rgba(255, 77, 79, 0.2);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.history-item:active {
  background: #F5F5F5;
}

.history-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FFE4B5, #FFD700);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
  min-width: 0;
}

.history-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.history-id {
  font-size: 24rpx;
  color: #2E8B57;
}

.history-time {
  font-size: 22rpx;
  color: #999999;
}

.history-actions {
  margin-right: 16rpx;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #ccc;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.delete-btn:active {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.history-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* ==================== 轮播 Banner 区域 ==================== */
.banner-section {
  position: relative;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-swiper {
  height: 320rpx;
  border-radius: 24rpx;
}

.banner-slide {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
}

.banner-content-wrapper {
  position: absolute;
  bottom: 24rpx;
  left: 28rpx;
  right: 80rpx;
  z-index: 2;
}

.banner-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.banner-tag.newProduct {
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
}

.banner-tag.certAward {
  background: linear-gradient(135deg, #DAA520, #F0C75E);
}

.banner-tag.pickSeason {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
}

.banner-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.banner-subtitle-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
}

.banner-counter {
  position: absolute;
  bottom: 12rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.4);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  z-index: 3;
}

/* ==================== 公告栏区域 ==================== */
.announcement-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.announcement-icon-row {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.announcement-label {
  font-size: 28rpx;
}

.announcement-scroll {
  flex: 1;
  overflow: hidden;
  height: 40rpx;
  line-height: 40rpx;
  transition: opacity 0.3s ease;
}

.announcement-scroll.animating {
  opacity: 0;
}

.announcement-text {
  font-size: 26rpx;
  color: #666666;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.announcement-text.recall {
  color: #FF4D4F;
  font-weight: 500;
}

.announcement-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ==================== 功能卡片点击样式 ==================== */
.feature-card-clickable {
  position: relative;
  cursor: pointer;
}

.feature-card-clickable:active {
  transform: scale(0.96);
  background: #F0F0F0;
}

.feature-card-arrow {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 28rpx;
  color: #B8860B;
  font-weight: 600;
}

/* ==================== 品牌视频区域 ==================== */
.brand-video-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.video-card {
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.brand-video {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
}

.video-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 4rpx 0;
}

.video-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-duration {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ==================== 扫码引导弹窗 ==================== */
.scan-guide-overlay {
  z-index: 10000;
}

.scan-guide-modal {
  width: 620rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 36rpx 36rpx;
  position: relative;
  animation: modalIn 0.3s ease;
}

.scan-guide-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #999999;
}

.scan-guide-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.scan-guide-header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.scan-guide-header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.scan-guide-header-subtitle {
  font-size: 26rpx;
  color: #999999;
}

.scan-guide-steps {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.scan-guide-step {
  display: flex;
  align-items: flex-start;
  opacity: 0.4;
  transition: all 0.3s ease;
}

.scan-guide-step.active {
  opacity: 1;
}

.scan-guide-step.current {
  opacity: 1;
}

.step-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 50%;
  background: #F0F0F0;
  transition: all 0.3s ease;
}

.scan-guide-step.active .step-dot {
  background: rgba(46, 139, 87, 0.15);
}

.scan-guide-step.current .step-dot {
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  transform: scale(1.1);
}

.step-line {
  width: 4rpx;
  height: 20rpx;
  background: #E0E0E0;
  margin: 8rpx 0;
}

.step-content-area {
  padding-top: 8rpx;
}

.step-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.step-desc-text {
  font-size: 24rpx;
  color: #999999;
}

.scan-guide-animation {
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
}

.guide-phone-frame {
  width: 200rpx;
  height: 360rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  border: 4rpx solid #E0E0E0;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.guide-phone-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.guide-scan-icon-mini {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.guide-scan-line-anim {
  width: 48rpx;
  height: 4rpx;
  background: #DAA520;
  animation: scanMove 2s ease-in-out infinite;
}

.guide-scan-text-mini {
  font-size: 18rpx;
  color: #666666;
}

.scan-guide-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.scan-guide-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.scan-guide-btn:active {
  opacity: 0.9;
}

.scan-guide-skip {
  font-size: 26rpx;
  color: #999999;
  padding: 8rpx 24rpx;
}

/* ==================== 无障碍入口按钮（悬浮右上角） ==================== */

.a11y-entry-btn {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(46, 139, 87, 0.35);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(6rpx);
}

.a11y-entry-btn:active {
  transform: scale(0.96);
  background: #FFFFFF;
}

.a11y-entry-icon {
  font-size: 30rpx;
  line-height: 1;
}

.a11y-entry-label {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: 600;
  line-height: 1;
}

/* ==================== 无障碍设置弹窗 ==================== */

.a11y-overlay {
  background: rgba(0, 0, 0, 0.55);
  z-index: 1000;
}

.a11y-modal {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.a11y-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 36rpx 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.a11y-modal-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1F3A2C;
}

.a11y-title-icon {
  font-size: 38rpx;
}

.a11y-modal-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 44rpx;
  color: #888888;
  border-radius: 50%;
  background: #F5F5F5;
}

.a11y-modal-close:active {
  background: #E8E8E8;
  color: #333333;
}

.a11y-modal-body {
  flex: 1;
  padding: 20rpx 36rpx 10rpx;
  max-height: 60vh;
}

.a11y-row-block {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.a11y-row-block:last-of-type {
  border-bottom: none;
}

/* 使用说明 */
.a11y-tips {
  margin-top: 30rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(46, 139, 87, 0.06), rgba(218, 165, 32, 0.05));
  border-radius: 16rpx;
  border: 1rpx solid rgba(46, 139, 87, 0.1);
}

.a11y-tips-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-bottom: 16rpx;
}

.a11y-tips-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
  font-size: 26rpx;
  line-height: 1.65;
  color: #555555;
}

.a11y-tip-bullet {
  flex-shrink: 0;
  margin-right: 10rpx;
  color: #2E8B57;
  font-weight: 700;
}

/* 弹窗底部确认按钮 */
.a11y-modal-footer {
  padding: 20rpx 36rpx 36rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.a11y-confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
}

.a11y-confirm-btn:active {
  opacity: 0.92;
  transform: scale(0.98);
}

/* ==================== 茶食搭配与节日礼盒专区 ==================== */
.pairing-festival-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.festival-shortcut-card {
  width: 100%;
  height: 200rpx;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 24rpx;
}

.festival-bg-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.festival-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.3) 50%, transparent 100%);
  z-index: 2;
}

.festival-content {
  position: relative;
  z-index: 3;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
}

.festival-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.festival-info {
  flex: 1;
  min-width: 0;
}

.festival-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.festival-tagline {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 6rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.festival-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.festival-action {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.festival-action-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-right: 6rpx;
}

.festival-arrow {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}

.quick-pairing-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.quick-pairing-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border: 1rpx solid #F0F0F0;
  transition: all 0.2s ease;
}

.quick-pairing-card:active {
  transform: scale(0.96);
  background: #FAFAFA;
}

.qp-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.qp-jin-gui {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

.qp-yin-gui {
  background: linear-gradient(135deg, #C0C0C0, #A9A9A9);
}

.qp-pref {
  background: linear-gradient(135deg, #DA70D6, #FF69B4);
}

.qp-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-top: 12rpx;
  margin-bottom: 4rpx;
}

.qp-desc {
  font-size: 24rpx;
  color: #999999;
}

/* Banner 新增节日类型样式 */
.banner-tag.giftBoxMidAutumn {
  background: linear-gradient(135deg, #FF8C00, #FF6347);
}

.banner-tag.giftBoxSpringFestival {
  background: linear-gradient(135deg, #DC143C, #FF4500);
}
