<view class="profile-page {{pageClass}}">
  <privacy-popup
    show="{{showPrivacyPopup}}"
    bind:agree="onPrivacyAgree"
    bind:deny="onPrivacyDeny"
  ></privacy-popup>

  <view class="profile-header">
    <view class="profile-header-bg"></view>
    <view class="profile-header-content">
      <block wx:if="{{isLoggedIn && userInfo}}">
        <view class="avatar-wrapper" bindtap="handleGetProfile">
          <view class="avatar {{userInfo.avatarUrl ? '' : 'avatar-default'}}">
            <image wx:if="{{userInfo.avatarUrl}}" class="avatar-image" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="avatar-text">{{userInfo.nickname[0] || '茶'}}</text>
          </view>
          <view class="avatar-edit-hint">编辑</view>
        </view>
        <view class="user-info">
          <view class="user-name">{{userInfo.nickname || '茶友'}}</view>
          <view class="user-id">ID: {{userInfo.openid ? userInfo.openid.substr(-8) : ''}}</view>
        </view>
        <view class="logout-btn" bindtap="handleLogout">退出</view>
      </block>
      <block wx:else>
        <view class="avatar-wrapper">
          <view class="avatar avatar-default">
            <text class="avatar-text">🍵</text>
          </view>
        </view>
        <view class="user-info">
          <view class="login-btn" bindtap="handleLogin">微信登录</view>
          <view class="login-hint">登录后享受更多专属服务</view>
        </view>
      </block>
    </view>

    <view class="stats-bar">
      <view class="stat-item">
        <view class="stat-value">{{scanCount}}</view>
        <view class="stat-label">查询次数</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{favoriteCount}}</view>
        <view class="stat-label">收藏产品</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{noteCount}}</view>
        <view class="stat-label">品鉴笔记</view>
      </view>
    </view>
  </view>

  <view class="profile-body">
    <block wx:for="{{menuSections}}" wx:key="title" wx:for-item="section">
      <view class="menu-section">
        <view class="menu-section-title">{{section.title}}</view>
        <view class="menu-list">
          <view
            wx:for="{{section.items}}"
            wx:key="key"
            wx:for-item="menuItem"
            class="menu-item"
            data-item="{{menuItem}}"
            bindtap="onMenuItemTap"
          >
            <view class="menu-item-icon">{{menuItem.icon}}</view>
            <view class="menu-item-content">
              <view class="menu-item-name">{{menuItem.name}}</view>
              <view class="menu-item-desc">{{menuItem.desc}}</view>
            </view>
            <view class="menu-item-right">
              <view wx:if="{{menuItem.badge}}" class="menu-item-badge">{{menuItem.badge}}</view>
              <view class="menu-item-arrow">›</view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{hasActivatedDealer}}" class="menu-section">
      <view class="menu-section-title">经销商工作台</view>
      <view class="menu-list">
        <view class="menu-item dealer-workbench" bindtap="goToDealer">
          <view class="menu-item-icon">🏢</view>
          <view class="menu-item-content">
            <view class="menu-item-name">
              经销商工作台
              <text wx:if="{{dealerLoggedIn && dealerUser}}" class="dealer-status online">[已登录·{{dealerUser.roleLabel}}]</text>
              <text wx:else class="dealer-status">[未登录]</text>
            </view>
            <view class="menu-item-desc">
              <text wx:if="{{dealerLoggedIn && dealerUser}}">{{dealerUser.dealerName}} · {{dealerUser.name}}</text>
              <text wx:else>扫码出入库、窜货告警管理</text>
            </view>
          </view>
          <view class="menu-item-right">
            <view wx:if="{{dealerLoggedIn}}" class="dealer-logout" catchtap="dealerLogout">退出</view>
            <view class="menu-item-arrow">›</view>
          </view>
        </view>
      </view>
    </view>

    <view class="settings-entry" bindtap="toggleSettingsPanel">
      <view class="settings-entry-icon">⚙️</view>
      <view class="settings-entry-content">
        <view class="settings-entry-title">{{t('settings.title')}}</view>
        <view class="settings-entry-desc">{{t('settings.language')}} · {{t('settings.fontSize')}} · {{t('settings.theme')}}</view>
      </view>
      <view class="settings-entry-arrow">{{showSettingsPanel ? '▲' : '▼'}}</view>
    </view>

    <view wx:if="{{showSettingsPanel}}" class="settings-panel">
      <view class="a11y-panel">
        <view class="a11y-panel-title">
          <text class="a11y-panel-title-icon">🌐</text>
          <text>{{t('settings.language')}}</text>
        </view>
        <view class="a11y-row">
          <view class="a11y-label">
            <view class="a11y-label-stack">
              <text class="a11y-label-text">{{t('settings.language')}}</text>
            </view>
          </view>
          <view class="a11y-options">
            <view
              wx:for="{{availableLanguages}}"
              wx:key="code"
              class="a11y-option {{currentLang === item.code ? 'active' : ''}}"
              data-lang="{{item.code}}"
              bindtap="onLanguageTap"
            >{{item.label}}</view>
          </view>
        </view>
      </view>

      <view class="a11y-panel">
        <view class="a11y-panel-title">
          <text class="a11y-panel-title-icon">🔤</text>
          <text>{{t('settings.fontSize')}}</text>
        </view>
        <view class="a11y-row">
          <view class="a11y-label">
            <view class="a11y-label-stack">
              <text class="a11y-label-text">{{t('settings.fontSize')}}</text>
            </view>
          </view>
          <view class="a11y-options">
            <view
              class="a11y-option {{currentFontSize === 'normal' ? 'active' : ''}}"
              data-size="normal"
              bindtap="onFontSizeTap"
            >{{t('settings.fontSizeNormal')}}</view>
            <view
              class="a11y-option {{currentFontSize === 'large' ? 'active' : ''}}"
              data-size="large"
              bindtap="onFontSizeTap"
            >{{t('settings.fontSizeLarge')}}</view>
            <view
              class="a11y-option {{currentFontSize === 'extra' ? 'active' : ''}}"
              data-size="extra"
              bindtap="onFontSizeTap"
            >{{t('settings.fontSizeExtra')}}</view>
          </view>
        </view>
      </view>

      <view class="a11y-panel">
        <view class="a11y-panel-title">
          <text class="a11y-panel-title-icon">👁️</text>
          <text>{{t('settings.colorWeak')}}</text>
        </view>
        <view class="a11y-row">
          <view class="a11y-label">
            <view class="a11y-label-stack">
              <text class="a11y-label-text">{{t('settings.colorWeak')}}</text>
              <text class="a11y-label-desc">{{t('settings.colorWeakDesc')}}</text>
            </view>
          </view>
          <view class="a11y-switch {{currentColorWeak ? 'on' : ''}}" bindtap="onColorWeakTap">
            <view class="a11y-switch-dot"></view>
          </view>
        </view>
      </view>

      <view class="a11y-panel">
        <view class="a11y-panel-title">
          <text class="a11y-panel-title-icon">🎨</text>
          <text>{{t('settings.theme')}}</text>
        </view>
        <view class="a11y-row">
          <view class="a11y-label">
            <view class="a11y-label-stack">
              <text class="a11y-label-text">{{t('settings.theme')}}</text>
              <text class="a11y-label-desc">{{t('settings.themeDesc')}}</text>
            </view>
          </view>
        </view>
        <view class="a11y-row theme-options">
          <view
            wx:for="{{availableThemes}}"
            wx:key="mode"
            class="a11y-option theme-option {{currentThemeMode === item.mode ? 'active' : ''}}"
            data-mode="{{item.mode}}"
            bindtap="onThemeTap"
          >
            <text class="theme-option-icon">{{item.icon}}</text>
            <text class="theme-option-label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="privacy-reminder">
      <view class="privacy-reminder-icon">🛡️</view>
      <view class="privacy-reminder-text">
        <text class="privacy-reminder-title">隐私保护承诺</text>
        <text class="privacy-reminder-desc">我们仅收集必要信息，所有数据本地存储，不上传服务器</text>
      </view>
    </view>
  </view>
</view>
