.profile-page {
  min-height: 100vh;
  background: var(--color-bg-primary);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  transition: background-color 0.3s ease;
}

.profile-header {
  position: relative;
  padding: 80rpx 40rpx 0;
  overflow: hidden;
}

.profile-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: -40rpx;
  background: var(--gradient-header);
  border-radius: 0 0 60rpx 60rpx;
}

.profile-header-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    radial-gradient(circle at 20% 40%, rgba(255,255,255,0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 60%, rgba(218,165,32,0.12) 0%, transparent 40%);
}

.settings-entry {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border-light);
  transition: all 0.3s ease;
}

page.theme-dark .settings-entry {
  border-color: var(--color-border);
}

.settings-entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, rgba(46, 139, 87, 0.1), rgba(218, 165, 32, 0.1));
  flex-shrink: 0;
}

.settings-entry-content {
  flex: 1;
  min-width: 0;
}

.settings-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.settings-entry-desc {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.settings-entry-arrow {
  font-size: 28rpx;
  color: var(--color-text-hint);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.settings-panel {
  margin-bottom: 32rpx;
}

.theme-options {
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 16rpx;
}

.theme-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  min-width: 180rpx;
  gap: 8rpx;
}

.theme-option-icon {
  font-size: 40rpx;
}

.theme-option-label {
  font-size: 24rpx;
}

.profile-header-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding-bottom: 32rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.avatar-default {
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 52rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.avatar-edit-hint {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 2rpx 16rpx;
  border-radius: 8rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.login-btn {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 48rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 44rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
}

.login-btn:active {
  background: rgba(255, 255, 255, 0.35);
}

.login-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
}

.logout-btn {
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  flex-shrink: 0;
}

.logout-btn:active {
  background: rgba(255, 255, 255, 0.25);
}

.stats-bar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 28rpx 0;
  margin-top: 8rpx;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

.profile-body {
  padding: 32rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

.menu-section {
  margin-bottom: 32rpx;
}

.menu-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #999999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  transition: background 0.2s ease;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FAFAFA;
}

.menu-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #F8F8F5;
}

.menu-item-content {
  flex: 1;
  min-width: 0;
}

.menu-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.menu-item-desc {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-item-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.menu-item-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 18rpx;
  padding: 0 10rpx;
  margin-right: 12rpx;
}

.menu-item-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

.privacy-reminder {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(46, 139, 87, 0.06), rgba(218, 165, 32, 0.04));
  border: 2rpx solid rgba(46, 139, 87, 0.15);
  border-radius: 20rpx;
  margin-top: 16rpx;
}

.privacy-reminder-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.privacy-reminder-text {
  display: flex;
  flex-direction: column;
}

.privacy-reminder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E8B57;
  margin-bottom: 6rpx;
}

.privacy-reminder-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

.dealer-workbench {
  background: linear-gradient(135deg, #F0FFF4 0%, #FFF8E1 100%);
}

.dealer-workbench .menu-item-icon {
  background: #E8F5E9;
}

.dealer-status {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
  font-weight: normal;
}

.dealer-status.online {
  color: #2E8B57;
}

.dealer-logout {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 18rpx;
  border: 1rpx solid #ff4d4f;
  border-radius: 20rpx;
  margin-right: 12rpx;
}
